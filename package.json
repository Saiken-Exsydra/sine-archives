{
  "name": "sine-archives",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "check:archive-refs": "node scripts/check-archive-refs.mjs",
    "report:archive-refs": "node scripts/report-archive-ref-candidates.mjs",
    "check:pt-br-fallbacks": "node scripts/create-pt-br-fallbacks.mjs --check",
    "check:text-encoding": "node scripts/pt-br-encoding-guard.mjs --check",
    "dev": "astro dev",
    "build": "npm run songs:generate && npm run check:pt-br-fallbacks && npm run check:text-encoding && npm run check:archive-refs && astro build",
    "check": "astro check",
    "fix:text-encoding": "node scripts/pt-br-encoding-guard.mjs --fix",
    "seed:pt-br-fallbacks": "node scripts/create-pt-br-fallbacks.mjs",
    "songs:generate": "node scripts/generate-song-metadata.mjs",
    "songs:update": "node scripts/update-song-metadata.mjs",
    "test:characters": "playwright test tests/character-navigation.spec.ts",
    "test:transitions": "playwright test tests/transition-smoke.spec.ts",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^5.18.1",
    "fast-glob": "^3.3.3",
    "mermaid": "^11.16.0",
    "music-metadata": "^11.12.3",
    "node-id3": "^0.2.9"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "typescript": "^5.9.3"
  }
}
