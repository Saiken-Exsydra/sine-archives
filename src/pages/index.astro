---
import MainLayout from "../layouts/MainLayout.astro";
import { CONTENT_KEYS, type ContentKey } from "../content-keys";
import { getLocalizedMusicCatalog } from "../data/music";
import { getLocalizedCollection } from "../i18n/content";
import { localizedPath, type SiteLocale } from "../i18n/config";
import { sectionLabel as getSectionLabel } from "../i18n/ui";

const { locale = "en" } = Astro.props as { locale?: SiteLocale };

const sections = CONTENT_KEYS.map((key) => ({ key, label: getSectionLabel(locale, key) }));
const soundtrackLabel = locale === "pt-br" ? "Trilhas Sonoras" : "Soundtracks";
const soundtrackEntries = getLocalizedMusicCatalog(locale);

async function getPublic(key: ContentKey) {
  const all = await getLocalizedCollection(key, locale);
  return all.filter((e) => e.data.status === "public");
}

const bySection = await Promise.all(
  sections.map(async (s) => {
    const entries = await getPublic(s.key);
    return {
      ...s,
      entries,
      count: entries.length,
      href: localizedPath(locale, `/${s.key}/`),
    };
  })
);

const indexSections = [
  ...bySection,
  {
    key: "soundtracks",
    label: soundtrackLabel,
    entries: soundtrackEntries,
    count: soundtrackEntries.length,
    href: localizedPath(locale, "/soundtracks/"),
  },
] as const;

const totalPublic = indexSections.reduce((sum, s) => sum + s.count, 0);
const notebookHref = "https://notebooklm.google.com/notebook/49ddad83-b67a-43aa-b35d-b76e94bb57e5";
const showNotebookCta = false;
const copy = locale === "pt-br"
  ? {
      heroSub: "Compêndio de registros classificados, avaliações de campo e estruturas teóricas originadas no Império de Synus e em suas estruturas cosmológicas adjacentes.",
      heroMeta: `ANO DE ARQUIVO 1127 · NÍVEL DE ACESSO: PÚBLICO · ${totalPublic} REGISTROS`,
      notebookKicker: "Anexo de pesquisa",
      notebookTitle: "Caderno vivo do mundo",
      notebookText: "Abrir os arquivos-fonte no NotebookLM",
      notebookAction: "Abrir NotebookLM",
      notebookAria: "Abrir o NotebookLM dos arquivos do mundo em uma nova aba",
      scroll: "Índice",
      sections: "Seções Classificadas",
      sectionTag: "Seção",
      count: (n: number) => `${n} ${n === 1 ? "entrada" : "entradas"}`,
      stamp: "CLASSIFICADO · USO INTERNO",
    }
  : {
      heroSub: "A compendium of classified records, field assessments, and theoretical frameworks originating from within the Empire of Synus and its adjacent cosmological structures.",
      heroMeta: `FILING YEAR 1127 · ACCESS LEVEL: PUBLIC · ${totalPublic} RECORDS`,
      notebookKicker: "Research annex",
      notebookTitle: "Living World Notebook",
      notebookText: "Open the source files in NotebookLM",
      notebookAction: "Open NotebookLM",
      notebookAria: "Open the SiNE Archives NotebookLM world file in a new tab",
      scroll: "Index",
      sections: "Classified Sections",
      sectionTag: "Section",
      count: (n: number) => `${n} ${n === 1 ? "entry" : "entries"}`,
      stamp: "CLASSIFIED · INTERNAL USE ONLY",
    };

const sectionMeta: Record<string, { image: string; desc: string }> = {
  characters:    { image: "/uploads/ui-characters-bg.png",  desc: locale === "pt-br" ? "Individuos de relevancia dentro da Faixa do Crepusculo e alem." : "Individuals of note within the Twilight Band and beyond." },
  organizations: { image: "/uploads/org-apocachynthion.png", desc: locale === "pt-br" ? "Instituicoes e casas que estruturam o Imperio de Synus." : "Institutions and houses that structure the Empire of Synus." },
  sine:          { image: "/uploads/ui-sine-logo.png",       desc: locale === "pt-br" ? "A Divisao Seam e tudo sob o Assento Wonderwall." : "The Seam Division and all that falls under the Wonderwall Seat." },
  places:        { image: "/uploads/map-places-index.png",   desc: locale === "pt-br" ? "Territorios, cidades e geografias do mundo conhecido." : "Territories, cities, and the geographies of the known world." },
  apparatus:     { image: "/uploads/app-clepsydra-apparatus.png", desc: locale === "pt-br" ? "Instrumentos, construcoes e mecanismos classificados." : "Classified instruments, constructions, and mechanisms." },
  systems:       { image: "/uploads/sys-redactory.png",      desc: locale === "pt-br" ? "Estruturas institucionais e ontologicas que sustentam o mundo." : "Structural and institutional frameworks that underpin the world." },
  cosmology:     { image: "/uploads/ui-cosmology-bg.png",    desc: locale === "pt-br" ? "A natureza do Arquivo, do Dive e da propria existencia." : "The nature of the Archive, the Dive, and existence itself." },
  soundtracks:   { image: "/uploads/ui-banner.png",          desc: locale === "pt-br" ? "Cancoes, camas atmosfericas e trilhas de cena para acompanhar leitura pelo arquivo." : "Songs, atmospheric beds, and scene score pieces for reading through the archive." },
};

const FALLBACK_IMG = "/uploads/ui-stars-fallback.jpg";
const observatoryHref = localizedPath(locale, "/systems/observatory/");
const searchHref = localizedPath(locale, "/search/");
---

<MainLayout active="home" pageTitle="SiNE Archives" locale={locale}>
  <Fragment slot="head">
    <link rel="prefetch" href={observatoryHref} as="document" />
    <link rel="prerender" href={observatoryHref} />
    <link rel="prefetch" href={searchHref} as="document" />
    <link rel="prerender" href={searchHref} />
  </Fragment>

  <a
    class="observatory-gate"
    href={observatoryHref}
    aria-label="Open the Systems Observatory"
    data-astro-prefetch="load"
    data-transition-trigger="observatory-handle"
  >
    <span class="observatory-gate__seam" aria-hidden="true"></span>
    <span class="observatory-gate__glow" aria-hidden="true"></span>
    <span class="observatory-gate__label" aria-hidden="true">
      <span class="observatory-gate__arrow"></span>
      <span>Open the Observatory</span>
    </span>
  </a>

  <a
    class="observatory-gate search-gate"
    href={searchHref}
    aria-label="Open Search"
    data-astro-prefetch="load"
    data-transition-trigger="search-handle"
  >
    <span class="observatory-gate__seam" aria-hidden="true"></span>
    <span class="observatory-gate__glow" aria-hidden="true"></span>
    <span class="observatory-gate__label" aria-hidden="true">
      <span>Open Search</span>
      <span class="observatory-gate__arrow"></span>
    </span>
  </a>

  <!-- ── HERO ── -->
  <div class="hero">
    <div class="hero__bg-wrap">
      <img src="/uploads/ui-cosmology-bg.png" alt="" class="hero__bg-img" />
    </div>
    <div class="hero__overlay"></div>
    <div class="sine-grain"></div>
    <div class="sine-scanline"></div>

    <div class="hero__content">
      <img src="/uploads/ui-sine-logo.png" alt="SiNE" class="hero__logo" />
      <p class="hero__sub">{copy.heroSub}</p>
      <div class="hero__divider"></div>
      <p class="hero__meta">{copy.heroMeta}</p>
      {showNotebookCta && (
        <a
          class="hero-notebook"
          href={notebookHref}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={copy.notebookAria}
        >
          <span class="hero-notebook__seal" aria-hidden="true">LM</span>
          <span class="hero-notebook__copy">
            <span class="hero-notebook__kicker">{copy.notebookKicker}</span>
            <span class="hero-notebook__title">{copy.notebookTitle}</span>
            <span class="hero-notebook__text">{copy.notebookText}</span>
          </span>
          <span class="hero-notebook__action">
            <span>{copy.notebookAction}</span>
            <span class="hero-notebook__arrow" aria-hidden="true"></span>
          </span>
        </a>
      )}
    </div>

    <div class="hero__scroll">
      <span class="hero__scroll-text">{copy.scroll}</span>
      <svg width="12" height="20" viewBox="0 0 12 20" fill="none">
        <line x1="6" y1="0" x2="6" y2="15" stroke="rgba(232,228,220,0.28)" stroke-width="1"/>
        <path d="M1 10 L6 16 L11 10" stroke="rgba(232,228,220,0.28)" stroke-width="1" fill="none" stroke-linecap="round"/>
      </svg>
    </div>
  </div>

  <!-- ── INDEX SPLIT PANEL ── -->
  <div class="index-wrap">

    <!-- LEFT: typographic list -->
    <div class="list-panel">
      <div class="list-header">
        <div class="list-header__rule"></div>
        <span class="list-header__label">{copy.sections}</span>
      </div>

      <div class="list-toprule"></div>

      {indexSections.map((s, i) => {
        const meta = sectionMeta[s.key] ?? { image: FALLBACK_IMG, desc: "" };
        return (
          <a
            class="list-row"
            href={s.href}
            data-key={s.key}
            data-img={meta.image || FALLBACK_IMG}
            data-desc={meta.desc}
            data-label={s.label}
            style={`--row-delay: ${i * 0.07 + 0.2}s;`}
          >
            <div class="list-row__bar"></div>
            <span class="list-row__num">{String(i + 1).padStart(2, "0")}</span>
            <span class="list-row__label">{s.label}</span>
            <span class="list-row__count">{copy.count(s.count)}</span>
            <span class="list-row__arrow">›</span>
            <div class="list-row__rule"></div>
          </a>
        );
      })}

    </div>

    <!-- RIGHT: sticky ambient preview -->
    <div class="preview-panel" id="preview-panel">
      <div class="preview-sticky">
      <div class="preview-default" id="preview-default">
        <img src="/uploads/ui-sine-logo.png" alt="" class="preview-default__logo" />
      </div>

      {indexSections.map((s) => {
        const meta = sectionMeta[s.key] ?? { image: FALLBACK_IMG, desc: "" };
        return (
          <div class="preview-layer" data-key={s.key}>
            <img src={meta.image || FALLBACK_IMG} alt="" class="preview-layer__img" />
            <div class="preview-layer__vignette"></div>
            <div class="preview-info">
              <div class="preview-info__inner">
                <div class="preview-info__tag">{copy.sectionTag}</div>
                <div class="preview-info__title">{s.label}</div>
                <div class="preview-info__desc">{meta.desc}</div>
              </div>
            </div>
            <div class="preview-stamp">
              <span class="preview-stamp__text">{copy.stamp}</span>
            </div>
          </div>
        );
      })}

      <div class="sine-grain preview-grain"></div>
      </div>
    </div>
  </div>

</MainLayout>

<script is:inline>
  window.registerPageInit?.("home-preview-panel", () => {
    const panel = document.getElementById("preview-panel");
    if (!panel) return;

    const controller = new AbortController();
    const { signal } = controller;
    const def = document.getElementById("preview-default");
    const layers = panel.querySelectorAll(".preview-layer");
    const rows = document.querySelectorAll(".list-row");

    function activate(key) {
      if (def) def.classList.toggle("is-hidden", !!key);
      layers.forEach((layer) => {
        layer.classList.toggle("is-active", layer.dataset.key === key);
      });
    }

    rows.forEach((row) => {
      row.addEventListener("mouseenter", () => activate(row.dataset.key), { signal });
      row.addEventListener("focus", () => activate(row.dataset.key), { signal });
      row.addEventListener("mouseleave", () => activate(null), { signal });
      row.addEventListener("blur", () => activate(null), { signal });
    });

    return () => controller.abort();
  });

</script>

<style>
  /* ── HERO ── */
  .observatory-gate {
    position: fixed;
    left: 0;
    top: 58px;
    bottom: 0;
    z-index: 70;
    display: flex;
    align-items: center;
    width: 124px;
    color: rgba(232, 228, 220, 0.62);
    text-decoration: none;
    cursor: pointer;
  }

  .search-gate {
    left: auto;
    right: 0;
    justify-content: flex-end;
  }

  .observatory-gate::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 260px;
    opacity: 0.42;
    pointer-events: none;
    background:
      radial-gradient(ellipse at left center, rgba(219, 69, 58, 0.22), rgba(102, 20, 24, 0.1) 34%, transparent 70%),
      linear-gradient(90deg, rgba(226, 92, 70, 0.18), transparent 62%);
    transform: scaleX(0.58);
    transform-origin: left center;
    transition: opacity 0.46s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .search-gate::before {
    inset: 0 0 0 auto;
    background:
      radial-gradient(ellipse at right center, rgba(219, 69, 58, 0.22), rgba(102, 20, 24, 0.1) 34%, transparent 70%),
      linear-gradient(270deg, rgba(226, 92, 70, 0.18), transparent 62%);
    transform-origin: right center;
  }

  .observatory-gate::after {
    content: "";
    position: absolute;
    left: -78px;
    top: 12%;
    width: 160px;
    height: 76%;
    border-right: 1px solid rgba(234, 118, 102, 0.24);
    border-radius: 50%;
    filter: blur(0.2px);
    opacity: 0;
    pointer-events: none;
    transform: translateX(-18px);
    transition: opacity 0.46s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .search-gate::after {
    left: auto;
    right: -78px;
    border-right: 0;
    border-left: 1px solid rgba(234, 118, 102, 0.24);
    transform: translateX(18px);
  }

  .observatory-gate:hover,
  .observatory-gate:focus,
  .observatory-gate:focus-visible {
    color: rgba(232, 228, 220, 0.92);
    outline: none;
  }

  .observatory-gate:hover::before,
  .observatory-gate:focus::before,
  .observatory-gate:focus-visible::before {
    opacity: 1;
    transform: scaleX(1);
  }

  .observatory-gate:hover::after,
  .observatory-gate:focus::after,
  .observatory-gate:focus-visible::after {
    opacity: 1;
    transform: translateX(0);
  }

  .observatory-gate__seam {
    position: absolute;
    left: 0;
    top: 8%;
    bottom: 8%;
    width: 3px;
    background: linear-gradient(180deg, transparent, rgba(255, 180, 158, 0.78) 18%, rgba(229, 74, 56, 1) 50%, rgba(255, 180, 158, 0.72) 82%, transparent);
    box-shadow:
      0 0 16px rgba(235, 91, 68, 0.68),
      0 0 42px rgba(177, 58, 52, 0.38);
    opacity: 0.94;
    transition: opacity 0.4s ease, box-shadow 0.4s ease, width 0.4s ease;
  }

  .search-gate .observatory-gate__seam {
    left: auto;
    right: 0;
  }

  .observatory-gate:hover .observatory-gate__seam,
  .observatory-gate:focus .observatory-gate__seam,
  .observatory-gate:focus-visible .observatory-gate__seam {
    width: 3px;
    opacity: 1;
    box-shadow:
      0 0 18px rgba(241, 133, 104, 0.78),
      0 0 58px rgba(177, 58, 52, 0.44);
  }

  .observatory-gate__glow {
    position: absolute;
    left: 0;
    top: 18%;
    width: 82px;
    height: 64%;
    opacity: 0.44;
    background: linear-gradient(90deg, rgba(220, 72, 58, 0.34), transparent);
    filter: blur(18px);
    transform: translateX(-36px);
    transition: opacity 0.5s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .search-gate .observatory-gate__glow {
    left: auto;
    right: 0;
    background: linear-gradient(270deg, rgba(220, 72, 58, 0.34), transparent);
    transform: translateX(36px);
  }

  .observatory-gate:hover .observatory-gate__glow,
  .observatory-gate:focus .observatory-gate__glow,
  .observatory-gate:focus-visible .observatory-gate__glow {
    opacity: 1;
    transform: translateX(0);
  }

  .observatory-gate__label {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-left: 24px;
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(-14px);
    transition: opacity 0.32s ease, transform 0.54s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .search-gate .observatory-gate__label {
    margin-left: 0;
    margin-right: 24px;
    transform: translateX(14px);
  }

  .observatory-gate:hover .observatory-gate__label,
  .observatory-gate:focus .observatory-gate__label,
  .observatory-gate:focus-visible .observatory-gate__label {
    opacity: 1;
    transform: translateX(0);
  }

  .observatory-gate__arrow {
    position: relative;
    width: 28px;
    height: 28px;
    border: 1px solid rgba(237, 139, 118, 0.38);
    border-radius: 50%;
    background: rgba(7, 13, 24, 0.46);
    box-shadow: inset 0 0 18px rgba(177, 58, 52, 0.16);
  }

  .observatory-gate__arrow::before {
    content: "";
    position: absolute;
    left: 9px;
    top: 10px;
    width: 7px;
    height: 7px;
    border-top: 1px solid rgba(255, 224, 218, 0.82);
    border-right: 1px solid rgba(255, 224, 218, 0.82);
    transform: rotate(45deg);
  }

  .search-gate .observatory-gate__arrow::before {
    left: 11px;
    transform: rotate(225deg);
  }

  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__bg-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    animation: kenburns 28s ease-out forwards;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: saturate(0.65) brightness(0.3);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      180deg,
      rgba(6, 6, 11, 0.25) 0%,
      rgba(6, 6, 11, 0.05) 35%,
      rgba(6, 6, 11, 0.75) 78%,
      var(--bg) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 5;
    text-align: center;
    max-width: 620px;
    padding: 0 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .hero__logo {
    width: clamp(188px, 24vw, 270px);
    max-width: 64vw;
    filter: drop-shadow(0 0 52px rgba(177, 58, 52, 0.28));
    animation: fadeSlideUp 1.3s 0.25s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero__sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: rgba(232, 228, 220, 0.5);
    line-height: 1.8;
    letter-spacing: 0.01em;
    margin: 0;
    max-width: 490px;
    animation: fadeSlideUp 1.1s 0.85s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero__divider {
    width: 52px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--crimson), transparent);
    animation: fadeSlideUp 0.9s 1.4s ease both, pulseRule 4s 2.5s ease-in-out infinite;
  }

  .hero__meta {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.26em;
    color: rgba(232, 228, 220, 0.2);
    text-transform: uppercase;
    margin: 0;
    animation: fadeSlideUp 0.8s 1.8s ease both;
  }

  .hero-notebook {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 16px;
    width: min(100%, 520px);
    margin-top: 4px;
    padding: 14px 16px;
    color: var(--text);
    text-align: left;
    text-decoration: none;
    border: 1px solid rgba(176, 141, 60, 0.28);
    border-radius: 3px;
    background:
      linear-gradient(90deg, rgba(176, 141, 60, 0.11), rgba(177, 58, 52, 0.08), rgba(10, 10, 20, 0.44)),
      rgba(5, 4, 7, 0.42);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.025),
      0 18px 48px rgba(0, 0, 0, 0.24);
    overflow: hidden;
    animation: fadeSlideUp 0.8s 2.05s ease both;
    transition:
      border-color 0.28s ease,
      background 0.28s ease,
      box-shadow 0.28s ease,
      transform 0.28s ease;
  }

  .hero-notebook::before,
  .hero-notebook::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(176, 141, 60, 0.5), transparent);
    opacity: 0.42;
    pointer-events: none;
  }

  .hero-notebook::before { top: 0; }
  .hero-notebook::after { bottom: 0; }

  .hero-notebook:hover,
  .hero-notebook:focus-visible {
    border-color: rgba(176, 141, 60, 0.58);
    background:
      linear-gradient(90deg, rgba(176, 141, 60, 0.16), rgba(177, 58, 52, 0.12), rgba(10, 10, 20, 0.5)),
      rgba(5, 4, 7, 0.56);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.04),
      0 22px 64px rgba(0, 0, 0, 0.34),
      0 0 46px rgba(176, 141, 60, 0.08);
    transform: translateY(-2px);
    outline: none;
  }

  .hero-notebook:focus-visible {
    outline: 1px solid rgba(232, 228, 220, 0.5);
    outline-offset: 4px;
  }

  .hero-notebook__seal {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border: 1px solid rgba(176, 141, 60, 0.42);
    border-radius: 50%;
    color: rgba(232, 228, 220, 0.64);
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    background:
      radial-gradient(circle, rgba(176, 141, 60, 0.18), transparent 66%),
      rgba(5, 4, 7, 0.44);
    box-shadow: inset 0 0 18px rgba(176, 141, 60, 0.1);
  }

  .hero-notebook__copy {
    min-width: 0;
    display: grid;
    gap: 3px;
  }

  .hero-notebook__kicker,
  .hero-notebook__action {
    font-family: 'DM Sans', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .hero-notebook__kicker {
    color: rgba(176, 141, 60, 0.72);
  }

  .hero-notebook__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-weight: 700;
    line-height: 1;
    color: rgba(232, 228, 220, 0.9);
  }

  .hero-notebook__text {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    line-height: 1.45;
    color: rgba(232, 228, 220, 0.48);
  }

  .hero-notebook__action {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: rgba(232, 228, 220, 0.66);
    white-space: nowrap;
  }

  .hero-notebook__arrow {
    position: relative;
    width: 24px;
    height: 24px;
    border: 1px solid rgba(177, 58, 52, 0.42);
    border-radius: 50%;
