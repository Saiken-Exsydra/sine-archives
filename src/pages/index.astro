---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import { SECTIONS } from "../sections";
import { CONTENT_KEYS, type ContentKey } from "../content-keys";

const labelByKey = Object.fromEntries(SECTIONS.map((s) => [s.key, s.label])) as Record<string, string>;
const sections = CONTENT_KEYS.map((key) => ({ key, label: labelByKey[key] ?? key }));

async function getPublic(key: ContentKey) {
  const all = await getCollection(key);
  return all.filter((e) => e.data.status === "public");
}

const bySection = await Promise.all(
  sections.map(async (s) => {
    const entries = await getPublic(s.key);
    return { ...s, entries, count: entries.length };
  })
);

const totalPublic = bySection.reduce((sum, s) => sum + s.count, 0);

const sectionMeta: Record<string, { image: string; desc: string }> = {
  characters:    { image: "/uploads/CharaBG.png",        desc: "Individuals of note within the Twilight Band and beyond." },
  organizations: { image: "/uploads/Apocachynthion.png", desc: "Institutions and houses that structure the Empire of Synus." },
  sine:          { image: "/uploads/SiNELG.png",         desc: "The Seam Division and all that falls under the Wonderwall Seat." },
  places:        { image: "/uploads/PLACESMAP.png",      desc: "Territories, cities, and the geographies of the known world." },
  apparatus:     { image: "/uploads/Clepsydra.png",      desc: "Classified instruments, constructions, and mechanisms." },
  systems:       { image: "/uploads/Redactory.png",      desc: "Structural and institutional frameworks that underpin the world." },
  cosmology:     { image: "/uploads/CosmologyBG.png",    desc: "The nature of the Archive, the Dive, and existence itself." },
};

const FALLBACK_IMG = "/uploads/StarsV2.jpg";
---

<MainLayout active="home" pageTitle="SiNE Archives">

  <!-- ── HERO ── -->
  <div class="hero">
    <div class="hero__bg-wrap">
      <img src="/uploads/CosmologyBG.png" alt="" class="hero__bg-img" />
    </div>
    <div class="hero__overlay"></div>
    <div class="sine-grain"></div>
    <div class="sine-scanline"></div>

    <div class="hero__content">
      <img src="/uploads/SLOGOHOME.png" alt="SiNE" class="hero__logo" />
      <p class="hero__sub">
        A compendium of classified records, field assessments, and theoretical frameworks
        originating from within the Empire of Synus and its adjacent cosmological structures.
      </p>
      <div class="hero__divider"></div>
      <p class="hero__meta">FILING YEAR 1127 · ACCESS LEVEL: PUBLIC · {totalPublic} RECORDS</p>
    </div>

    <div class="hero__scroll">
      <span class="hero__scroll-text">Index</span>
      <svg width="12" height="20" viewBox="0 0 12 20" fill="none">
        <line x1="6" y1="0" x2="6" y2="15" stroke="rgba(232,228,220,0.28)" stroke-width="1"/>
        <path d="M1 10 L6 16 L11 10" stroke="rgba(232,228,220,0.28)" stroke-width="1" fill="none" stroke-linecap="round"/>
      </svg>
    </div>
  </div>

  <!-- ── INDEX SPLIT PANEL ── -->
  <div class="index-wrap">

    <!-- LEFT: typographic list -->
    <div class="list-panel">
      <div class="list-header">
        <div class="list-header__rule"></div>
        <span class="list-header__label">Classified Sections</span>
      </div>

      <div class="list-toprule"></div>

      {bySection.map((s, i) => {
        const meta = sectionMeta[s.key] ?? { image: FALLBACK_IMG, desc: "" };
        return (
          <a
            class="list-row"
            href={`/${s.key}/`}
            data-key={s.key}
            data-img={meta.image || FALLBACK_IMG}
            data-desc={meta.desc}
            data-label={s.label}
            style={`--row-delay: ${i * 0.07 + 0.2}s;`}
          >
            <div class="list-row__bar"></div>
            <span class="list-row__num">{String(i + 1).padStart(2, "0")}</span>
            <span class="list-row__label">{s.label}</span>
            <span class="list-row__count">{s.count}&thinsp;{s.count === 1 ? "entry" : "entries"}</span>
            <span class="list-row__arrow">›</span>
            <div class="list-row__rule"></div>
          </a>
        );
      })}

    </div>

    <!-- RIGHT: sticky ambient preview -->
    <div class="preview-panel" id="preview-panel">
      <div class="preview-sticky">
      <div class="preview-default" id="preview-default">
        <img src="/uploads/SLOGO.png" alt="" class="preview-default__logo" />
      </div>

      {bySection.map((s) => {
        const meta = sectionMeta[s.key] ?? { image: FALLBACK_IMG, desc: "" };
        return (
          <div class="preview-layer" data-key={s.key}>
            <img src={meta.image || FALLBACK_IMG} alt="" class="preview-layer__img" />
            <div class="preview-layer__vignette"></div>
            <div class="preview-info">
              <div class="preview-info__inner">
                <div class="preview-info__tag">Section</div>
                <div class="preview-info__title">{s.label}</div>
                <div class="preview-info__desc">{meta.desc}</div>
              </div>
            </div>
            <div class="preview-stamp">
              <span class="preview-stamp__text">CLASSIFIED · INTERNAL USE ONLY</span>
            </div>
          </div>
        );
      })}

      <div class="sine-grain preview-grain"></div>
      </div>
    </div>
  </div>

</MainLayout>

<script is:inline>
  (function () {
    const panel = document.getElementById("preview-panel");
    if (!panel) return;
    const def = document.getElementById("preview-default");
    const layers = panel.querySelectorAll(".preview-layer");
    const rows = document.querySelectorAll(".list-row");

    function activate(key) {
      if (def) def.classList.toggle("is-hidden", !!key);
      layers.forEach((l) => {
        l.classList.toggle("is-active", l.dataset.key === key);
      });
    }

    rows.forEach((row) => {
      row.addEventListener("mouseenter", () => activate(row.dataset.key));
      row.addEventListener("focus", () => activate(row.dataset.key));
      row.addEventListener("mouseleave", () => activate(null));
      row.addEventListener("blur", () => activate(null));
    });
  })();
</script>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__bg-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    animation: kenburns 28s ease-out forwards;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: saturate(0.65) brightness(0.3);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      180deg,
      rgba(6, 6, 11, 0.25) 0%,
      rgba(6, 6, 11, 0.05) 35%,
      rgba(6, 6, 11, 0.75) 78%,
      var(--bg) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 5;
    text-align: center;
    max-width: 620px;
    padding: 0 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .hero__logo {
    width: 370px;
    max-width: 78vw;
    filter: drop-shadow(0 0 52px rgba(177, 58, 52, 0.28));
    animation: fadeSlideUp 1.3s 0.25s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero__sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: rgba(232, 228, 220, 0.5);
    line-height: 1.8;
    letter-spacing: 0.01em;
    margin: 0;
    max-width: 490px;
    animation: fadeSlideUp 1.1s 0.85s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero__divider {
    width: 52px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--crimson), transparent);
    animation: fadeSlideUp 0.9s 1.4s ease both, pulseRule 4s 2.5s ease-in-out infinite;
  }

  .hero__meta {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.26em;
    color: rgba(232, 228, 220, 0.2);
    text-transform: uppercase;
    margin: 0;
    animation: fadeSlideUp 0.8s 1.8s ease both;
  }

  .hero__scroll {
    position: absolute;
    bottom: 34px;
    left: 50%;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 9px;
    animation: scrollBounce 2.8s 2.5s ease-in-out infinite;
  }

  .hero__scroll-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 9px;
    letter-spacing: 0.24em;
    color: rgba(232, 228, 220, 0.2);
    text-transform: uppercase;
  }

  /* ── INDEX SPLIT ── */
  .index-wrap {
    display: flex;
    background: var(--bg);
    position: relative;
    align-items: stretch;
  }

  /* LEFT */
  .list-panel {
    flex: 1;
    min-width: 0;
    padding: 32px 52px 88px 68px;
    position: relative;
  }

  .list-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 44px;
  }

  .list-header__rule {
    width: 20px;
    height: 1px;
    background: var(--crimson);
    opacity: 0.7;
  }

  .list-header__label {
    font-family: 'DM Sans', sans-serif;
    font-size: 9px;
    letter-spacing: 0.28em;
    color: rgba(232, 228, 220, 0.28);
    text-transform: uppercase;
  }

  .list-toprule {
    height: 1px;
    background: rgba(255, 255, 255, 0.07);
  }

  .list-row {
    position: relative;
    display: flex;
    align-items: center;
    gap: 22px;
    width: 100%;
    text-align: left;
    padding: 24px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    opacity: 0;
    transform: translateY(14px);
    animation: fadeSlideUp 0.65s var(--row-delay, 0.2s) cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .list-row__bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--crimson);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .list-row:hover .list-row__bar,
  .list-row:focus-visible .list-row__bar { opacity: 1; }

  .list-row__num {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.16);
    flex-shrink: 0;
    width: 30px;
    text-align: right;
    transition: color 0.25s ease;
    user-select: none;
  }

  .list-row:hover .list-row__num,
  .list-row:focus-visible .list-row__num { color: var(--crimson); }

  .list-row__label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 46px;
    font-weight: 700;
    color: rgba(232, 228, 220, 0.6);
    line-height: 1;
    flex: 1;
    letter-spacing: 0.01em;
    transition: color 0.3s ease, letter-spacing 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .list-row:hover .list-row__label,
  .list-row:focus-visible .list-row__label {
    color: var(--text);
    letter-spacing: 0.035em;
  }

  .list-row__count {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--text-dim);
    text-transform: uppercase;
    opacity: 0.4;
    transition: opacity 0.25s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .list-row:hover .list-row__count,
  .list-row:focus-visible .list-row__count { opacity: 1; }

  .list-row__arrow {
    color: var(--crimson);
    font-size: 22px;
    opacity: 0;
    transform: translateX(-10px);
    transition: opacity 0.25s ease, transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
    line-height: 1;
  }

  .list-row:hover .list-row__arrow,
  .list-row:focus-visible .list-row__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .list-row__rule {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.07);
    transition: background 0.4s ease;
  }

  .list-row:hover .list-row__rule,
  .list-row:focus-visible .list-row__rule {
    background: linear-gradient(90deg, var(--crimson), rgba(255, 255, 255, 0.07) 60%, transparent);
  }

  /* RIGHT */
  .preview-panel {
    width: 42%;
    flex-shrink: 0;
    position: relative;
    border-left: 1px solid rgba(255, 255, 255, 0.05);
    align-self: stretch;
  }

  .preview-sticky {
    position: sticky;
    top: 56px;
    height: calc(100vh - 56px);
    max-height: 100%;
    overflow: hidden;
  }

  .preview-default {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }

  .preview-default.is-hidden { opacity: 0; }

  .preview-default__logo {
    width: 72px;
    opacity: 0.18;
    filter: blur(0.5px);
  }

  .preview-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .preview-layer.is-active { opacity: 1; }

  .preview-layer__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.75) brightness(0.6);
    transform: scale(1);
    transition: transform 1.1s cubic-bezier(0.16, 1, 0.3, 1), filter 0.7s ease;
  }

  .preview-layer.is-active .preview-layer__img {
    filter: saturate(0.95) brightness(0.85);
  }

  .preview-layer.is-active .preview-layer__img { transform: scale(1.04); }

  .preview-layer__vignette {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(6, 6, 11, 0.55) 0%,
      rgba(6, 6, 11, 0.15) 50%,
      rgba(6, 6, 11, 0.45) 100%
    );
  }

  .preview-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(
      to top,
      rgba(6, 6, 11, 0.97) 0%,
      rgba(6, 6, 11, 0.7) 55%,
      transparent 100%
    );
  }

  .preview-info__inner { padding: 52px 48px 48px; }

  .preview-info__tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--crimson);
    margin-bottom: 10px;
  }

  .preview-info__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 52px;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
    letter-spacing: 0.01em;
    margin-bottom: 14px;
  }

  .preview-info__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.68;
    max-width: 280px;
  }

  .preview-stamp {
    position: absolute;
    top: 24px;
    right: 24px;
    padding: 5px 10px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 2px;
  }

  .preview-stamp__text {
    font-family: 'DM Sans', sans-serif;
    font-size: 8px;
    letter-spacing: 0.2em;
    color: rgba(232, 228, 220, 0.15);
    text-transform: uppercase;
  }

  .preview-grain { opacity: 0.025; }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .index-wrap { flex-direction: column; }
    .list-panel { padding: 56px 24px 80px; }
    .preview-panel {
      width: 100%;
      height: 60vh;
      min-height: 360px;
      border-left: none;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      order: -1;
    }
    .preview-sticky {
      position: relative;
      top: 0;
      height: 100%;
    }
    .list-row__label { font-size: 32px; }
    .preview-info__inner { padding: 32px 24px 24px; }
    .preview-info__title { font-size: 36px; }
  }

  @media (max-width: 640px) {
    .list-row { gap: 14px; padding: 18px 0; }
    .list-row__label { font-size: 26px; }
    .list-row__num { width: 22px; font-size: 9px; }
    .list-row__count { display: none; }
  }
</style>
