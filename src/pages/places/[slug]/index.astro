---
import EntryLayout from "../../../layouts/EntryLayout.astro";
import { getLocalizedCollection } from "../../../i18n/content";

export async function getStaticPaths() {
  const entries = await getLocalizedCollection("places", "en");
  return entries
    .filter((e) => e.data.status === "public")
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
---

<EntryLayout active="places" entry={entry} locale="en" />
