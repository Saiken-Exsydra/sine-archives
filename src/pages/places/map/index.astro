---
import MainLayout from "../../../layouts/MainLayout.astro";

const DOSSIER = {
  north: {
    eyebrow: "Region I",
    title: "Northern Region",
    subhead: "The snow belt between the Black Shores, the Thornwall, and the northern fleet roads.",
    accent: "#6a9ab5",
    summary:
      "The north is the Empire's cold-facing edge. Its cities sit close to the sea, mountain passes, and timber rivers, making the region less dense than the center but strategically necessary. Ael'rath, Hal'vorn, Kor'rath, and Mire'thian Falls form the visible chain between coast, fleet, forest, and pass.",
    stats: [
      ["Dominant terrain", "Ice coast"],
      ["Main route", "Coastal fleet road"],
      ["Southern break", "Thornwall"],
    ],
    facts: [
      { title: "Ael'rath", text: "The northernmost major city and primary naval base of the Cold Fleet along the Dark-Side coast.", href: "/places/aelrath/" },
      { title: "Hal'vorn", text: "Administrative capital of the north, built where highland water becomes navigable river depth.", href: "/places/halvorn/" },
      { title: "Kor'rath", text: "A timber city whose river access gives the region much of its resource character.", href: "/places/korrath/" },
    ],
    routes: [
      ["Coast", "The Black Shores give the north its fleet identity and its harshest weather."],
      ["Interior", "Hal'vorn and Kor'rath mark the transition from naval edge to resource corridor."],
      ["Southern threshold", "The Thornwall is the visual hinge between northern cold and central green."],
    ],
    quote: "The north is sparse by population, but dense with routes that the Empire cannot afford to lose.",
    byline: "Northern geography",
    docRef: "IGS-I-NORTH-004",
  },
  central: {
    eyebrow: "Region II",
    title: "Central Region",
    subhead: "The green administrative basin where rivers, academies, and capital authority collect.",
    accent: "#b13a34",
    summary:
      "The central region is the Empire's most integrated landscape. Roads converge around Kalt'sen, the Vel'zaya River cuts across the basin, and academy cities sit close enough to the capital to feel like part of the same administrative weather. This is where Synus becomes legible as a state rather than a collection of frontiers.",
    stats: [
      ["Capital", "Kalt'sen"],
      ["Primary corridor", "Vel'zaya River"],
      ["Urban pattern", "Capital satellites"],
    ],
    facts: [
      { title: "Kalt'sen", text: "The place where every major institution keeps a central address and consequence accumulates block by block.", href: "/places/kaltsen/" },
      { title: "Vrenne", text: "An academy city that gives the center its intellectual and bureaucratic weight.", href: "/places/vrenne/" },
      { title: "Lon'drina", text: "A central city tied to education, administration, and the Empire's cultivated self-image.", href: "/places/londrina/" },
    ],
    routes: [
      ["Capital basin", "Kalt'sen is placed where river access, roads, and defensible elevation overlap."],
      ["Academy arc", "Lon'drina and Vrenne show how education and administration orbit the capital."],
      ["Eastern crossing", "Ube'lius connects the green center to the harder terrain near the Ardeatus border."],
    ],
    quote: "The center is where distance is converted into bureaucracy, trade, and command.",
    byline: "Central geography",
    docRef: "IGS-II-CENTRAL-011",
  },
  south: {
    eyebrow: "Region III",
    title: "Southern Region",
    subhead: "The descent from farmland into extraction spurs, furnace cities, and the Scorch belts.",
    accent: "#b08d3c",
    summary:
      "The south is the Empire's industrial slope. It begins at the central green belt, drops through the Scorch Escarpment, and ends in cracked extraction country. Lu'mia, Hora'veil, Cal'thas, and Sarn Pell make the southern geography feel engineered around fuel, armament, and frontier supply.",
    stats: [
      ["Northern lip", "Scorch Escarpment"],
      ["Industrial axis", "Hora'veil · Cal'thas"],
      ["Deep feature", "Vael Mouth"],
    ],
    facts: [
      { title: "Hora'veil", text: "Regional capital and primary military-industrial hub of the Long War effort.", href: "/places/horaveil/" },
      { title: "Cal'thas", text: "A weapons-production center that makes the southern region's war economy concrete.", href: "/places/calthas/" },
      { title: "Sarn Pell", text: "The civilian and military gate near the Ardeatus frontier.", href: "/places/sarn-pell/" },
    ],
    routes: [
      ["Escarpment", "The Scorch Escarpment is the break where the map stops being temperate."],
      ["Extraction chain", "Lu'mia, Hora'veil, and Cal'thas convert the south into supply geography."],
      ["Deep Scorch", "Vael Mouth anchors the red belt as a landmark, hazard, and mythic wound."],
    ],
    quote: "The south is where geography becomes output: crystal, weapons, road dust, and heat.",
    byline: "Southern geography",
    docRef: "IGS-III-SOUTH-019",
  },
  west: {
    eyebrow: "Western Border",
    title: "Aurora Approach",
    subhead: "The western cold frontier of mountains, passes, and white desert routes.",
    accent: "#88abc5",
    summary:
      "The western side is dominated by Aurora, the White Desert, and the mountain approach into the Empire. It reads as altitude, snow, passes, and watchful distance. Greygate Pass and the fortified line around Valerie make the border legible as a controlled crossing rather than a continuous furnace front.",
    stats: [
      ["Counterpower", "Aurora"],
      ["Key crossing", "Greygate Pass"],
      ["Terrain type", "Snow desert"],
    ],
    facts: [
      { title: "Aurora", text: "A neighboring power whose geography is defined by snow fields, mountain roads, and guarded approaches.", href: "/places/aurora/" },
      { title: "Greygate Pass", text: "The western pass compresses travel, diplomacy, and defense into one narrow route." },
      { title: "White Desert", text: "The silicate flats make the western approach visually open but logistically severe." },
    ],
    routes: [
      ["Mountain entry", "The border is easiest to understand through the pass system, not through open field movement."],
      ["Cold pressure", "The west presses on Synus through weather, elevation, and distance."],
      ["Imperial response", "Valerie and Vel'hara mark the Empire's effort to hold the approach with settlements and roads."],
    ],
    quote: "The western frontier is quiet only from a distance; every road across it is a decision point.",
    byline: "Western geography",
    docRef: "IGS-W-AURORA-007",
  },
  east: {
    eyebrow: "Eastern Border",
    title: "Ardeatus Frontier",
    subhead: "The eastern fortified edge where foundries, walls, and frontier roads dominate the map.",
    accent: "#c75b43",
    summary:
      "The eastern side is the map's hard border. Ardeatus rises beyond the wall, with Velitrachsen, state foundries, the Iron Bastion, and Kovansk forming an industrial frontier opposite the Empire's southern and central roads. This edge is visually warmer, harsher, and more militarized than the west.",
    stats: [
      ["Counterpower", "Ardeatus"],
      ["Border identity", "Iron Bastion"],
      ["Imperial gate", "Sarn Pell"],
    ],
    facts: [
      { title: "Ardeatus", text: "A federation-state of industry and forge theology whose border presence reshapes the eastern map.", href: "/places/ardeatus/" },
      { title: "Iron Bastion", text: "The wall reads as infrastructure, threat, and political statement at the same time." },
      { title: "Sarn Pell", text: "The Empire's southeastern gate sits where southern logistics meet frontier risk.", href: "/places/sarn-pell/" },
    ],
    routes: [
      ["Wall line", "The eastern border is read through fortification first and settlement second."],
      ["Industrial pressure", "Foundries and extraction roads make the edge feel active even where the map is still."],
      ["Southern tie", "Sarn Pell links the Ardeatus frontier back into the Empire's southern supply chain."],
    ],
    quote: "The east is where the Empire's map becomes a border engine: walls, roads, foundries, and gates.",
    byline: "Eastern geography",
    docRef: "IGS-E-ARDEATUS-023",
  },
};

const handles = [
  { region: "north",   id: "I",   label: "Northern Region", x: "48%", y: "26%" },
  { region: "central", id: "II",  label: "Central Region",  x: "42%", y: "51%" },
  { region: "south",   id: "III", label: "Southern Region", x: "56%", y: "67%" },
  { region: "west",    id: "W",   label: "Aurora",          x: "9%",  y: "31%" },
  { region: "east",    id: "E",   label: "Ardeatus",        x: "88%", y: "44%" },
];

const MAP_SRC = "/uploads/New%20Empire%20Map.png";
---

<MainLayout active="places" pageTitle="Empire Map — SiNE Archives">
  <section class="atlas" id="atlasRoot">

    <a class="atlas-back" href="/places/">
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
        <path d="M7 1.5L3 5L7 8.5" stroke="currentColor" stroke-width="1.4"
              stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>PLACES</span>
    </a>

    <div class="atlas-stage" id="atlasStage">

      <div class="map-frame" id="mapFrame">
        <div class="map-transform" id="mapTransform">
          <div class="map-canvas" id="mapCanvas">

            <img
              class="map-img"
              id="mapImg"
              src={MAP_SRC}
              alt="Illustrated map of the Empire of Synus"
              draggable="false"
            />

            {handles.map((h) => (
              <button class="handle" data-region={h.region} type="button" style={`--hx:${h.x};--hy:${h.y}`}>
                <span class="handle__id">{h.id}</span>
                <span class="handle__label">{h.label}</span>
              </button>
            ))}

          </div>
        </div>
      </div>

      <div class="map-vignette" aria-hidden="true"></div>
      <div class="map-grain" aria-hidden="true"></div>

      <div class="carto-chrome" aria-hidden="true">
        <div class="carto-compass">
          <span class="carto-compass__n">N</span>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"
               style="color:rgba(232,228,220,0.18)">
            <line x1="10" y1="1" x2="10" y2="19" stroke="currentColor" stroke-width="0.7"/>
            <line x1="1"  y1="10" x2="19" y2="10" stroke="currentColor" stroke-width="0.7"/>
            <circle cx="10" cy="10" r="2" fill="none" stroke="currentColor" stroke-width="0.7"/>
          </svg>
        </div>
        <div class="carto-ref">IGS · REF 44·7</div>
        <div class="carto-classification">
          IMPERIAL GEOGRAPHIC SURVEY · RESTRICTED CIRCULATION
        </div>
      </div>

      <div class="atlas-controls">
        <button class="ctrl-btn" id="resetBtn" type="button">RESET TO SURVEY VIEW</button>
        <button class="ctrl-btn ctrl-btn--icon" id="fullscreenBtn"
                type="button" aria-label="Toggle fullscreen">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
            <path d="M1.5 4.5V1.5h3M8.5 1.5h3v3M11.5 8.5v3h-3M4.5 11.5h-3v-3"
                  stroke="currentColor" stroke-width="1.3"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

    </div>

    <aside class="dossier" id="dossier" aria-hidden="true">

      <div class="dossier-stamp">CLASSIFIED · INTERNAL USE ONLY</div>

      <button class="dossier-close" id="dossierClose" type="button" aria-label="Close">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
          <line x1="1" y1="1" x2="10" y2="10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="10" y1="1" x2="1" y2="10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </button>

      <header class="dossier-head">
        <p class="dossier-eyebrow" id="dossierEyebrow"></p>
        <h2 id="dossierTitle"></h2>
        <p class="dossier-subhead" id="dossierSubhead"></p>
      </header>

      <div class="dossier-body" id="dossierBody">
        <p class="dossier-summary" id="dossierSummary"></p>
        <div class="dossier-stats" id="dossierStats"></div>
        <section class="dossier-section">
          <h3 class="dossier-section-title">Anchor Places</h3>
          <div class="dossier-facts" id="dossierFacts"></div>
        </section>
        <section class="dossier-section">
          <h3 class="dossier-section-title">Reading Lines</h3>
          <div class="dossier-routes" id="dossierRoutes"></div>
        </section>
        <blockquote class="dossier-quote">
          <p id="dossierQuote"></p>
          <cite id="dossierByline"></cite>
        </blockquote>
      </div>

      <footer class="dossier-foot">
        <span id="dossierRef"></span>
        <span id="dossierStatus">Imperial Geographic Survey</span>
      </footer>

    </aside>

  </section>
</MainLayout>

<script define:vars={{ DOSSIER }}>
  const atlasRoot     = document.getElementById("atlasRoot");
  const atlasStage    = document.getElementById("atlasStage");
  const mapFrame      = document.getElementById("mapFrame");
  const mapTransform  = document.getElementById("mapTransform");
  const mapCanvas     = document.getElementById("mapCanvas");
  const mapImgEl      = document.getElementById("mapImg");
  const dossierEl     = document.getElementById("dossier");
  const dossierClose  = document.getElementById("dossierClose");
  const resetBtn      = document.getElementById("resetBtn");
  const fullscreenBtn = document.getElementById("fullscreenBtn");

  let MAP_ASPECT = 1534 / 1025;

  const FOCUS = {
    empire:  { scale: 1.00, x:    0, y:    0 },
    north:   { scale: 1.46, x:    0, y:  180 },
    central: { scale: 1.58, x:  -70, y:   10 },
    south:   { scale: 1.44, x: -120, y: -178 },
    west:    { scale: 1.60, x:  390, y:   22 },
    east:    { scale: 1.60, x: -410, y:   18 },
  };

  const state = { scale: 1, x: 0, y: 0, selection: null };

  function syncMapSize() {
    if (!mapFrame || !mapCanvas) return;
    const frame = mapFrame.getBoundingClientRect();
    const w = Math.min(frame.width, frame.height * MAP_ASPECT);
    mapCanvas.style.width = Math.floor(w) + "px";
  }

  function applyTransform() {
    if (!mapTransform) return;
    mapTransform.style.transform =
      `translate(calc(-50% + ${state.x}px), calc(-50% + ${state.y}px)) scale(${state.scale})`;
  }

  function focusMap(key) {
    const f = FOCUS[key] || FOCUS.empire;
    syncMapSize();
    const ratio = (mapCanvas ? mapCanvas.offsetWidth : 1000) / 1000;
    state.scale = f.scale;
    state.x     = f.x * ratio;
    state.y     = f.y * ratio;
    applyTransform();
  }

  function el(id) { return document.getElementById(id); }
  function setText(id, val) { const e = el(id); if (e) e.textContent = val; }

  function openRegion(key) {
    const data = DOSSIER[key];
    if (!data) return;
    state.selection = key;

    atlasRoot.style.setProperty("--atlas-accent", data.accent);

    setText("dossierEyebrow", data.eyebrow);
    setText("dossierTitle",   data.title);
    setText("dossierSubhead", data.subhead);
    setText("dossierSummary", data.summary);
    setText("dossierQuote",   data.quote);
    setText("dossierByline",  data.byline);
    setText("dossierRef",     data.docRef || "");
    setText("dossierStatus",  data.eyebrow + " · " + data.title);

    const statsEl = el("dossierStats");
    if (statsEl) {
      statsEl.innerHTML = "";
      data.stats.forEach(function(s) {
        const d = document.createElement("div");
        d.className = "dossier-stat";
        d.innerHTML = '<div class="dossier-stat__label">' + s[0] + '</div>' +
                      '<div class="dossier-stat__value">' + s[1] + '</div>';
        statsEl.appendChild(d);
      });
    }

    const factsEl = el("dossierFacts");
    if (factsEl) {
      factsEl.innerHTML = "";
      data.facts.forEach(function(f) {
        const tag = f.href ? "a" : "article";
        const item = document.createElement(tag);
        item.className = "dossier-fact";
        if (f.href) item.href = f.href;
        item.innerHTML = "<span>" + f.title + "</span><em>" + f.text + "</em>";
        factsEl.appendChild(item);
      });
    }

    const routesEl = el("dossierRoutes");
    if (routesEl) {
      routesEl.innerHTML = "";
      data.routes.forEach(function(r) {
        const item = document.createElement("article");
        item.className = "dossier-route";
        item.innerHTML = "<h4>" + r[0] + "</h4><p>" + r[1] + "</p>";
        routesEl.appendChild(item);
      });
    }

    dossierEl.style.setProperty("--atlas-accent", data.accent);
    const quoteEl = dossierEl.querySelector(".dossier-quote");
    if (quoteEl) quoteEl.style.borderColor = data.accent;

    focusMap(key);

    dossierEl.classList.add("is-open");
    dossierEl.setAttribute("aria-hidden", "false");
    const body = el("dossierBody");
    if (body) body.scrollTop = 0;

    document.querySelectorAll(".handle").forEach(function(h) {
      h.classList.toggle("is-active", h.dataset.region === key);
    });
  }

  function closeRegion() {
    state.selection = null;
    dossierEl.classList.remove("is-open");
    dossierEl.setAttribute("aria-hidden", "true");
    document.querySelectorAll(".handle.is-active").forEach(function(h) {
      h.classList.remove("is-active");
    });
    atlasRoot.style.setProperty("--atlas-accent", "#b13a34");
    focusMap("empire");
  }

  document.querySelectorAll(".handle").forEach(function(h) {
    h.addEventListener("click", function(e) {
      e.stopPropagation();
      if (h.dataset.region === state.selection) {
        closeRegion();
      } else {
        openRegion(h.dataset.region);
      }
    });
  });

  atlasStage.addEventListener("click", function() {
    if (state.selection) closeRegion();
  });
  dossierEl.addEventListener("click", function(e) { e.stopPropagation(); });
  dossierClose.addEventListener("click", closeRegion);
  resetBtn.addEventListener("click", closeRegion);

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && state.selection) closeRegion();
  });

  fullscreenBtn.addEventListener("click", async function() {
    try {
      if (!document.fullscreenElement) {
        await document.documentElement.requestFullscreen();
      } else {
        await document.exitFullscreen();
      }
    } catch(err) {}
  });

  document.addEventListener("fullscreenchange", function() {
    requestAnimationFrame(function() { focusMap(state.selection || "empire"); });
  });

  window.addEventListener("resize", function() {
    requestAnimationFrame(function() { focusMap(state.selection || "empire"); });
  });

  function onMapLoaded() {
    if (mapImgEl.naturalWidth && mapImgEl.naturalHeight) {
      MAP_ASPECT = mapImgEl.naturalWidth / mapImgEl.naturalHeight;
      if (mapCanvas) mapCanvas.style.aspectRatio = MAP_ASPECT;
    }
    syncMapSize();
    applyTransform();
  }

  mapImgEl.addEventListener("load", onMapLoaded);
  if (mapImgEl.complete && mapImgEl.naturalWidth) onMapLoaded();
</script>

<style is:global>
  .atlas {
    --atlas-accent: #b13a34;
    position: fixed;
    top: 56px; left: 0; right: 0; bottom: 0;
    overflow: hidden;
    background: #030305;
    color: var(--text);
  }

  body:has(.atlas) .footer { display: none; }
  body:has(.atlas) .main { padding: 0; }

  @keyframes grainShift {
    0%   { background-position: 0 0; }
    25%  { background-position: 12% 18%; }
    50%  { background-position: -6% 9%; }
    75%  { background-position: 9% -6%; }
    100% { background-position: 0 0; }
  }

  .atlas-back {
    position: absolute;
    top: 20px;
    left: 24px;
    z-index: 20;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    height: 30px;
    padding: 0 11px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(6,6,11,0.72);
    backdrop-filter: blur(8px);
    color: rgba(232,228,220,0.56);
    text-decoration: none;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: color 160ms, border-color 160ms, background 160ms;
  }
  .atlas-back:hover {
    color: var(--text);
    border-color: rgba(255,255,255,0.2);
    background: rgba(6,6,11,0.92);
  }

  .atlas-stage {
    position: absolute;
    inset: 0;
    cursor: crosshair;
    background: #030305;
  }

  .map-frame {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .map-transform {
    position: absolute;
    left: 50%;
    top: 50%;
    transform-origin: center center;
    will-change: transform;
    transition: transform 640ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .map-canvas {
    position: relative;
    max-width: none;
  }
  .map-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
    pointer-events: none;
    filter: saturate(0.90) contrast(1.06) brightness(0.86);
  }

  .map-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background:
      radial-gradient(ellipse 90% 80% at 50% 50%, transparent 28%, rgba(3,3,5,0.58) 100%),
      linear-gradient(180deg, rgba(6,6,11,0.38) 0%, transparent 12%, transparent 80%, rgba(6,6,11,0.60) 100%),
      linear-gradient(90deg,  rgba(6,6,11,0.28) 0%, transparent 12%, transparent 88%, rgba(6,6,11,0.28) 100%);
  }

  .map-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.88' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    opacity: 0.03;
    mix-blend-mode: overlay;
    animation: grainShift 8s steps(1) infinite;
  }

  .handle {
    position: absolute;
    left: var(--hx);
    top:  var(--hy);
    transform: translate(-50%, -50%);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 5px 10px 5px 8px;
    border: 1px solid rgba(255,255,255,0.16);
    background: rgba(6,6,11,0.72);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: rgba(232,228,220,0.68);
    cursor: pointer;
    white-space: nowrap;
    font-family: inherit;
    transition: border-color 200ms, background 200ms, color 200ms, box-shadow 200ms;
  }
  .handle:hover {
    border-color: rgba(255,255,255,0.36);
    background: rgba(6,6,11,0.92);
    color: var(--text);
  }
  .handle.is-active {
    border-color: var(--atlas-accent);
    background: color-mix(in srgb, var(--atlas-accent) 16%, rgba(6,6,11,0.92));
    color: var(--text);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--atlas-accent) 30%, transparent);
  }
  .handle__id {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    color: var(--atlas-accent);
    min-width: 10px;
    text-align: center;
  }
  .handle__label {
    display: block;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1;
  }

  .carto-chrome {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 6;
  }
  .carto-compass {
    position: absolute;
    bottom: 52px;
    right: 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    color: rgba(232,228,220,0.22);
  }
  .carto-compass__n {
    font-size: 7px;
    font-weight: 700;
    letter-spacing: 0.14em;
  }
  .carto-ref {
    position: absolute;
    top: 18px;
    right: 28px;
