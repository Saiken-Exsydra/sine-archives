---
import MainLayout from "../../../layouts/MainLayout.astro";

const dossier = {
  empire: {
    eyebrow: "Empire",
    title: "The Empire of Synus",
    subhead: "A west-to-east empire organized by climate bands, river corridors, and fortified borders.",
    accent: "#b13a34",
    summary:
      "The Empire of Synus occupies the habitable band between the Black Shores and the Scorch. Its geography is easiest to read as a layered system: snow and fleet roads in the north, institutional and agricultural density through the center, extraction and war industry in the south, with Aurora and Ardeatus pressing against opposite borders.",
    stats: [
      ["North edge", "Black Shores"],
      ["Central hinge", "Kalt'sen basin"],
      ["South edge", "Scorch belts"],
    ],
    facts: [
      {
        title: "Imperial Center",
        text: "Kalt'sen sits where the central river routes, Pluribus Hill, and the Empire's institutional core converge.",
        href: "/places/kaltsen/",
      },
      {
        title: "Northern Wall",
        text: "The Thornwall and the northern highlands separate the cold coastal belt from the warmer central lowlands.",
        href: "/places/thornwall/",
      },
      {
        title: "Border Powers",
        text: "Aurora holds the western cold approach; Ardeatus hardens the eastern frontier into a long industrial border.",
      },
    ],
    routes: [
      ["Climate gradient", "The map descends from the ice of the Black Shores into the green center and then the red Scorch."],
      ["Transit spine", "Coastal fleet routes, river valleys, and extraction spurs tie distant regions into one imperial network."],
      ["Defensive shape", "The Empire is broadest where roads and rivers cooperate, and most brittle where the borders become walls."],
    ],
    quote: "Synus is not a single landscape. It is a chain of climates held together by roads, rivers, and command.",
    byline: "Geographical survey",
  },
  north: {
    eyebrow: "Region I",
    title: "Northern Region",
    subhead: "The snow belt between the Black Shores, the Thornwall, and the northern fleet roads.",
    accent: "#6a9ab5",
    summary:
      "The north is the Empire's cold-facing edge. Its cities sit close to the sea, mountain passes, and timber rivers, making the region less dense than the center but strategically necessary. Ael'rath, Hal'vorn, Kor'rath, and Mire'thian Falls form the visible chain between coast, fleet, forest, and pass.",
    stats: [
      ["Dominant terrain", "Ice coast"],
      ["Main route", "Coastal fleet road"],
      ["Southern break", "Thornwall"],
    ],
    facts: [
      {
        title: "Ael'rath",
        text: "The northernmost major city and primary naval base of the Cold Fleet along the Dark-Side coast.",
        href: "/places/aelrath/",
      },
      {
        title: "Hal'vorn",
        text: "Administrative capital of the north, built where highland water becomes navigable river depth.",
        href: "/places/halvorn/",
      },
      {
        title: "Kor'rath",
        text: "A timber city whose river access gives the region much of its resource character.",
        href: "/places/korrath/",
      },
    ],
    routes: [
      ["Coast", "The Black Shores give the north its fleet identity and its harshest weather."],
      ["Interior", "Hal'vorn and Kor'rath mark the transition from naval edge to resource corridor."],
      ["Southern threshold", "The Thornwall is the visual hinge between northern cold and central green."],
    ],
    quote: "The north is sparse by population, but dense with routes that the Empire cannot afford to lose.",
    byline: "Northern geography",
  },
  central: {
    eyebrow: "Region II",
    title: "Central Region",
    subhead: "The green administrative basin where rivers, academies, and capital authority collect.",
    accent: "#b13a34",
    summary:
      "The central region is the Empire's most integrated landscape. Roads converge around Kalt'sen, the Vel'zaya River cuts across the basin, and academy cities sit close enough to the capital to feel like part of the same administrative weather. This is where Synus becomes legible as a state rather than a collection of frontiers.",
    stats: [
      ["Capital", "Kalt'sen"],
      ["Primary corridor", "Vel'zaya River"],
      ["Urban pattern", "Capital satellites"],
    ],
    facts: [
      {
        title: "Kalt'sen",
        text: "The place where every major institution keeps a central address and consequence accumulates block by block.",
        href: "/places/kaltsen/",
      },
      {
        title: "Vrenne",
        text: "An academy city that gives the center its intellectual and bureaucratic weight.",
        href: "/places/vrenne/",
      },
      {
        title: "Lon'drina",
        text: "A central city tied to education, administration, and the Empire's cultivated self-image.",
        href: "/places/londrina/",
      },
    ],
    routes: [
      ["Capital basin", "Kalt'sen is placed where river access, roads, and defensible elevation overlap."],
      ["Academy arc", "Lon'drina and Vrenne show how education and administration orbit the capital."],
      ["Eastern crossing", "Ube'lius connects the green center to the harder terrain near the Ardeatus border."],
    ],
    quote: "The center is where distance is converted into bureaucracy, trade, and command.",
    byline: "Central geography",
  },
  south: {
    eyebrow: "Region III",
    title: "Southern Region",
    subhead: "The descent from farmland into extraction spurs, furnace cities, and the Scorch belts.",
    accent: "#b08d3c",
    summary:
      "The south is the Empire's industrial slope. It begins at the central green belt, drops through the Scorch Escarpment, and ends in cracked extraction country. Lu'mia, Hora'veil, Cal'thas, and Sarn Pell make the southern geography feel engineered around fuel, armament, and frontier supply.",
    stats: [
      ["Northern lip", "Scorch Escarpment"],
      ["Industrial axis", "Hora'veil · Cal'thas"],
      ["Deep feature", "Vael Mouth"],
    ],
    facts: [
      {
        title: "Hora'veil",
        text: "Regional capital and primary military-industrial hub of the Long War effort.",
        href: "/places/horaveil/",
      },
      {
        title: "Cal'thas",
        text: "A weapons-production center that makes the southern region's war economy concrete.",
        href: "/places/calthas/",
      },
      {
        title: "Sarn Pell",
        text: "The civilian and military gate near the Ardeatus frontier.",
        href: "/places/sarn-pell/",
      },
    ],
    routes: [
      ["Escarpment", "The Scorch Escarpment is the break where the map stops being temperate."],
      ["Extraction chain", "Lu'mia, Hora'veil, and Cal'thas convert the south into supply geography."],
      ["Deep Scorch", "Vael Mouth anchors the red belt as a landmark, hazard, and mythic wound."],
    ],
    quote: "The south is where geography becomes output: crystal, weapons, road dust, and heat.",
    byline: "Southern geography",
  },
  west: {
    eyebrow: "Western Border",
    title: "Aurora Approach",
    subhead: "The western cold frontier of mountains, passes, and white desert routes.",
    accent: "#88abc5",
    summary:
      "The western side of the map is dominated by Aurora, the White Desert, and the mountain approach into the Empire. It is not as industrial as the eastern border; it reads as altitude, snow, passes, and watchful distance. Greygate Pass and the fortified line around Valerie make the border legible as a controlled crossing rather than a continuous furnace front.",
    stats: [
      ["Counterpower", "Aurora"],
      ["Key crossing", "Greygate Pass"],
      ["Terrain type", "Snow desert"],
    ],
    facts: [
      {
        title: "Aurora",
        text: "A neighboring power whose geography is defined by snow fields, mountain roads, and guarded approaches.",
        href: "/places/aurora/",
      },
      {
        title: "Greygate Pass",
        text: "The western pass compresses travel, diplomacy, and defense into one narrow route.",
      },
      {
        title: "White Desert",
        text: "The silicate flats make the western approach visually open but logistically severe.",
      },
    ],
    routes: [
      ["Mountain entry", "The border is easiest to understand through the pass system, not through open field movement."],
      ["Cold pressure", "The west presses on Synus through weather, elevation, and distance."],
      ["Imperial response", "Valerie and Vel'hara mark the Empire's effort to hold the approach with settlements and roads."],
    ],
    quote: "The western frontier is quiet only from a distance; every road across it is a decision point.",
    byline: "Western geography",
  },
  east: {
    eyebrow: "Eastern Border",
    title: "Ardeatus Frontier",
    subhead: "The eastern fortified edge where foundries, walls, and frontier roads dominate the map.",
    accent: "#c75b43",
    summary:
      "The eastern side is the map's hard border. Ardeatus rises beyond the wall, with Velitrachsen, state foundries, the Iron Bastion, and Kovansk forming an industrial frontier opposite the Empire's southern and central roads. This edge is visually warmer, harsher, and more militarized than the west.",
    stats: [
      ["Counterpower", "Ardeatus"],
      ["Border identity", "Iron Bastion"],
      ["Imperial gate", "Sarn Pell"],
    ],
    facts: [
      {
        title: "Ardeatus",
        text: "A federation-state of industry and forge theology whose border presence reshapes the eastern map.",
        href: "/places/ardeatus/",
      },
      {
        title: "Iron Bastion",
        text: "The wall reads as infrastructure, threat, and political statement at the same time.",
      },
      {
        title: "Sarn Pell",
        text: "The Empire's southeastern gate sits where southern logistics meet frontier risk.",
        href: "/places/sarn-pell/",
      },
    ],
    routes: [
      ["Wall line", "The eastern border is read through fortification first and settlement second."],
      ["Industrial pressure", "Foundries and extraction roads make the edge feel active even where the map is still."],
      ["Southern tie", "Sarn Pell links the Ardeatus frontier back into the Empire's southern supply chain."],
    ],
    quote: "The east is where the Empire's map becomes a border engine: walls, roads, foundries, and gates.",
    byline: "Eastern geography",
  },
};

const initial = dossier.empire;
const tabs = [
  ["empire", "Empire"],
  ["north", "North"],
  ["central", "Central"],
  ["south", "South"],
  ["west", "West"],
  ["east", "East"],
];
---

<MainLayout active="places" pageTitle="Empire Map — SiNE Archives">
  <section class="atlas" id="atlasRoot">
    <header class="atlas__header">
      <div class="atlas__identity">
        <a class="atlas__back" href="/places/" aria-label="Back to Places">
          <span aria-hidden="true">‹</span>
          <span>Places</span>
        </a>
        <div>
          <p class="atlas__kicker">Places · Imperial Atlas</p>
          <h1>Empire Map</h1>
        </div>
      </div>

      <div class="atlas__actions">
        <button class="atlas-btn" id="resetBtn" type="button">Empire View</button>
        <button class="atlas-btn atlas-btn--solid" id="fullscreenBtn" type="button">Fullscreen</button>
      </div>
    </header>

    <div class="atlas__workspace">
      <div class="atlas__stage">
        <div class="map-frame" id="mapFrame" aria-label="Map of the Empire of Synus">
          <div class="map-transform" id="mapTransform">
            <div class="map-canvas" id="mapCanvas">
              <img
                class="map-image"
                src="/uploads/New%20Empire%20Map.png"
                alt="Illustrated map of the Empire of Synus, including northern, central, and southern regions."
                draggable="false"
              />
            </div>
          </div>
        </div>
        <div class="map-vignette" aria-hidden="true"></div>
      </div>

      <aside class="dossier" aria-live="polite">
        <header class="dossier__head">
          <p class="dossier__eyebrow" id="dossierEyebrow">{initial.eyebrow}</p>
          <h2 id="dossierTitle">{initial.title}</h2>
          <p class="dossier__subhead" id="dossierSubhead">{initial.subhead}</p>
        </header>

        <nav class="tabstrip" id="tabstrip" aria-label="Map focus">
          {tabs.map(([key, label]) => (
            <button class={key === "empire" ? "is-active" : ""} data-target={key} type="button">
              {label}
            </button>
          ))}
        </nav>

        <div class="dossier__body">
          <p class="summary" id="dossierSummary">{initial.summary}</p>

          <div class="stats" id="dossierStats">
            {initial.stats.map(([label, value]) => (
              <div class="stat">
                <div class="stat__label">{label}</div>
                <div class="stat__value">{value}</div>
              </div>
            ))}
          </div>

          <section class="section">
            <h3 class="section__title">Anchor Places</h3>
            <div class="fact-list" id="dossierFacts">
              {initial.facts.map((fact) => (
                <a class="fact-link" href={fact.href ?? "#"}>
                  <span>{fact.title}</span>
                  <em>{fact.text}</em>
                </a>
              ))}
            </div>
          </section>

          <section class="section">
            <h3 class="section__title">Reading Lines</h3>
            <div class="route-list" id="dossierRoutes">
              {initial.routes.map(([title, text]) => (
                <article>
                  <h4>{title}</h4>
                  <p>{text}</p>
                </article>
              ))}
            </div>
          </section>

          <blockquote class="quote">
            <p id="dossierQuote">{initial.quote}</p>
            <cite id="dossierQuoteByline">{initial.byline}</cite>
          </blockquote>
        </div>

        <footer class="dossier__foot">
          <span id="dossierStatus">Imperial survey overlay</span>
        </footer>
      </aside>
    </div>
  </section>
</MainLayout>

<script define:vars={{ dossierJson: JSON.stringify(dossier) }}>
  const DOSSIER = JSON.parse(dossierJson);

  const root = document.getElementById("atlasRoot");
  const mapTransform = document.getElementById("mapTransform");
  const mapFrame = document.getElementById("mapFrame");
  const mapCanvas = document.getElementById("mapCanvas");
  const resetBtn = document.getElementById("resetBtn");
  const fullscreenBtn = document.getElementById("fullscreenBtn");
  const tabs = Array.from(document.querySelectorAll("#tabstrip button"));
  const mapAspect = 1534 / 1025;

  const focus = {
    empire: { scale: 1, x: 0, y: 0 },
    north: { scale: 1.46, x: 0, y: 180 },
    central: { scale: 1.58, x: -70, y: 10 },
    south: { scale: 1.44, x: -120, y: -178 },
    west: { scale: 1.58, x: 390, y: 22 },
    east: { scale: 1.58, x: -410, y: 18 },
  };

  const state = {
    scale: focus.empire.scale,
    x: 0,
    y: focus.empire.y,
    selection: "empire",
  };

  function syncMapSize() {
    if (!mapFrame || !mapCanvas) return;
    const frame = mapFrame.getBoundingClientRect();
    const containWidth = Math.min(frame.width, frame.height * mapAspect);
    mapCanvas.style.width = `${Math.floor(containWidth)}px`;
  }

  function text(id, value) {
    const element = document.getElementById(id);
    if (element) element.textContent = value;
  }

  function applyTransform() {
    if (!mapTransform || !mapFrame || !mapCanvas) return;
    syncMapSize();
    mapTransform.style.transform = `translate(calc(-50% + ${state.x}px), calc(-50% + ${state.y}px)) scale(${state.scale})`;
  }

  function focusMap(key) {
    const next = focus[key] || focus.empire;
    syncMapSize();
    const offsetRatio = (mapCanvas?.offsetWidth || 1000) / 1000;
    state.scale = next.scale;
    state.x = next.x * offsetRatio;
    state.y = next.y * offsetRatio;
    applyTransform();
  }

  function renderStats(data) {
    const stats = document.getElementById("dossierStats");
    if (!stats) return;
    stats.replaceChildren();

    data.stats.forEach(([label, value]) => {
      const item = document.createElement("div");
      item.className = "stat";

      const labelEl = document.createElement("div");
      labelEl.className = "stat__label";
      labelEl.textContent = label;

      const valueEl = document.createElement("div");
      valueEl.className = "stat__value";
      valueEl.textContent = value;

      item.append(labelEl, valueEl);
      stats.appendChild(item);
    });
  }

  function renderFacts(data) {
    const facts = document.getElementById("dossierFacts");
    if (!facts) return;
    facts.replaceChildren();

    data.facts.forEach((fact) => {
      const item = document.createElement(fact.href ? "a" : "article");
      item.className = "fact-link";
      if (fact.href) item.href = fact.href;

      const title = document.createElement("span");
      title.textContent = fact.title;

      const body = document.createElement("em");
      body.textContent = fact.text;

      item.append(title, body);
      facts.appendChild(item);
    });
  }

  function renderRoutes(data) {
    const routes = document.getElementById("dossierRoutes");
    if (!routes) return;
    routes.replaceChildren();

    data.routes.forEach(([title, body]) => {
      const item = document.createElement("article");
      const h = document.createElement("h4");
      const p = document.createElement("p");
      h.textContent = title;
      p.textContent = body;
      item.append(h, p);
      routes.appendChild(item);
    });
  }

  function setSelection(key) {
    const data = DOSSIER[key];
    if (!data || !root) return;

    state.selection = key;
    root.style.setProperty("--atlas-accent", data.accent);
    focusMap(key);

    text("dossierEyebrow", data.eyebrow);
    text("dossierTitle", data.title);
    text("dossierSubhead", data.subhead);
    text("dossierSummary", data.summary);
    text("dossierQuote", data.quote);
    text("dossierQuoteByline", data.byline);
    text("dossierStatus", `${data.eyebrow} · ${data.title}`);

    renderStats(data);
    renderFacts(data);
    renderRoutes(data);

    tabs.forEach((tab) => {
      const active = tab.dataset.target === key;
      tab.classList.toggle("is-active", active);
      tab.setAttribute("aria-current", active ? "true" : "false");
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => setSelection(tab.dataset.target));
  });

  resetBtn?.addEventListener("click", () => setSelection("empire"));

  fullscreenBtn?.addEventListener("click", async () => {
    if (!root) return;
    try {
      if (!document.fullscreenElement) {
        await root.requestFullscreen();
        fullscreenBtn.textContent = "Exit";
      } else {
        await document.exitFullscreen();
        fullscreenBtn.textContent = "Fullscreen";
      }
    } catch {
      fullscreenBtn.textContent = "Fullscreen";
    }
  });

  document.addEventListener("fullscreenchange", () => {
    if (fullscreenBtn) fullscreenBtn.textContent = document.fullscreenElement ? "Exit" : "Fullscreen";
    requestAnimationFrame(() => focusMap(state.selection));
  });

  window.addEventListener("resize", () => requestAnimationFrame(() => focusMap(state.selection)));

  applyTransform();
  setSelection("empire");
</script>

<style is:global>
  .atlas {
    --atlas-accent: var(--crimson);
    min-height: calc(100vh - 56px);
    background:
      radial-gradient(circle at 18% 0%, rgba(255, 255, 255, 0.045), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 18%),
      var(--bg);
    color: var(--text);
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
  }

  .atlas:fullscreen {
    min-height: 100vh;
  }

  .atlas__header {
    min-height: 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 16px 28px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(6, 6, 11, 0.72);
  }

  .atlas__identity {
    display: flex;
    align-items: center;
    gap: 18px;
    min-width: 0;
  }

  .atlas__back {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 34px;
    padding: 0 11px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(232, 228, 220, 0.64);
    text-decoration: none;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.025);
  }

  .atlas__back span:first-child {
    font-size: 18px;
    line-height: 0;
  }

  .atlas__back:hover {
    color: var(--text);
    border-color: rgba(255, 255, 255, 0.16);
  }

  .atlas__kicker {
    margin: 0 0 4px;
    color: var(--atlas-accent);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .atlas__header h1 {
    margin: 0;
    font-family: 'Cormorant Garamond', serif;
    font-size: 34px;
    line-height: 0.95;
    letter-spacing: 0.02em;
  }

  .atlas__actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .atlas-btn {
    appearance: none;
    height: 34px;
    min-width: 112px;
    padding: 0 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(4, 5, 8, 0.74);
    color: var(--text);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 160ms ease, border-color 160ms ease;
  }

  .atlas-btn:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.16);
  }

  .atlas-btn--solid {
    background: linear-gradient(180deg, color-mix(in srgb, var(--atlas-accent) 32%, transparent), rgba(177, 58, 52, 0.12));
    border-color: color-mix(in srgb, var(--atlas-accent) 58%, transparent);
  }

  .atlas__workspace {
    min-height: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 380px;
  }

  .atlas__stage {
    min-width: 0;
    position: relative;
    overflow: hidden;
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.015), transparent 12%),
      radial-gradient(circle at 50% -10%, rgba(177, 58, 52, 0.1), transparent 28%),
      #030305;
  }

  .map-frame {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .map-transform {
    position: absolute;
    left: 50%;
    top: 50%;
    transform-origin: center center;
    will-change: transform;
    transition: transform 620ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .map-canvas {
    position: relative;
    width: min(100%, calc(100vh * 1.496));
    aspect-ratio: 1534 / 1025;
    max-width: none;
  }

  .map-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
    pointer-events: none;
    filter: saturate(0.92) contrast(1.05) brightness(0.9);
  }

  .map-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(6, 6, 11, 0.28), transparent 18%, transparent 72%, rgba(6, 6, 11, 0.34)),
      linear-gradient(180deg, rgba(6, 6, 11, 0.28), transparent 22%, rgba(6, 6, 11, 0.46));
  }

  .dossier {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.025), transparent 16%),
      color-mix(in srgb, var(--surface) 78%, #000);
    display: grid;
    grid-template-rows: auto auto minmax(0, 1fr) auto;
    min-height: 0;
  }

  .dossier__head {
    padding: 24px 24px 18px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .dossier__eyebrow {
    margin: 0 0 8px;
    color: var(--atlas-accent);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .dossier__head h2 {
    margin: 0;
    font-family: 'Cormorant Garamond', serif;
    font-size: 34px;
    line-height: 0.98;
  }

  .dossier__subhead {
    margin: 9px 0 0;
    color: rgba(232, 228, 220, 0.7);
    font-size: 13px;
    line-height: 1.55;
  }

  .tabstrip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tabstrip button {
    appearance: none;
    border: 0;
    background: rgba(255, 255, 255, 0.02);
    color: rgba(232, 228, 220, 0.54);
    padding: 12px 6px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .tabstrip button:hover,
