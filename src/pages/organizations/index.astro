---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const rawEntries = await getCollection("organizations");
const publicEntries = rawEntries
  .filter((e) => e.data.status === "public")
  .sort((a, b) => {
    const pa = (a.data as any).priority ?? Infinity;
    const pb = (b.data as any).priority ?? Infinity;
    if (pa !== pb) return pa - pb;
    return a.data.title.localeCompare(b.data.title);
  });

const ROMAN = ["I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX", "X"];

const ACCENTS: Record<string, string> = {
  "apocachynthion": "#b13a34",
  "the-church":     "#b08d3c",
  "obsidian-rite":  "#6a5a9a",
};

const OBJECT_POSITION: Record<string, string> = {
  "apocachynthion": "center 35%",
  "the-church":     "center 40%",
};

type Entry = (typeof publicEntries)[number];

type Panel = {
  slug:           string;
  title:          string;
  type:           string;
  designation:    string;
  summary:        string;
  image:          string;
  accent:         string;
  numeral:        string;
  objectPosition: string;
  tags:           string[];
  fields:         Record<string, string>;
};

const buildPanel = (e: Entry, idx: number): Panel => {
  const d = e.data as any;
  // Full fields for modal (designation + all contextual + filed)
  const allFields: Record<string, string> = {};
  if (d.designation)  allFields["Designation"]  = d.designation;
  if (d.affiliation)  allFields["Affiliation"]  = d.affiliation;
  if (d.headquarters) allFields["Headquarters"] = d.headquarters;
  if (d.founded)      allFields["Founded"]      = d.founded;
  if (d.jurisdiction) allFields["Jurisdiction"] = d.jurisdiction;
  if (d.status_label) allFields["Status"]       = d.status_label;
  allFields["Filed"] = "Organizations";

  return {
    slug:           e.slug,
    title:          d.title,
    type:           d.type || "Organization",
    designation:    d.designation || "",
    summary:        d.summary || "",
    image:          (d.image && d.image.length > 0) ? d.image : "",
    accent:         ACCENTS[e.slug] || "#b13a34",
    numeral:        ROMAN[idx] || String(idx + 1),
    objectPosition: OBJECT_POSITION[e.slug] || "center 40%",
    tags:           Array.isArray(d.tags) ? d.tags.slice(0, 5) : [],
    fields:         allFields,
  };
};

const panels = publicEntries.map(buildPanel);

// Spread display fields (no designation, no filed)
const spreadFields = publicEntries.map((e) => {
  const d = e.data as any;
  const f: Record<string, string> = {};
  if (d.affiliation)  f["Affiliation"]  = d.affiliation;
  if (d.headquarters) f["Headquarters"] = d.headquarters;
  if (d.founded)      f["Founded"]      = d.founded;
  if (d.jurisdiction) f["Jurisdiction"] = d.jurisdiction;
  if (d.status_label) f["Status"]       = d.status_label;
  return f;
});
---

<MainLayout active="organizations" pageTitle="Organizations — SiNE Archives">
  <div class="orgs-root">

    <!-- Page header -->
    <header class="orgs-hdr">
      <div class="orgs-hdr__pre">
        <span class="orgs-hdr__label">INSTITUTIONAL REGISTRY</span>
        <span class="orgs-hdr__sep" aria-hidden="true">·</span>
        <span class="orgs-hdr__count">{panels.length} {panels.length === 1 ? "entity" : "entities"} on file</span>
      </div>
      <h1 class="orgs-hdr__title">Organizations</h1>
      <p class="orgs-hdr__desc">Active institutions, governance bodies, and faith orders operating within the SiNE</p>
    </header>

    <!-- Quick index strip -->
    <nav class="orgs-index" aria-label="Organization index">
      {panels.map((p, i) => (
        <a href={`#org-${p.slug}`} class="orgs-index__item" style={`--accent: ${p.accent};`}>
          <span class="orgs-index__num" aria-hidden="true">{p.numeral}</span>
          <span class="orgs-index__name">{p.title}</span>
          <span class="orgs-index__type">{p.type}</span>
        </a>
      ))}
    </nav>

    <!-- Registry spreads -->
    <div class="orgs-registry">
      {panels.map((p, i) => (
        <article
          class:list={["org-spread", { "org-spread--flip": i % 2 === 1 }]}
          id={`org-${p.slug}`}
          style={`--accent: ${p.accent};`}
          data-slug={p.slug}
        >
          <!-- Image side -->
          <div class="org-spread__img-wrap">
            {p.image ? (
              <img
                class="org-spread__img"
                src={p.image}
                alt=""
                loading={i === 0 ? "eager" : "lazy"}
                style={`object-position: ${p.objectPosition};`}
              />
            ) : (
              <div class="org-spread__img-fallback"></div>
            )}
            <div class="org-spread__img-vignette"></div>
            <div class="org-spread__img-grain" aria-hidden="true"></div>
            <div class="org-spread__img-numeral" aria-hidden="true">{p.numeral}</div>
            {p.tags.length > 0 && (
              <div class="org-spread__img-tags">
                {p.tags.map((t) => (
                  <span class="org-spread__img-tag">{t}</span>
                ))}
              </div>
            )}
          </div>

          <!-- Content side -->
          <div class="org-spread__content">
            <div class="org-spread__content-inner">
              <div class="org-spread__eyebrow">
                <span class="org-spread__eye-type">{p.type.toUpperCase()}</span>
                <span class="org-spread__eye-dot" aria-hidden="true">·</span>
                <span class="org-spread__eye-ord">{String(i + 1).padStart(2, "0")} / {String(panels.length).padStart(2, "0")}</span>
              </div>

              <h2 class="org-spread__title">{p.title}</h2>

              {p.designation && (
                <div class="org-spread__designation">{p.designation}</div>
              )}

              <div class="org-spread__rule" aria-hidden="true"></div>

              {Object.keys(spreadFields[i]).length > 0 && (
                <dl class="org-spread__meta">
                  {Object.entries(spreadFields[i]).map(([k, v]) => (
                    <>
                      <dt class="org-spread__meta-key">{k}</dt>
                      <dd class="org-spread__meta-val">{v}</dd>
                    </>
                  ))}
                </dl>
              )}

              <p class="org-spread__summary">{p.summary}</p>

              <button class="org-spread__cta" type="button" data-open-entry={p.slug}>
                Open Dossier
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                  <path d="M1 5.5h9M5.5 1l4.5 4.5-4.5 4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Footer -->
    <footer class="orgs-footer">
      <div class="orgs-footer__inner">
        <div class="orgs-footer__rule"></div>
        <div class="orgs-footer__mid">
          <span class="orgs-footer__label">Institutional Registry</span>
          <span class="orgs-footer__count">{panels.length} {panels.length === 1 ? "entry" : "entries"} on file</span>
        </div>
        <div class="orgs-footer__rule"></div>
      </div>
      <div class="orgs-footer__nav">
        <div class="orgs-footer__nav-rule"></div>
        <a href="/" class="orgs-footer__back">← Return to Archives Index</a>
      </div>
    </footer>
  </div>

  <!-- Modal overlay (unchanged from previous implementation) -->
  <div class="org-overlay" id="org-overlay" aria-hidden="true">
    <div class="org-modal" id="org-modal" role="dialog" aria-modal="true">
      <button class="org-modal__close" id="org-modal-close" aria-label="Close entry">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
          <line x1="1" y1="1" x2="10" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="10" y1="1" x2="1" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

      <aside class="org-modal__hero" id="org-modal-hero">
        <img class="org-modal__hero-img" id="org-modal-img" src="" alt="" />
        <div class="org-modal__hero-fade"></div>
        <div class="org-modal__hero-accent" id="org-modal-accent"></div>
        <div class="org-grain"></div>
        <div class="org-modal__hero-bar" id="org-modal-bar"></div>
        <div class="org-modal__hero-tags" id="org-modal-tags"></div>
        <div class="org-modal__hero-content">
          <div class="org-modal__hero-type" id="org-modal-type"></div>
          <div class="org-modal__hero-title" id="org-modal-title"></div>
          <div class="org-modal__hero-designation" id="org-modal-designation"></div>
        </div>
      </aside>

      <div class="org-modal__pane" id="org-modal-pane">
        <div class="org-modal__pane-inner">
          <div class="org-modal__fields-card">
            <div class="org-modal__fields-title" id="org-modal-fields-title">Classification Data</div>
            <div id="org-modal-fields"></div>
          </div>

          <p class="org-modal__lead" id="org-modal-lead"></p>

          <div class="org-modal__divider"></div>

          <div class="org-modal__body" id="org-modal-body">
            <p class="org-modal__loading">Loading entry…</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script define:vars={{ panels }} is:inline>
  const PANELS = panels;
  const byId = (id) => document.getElementById(id);

  const overlay          = byId("org-overlay");
  const modal            = byId("org-modal");
  const modalImg         = byId("org-modal-img");
  const modalAccent      = byId("org-modal-accent");
  const modalBar         = byId("org-modal-bar");
  const modalType        = byId("org-modal-type");
  const modalTitle       = byId("org-modal-title");
  const modalDes         = byId("org-modal-designation");
  const modalTags        = byId("org-modal-tags");
  const modalFieldsTitle = byId("org-modal-fields-title");
  const modalFields      = byId("org-modal-fields");
  const modalLead        = byId("org-modal-lead");
  const modalBody        = byId("org-modal-body");
  const closeBtn         = byId("org-modal-close");

  let closing = false;

  function openModal(slug) {
    const p = PANELS.find((x) => x.slug === slug);
    if (!p) return;

    if (p.image) {
      modalImg.src = p.image;
      modalImg.style.display = "";
    } else {
      modalImg.removeAttribute("src");
      modalImg.style.display = "none";
    }

    modalAccent.style.background = `linear-gradient(to top, ${p.accent}33, transparent 55%)`;
    modalBar.style.background = `linear-gradient(to bottom, transparent, ${p.accent}aa, transparent)`;

    modalType.textContent = (p.type || "Organization").toUpperCase();
    modalType.style.color = p.accent;
    modalTitle.textContent = p.title;
    modalDes.textContent = p.designation || "";
    modalDes.style.color = p.accent;

    modalFieldsTitle.style.color = p.accent;
    modalFields.innerHTML = Object.entries(p.fields || {}).map(([k, v]) => `
      <div class="org-field-row">
        <div class="org-field-key">${k}</div>
        <div class="org-field-val">${v}</div>
      </div>
    `).join("");

    modalTags.innerHTML = (p.tags || []).map((t) => `
      <span class="org-modal__tag" style="border-color: ${p.accent}55">${t}</span>
    `).join("");

    modalLead.textContent = p.summary || "";

    modalBody.innerHTML = `<p class="org-modal__loading">Loading entry…</p>`;
    fetch(`/organizations/${p.slug}/`)
      .then((r) => r.text())
      .then((html) => {
        const doc = new DOMParser().parseFromString(html, "text/html");
        const content =
          doc.querySelector("[data-entry-body]") ||
          doc.querySelector(".entry-body") ||
          doc.querySelector("article");
        if (content) {
          modalBody.innerHTML = content.innerHTML;
        } else {
          modalBody.innerHTML = `<p class="org-modal__para">${p.summary || ""}</p>`;
        }
      })
      .catch(() => {
        modalBody.innerHTML = `<p class="org-modal__para">${p.summary || ""}</p>`;
      });

    overlay.classList.add("is-open");
    overlay.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    const pane = byId("org-modal-pane");
    if (pane) pane.scrollTop = 0;
  }

  function closeModal() {
    if (closing) return;
    closing = true;
    modal.classList.add("is-closing");
    setTimeout(() => {
      overlay.classList.remove("is-open");
      overlay.setAttribute("aria-hidden", "true");
      modal.classList.remove("is-closing");
      document.body.style.overflow = "";
      closing = false;
    }, 380);
  }

  document.querySelectorAll("[data-open-entry]").forEach((el) => {
    el.addEventListener("click", () => {
      const slug = el.getAttribute("data-open-entry");
      openModal(slug);
    });
  });

  closeBtn.addEventListener("click", closeModal);
  overlay.addEventListener("click", (e) => { if (e.target === overlay) closeModal(); });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && overlay.classList.contains("is-open")) closeModal();
  });

  // Reveal-on-scroll for spreads
  const spreadEls = document.querySelectorAll(".org-spread");
  spreadEls.forEach((el, i) => {
    if (i === 0) {
      requestAnimationFrame(() => el.classList.add("in-view"));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            el.classList.add("in-view");
            io.disconnect();
          }
        });
      },
      { threshold: 0.08 }
    );
    io.observe(el);
  });
</script>

<style>
  /* ── keyframes ── */
  @keyframes orgGrainShift {
    0%   { background-position: 0 0; }
    25%  { background-position: 12% 18%; }
    50%  { background-position: -6% 9%; }
    75%  { background-position: 9% -6%; }
    100% { background-position: 0 0; }
  }
  @keyframes orgRuleIn {
    from { transform: scaleX(0); opacity: 0; }
    to   { transform: scaleX(1); opacity: 1; }
  }

  /* ── shared grain ── */
  :global(.org-grain) {
    position: absolute; inset: 0; pointer-events: none; z-index: 4;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.88' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    opacity: 0.03;
    mix-blend-mode: overlay;
    animation: orgGrainShift 8s steps(1) infinite;
  }

  /* ── root ── */
  .orgs-root {
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* ── page header ── */
  .orgs-hdr {
    padding: clamp(64px, 8vh, 96px) clamp(40px, 6vw, 80px) clamp(40px, 5vh, 64px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .orgs-hdr__pre {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }
  .orgs-hdr__label {
    font-family: 'DM Sans', sans-serif;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.2);
  }
  .orgs-hdr__sep {
    color: rgba(232, 228, 220, 0.1);
    font-size: 8px;
  }
  .orgs-hdr__count {
    font-family: 'DM Sans', sans-serif;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.13);
  }
  .orgs-hdr__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(52px, 7vw, 88px);
    font-weight: 700;
    color: var(--text);
    line-height: 0.9;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }
  .orgs-hdr__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--text-dim);
    max-width: 460px;
    line-height: 1.85;
  }

  /* ── quick index ── */
  .orgs-index {
    display: flex;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .orgs-index::-webkit-scrollbar { display: none; }
  .orgs-index__item {
    flex: 1;
    min-width: 160px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 18px clamp(24px, 3vw, 36px) 16px;
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    text-decoration: none;
    transition: background 0.22s ease;
    position: relative;
    overflow: hidden;
  }
  .orgs-index__item:last-child { border-right: none; }
  .orgs-index__item::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .orgs-index__item:hover { background: rgba(255, 255, 255, 0.015); }
  .orgs-index__item:hover::after { transform: scaleX(1); }
  .orgs-index__num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
    opacity: 0.7;
    letter-spacing: 0.1em;
  }
  .orgs-index__name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    opacity: 0.75;
    letter-spacing: 0.01em;
    line-height: 1.2;
    transition: opacity 0.2s;
  }
  .orgs-index__item:hover .orgs-index__name { opacity: 1; }
  .orgs-index__type {
    font-family: 'DM Sans', sans-serif;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.2);
  }

  /* ── registry ── */
  .orgs-registry { display: block; }

  /* ── spread ── */
  .org-spread {
    display: flex;
    flex-direction: row;
    min-height: clamp(520px, 82vh, 840px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    background: var(--bg);
    position: relative;
  }
  .org-spread--flip { flex-direction: row-reverse; }

  /* image side */
  .org-spread__img-wrap {
    flex: 0 0 42%;
    position: relative;
    overflow: hidden;
    background: #030308;
    opacity: 0;
    transition: opacity 1.2s ease;
  }
  .org-spread.in-view .org-spread__img-wrap {
    opacity: 1;
  }
  .org-spread__img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: saturate(0.8) brightness(0.62);
    transition: filter 0.7s ease, transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .org-spread:hover .org-spread__img {
    filter: saturate(0.88) brightness(0.7);
    transform: scale(1.025);
  }
  .org-spread__img-fallback {
    position: absolute; inset: 0;
    background: radial-gradient(
      ellipse 80% 60% at 55% 50%,
      color-mix(in srgb, var(--accent) 20%, transparent),
      transparent 70%
    ), linear-gradient(155deg, #06060e 0%, #0a0a18 50%, #06060b 100%);
  }
  .org-spread__img-vignette {
    position: absolute; inset: 0; z-index: 2;
    pointer-events: none;
  }
  .org-spread:not(.org-spread--flip) .org-spread__img-vignette {
    background:
      linear-gradient(to right, transparent 55%, rgba(6, 6, 11, 0.55) 100%),
      linear-gradient(to bottom, rgba(6, 6, 11, 0.2) 0%, transparent 20%, transparent 75%, rgba(6, 6, 11, 0.3) 100%);
  }
  .org-spread--flip .org-spread__img-vignette {
    background:
      linear-gradient(to left, transparent 55%, rgba(6, 6, 11, 0.55) 100%),
      linear-gradient(to bottom, rgba(6, 6, 11, 0.2) 0%, transparent 20%, transparent 75%, rgba(6, 6, 11, 0.3) 100%);
  }
  .org-spread__img-grain {
    position: absolute; inset: 0; z-index: 3;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.88' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    opacity: 0.025;
    mix-blend-mode: overlay;
    animation: orgGrainShift 8s steps(1) infinite;
  }
  .org-spread__img-numeral {
    position: absolute;
    right: 18px; bottom: 18px;
    z-index: 4;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(72px, 10vw, 120px);
    font-weight: 700;
    line-height: 1;
    color: rgba(255, 255, 255, 0.055);
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.02em;
  }
  .org-spread__img-tags {
    position: absolute;
    left: 18px; bottom: 20px;
    z-index: 5;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .org-spread__img-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 7px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.38);
    background: rgba(6, 6, 11, 0.55);
    border: 1px solid color-mix(in srgb, var(--accent) 22%, rgba(255, 255, 255, 0.06));
    padding: 3px 7px;
    border-radius: 1px;
  }

  /* content side */
  .org-spread__content {
    flex: 1;
    display: flex;
    align-items: center;
    padding: clamp(40px, 5vw, 72px) clamp(36px, 5vw, 72px);
    background: color-mix(in srgb, var(--accent) 2.5%, var(--bg));
    position: relative;
  }
  /* subtle vertical rule at the seam */
  .org-spread:not(.org-spread--flip) .org-spread__content::before {
    content: '';
    position: absolute;
    left: 0; top: 12%; bottom: 12%;
    width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.04), transparent);
  }
  .org-spread--flip .org-spread__content::before {
    content: '';
    position: absolute;
    right: 0; top: 12%; bottom: 12%;
    width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.04), transparent);
  }
  .org-spread__content-inner {
    display: flex;
    flex-direction: column;
