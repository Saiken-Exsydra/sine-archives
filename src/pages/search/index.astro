      pointer-events: none;
    }

    .search-primary-card__visual.is-loaded .search-primary-card__loading {
      display: none;
    }

    .search-primary-card__body {
      display: grid;
      align-content: center;
      gap: 12px;
      min-width: 0;
      padding: 28px 30px 24px;
