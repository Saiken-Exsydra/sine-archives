    .search-card__seal::before {
      content: "";
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: rgba(176, 141, 60, 0.88);
      box-shadow: 0 0 10px rgba(176, 141, 60, 0.3);
    }

    .search-card__loading,
    .search-row__thumb::after {
      position: absolute;
      inset: 0;
      background: linear-gradient(
