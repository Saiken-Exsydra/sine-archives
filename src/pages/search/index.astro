    .search-featured-grid {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 20px;
      align-items: start;
    }

    .search-featured-grid[data-featured-count="1"] .search-card:not([hidden]) {
      grid-column: 4 / span 6;
    }

    .search-featured-grid[data-featured-count="2"] .search-card:not([hidden]) {
      grid-column: span 6;
    }

    .search-featured-grid[data-featured-count="3"] .search-card:not([hidden]) {
      grid-column: span 4;
    }

    .search-featured-grid[data-featured-count="4"] .search-card:not([hidden]),
    .search-featured-grid[data-featured-count="0"] .search-card:not([hidden]) {
      grid-column: span 3;
    }

    .search-card,
    .search-row {
      min-width: 0;
      transition: transform 0.18s ease, opacity 0.18s ease;
    }

    .search-card.is-opening,
    .search-row.is-opening {
      transform: scale(0.992);
    }

    .search-card__surface,
    .search-row__surface {
      color: inherit;
      text-decoration: none;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: linear-gradient(180deg, rgba(10, 10, 16, 0.96), rgba(7, 7, 12, 0.98));
      box-shadow: 0 24px 74px rgba(0, 0, 0, 0.36);
      transition: border-color 0.26s, transform 0.26s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.26s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .search-card__surface {
      display: grid;
      height: 100%;
      overflow: hidden;
    }

    .search-card__surface:hover,
    .search-card__surface:focus-visible,
    .search-row__surface:hover,
    .search-row__surface:focus-visible {
      border-color: rgba(177, 58, 52, 0.34);
      box-shadow: 0 30px 88px rgba(0, 0, 0, 0.44);
      outline: none;
    }

    .search-card__surface:hover,
    .search-card__surface:focus-visible {
      transform: translateY(-4px);
    }

    .search-card__visual {
      position: relative;
      aspect-ratio: 4 / 5;
      overflow: hidden;
      background: #06060b;
    }

    .search-card__visual picture,
    .search-card__visual img {
      display: block;
      width: 100%;
      height: 100%;
    }

    .search-card__img {
      object-fit: cover;
      object-position: center 28%;
      filter: saturate(0.76) brightness(0.76);
      transform: scale(1.02);
      transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1), filter 0.4s;
    }

    .search-card__surface:hover .search-card__img,
    .search-card__surface:focus-visible .search-card__img {
      transform: scale(1.05);
      filter: saturate(0.88) brightness(0.88);
    }

    .search-card__placeholder,
    .search-card__placeholder svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .search-card__visual-shade {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(6, 6, 11, 0.08) 0%, rgba(6, 6, 11, 0.34) 55%, rgba(6, 6, 11, 0.86) 100%),
        linear-gradient(90deg, rgba(6, 6, 11, 0.18), transparent 38%);
      pointer-events: none;
    }

    .search-card__visual-frame {
      position: absolute;
      inset: 12px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.28s;
    }

    .search-card__visual-frame span {
      position: absolute;
      width: 18px;
      height: 18px;
      border-color: rgba(177, 58, 52, 0.68);
      border-style: solid;
    }

    .search-card__visual-frame span:nth-child(1) { top: 0; left: 0; border-width: 1.5px 0 0 1.5px; }
    .search-card__visual-frame span:nth-child(2) { top: 0; right: 0; border-width: 1.5px 1.5px 0 0; }
    .search-card__visual-frame span:nth-child(3) { bottom: 0; left: 0; border-width: 0 0 1.5px 1.5px; }
    .search-card__visual-frame span:nth-child(4) { bottom: 0; right: 0; border-width: 0 1.5px 1.5px 0; }

    .search-card__surface:hover .search-card__visual-frame,
    .search-card__surface:focus-visible .search-card__visual-frame,
    .search-card.is-opening .search-card__visual-frame {
      opacity: 1;
