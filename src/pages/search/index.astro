---
import MainLayout from "../../layouts/MainLayout.astro";
import type { SiteLocale } from "../../i18n/config";

const { locale = "en" } = Astro.props as { locale?: SiteLocale };
const copy = locale === "pt-br"
  ? {
      pageTitle: "Busca - SiNE Archives",
      title: "Busca",
      searchAll: "Buscar em todas as entradas",
      placeholder: "Buscar titulo, resumo, tags, corpo...",
      filter: "Filtrar",
      tags: "Tags",
      clear: "Limpar",
      loading: "Carregando indice...",
      noscript: "A busca requer JavaScript.",
      noResults: "Nenhum resultado.",
      result: "resultado",
      results: "resultados",
      noTagFilters: "Nenhum filtro de tag.",
      active: "Ativo",
      error: "Nao foi possivel carregar a busca. Atualize a pagina ou tente novamente.",
    }
  : {
      pageTitle: "Search - SiNE Archives",
      title: "Search",
      searchAll: "Search all entries",
      placeholder: "Search title, summary, tags, body...",
      filter: "Filter",
      tags: "Tags",
      clear: "Clear",
      loading: "Loading index...",
      noscript: "Search requires JavaScript to run.",
      noResults: "No results.",
      result: "result",
      results: "results",
      noTagFilters: "No tag filters.",
      active: "Active",
      error: "Could not load search. Please refresh or try again later.",
    };
---

<MainLayout active="search" pageTitle={copy.pageTitle} locale={locale}>
  <section class="searchPage" data-locale={locale}>
    <div class="section__head">
      <h2 class="section__title">{copy.title}</h2>

      <div class="controls">
        <label class="section__search" aria-label={copy.searchAll}>
          <span class="section__icon" aria-hidden="true">⌕</span>
          <input id="q" class="section__input" type="search" placeholder={copy.placeholder} />
        </label>

        <button id="toggleFilters" class="filter" type="button">
          {copy.filter}
        </button>
      </div>
    </div>

    <div id="filters" class="filters" hidden>
      <div class="filters__head">
      <div id="activeTags" class="activeTags" aria-live="polite"></div>
        <div class="filters__title">{copy.tags}</div>
        <button id="clearTags" class="filters__clear" type="button">{copy.clear}</button>
      </div>
      <div id="tagList" class="taglist" aria-label="Tag filters"></div>
    </div>

    <div id="status" class="status" aria-live="polite">{copy.loading}</div>
    <noscript>
  <div class="status">{copy.noscript}</div>
</noscript>


    <div id="results" class="results" aria-label="Search results"></div>
  </section>

  <script define:vars={{ copy }} is:inline type="module">
    const locale = document.querySelector(".searchPage")?.dataset.locale || "en";
    const $q = document.querySelector("#q");
    const $results = document.querySelector("#results");
    const $status = document.querySelector("#status");
    const $filters = document.querySelector("#filters");
    const $tagList = document.querySelector("#tagList");
    const $toggleFilters = document.querySelector("#toggleFilters");
    const $clearTags = document.querySelector("#clearTags");

    const params = new URLSearchParams(location.search);
    const initialQ = params.get("q") || "";
    $q.value = initialQ;
    if (initialQ) $q.focus();


    let indexItems = [];
    let selectedTags = new Set();
    // Waits a tiny moment after typing stops before running run()
function debounce(fn, delay = 120) {
  let t;
  return () => {
    clearTimeout(t);
    t = setTimeout(fn, delay);
  };
}


    const CONCEPT_GROUPS = {
      "pt-br": [
        ["igreja", "church"],
        ["fe", "fé", "faith"],
        ["demonio", "demônio", "demon", "demonic"],
        ["exorcismo", "expulsao", "expulsão", "exorcism", "expulsion"],
      ],
      en: [
        ["church", "igreja"],
        ["faith", "fe", "fé"],
        ["demon", "demonic", "demonio", "demônio"],
        ["exorcism", "expulsion", "exorcismo", "expulsao", "expulsão"],
      ],
    };

    function norm(s){
      return (s || "")
        .toString()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase();
    }

    function buildSearchText(item){
      const base = [
        item.title,
        item.summary,
        (item.tags || []).join(" "),
        item.body || "",
      ].map(norm).join(" | ");

      const groups = CONCEPT_GROUPS[locale] || CONCEPT_GROUPS.en;
      const aliases = [];

      for (const group of groups){
        const hit = group.some((term) => base.includes(norm(term)));
        if (hit) aliases.push(...group);
      }

      return `${base} | ${aliases.map(norm).join(" | ")}`;
    }

    function scoreItem(item, query){
  const q = norm((query || "").trim());
  if (!q) return 0;

  const terms = q.split(/\s+/).filter(Boolean);
  const hay = buildSearchText(item);

  const title = norm(item.title);
  const summary = norm(item.summary);
  const tags = norm((item.tags || []).join(" "));
  const body = norm(item.body || "");

  let score = 0;

  // Bonus if the whole query phrase appears
  const phrase = q;
  if (phrase.length >= 3){
    if (title.includes(phrase)) score += 60;
    if (tags.includes(phrase)) score += 35;
    if (summary.includes(phrase)) score += 20;
    if (body.includes(phrase)) score += 10;
  }

  // Per-term scoring (AND query is still enforced by matchesQuery)
  for (const t of terms){
    if (title.includes(t)) score += 25;
    if (tags.includes(t)) score += 14;
    if (summary.includes(t)) score += 10;
    if (body.includes(t)) score += 4;
    if (hay.includes(t)) score += 6;
  }

  return score;
}


    function matchesQuery(item, query){
  const q = (query || "").trim();
  if (!q) return true;

  const terms = q
    .split(/\s+/)
    .map(norm)
    .filter(Boolean);

  const hay = buildSearchText(item);

  // every word must be present (AND search)
  return terms.every(t => hay.includes(t));
}


    function matchesTags(item){
      if (selectedTags.size === 0) return true;
      const tags = new Set((item.tags || []).map(t => norm(t)));
      for (const t of selectedTags){
        if (!tags.has(t)) return false;
      }
      return true;
    }

    function renderResults(items){
      $results.innerHTML = "";
      if (items.length === 0){
        $status.textContent = copy.noResults;
        return;
      }

      $status.textContent = `${items.length} ${items.length === 1 ? copy.result : copy.results}.`;

      for (const item of items){
        const a = document.createElement("a");
        a.className = "rcard";
        a.href = item.href;

        const section = item.href.split("/").filter(Boolean)[0] || "";

        const img = item.image
          ? `<img class="rcard__img" src="${item.image}" alt="" loading="lazy">`
          : `<div class="rcard__img rcard__img--empty" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.2"/><path d="M4 20c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg></div>`;

        const firstTag = (item.tags || [])[0];
        const tagHtml = firstTag ? `<span class="rcard__tag">${String(firstTag).toUpperCase()}</span>` : "";

        a.innerHTML = `
          <div class="rcard__thumb">${img}</div>
          <div class="rcard__body">
            <div class="rcard__section">${section.toUpperCase()}</div>
            <div class="rcard__title">${item.title}</div>
            ${tagHtml}
          </div>
        `;

        $results.appendChild(a);
      }
    }

    function buildTagFilters(items){
      const counts = new Map();
      for (const it of items){
        for (const t of (it.tags || [])){
          const key = norm(t);
          counts.set(key, (counts.get(key) || 0) + 1);
        }
      }

      const tags = [...counts.entries()]
        .sort((a,b) => b[1] - a[1])
        .slice(0, 60); // keep UI tidy

      $tagList.innerHTML = "";
      for (const [key, count] of tags){
        const label = document.createElement("label");
        label.className = "tagcheck";
        label.innerHTML = `
          <input type="checkbox" value="${key}">
          <span class="tagcheck__pill">${key.toUpperCase()}</span>
          <span class="tagcheck__count">${count}</span>
        `;
        const input = label.querySelector("input");
        input.addEventListener("change", () => {
  if (input.checked) selectedTags.add(key);
  else selectedTags.delete(key);

  // Firefox-friendly active styling fallback
  label.classList.toggle("is-active", input.checked);

  run();
});

        $tagList.appendChild(label);
      }
    }

    function run(){
      const query = $q.value.trim();
      const filtered = indexItems
  .filter(it => matchesQuery(it, query))
  .filter(it => matchesTags(it))
  .map(it => ({ it, score: scoreItem(it, query) }))
  .sort((a, b) => {
    // Higher score first
    if (b.score !== a.score) return b.score - a.score;

    // Tie-breaker: newer updated first
    return (a.it.updated < b.it.updated ? 1 : -1);
  })
  .map(x => x.it);


      renderResults(filtered);
      const $activeTags = document.querySelector("#activeTags");
if ($activeTags){
  const list = [...selectedTags].map(t => t.toUpperCase());
  $activeTags.textContent = list.length ? `${copy.active}: ${list.join(" · ")}` : copy.noTagFilters;
}


      // keep URL in sync (so header search can link here)
      const next = new URL(location.href);
      if (query) next.searchParams.set("q", query);
      else next.searchParams.delete("q");
      history.replaceState({}, "", next);
    }

    $q.addEventListener("input", debounce(run, 120));

    $toggleFilters.addEventListener("click", () => {
      $filters.hidden = !$filters.hidden;
    });

    $clearTags.addEventListener("click", () => {
  selectedTags.clear();
  $tagList.querySelectorAll("input[type=checkbox]").forEach(cb => {
    cb.checked = false;
    cb.closest(".tagcheck")?.classList.remove("is-active");
  });
  run();
});

    // Keyboard shortcut: press "/" to focus the search input
window.addEventListener("keydown", (e) => {
  if (e.key !== "/") return;

  const el = document.activeElement;
  const typing =
    el &&
    (el.tagName === "INPUT" ||
     el.tagName === "TEXTAREA" ||
     el.isContentEditable);

  // If you're already typing somewhere, don't steal the "/" key
  if (typing) return;

  e.preventDefault();
  $q.focus();
});


    // load index
    fetch(`/search-index.json?locale=${locale}`)
      .then(r => r.json())
      .then(({ items }) => {
        indexItems = items || [];
        buildTagFilters(indexItems);
        run();
      })
      .catch(() => {
  $status.textContent = copy.error;
  $results.innerHTML = "";
});

  </script>

  <style>
    /* ── Page shell ── */
    .searchPage {
      max-width: 1300px;
      margin: 0 auto;
      padding: 60px 32px 100px;
    }

    /* ── Header ── */
    .section__head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 32px;
    }

    .section__title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 40px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: 0.01em;
      margin: 0;
    }

    /* ── Controls ── */
    .controls {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .section__search {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      background: rgba(10, 10, 18, 0.7);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 6px;
      min-width: 360px;
      transition: border-color 0.2s;
    }

    .section__search:focus-within {
      border-color: rgba(177, 58, 52, 0.5);
    }

    .section__icon {
      font-size: 15px;
      color: var(--text-dim);
      line-height: 1;
    }

    .section__input {
      flex: 1;
      border: 0;
      outline: none;
      background: transparent;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      padding: 0;
      margin: 0;
    }

    .section__input::placeholder { color: var(--text-dim); }
    .section__input::-webkit-search-decoration,
    .section__input::-webkit-search-cancel-button { -webkit-appearance: none; }

    .filter {
      appearance: none;
      cursor: pointer;
      color: var(--text);
      background: rgba(177, 58, 52, 0.1);
      border: 1px solid rgba(177, 58, 52, 0.3);
      border-radius: 6px;
      padding: 10px 16px;
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      transition: background 0.2s, border-color 0.2s;
    }

    .filter:hover {
      background: rgba(177, 58, 52, 0.2);
      border-color: rgba(177, 58, 52, 0.5);
    }

    /* ── Filters panel ── */
    .filters__head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.07);
      margin-bottom: 14px;
    }

    .filters__title {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-dim);
    }

    .filters__clear {
      appearance: none;
      cursor: pointer;
      color: var(--text-muted);
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 4px;
      padding: 6px 12px;
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: border-color 0.2s, color 0.2s;
    }

    .filters__clear:hover { border-color: rgba(177, 58, 52, 0.4); color: var(--text); }

    /* ── Tag filters ── */
    .searchPage :global(.activeTags) {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      color: var(--text-dim);
      letter-spacing: 0.04em;
      margin: 8px 0 12px;
    }

    .searchPage :global(.taglist) {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      max-height: 140px;
      overflow: auto;
    }

    .searchPage :global(.tagcheck) {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 10px;
      border-radius: 4px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(10, 10, 18, 0.6);
      cursor: pointer;
      user-select: none;
      transition: border-color 0.15s, background 0.15s;
    }

    .searchPage :global(.tagcheck:hover) { border-color: rgba(177, 58, 52, 0.3); }
    .searchPage :global(.tagcheck input) { position: absolute; opacity: 0; pointer-events: none; }

    .searchPage :global(.tagcheck__pill) {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .searchPage :global(.tagcheck__count) {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      color: var(--text-dim);
    }

    .searchPage :global(.tagcheck:has(input:checked)),
    .searchPage :global(.tagcheck.is-active) {
      border-color: rgba(177, 58, 52, 0.5);
      background: rgba(177, 58, 52, 0.12);
    }

    /* ── Status ── */
    .searchPage :global(.status) {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin: 16px 0 20px;
    }

    /* ── Results grid — 5 columns ── */
    .searchPage :global(.results) {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
    }

    /* ── Result card ── */
    .searchPage :global(.rcard) {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: var(--text);
      background: rgba(10, 10, 18, 0.7);
      border: 1px solid rgba(255, 255, 255, 0.07);
      border-radius: 6px;
      overflow: hidden;
      transition: border-color 0.25s;
    }

    .searchPage :global(.rcard:hover) {
      border-color: rgba(177, 58, 52, 0.45);
    }

    .searchPage :global(.rcard__thumb) {
      width: 100%;
      aspect-ratio: 3 / 4;
      overflow: hidden;
      background: rgba(6, 6, 11, 0.8);
      flex-shrink: 0;
    }

    .searchPage :global(.rcard__img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
      transition: transform 0.4s;
    }

    .searchPage :global(.rcard:hover .rcard__img) {
      transform: scale(1.04);
    }

    .searchPage :global(.rcard__img--empty) {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, rgba(177, 58, 52, 0.12), rgba(6, 6, 11, 0.6));
    }

    .searchPage :global(.rcard__img--empty svg) {
      width: 32px;
      height: 32px;
      color: rgba(177, 58, 52, 0.35);
    }

    .searchPage :global(.rcard__body) {
      padding: 12px 14px 14px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .searchPage :global(.rcard__section) {
      font-family: 'DM Sans', sans-serif;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.18em;
      color: var(--crimson);
      text-transform: uppercase;
    }

    .searchPage :global(.rcard__title) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 16px;
      font-weight: 700;
      color: var(--text);
      line-height: 1.2;
    }

    .searchPage :global(.rcard__tag) {
      font-family: 'DM Sans', sans-serif;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-top: 2px;
    }

    /* ── Responsive ── */
    @media (max-width: 1100px) {
      .searchPage :global(.results) { grid-template-columns: repeat(4, 1fr); }
    }

    @media (max-width: 820px) {
      .searchPage :global(.results) { grid-template-columns: repeat(3, 1fr); }
      .section__search { min-width: 260px; }
    }

    @media (max-width: 540px) {
      .searchPage :global(.results) { grid-template-columns: repeat(2, 1fr); }
      .searchPage { padding: 40px 16px 80px; }
      .section__head { align-items: stretch; }
      .controls {
        width: 100%;
        flex-direction: column;
        align-items: stretch;
      }
      .section__search {
        min-width: 0;
        width: 100%;
        min-height: 46px;
      }
      .filter {
        width: 100%;
      }
      .filters__head {
        align-items: flex-start;
        flex-wrap: wrap;
      }
      .searchPage :global(.taglist) {
        max-height: 180px;
      }
    }

    @media (max-width: 400px) {
      .searchPage :global(.results) { grid-template-columns: 1fr; }
    }
  </style>
</MainLayout>
