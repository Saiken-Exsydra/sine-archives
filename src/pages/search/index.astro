        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.08) 45%,
        rgba(255, 255, 255, 0) 100%
      );
      transform: translateX(-100%);
      animation: searchCardSweep 1.4s ease-in-out infinite;
      pointer-events: none;
    }

    .search-card__visual.is-loaded .search-card__loading,
    .search-row__thumb.is-loaded::after {
