---
import MainLayout from "../../layouts/MainLayout.astro";
import type { SiteLocale } from "../../i18n/config";
import { buildSearchIndex } from "../../utils/search-index";

export const prerender = true;

const { locale = "en" } = Astro.props as { locale?: SiteLocale };
const { items } = await buildSearchIndex(locale);

const normalizeTag = (value: string) =>
  value
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .replace(/[^\p{L}\p{N}\s]+/gu, " ")
    .replace(/\s+/g, " ")
    .trim();

const getGroupKey = (section: string) => (section === "sine" || section === "systems" ? "dossiers" : section);
const getYear = (value: string) => value.match(/(\d{4})/)?.[1] ?? "";

const copy = locale === "pt-br"
  ? {
      pageTitle: "Busca - SiNE Archives",
      eyebrow: "Indice Cruzado",
      title: "Search the Archive",
      description: "Cruze personagens, aparatos, cosmologia, lugares e registros relacionados em um indice de arquivo rapido e estavel.",
      searchLabel: "Buscar no arquivo",
      searchPlaceholder: "Buscar titulos, designacoes, tags, secoes e passagens...",
      searchHint: "Pressione / para focar",
      autocompleteHint: "Tab para completar",
      clearSearch: "Limpar busca",
      liveFilter: "Filtrando resultados instantaneamente",
      all: "All",
      characters: "Personagens",
      places: "Lugares",
      apparatus: "Aparatos",
      cosmology: "Cosmologia",
      organizations: "Organizacoes",
      dossiers: "Dossies",
      allRecords: "Todos os Registros",
      searchResults: "Resultados de Busca",
      bestMatch: "Melhor Correspondencia",
      featuredRecord: "Registro em Destaque",
      similarMatches: "Correspondencias Similares",
      records: "registros",
      record: "registro",
      results: "resultados",
      result: "resultado",
      matches: "correspondencias",
      matchesFor: "correspondencias para",
      remainingMatches: "Correspondencias Restantes",
      openEntry: "Abrir registro",
      publicRecord: "Registro Publico",
      noResultsTitle: "Nenhum registro encontrado",
      noResultsFor: "Nenhum registro encontrado para",
      noResultsBody: "Tente buscar por titulo, secao, tag, classificacao ou ano.",
      noJs: "A busca requer JavaScript.",
      filterBySection: "Filtrar por secao",
    }
  : {
      pageTitle: "Search - SiNE Archives",
      eyebrow: "Cross Index",
      title: "Search the Archive",
      description: "Move across characters, apparatus, cosmology, places, and related records through one fast, stable archive index.",
      searchLabel: "Search archive",
      searchPlaceholder: "Search titles, designations, tags, sections, and passages...",
      searchHint: "Press / to focus",
      autocompleteHint: "Tab to complete",
      clearSearch: "Clear search",
      liveFilter: "Filtering results instantly",
      all: "All",
      characters: "Characters",
      places: "Places",
      apparatus: "Apparatus",
      cosmology: "Cosmology",
      organizations: "Organizations",
      dossiers: "Dossiers",
      allRecords: "All Records",
      searchResults: "Search Results",
      bestMatch: "Best Match",
      featuredRecord: "Featured Record",
      similarMatches: "Similar Matches",
      records: "records",
      record: "record",
      results: "results",
      result: "result",
      matches: "matches",
      matchesFor: "matches for",
      remainingMatches: "Remaining Matches",
      openEntry: "Open entry",
      publicRecord: "Public Record",
      noResultsTitle: "No records found",
      noResultsFor: "No records found for",
      noResultsBody: "Try searching by title, section, tag, classification, or year.",
      noJs: "Search requires JavaScript.",
      filterBySection: "Filter by section",
    };

const filterGroups = [
  { key: "all", label: copy.all, sections: null },
  { key: "characters", label: copy.characters, sections: ["characters"] },
  { key: "places", label: copy.places, sections: ["places"] },
  { key: "apparatus", label: copy.apparatus, sections: ["apparatus"] },
  { key: "cosmology", label: copy.cosmology, sections: ["cosmology"] },
  { key: "organizations", label: copy.organizations, sections: ["organizations"] },
  { key: "dossiers", label: copy.dossiers, sections: ["sine", "systems"] },
] as const;

const groupLabelByKey = Object.fromEntries(filterGroups.map((group) => [group.key, group.label])) as Record<string, string>;
const groupCounts = filterGroups.map((group) => ({
  ...group,
  count: group.sections ? items.filter((item) => group.sections.includes(item.section as never)).length : items.length,
}));

const clientItems = items.map((item) => ({
  id: item.id,
  title: item.title,
  summary: item.summary,
  designation: item.designation,
  type: item.type,
  section: item.section,
  sectionLabel: item.sectionLabel,
  groupKey: getGroupKey(item.section),
  tags: item.tags.map((tag) => ({ key: normalizeTag(tag), label: tag })),
  updated: item.updated,
  updatedTimestamp: item.updatedTimestamp,
  priority: item.priority,
  defaultOrder: item.defaultOrder,
  searchText: item.searchText,
}));
---

<MainLayout active="search" pageTitle={copy.pageTitle} locale={locale}>
  <section class="search-shell" data-search-root data-locale={locale}>
    <div class="search-hero">
      <div class="search-hero__glow"></div>
      <div class="search-hero__grain"></div>
      <div class="search-hero__scanlines"></div>
      <div class="search-hero__diagram" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="search-hero__content">
        <div class="search-hero__eyebrow">{copy.eyebrow}</div>
        <h1 class="search-hero__title">{copy.title}</h1>
        <p class="search-hero__desc">{copy.description}</p>

        <div class="search-console">
          <label class="search-console__label" for="archive-search-input">{copy.searchLabel}</label>
          <div class="search-console__bar">
            <span class="search-console__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
                <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.35" />
                <line x1="10" y1="10" x2="14" y2="14" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" />
              </svg>
            </span>
            <span class="search-console__field">
              <span class="search-console__autocomplete" aria-hidden="true">
                <span id="archive-search-typed" class="search-console__autocomplete-typed"></span><span id="archive-search-completion" class="search-console__autocomplete-rest"></span>
              </span>
              <input
                id="archive-search-input"
                class="search-console__input"
                data-search-input
                type="search"
                placeholder={copy.searchPlaceholder}
                autocomplete="off"
                spellcheck="false"
              />
            </span>
            <button
              id="archive-search-clear"
              class="search-console__clear"
              type="button"
              aria-label={copy.clearSearch}
              title={copy.clearSearch}
              hidden
            >
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 3l8 8M11 3L3 11" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
              </svg>
            </button>
          </div>

          <div class="search-console__meta">
            <div class="search-console__statusline">
              <span class="search-console__statusdot"></span>
              <span>{copy.liveFilter}</span>
            </div>
            <div class="search-console__hint">{copy.searchHint} / {copy.autocompleteHint}</div>
            <div class="search-console__count" id="archive-search-count" aria-live="polite">
              {items.length} {items.length === 1 ? copy.record : copy.records}
            </div>
          </div>

          <div class="search-filters" role="toolbar" aria-label={copy.filterBySection}>
            {groupCounts.map((group, index) => (
              <button
                class:list={["search-chip", { "is-active": index === 0 }]}
                type="button"
                data-search-filter={group.key}
                aria-pressed={index === 0 ? "true" : "false"}
              >
                <span class="search-chip__label">{group.label}</span>
                <span class="search-chip__count">{group.count}</span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="search-results-shell">
      <div class="search-results-shell__bar">
        <div class="search-results-shell__heading">
          <div class="search-results-shell__eyebrow">{copy.eyebrow}</div>
          <div class="search-results-shell__active" id="archive-search-active-filter">{copy.allRecords}</div>
        </div>
        <div class="search-results-shell__status" id="archive-search-status" aria-live="polite">
          {items.length} {items.length === 1 ? copy.result : copy.results}
        </div>
      </div>

      <noscript>
        <div class="search-noscript">{copy.noJs}</div>
      </noscript>

      <div class="search-results-state" id="archive-search-results-state">
        <div class="search-primary" id="archive-search-primary">
          {items.map((item, index) => (
            <article
              class="search-primary-card"
              data-search-primary-card
              data-item-id={item.id}
              data-section={item.section}
              hidden={index > 0}
            >
              <a class="search-primary-card__surface" href={item.href} data-search-link>
                <div class:list={["search-primary-card__visual", { "is-loaded": !item.image }]}>
                  {item.image ? (
                    <picture>
                      {item.image.avifSrcset && (
                        <source
                          type="image/avif"
                          srcset={item.image.avifSrcset}
                          sizes="(max-width: 900px) 100vw, 44vw"
                        />
                      )}
                      {item.image.webpSrcset && (
                        <source
                          type="image/webp"
                          srcset={item.image.webpSrcset}
                          sizes="(max-width: 900px) 100vw, 44vw"
                        />
                      )}
                      <img
                        class="search-primary-card__img"
                        src={item.image.fallbackSrc}
                        srcset={item.image.fallbackSrcset || undefined}
                        sizes="(max-width: 900px) 100vw, 44vw"
                        width={item.image.width || undefined}
                        height={item.image.height || undefined}
                        alt=""
                        loading={index === 0 ? "eager" : "lazy"}
                        fetchpriority={index === 0 ? "high" : "auto"}
                        decoding="async"
                        style={item.imagePosition ? `--search-primary-object-position:${item.imagePosition};` : undefined}
                      />
                    </picture>
                  ) : (
                    <div class="search-primary-card__placeholder" aria-hidden="true">
                      <svg viewBox="0 0 960 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                          <radialGradient id={`search-primary-rg-${item.id.replace(/[^a-z0-9]+/gi, "-")}`} cx="50%" cy="42%" r="58%">
                            <stop offset="0%" stop-color="rgba(177,58,52,0.18)" />
                            <stop offset="100%" stop-color="rgba(6,6,11,0)" />
                          </radialGradient>
                        </defs>
                        <rect width="960" height="520" fill="#06060b" />
                        <rect width="960" height="520" fill={`url(#search-primary-rg-${item.id.replace(/[^a-z0-9]+/gi, "-")})`} />
                        <circle cx="640" cy="250" r="70" fill="none" stroke="rgba(232,228,220,0.14)" stroke-width="1.6" />
                        <circle cx="640" cy="250" r="132" fill="none" stroke="rgba(232,228,220,0.08)" stroke-width="1.2" />
                        <line x1="120" y1="92" x2="840" y2="92" stroke="rgba(232,228,220,0.06)" stroke-width="1" />
                        <line x1="120" y1="428" x2="840" y2="428" stroke="rgba(232,228,220,0.06)" stroke-width="1" />
                      </svg>
                    </div>
                  )}
                  <div class="search-primary-card__shade"></div>
                  <div class="search-primary-card__loading"></div>
                </div>

                <div class="search-primary-card__body">
                  <div class="search-primary-card__eyebrow" data-search-primary-kicker>{copy.featuredRecord}</div>
                  <div class="search-primary-card__type">{item.type}</div>
                  <h2 class="search-primary-card__title">{item.title}</h2>
                  {item.designation && <div class="search-primary-card__designation">{item.designation}</div>}
                  <p class="search-primary-card__summary">{item.summary}</p>
                  <div class="search-primary-card__footer">
                    <div class="search-primary-card__tags">
                      {item.tags.slice(0, 4).map((tag) => (
                        <span class="search-primary-card__tag">{tag}</span>
                      ))}
                    </div>
                    <div class="search-primary-card__trail">
                      <span class="search-primary-card__access">{copy.publicRecord}</span>
                      {getYear(item.updated) && <span class="search-primary-card__year">YR {getYear(item.updated)}</span>}
                    </div>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>

        <section class="search-secondary" id="archive-search-secondary" hidden={items.length <= 1}>
          <div class="search-secondary__head">
            <span class="search-secondary__label">{copy.similarMatches}</span>
            <span class="search-secondary__line"></span>
          </div>

          <div class="search-featured-grid" id="archive-search-featured-grid" data-featured-count={Math.max(Math.min(items.length - 1, 4), 0)}>
          {items.map((item, index) => (
            <article
              class="search-card"
              data-search-featured-card
              data-item-id={item.id}
              hidden={index === 0 || index >= 5}
            >
              <a class="search-card__surface" href={item.href} data-search-link>
                <div class:list={["search-card__visual", { "is-loaded": !item.image }]}>
                  {item.image ? (
                    <picture>
                      {item.image.avifSrcset && (
                        <source
                          type="image/avif"
                          srcset={item.image.avifSrcset}
                          sizes={item.image.sizes}
                        />
                      )}
                      {item.image.webpSrcset && (
                        <source
                          type="image/webp"
                          srcset={item.image.webpSrcset}
                          sizes={item.image.sizes}
                        />
                      )}
                      <img
                        class="search-card__img"
                        src={item.image.fallbackSrc}
                        srcset={item.image.fallbackSrcset || undefined}
                        sizes={item.image.sizes}
                        width={item.image.width || undefined}
                        height={item.image.height || undefined}
                        alt=""
                        loading={index > 0 && index < 3 ? "eager" : "lazy"}
                        fetchpriority={index === 1 ? "high" : "auto"}
                        decoding="async"
                        style={item.imagePosition ? `object-position:${item.imagePosition};` : undefined}
                      />
                    </picture>
                  ) : (
                    <div class="search-card__placeholder" aria-hidden="true">
                      <svg viewBox="0 0 480 620" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                          <radialGradient id={`search-rg-${item.id.replace(/[^a-z0-9]+/gi, "-")}`} cx="50%" cy="38%" r="60%">
                            <stop offset="0%" stop-color="rgba(177,58,52,0.18)" />
                            <stop offset="100%" stop-color="rgba(6,6,11,0)" />
                          </radialGradient>
                        </defs>
                        <rect width="480" height="620" fill="#06060b" />
                        <rect width="480" height="620" fill={`url(#search-rg-${item.id.replace(/[^a-z0-9]+/gi, "-")})`} />
                        <circle cx="240" cy="230" r="46" fill="none" stroke="rgba(232,228,220,0.16)" stroke-width="1.4" />
                        <path d="M150 390c0-50 36-92 90-92s90 42 90 92" fill="none" stroke="rgba(232,228,220,0.14)" stroke-width="1.4" />
                        <line x1="86" y1="110" x2="394" y2="110" stroke="rgba(232,228,220,0.08)" stroke-width="1" />
                        <line x1="86" y1="510" x2="394" y2="510" stroke="rgba(232,228,220,0.08)" stroke-width="1" />
                      </svg>
                    </div>
                  )}
                  <div class="search-card__visual-shade"></div>
                  <div class="search-card__visual-frame" aria-hidden="true">
                    <span></span><span></span><span></span><span></span>
                  </div>
                  <div class="search-card__section">{item.sectionLabel}</div>
                  <div class="search-card__seal">{copy.publicRecord}</div>
                  <div class="search-card__loading"></div>
                </div>

                <div class="search-card__content">
                  <div class="search-card__heading">
                    <div class="search-card__type">{item.type}</div>
                    <h2 class="search-card__title">{item.title}</h2>
                    {item.designation && <div class="search-card__designation">{item.designation}</div>}
                  </div>
                  <p class="search-card__summary">{item.summary}</p>
                  <div class="search-card__footer">
                    <div class="search-card__tags">
                      {item.tags.slice(0, 3).map((tag) => (
                        <span class="search-card__tag">{tag}</span>
                      ))}
                    </div>
                    <div class="search-card__trail">
                      {getYear(item.updated) && <span class="search-card__year">YR {getYear(item.updated)}</span>}
                      <span class="search-card__action">{copy.openEntry}</span>
                      <span class="search-card__chevron" aria-hidden="true">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                          <path d="M1.5 6H10M6.2 1.5L10.5 6 6.2 10.5" stroke="currentColor" stroke-width="1.15" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </span>
                    </div>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
        </section>

        <section class="search-remaining" id="archive-search-remaining" hidden={items.length <= 4}>
          <div class="search-remaining__head">
            <span class="search-remaining__label">{copy.remainingMatches}</span>
            <span class="search-remaining__line"></span>
          </div>

          <div class="search-remaining__list" id="archive-search-remaining-list">
            {items.map((item, index) => (
              <article
                class="search-row"
                data-search-remaining-row
                data-item-id={item.id}
                hidden={index < 5}
              >
                <a class="search-row__surface" href={item.href} data-search-link>
                  <div class:list={["search-row__thumb", { "is-loaded": !item.image }]}>
                    {item.image ? (
                      <picture>
                        {item.image.avifSrcset && (
                          <source
                            type="image/avif"
                            srcset={item.image.avifSrcset}
                            sizes="72px"
                          />
                        )}
                        {item.image.webpSrcset && (
                          <source
                            type="image/webp"
                            srcset={item.image.webpSrcset}
                            sizes="72px"
                          />
                        )}
                        <img
                          class="search-row__img"
                          src={item.image.fallbackSrc}
                          srcset={item.image.fallbackSrcset || undefined}
                          sizes="72px"
                          width={72}
                          height={72}
                          alt=""
                          loading="lazy"
                          decoding="async"
                          style={item.imagePosition ? `object-position:${item.imagePosition};` : undefined}
                        />
                      </picture>
                    ) : (
                      <div class="search-row__placeholder" aria-hidden="true">
                        <svg viewBox="0 0 72 72" xmlns="http://www.w3.org/2000/svg">
                          <rect width="72" height="72" fill="#06060b" />
                          <circle cx="36" cy="28" r="12" fill="none" stroke="rgba(232,228,220,0.16)" stroke-width="1.2" />
                          <path d="M18 54c0-10 8-18 18-18s18 8 18 18" fill="none" stroke="rgba(232,228,220,0.14)" stroke-width="1.2" />
                        </svg>
                      </div>
                    )}
                  </div>

                  <div class="search-row__content">
                    <div class="search-row__category">{item.sectionLabel}</div>
                    <h3 class="search-row__title">{item.title}</h3>
                    <p class="search-row__summary">{item.designation || item.summary}</p>
                  </div>

                  <div class="search-row__meta">
                    <span class="search-row__access">{copy.publicRecord}</span>
                    {getYear(item.updated) && <span class="search-row__year">YR {getYear(item.updated)}</span>}
                    <span class="search-row__chevron" aria-hidden="true">
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <path d="M1.5 6H10M6.2 1.5L10.5 6 6.2 10.5" stroke="currentColor" stroke-width="1.15" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </section>

        <div class="search-empty" id="archive-search-empty" hidden={items.length > 0} aria-live="polite">
          <div class="search-empty__line"></div>
          <h2 class="search-empty__title">{copy.noResultsTitle}</h2>
          <p class="search-empty__body">{copy.noResultsBody}</p>
        </div>
      </div>
    </div>

    <script
      id="archive-search-data"
      type="application/json"
      set:html={JSON.stringify({
        items: clientItems,
        groupLabelByKey,
      })}
    ></script>
  </section>

  <script define:vars={{ copy }} is:inline>
    const searchInitKey = "__sineSearchInit";
    const searchCleanupKey = "__sineSearchCleanup";
    const searchBeforeSwapKey = "__sineSearchBeforeSwap";

    function initializeArchiveSearch() {
      const root = document.querySelector("[data-search-root]");
      if (!(root instanceof HTMLElement) || root.dataset.searchBound === "true") return;
      root.dataset.searchBound = "true";

      const controller = new AbortController();
      const { signal } = controller;
      window[searchCleanupKey] = () => {
        controller.abort();
        root.dataset.searchBound = "false";
      };

      const locale = root.dataset.locale || "en";
      const storageKey = `sine-search-state:${locale}`;
      const input = root.querySelector("#archive-search-input");
      const typedGhost = root.querySelector("#archive-search-typed");
      const completionGhost = root.querySelector("#archive-search-completion");
      const clearSearchButton = root.querySelector("#archive-search-clear");
      const countEl = root.querySelector("#archive-search-count");
      const statusEl = root.querySelector("#archive-search-status");
      const activeFilterEl = root.querySelector("#archive-search-active-filter");
      const primarySection = root.querySelector("#archive-search-primary");
      const primaryKickers = Array.from(root.querySelectorAll("[data-search-primary-kicker]"));
      const secondarySection = root.querySelector("#archive-search-secondary");
      const featuredGrid = root.querySelector("#archive-search-featured-grid");
      const remainingSection = root.querySelector("#archive-search-remaining");
      const emptyEl = root.querySelector("#archive-search-empty");
      const emptyTitleEl = emptyEl?.querySelector(".search-empty__title");
      const emptyBodyEl = emptyEl?.querySelector(".search-empty__body");
      const dataScript = root.querySelector("#archive-search-data");
      const filterButtons = Array.from(root.querySelectorAll("[data-search-filter]"));

      if (
        !(input instanceof HTMLInputElement) ||
        !(typedGhost instanceof HTMLElement) ||
        !(completionGhost instanceof HTMLElement) ||
        !(clearSearchButton instanceof HTMLButtonElement) ||
        !(countEl instanceof HTMLElement) ||
        !(statusEl instanceof HTMLElement) ||
        !(activeFilterEl instanceof HTMLElement) ||
        !(primarySection instanceof HTMLElement) ||
        !(secondarySection instanceof HTMLElement) ||
        !(featuredGrid instanceof HTMLElement) ||
        !(remainingSection instanceof HTMLElement) ||
        !(emptyEl instanceof HTMLElement) ||
        !(emptyTitleEl instanceof HTMLElement) ||
        !(emptyBodyEl instanceof HTMLElement) ||
        !(dataScript instanceof HTMLScriptElement)
      ) {
        return;
      }

      const parsed = JSON.parse(dataScript.textContent || '{"items":[],"groupLabelByKey":{}}');
      const groupLabelByKey = parsed.groupLabelByKey || {};
      const items = (parsed.items || []).map((item) => ({
        ...item,
        titleNorm: normalize(item.title),
        designationNorm: normalize(item.designation),
        summaryNorm: normalize(item.summary),
        typeNorm: normalize(item.type),
        sectionLabelNorm: normalize(item.sectionLabel),
      }));

      const featuredCards = Array.from(root.querySelectorAll("[data-search-featured-card]"));
      const primaryCards = Array.from(root.querySelectorAll("[data-search-primary-card]"));
      const remainingRows = Array.from(root.querySelectorAll("[data-search-remaining-row]"));
      const primaryCardsById = new Map(primaryCards.map((card) => [card.getAttribute("data-item-id"), card]));
      const featuredCardsById = new Map(featuredCards.map((card) => [card.getAttribute("data-item-id"), card]));
      const remainingRowsById = new Map(remainingRows.map((row) => [row.getAttribute("data-item-id"), row]));
      const searchLinks = Array.from(root.querySelectorAll("[data-search-link]"));
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const CONCEPT_GROUPS = [
        ["church", "igreja"],
        ["faith", "fe"],
        ["demon", "demonic", "demonio"],
        ["exorcism", "expulsion", "exorcismo", "expulsao"],
        ["archive", "arquivo"],
        ["moon", "lua", "lunar"],
      ];

      const state = {
        query: "",
        completion: "",
        group: "all",
      };

      function normalize(value) {
        return (value || "")
          .toString()
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .toLowerCase()
          .replace(/[^\p{L}\p{N}\s]+/gu, " ")
          .replace(/\s+/g, " ")
          .trim();
      }

      function normalizeCompact(value) {
        return (value || "")
          .toString()
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .toLowerCase()
          .replace(/[^\p{L}\p{N}]+/gu, "");
      }

      function loadInitialState() {
        const url = new URL(window.location.href);
        const q = url.searchParams.get("q");
        const group = url.searchParams.get("section");
        if (q || group) {
          return {
            query: q || "",
            group: group || "all",
          };
        }

        try {
          const raw = sessionStorage.getItem(storageKey);
          if (!raw) return { query: "", group: "all" };
          const saved = JSON.parse(raw);
          return {
            query: typeof saved.query === "string" ? saved.query : "",
            group: typeof saved.group === "string" ? saved.group : "all",
          };
        } catch {
          return { query: "", group: "all" };
        }
      }

      function persistState() {
        const snapshot = {
          query: state.query,
          group: state.group,
        };

        try {
          sessionStorage.setItem(storageKey, JSON.stringify(snapshot));
        } catch {}

        const url = new URL(window.location.href);
        if (state.query) url.searchParams.set("q", state.query);
        else url.searchParams.delete("q");

        if (state.group && state.group !== "all") url.searchParams.set("section", state.group);
        else url.searchParams.delete("section");

        history.replaceState({ ...(history.state || {}), sineSearch: snapshot }, "", url);
      }

      function queryAliases(term) {
        for (const group of CONCEPT_GROUPS) {
          const normalizedGroup = group.map((value) => normalize(value));
          if (normalizedGroup.includes(term)) return normalizedGroup;
        }
        return [term];
      }

      function matchesQuery(item, queryNorm) {
        if (!queryNorm) return true;
        const terms = queryNorm.split(" ").filter(Boolean);
        return terms.every((term) => queryAliases(term).some((variant) => item.searchText.includes(variant)));
      }

      function matchesGroup(item) {
        return state.group === "all" || item.groupKey === state.group;
      }

      function scoreItem(item, queryNorm) {
        if (!queryNorm) return 0;
        const phrase = queryNorm;
        const terms = phrase.split(" ").filter(Boolean);
        let score = 0;

        if (item.titleNorm.includes(phrase)) score += 120;
        if (item.titleNorm.startsWith(phrase)) score += 55;
        if (item.designationNorm.includes(phrase)) score += 40;
        if (item.typeNorm.includes(phrase)) score += 22;
        if (item.sectionLabelNorm.includes(phrase)) score += 18;
        if (item.summaryNorm.includes(phrase)) score += 12;

        for (const term of terms) {
          const variants = queryAliases(term);
          const tagHit = variants.some((variant) => item.tags.some((tag) => tag.key === variant));
          if (variants.some((variant) => item.titleNorm.includes(variant))) score += 28;
          if (variants.some((variant) => item.designationNorm.includes(variant))) score += 14;
          if (variants.some((variant) => item.summaryNorm.includes(variant))) score += 8;
          if (variants.some((variant) => item.typeNorm.includes(variant))) score += 8;
          if (variants.some((variant) => item.sectionLabelNorm.includes(variant))) score += 6;
          if (tagHit) score += 22;
        }

        score += Math.max(0, 100 - Math.min(item.priority, 100));
        score += Math.min(item.updatedTimestamp / 1000000000000, 20);
        return score;
      }

      function buildResultSet() {
        const queryNorm = normalize(state.query);
        return items
          .filter((item) => matchesGroup(item) && matchesQuery(item, queryNorm))
          .map((item) => ({ item, score: scoreItem(item, queryNorm) }))
          .sort((left, right) => {
            if (queryNorm && right.score !== left.score) return right.score - left.score;
            if (left.item.defaultOrder !== right.item.defaultOrder) {
              return left.item.defaultOrder - right.item.defaultOrder;
            }
            return left.item.title.localeCompare(right.item.title);
          })
          .map((entry) => entry.item);
      }

      function getCompletionSuffix(title, queryCompact) {
        if (!queryCompact) return "";
        let compactPrefix = "";
        let prefixEnd = 0;

        for (const char of title) {
          prefixEnd += char.length;
          compactPrefix += normalizeCompact(char);

          if (compactPrefix === queryCompact) {
            return title.slice(prefixEnd);
          }

          if (!queryCompact.startsWith(compactPrefix)) {
            return "";
          }
        }

        return "";
      }

      function getQueryToken(rawQuery) {
        if (!rawQuery || /\s$/.test(rawQuery)) {
          return { compactToken: "" };
        }

        const match = rawQuery.match(/([^\s]+)$/);
        const rawToken = match ? match[1] : "";
        return {
          compactToken: normalizeCompact(rawToken),
        };
      }

      function getSourceCompletionMatch(source, compactToken) {
        if (!source || !compactToken) return null;

        const words = source.split(/\s+/).filter(Boolean);
        for (let index = 0; index < words.length; index += 1) {
          const word = words[index];
          const compactWord = normalizeCompact(word);
          if (!compactWord || compactWord === compactToken || !compactWord.startsWith(compactToken)) continue;

          const suffix = getCompletionSuffix(word, compactToken);
          if (!suffix) continue;

          return {
            suffix,
            wordIndex: index,
          };
        }

        return null;
      }

      function updateInlineCompletion() {
        const rawQuery = input.value || "";
        const { compactToken } = getQueryToken(rawQuery);
        typedGhost.textContent = rawQuery;
        completionGhost.textContent = "";
        state.completion = "";

        if (compactToken.length < 2) return;

        const bestMatch = items
          .map((item) => {
            const titleMatch = getSourceCompletionMatch(item.title, compactToken);
            const designationMatch = getSourceCompletionMatch(item.designation, compactToken);

            if (titleMatch) {
              return {
                item,
                suffix: titleMatch.suffix,
                score: titleMatch.wordIndex === 0 ? 120 : 96,
              };
            }

            if (designationMatch) {
              return {
                item,
                suffix: designationMatch.suffix,
                score: designationMatch.wordIndex === 0 ? 72 : 56,
              };
            }

            return { item, suffix: "", score: -1 };
          })
          .filter((entry) => entry.score > 0 && entry.suffix)
          .sort((left, right) => {
            if (right.score !== left.score) return right.score - left.score;
            if (left.item.defaultOrder !== right.item.defaultOrder) {
              return left.item.defaultOrder - right.item.defaultOrder;
            }
            return left.item.title.localeCompare(right.item.title);
          })[0];

        if (!bestMatch) return;

        state.completion = bestMatch.suffix;
        completionGhost.textContent = bestMatch.suffix;
      }

      function acceptInlineCompletion() {
        if (!state.completion) return false;
        input.value = `${input.value}${state.completion}`;
        state.query = input.value;
        updateInlineCompletion();
        applyFilters();
        return true;
      }

      function setNodeVisibility(node, visible, order) {
        if (!(node instanceof HTMLElement)) return;
        node.hidden = !visible;
        node.style.order = visible ? String(order) : "";
      }

      function animatePrimary(primaryCard) {
        if (!(primaryCard instanceof HTMLElement) || reducedMotion) return;
        primaryCard.animate(
          [
            { opacity: 0.56, transform: "translateY(8px)" },
            { opacity: 1, transform: "translateY(0)" },
          ],
          {
            duration: 220,
            easing: "cubic-bezier(0.16, 1, 0.3, 1)",
          }
        );
      }

      function updateResultVisibility(nextItems) {
        const primaryItem = nextItems[0] ?? null;
        const secondaryItems = nextItems.slice(1, 5);
        const remainingItems = nextItems.slice(5);
        const primaryId = primaryItem?.id ?? null;
        const featuredIds = new Set(secondaryItems.map((item) => item.id));
        const remainingIds = new Set(remainingItems.map((item) => item.id));

        featuredGrid.dataset.featuredCount = String(secondaryItems.length);

        items.forEach((item) => {
          setNodeVisibility(primaryCardsById.get(item.id), primaryId === item.id, 0);
          setNodeVisibility(featuredCardsById.get(item.id), featuredIds.has(item.id), secondaryItems.findIndex((entry) => entry.id === item.id));
          setNodeVisibility(remainingRowsById.get(item.id), remainingIds.has(item.id), remainingItems.findIndex((entry) => entry.id === item.id));
        });

        if (primaryId) {
          animatePrimary(primaryCardsById.get(primaryId));
        }

        primarySection.hidden = primaryItem === null;
        secondarySection.hidden = secondaryItems.length === 0;
        featuredGrid.hidden = secondaryItems.length === 0;
        remainingSection.hidden = remainingItems.length === 0;
        emptyEl.hidden = nextItems.length !== 0;
      }

      function updateFilterButtons() {
        filterButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          const isActive = button.dataset.searchFilter === state.group;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", isActive ? "true" : "false");
        });
      }

      function updateClearButton() {
        clearSearchButton.hidden = !input.value.trim();
      }

      function updateStatus(resultCount) {
        const hasQuery = state.query.trim().length > 0;
        const resultLabel = resultCount === 1 ? copy.result : copy.results;
        const recordLabel = resultCount === 1 ? copy.record : copy.records;
        const activeLabel = groupLabelByKey[state.group] || copy.allRecords;
        const primaryLabel = hasQuery ? copy.bestMatch : copy.featuredRecord;

        countEl.textContent = `${resultCount} ${recordLabel}`;
        statusEl.textContent = hasQuery
          ? `${resultCount} ${copy.matchesFor} "${state.query.trim()}"`
          : `${resultCount} ${resultLabel}`;
        activeFilterEl.textContent = hasQuery ? copy.searchResults : (state.group === "all" ? copy.allRecords : activeLabel);
        primaryKickers.forEach((node) => {
          if (node instanceof HTMLElement) node.textContent = primaryLabel;
        });

        if (resultCount === 0) {
          const query = state.query.trim();
          emptyTitleEl.textContent = query ? `${copy.noResultsFor} "${query}"` : copy.noResultsTitle;
          emptyBodyEl.textContent = copy.noResultsBody;
        }
      }

      function applyFilters() {
        state.query = input.value;
        const filteredResults = buildResultSet();
        updateResultVisibility(filteredResults);
        updateStatus(filteredResults.length);
        updateInlineCompletion();
        updateClearButton();
        updateFilterButtons();
        persistState();
      }

      function syncImageLoading() {
        const imageSelectors = ".search-primary-card__img, .search-card__img, .search-row__img";
        const images = Array.from(root.querySelectorAll(imageSelectors));
        images.forEach((image) => {
          if (!(image instanceof HTMLImageElement)) return;
          const visual = image.closest(".search-primary-card__visual, .search-card__visual, .search-row__thumb");
          if (!(visual instanceof HTMLElement)) return;
          const markLoaded = () => visual.classList.add("is-loaded");
          if (image.complete) {
            markLoaded();
            return;
          }
          image.addEventListener("load", markLoaded, { once: true, signal });
          image.addEventListener("error", markLoaded, { once: true, signal });
        });
      }

      const initialState = loadInitialState();
      state.query = initialState.query;
      state.group = groupLabelByKey[initialState.group] ? initialState.group : "all";
      input.value = initialState.query;

      syncImageLoading();
      applyFilters();

      const rerunSearch = debounce(() => {
        applyFilters();
      }, 80);

      input.addEventListener("input", rerunSearch, { signal });

      input.addEventListener("keydown", (event) => {
        if (event.key === "Tab" || event.key === "ArrowRight") {
          if (!state.completion || input.selectionStart !== input.value.length || input.selectionEnd !== input.value.length) return;
          event.preventDefault();
          acceptInlineCompletion();
          return;
        }

        if (event.key === "Escape") {
          state.completion = "";
          completionGhost.textContent = "";
        }
      }, { signal });

      clearSearchButton.addEventListener("click", () => {
        input.value = "";
        state.query = "";
        state.completion = "";
        typedGhost.textContent = "";
        completionGhost.textContent = "";
        applyFilters();
        input.focus();
      }, { signal });

      filterButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener("click", () => {
          state.group = button.dataset.searchFilter || "all";
          applyFilters();
        }, { signal });
      });

      window.addEventListener("keydown", (event) => {
        if (event.key !== "/") return;
        const active = document.activeElement;
        const typing = active && (
          active.tagName === "INPUT" ||
          active.tagName === "TEXTAREA" ||
          active.isContentEditable
        );
        if (typing) return;
        event.preventDefault();
        input.focus();
      }, { signal });

      window.addEventListener("pagehide", persistState, { signal });

      searchLinks.forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;

        const surface = link.closest(".search-primary-card, .search-card, .search-row");
        link.addEventListener("pointerdown", () => {
          surface?.classList.add("is-opening");
        }, { signal });

        link.addEventListener("pointerleave", () => {
          surface?.classList.remove("is-opening");
        }, { signal });

        link.addEventListener("click", (event) => {
          if (
            event.defaultPrevented ||
            event.button !== 0 ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey
          ) {
            return;
          }
          persistState();
          surface?.classList.add("is-opening");
        }, { signal });
      });

      function debounce(fn, delay) {
        let timeoutId = 0;
        return () => {
          window.clearTimeout(timeoutId);
          timeoutId = window.setTimeout(() => fn(), delay);
        };
      }
    }

    if (!window[searchInitKey]) {
      window[searchInitKey] = initializeArchiveSearch;
      document.addEventListener("astro:page-load", window[searchInitKey]);
    }

    if (!window[searchBeforeSwapKey]) {
      window[searchBeforeSwapKey] = () => {
        if (typeof window[searchCleanupKey] === "function") {
          window[searchCleanupKey]();
          window[searchCleanupKey] = null;
        }
      };
      document.addEventListener("astro:before-swap", window[searchBeforeSwapKey]);
    }

    window[searchInitKey]();
  </script>

