    .search-primary-card[data-section="characters"] .search-primary-card__surface:hover .search-primary-card__img,
    .search-primary-card[data-section="characters"] .search-primary-card__surface:focus-visible .search-primary-card__img {
      transform: scale(1.12);
    }

    .search-primary-card__shade {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(6, 6, 11, 0.08) 0%, rgba(6, 6, 11, 0.28) 44%, rgba(6, 6, 11, 0.82) 100%),
        linear-gradient(180deg, rgba(6, 6, 11, 0) 0%, rgba(6, 6, 11, 0.12) 46%, rgba(6, 6, 11, 0.72) 100%);
      pointer-events: none;
    }

    .search-primary-card__loading {
