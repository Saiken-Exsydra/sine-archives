---
import EntryLayout from "../../../../layouts/EntryLayout.astro";
import { getLocalizedCollection } from "../../../../i18n/content";

export async function getStaticPaths() {
  const entries = await getLocalizedCollection("cosmology", "pt-br");
  return entries.map((entry) => ({
    params: { locale: "pt-br", slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<EntryLayout active="cosmology" entry={entry} locale="pt-br" />
