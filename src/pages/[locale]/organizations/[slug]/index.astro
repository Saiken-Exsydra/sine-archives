---
import OrganizationDossierLayout from "../../../../layouts/OrganizationDossierLayout.astro";
import { getLocalizedCollection } from "../../../../i18n/content";

export async function getStaticPaths() {
  const entries = await getLocalizedCollection("organizations", "pt-br");
  return entries.map((entry) => ({
    params: { locale: "pt-br", slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<OrganizationDossierLayout entry={entry} locale="pt-br" />
