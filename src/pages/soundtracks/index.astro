---
import MainLayout from "../../layouts/MainLayout.astro";
import { getLocalizedMusicCatalog } from "../../data/music";
import songs from "../../data/songs.json";
import { localizedPath, type SiteLocale } from "../../i18n/config";
import { getArchiveNavLabels } from "../../i18n/ui";

const formatDurationLabel = (duration?: number | null) => {
  if (!duration || !Number.isFinite(duration)) return null;
  const totalSeconds = Math.max(0, Math.floor(duration));
  const minutes = Math.floor(totalSeconds / 60);
  const seconds = String(totalSeconds % 60).padStart(2, "0");
  return `${String(minutes).padStart(2, "0")}:${seconds}`;
};

const { locale = "en" } = Astro.props as { locale?: SiteLocale };
const navLabels = getArchiveNavLabels(locale);
const tracks = getLocalizedMusicCatalog(locale);

const copy = locale === "pt-br"
  ? {
      pageTitle: "Trilhas Sonoras - SiNE Archives",
      featuredTrack: "Faixa em destaque",
      audioCatalog: "Catalogo de audio",
      title: "Trilhas Sonoras",
      countSingular: "faixa",
      countPlural: "faixas",
      track: "Faixa",
      artistAlbum: "Artista / Album",
      duration: "Duracao",
      mood: "Clima",
      playerReady: "Canal pronto",
      playerPlaying: "Em reproducao",
      playerPaused: "Em pausa",
      play: "Tocar",
      pause: "Pausar",
      previous: "Anterior",
      next: "Proxima",
      seek: "Buscar posicao",
      volume: "Volume",
      mute: "Silenciar",
      unmute: "Restaurar audio",
      moreOptions: "Mais opcoes",
      noResults: "Nenhuma faixa encontrada para este filtro.",
      queue: "Tocar no player",
      active: "No player",
      unavailable: "Reservado",
      unknownArtist: "Artista nao identificado",
      unknownAlbum: "Album desconhecido",
      unclassifiedMood: "Peca registrada",
    }
  : {
      pageTitle: "Soundtracks - SiNE Archives",
      featuredTrack: "Featured track",
      audioCatalog: "Audio catalog",
      title: "Soundtracks",
      countSingular: "track",
      countPlural: "tracks",
      track: "Track",
      artistAlbum: "Artist / Album",
      duration: "Duration",
      mood: "Mood",
      playerReady: "Channel ready",
      playerPlaying: "Now playing",
      playerPaused: "Paused",
      play: "Play",
      pause: "Pause",
      previous: "Previous",
      next: "Next",
      seek: "Seek position",
      volume: "Volume",
      mute: "Mute",
      unmute: "Restore audio",
      moreOptions: "More options",
      noResults: "No tracks found for this filter.",
      queue: "Play in player",
      active: "In player",
      unavailable: "Reserved",
      unknownArtist: "Unknown artist",
      unknownAlbum: "Unknown album",
      unclassifiedMood: "Recorded piece",
    };

const metadataEntries = songs.map((song, index) => {
  const linkedTrack = tracks.find((track) => track.audioSrc === song.src);

  return {
    id: linkedTrack?.id ?? `song-${index + 1}`,
    kind: linkedTrack?.kind ?? "song",
    kindLabel: linkedTrack?.kindLabel ?? copy.song,
    title: linkedTrack?.title ?? song.title,
    artist: song.artist || copy.unknownArtist,
    album: song.album || copy.unknownAlbum,
    durationSeconds: song.duration,
    durationLabel: formatDurationLabel(song.duration),
    src: song.src,
    cover: song.cover || linkedTrack?.image || "/uploads/ui-banner.png",
    summary: linkedTrack?.summary ?? song.album ?? "",
    trackId: linkedTrack?.id ?? null,
    mood: linkedTrack?.mood ?? copy.unclassifiedMood,
  };
});

const metadataSrcSet = new Set(metadataEntries.map((entry) => entry.src));
const fallbackEntries = tracks
  .filter((track) => track.audioSrc && !metadataSrcSet.has(track.audioSrc))
  .map((track) => ({
    id: track.id,
    kind: track.kind,
    kindLabel: track.kindLabel,
    title: track.title,
    artist: track.subtitle || copy.unknownArtist,
    album: track.kindLabel,
    durationSeconds: null,
    durationLabel: track.duration,
    src: track.audioSrc,
    cover: track.image,
    summary: track.summary,
    trackId: track.id,
    mood: track.mood,
  }));

const catalogEntries = [...metadataEntries, ...fallbackEntries];
const total = catalogEntries.length;
const featuredTrackId = "sistera-no-1";
const featuredEntry = catalogEntries.find((entry) => (entry.trackId ?? entry.id) === featuredTrackId) ?? catalogEntries[0];
---

<MainLayout
  active="soundtracks"
  pageTitle={copy.pageTitle}
  locale={locale}
  hideFooter={true}
  pageClass="page--soundtracks"
  navVariant="section"
  navTrail={[
    { label: navLabels.index, href: localizedPath(locale, "/") },
    { label: copy.title },
  ]}
>
  <section
    class="sound-archive"
    data-sound-page
    data-empty-label={copy.noResults}
    data-track-label-singular={copy.countSingular}
    data-track-label-plural={copy.countPlural}
    data-queue-label={copy.queue}
    data-active-label={copy.active}
    data-unavailable-label={copy.unavailable}
    data-player-ready={copy.playerReady}
    data-player-playing={copy.playerPlaying}
    data-player-paused={copy.playerPaused}
    data-play-label={copy.play}
    data-pause-label={copy.pause}
    data-volume-label={copy.volume}
    data-mute-label={copy.mute}
    data-unmute-label={copy.unmute}
    data-featured-track-id={featuredEntry.trackId ?? featuredEntry.id}
    data-search-base={localizedPath(locale, "/search/")}
  >
    <div class="sound-archive__veil"></div>
    <div class="sound-archive__glow"></div>
    <div class="sine-grain"></div>

    <div class="sound-shell">
      <aside class="sound-feature" data-sound-deck>
        <div class="sound-feature__header">{copy.featuredTrack}</div>

        <div class="sound-feature__artwrap">
          <img
            class="sound-feature__art"
            data-deck-art
            src={featuredEntry.cover}
            alt=""
            loading="lazy"
            decoding="async"
          />
          <div class="sound-feature__artshade"></div>
        </div>

        <div class="sound-feature__body">
          <div class="sound-feature__kind" data-deck-kind>{featuredEntry.kindLabel}</div>
          <h2 class="sound-feature__title" data-deck-title>{featuredEntry.title}</h2>

          <div class="sound-feature__meta-copy">
            <div class="sound-feature__artist" data-deck-artist>{featuredEntry.artist}</div>
            <div class="sound-feature__album" data-deck-album>{featuredEntry.album}</div>
          </div>

          <p class="sound-feature__summary" data-deck-summary>{featuredEntry.summary}</p>

          <div class="sound-feature__progress-block">
            <input
              class="sound-feature__progress"
              type="range"
              min="0"
              max={featuredEntry.durationSeconds ?? 0}
              step="0.1"
              value="0"
              data-deck-progress
              aria-label={copy.seek}
            />
            <div class="sound-feature__time">
              <span data-deck-current-time>00:00</span>
              <span data-deck-duration>{featuredEntry.durationLabel ?? "00:00"}</span>
            </div>
          </div>

          <div class="sound-feature__controls">
            <button class="sound-feature__transport" type="button" data-deck-prev aria-label={copy.previous} title={copy.previous}>
              <img src="/uploads/previous.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" />
            </button>
            <button class="sound-feature__transport sound-feature__transport--primary" type="button" data-deck-toggle aria-label={copy.play} title={copy.play}>
              <img data-deck-toggle-icon src="/uploads/play.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" />
            </button>
            <button class="sound-feature__transport" type="button" data-deck-next aria-label={copy.next} title={copy.next}>
              <img src="/uploads/next.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" />
            </button>
          </div>

          <div class="sound-feature__volume">
            <button class="sound-feature__volume-toggle" type="button" data-deck-mute aria-label={copy.mute} title={copy.mute}>
              <img data-deck-volume-icon src="/uploads/speaker-low.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" />
            </button>
            <input
              class="sound-feature__volume-input"
              type="range"
              min="0"
              max="100"
              step="1"
              value="68"
              data-deck-volume
              aria-label={copy.volume}
            />
            <span class="sound-feature__volume-value" data-deck-volume-value>68</span>
          </div>

          <a class="sound-feature__link" href="#" data-deck-link hidden aria-hidden="true" tabindex="-1">
            <span>{copy.viewAlbum}</span>
            <span aria-hidden="true">→</span>
          </a>

          <div class="sound-feature__status" data-deck-status>{copy.playerReady}</div>
        </div>
      </aside>

      <div class="sound-catalog">
        <header class="sound-catalog__hero">
          <div class="sound-catalog__lead">
            <div class="sound-catalog__eyebrow">{copy.audioCatalog}</div>
            <h1 class="sound-catalog__title">{copy.title}</h1>
            <div class="sound-catalog__ornament"></div>
            <div class="sound-catalog__count" id="sound-count-body">
              {total} {total === 1 ? copy.countSingular : copy.countPlural}
            </div>
          </div>
        </header>

        <div class="sound-table">
          <div class="sound-table__head">
            <div>{copy.track}</div>
            <div>{copy.artistAlbum}</div>
            <div>{copy.duration}</div>
          </div>

          <div class="sound-table__body" id="sound-list">
            {catalogEntries.map((entry, index) => {
              const rowTrackId = entry.trackId ?? entry.id;
              const queryText = entry.album !== copy.unknownAlbum ? entry.album : entry.title;
              const isFeaturedDefault = rowTrackId === (featuredEntry.trackId ?? featuredEntry.id);

              return (
                <article
                  class={`sound-row${isFeaturedDefault ? " is-active-track" : ""}`}
                  data-track-card
                  data-track-id={rowTrackId}
                  data-track-src={entry.src}
                  data-kind={entry.kind}
                  data-search={`${entry.title} ${entry.artist} ${entry.album} ${entry.summary}`.toLowerCase()}
                  data-image={entry.cover}
                  data-kind-label={entry.kindLabel}
                  data-title={entry.title}
                  data-artist={entry.artist}
                  data-album={entry.album}
                  data-summary={entry.summary}
                  data-mood={entry.mood}
                  data-duration-label={entry.durationLabel ?? "00:00"}
                  data-duration-seconds={entry.durationSeconds ?? ""}
                  data-link-query={queryText}
                  role={entry.src ? "button" : undefined}
                  tabindex={entry.src ? "0" : undefined}
                  aria-label={entry.src ? `${copy.queue}: ${entry.title}` : copy.unavailable}
                  style={`--sound-delay: ${0.06 * index}s;`}
                >
                  <div class="sound-row__track">
                    <div class="sound-row__accent"></div>
                    <div class="sound-row__cover">
                      <img src={entry.cover} alt="" loading="lazy" decoding="async" />
                    </div>

                    <div class="sound-row__copy">
                      <div class="sound-row__kind">{entry.kindLabel}</div>
                      <h2 class="sound-row__title">{entry.title}</h2>
                    </div>
                  </div>

                  <div class="sound-row__meta">
                    <span class="sound-row__artist">{entry.artist}</span>
                    <span class="sound-row__album">{entry.album}</span>
                  </div>

                  <div class="sound-row__actions">
                    <button
                      class="sound-row__play"
                      type="button"
                      data-track-select={rowTrackId}
                      aria-label={entry.src ? copy.play : copy.unavailable}
                      title={entry.src ? copy.play : copy.unavailable}
                      disabled={!entry.src}
                    >
                      <img class="sound-row__play-icon" data-track-button-icon src="/uploads/play.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" />
                    </button>

                    <span class="sound-row__duration">{entry.durationLabel ?? "00:00"}</span>

                    <button class="sound-row__more" type="button" aria-label={copy.moreOptions} title={copy.moreOptions}>
                      <span></span>
                      <span></span>
                      <span></span>
                    </button>
                  </div>
                </article>
              );
            })}
          </div>
        </div>

        <div class="sound-empty" id="sound-empty" hidden>{copy.noResults}</div>

        <div class="sound-pagination" aria-label="Pagination">
          <span class="sound-pagination__count">01 / 01</span>
          <div class="sound-pagination__controls">
            <button class="sound-pagination__btn" type="button" aria-label={copy.previous} disabled>
              <img src="/uploads/previous.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" />
            </button>
            <button class="sound-pagination__btn sound-pagination__btn--current" type="button" aria-current="page">1</button>
            <button class="sound-pagination__btn" type="button" aria-label={copy.next} disabled>
              <img src="/uploads/next.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" />
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const initializeSoundtracksPage = () => {
      const soundPage = document.querySelector('[data-sound-page]');

      if (!(soundPage instanceof HTMLElement)) {
        return;
      }

      const cards = Array.from(soundPage.querySelectorAll('[data-track-card]'));
      const emptyState = soundPage.querySelector('#sound-empty');
      const countNode = soundPage.querySelector('#sound-count-body');
      const deck = soundPage.querySelector('[data-sound-deck]');
      const deckArt = soundPage.querySelector('[data-deck-art]');
      const deckKind = soundPage.querySelector('[data-deck-kind]');
      const deckTitle = soundPage.querySelector('[data-deck-title]');
      const deckArtist = soundPage.querySelector('[data-deck-artist]');
      const deckAlbum = soundPage.querySelector('[data-deck-album]');
      const deckSummary = soundPage.querySelector('[data-deck-summary]');
      const deckDuration = soundPage.querySelector('[data-deck-duration]');
      const deckCurrentTime = soundPage.querySelector('[data-deck-current-time]');
      const deckProgress = soundPage.querySelector('[data-deck-progress]');
      const deckStatus = soundPage.querySelector('[data-deck-status]');
      const deckToggle = soundPage.querySelector('[data-deck-toggle]');
      const deckToggleIcon = soundPage.querySelector('[data-deck-toggle-icon]');
      const deckPrev = soundPage.querySelector('[data-deck-prev]');
      const deckNext = soundPage.querySelector('[data-deck-next]');
      const deckMute = soundPage.querySelector('[data-deck-mute]');
      const deckVolume = soundPage.querySelector('[data-deck-volume]');
      const deckVolumeIcon = soundPage.querySelector('[data-deck-volume-icon]');
      const deckVolumeValue = soundPage.querySelector('[data-deck-volume-value]');
      const deckLink = soundPage.querySelector('[data-deck-link]');

      if (!cards.length) {
        return;
      }

      const listenerScope = new AbortController();
      const { signal } = listenerScope;

      const featuredTrackId = soundPage.dataset.featuredTrackId || cards[0]?.dataset.trackId || '';
      const searchBase = soundPage.dataset.searchBase || '/search/';
      const singular = soundPage.dataset.trackLabelSingular || 'track';
      const plural = soundPage.dataset.trackLabelPlural || 'tracks';
      const playerReady = soundPage.dataset.playerReady || 'Channel ready';
      const playerPlaying = soundPage.dataset.playerPlaying || 'Now playing';
      const playerPaused = soundPage.dataset.playerPaused || 'Paused';
      const playLabel = soundPage.dataset.playLabel || 'Play';
      const pauseLabel = soundPage.dataset.pauseLabel || 'Pause';
      const muteLabel = soundPage.dataset.muteLabel || 'Mute';
      const unmuteLabel = soundPage.dataset.unmuteLabel || 'Restore audio';
      const unavailableLabel = soundPage.dataset.unavailableLabel || 'Reserved';

      let activeTrackId = featuredTrackId;
      let activePlaying = false;
      let activeState = null;
      let seeking = false;
      const sessionStateKey = 'sine:music:session-state';

      const applyPlayerState = (state) => {
        if (!state?.trackId) return false;
        activeState = state;
        activeTrackId = state.trackId;
        activePlaying = !!state.playing;
        return true;
      };

      const formatTime = (value) => {
        const seconds = Math.max(0, Math.floor(Number(value) || 0));
        const minutes = Math.floor(seconds / 60);
        const remainder = String(seconds % 60).padStart(2, '0');
        return `${String(minutes).padStart(2, '0')}:${remainder}`;
      };

      const readControllerState = () => {
        const controller = window.__sineMusicController;

        if (!controller || typeof controller.getState !== 'function') {
          return null;
        }

        return controller.getState() || null;
      };

      const readSavedSessionState = () => {
        try {
          const raw = window.sessionStorage.getItem(sessionStateKey);
          if (!raw) return null;

          const parsed = JSON.parse(raw);
          if (!parsed || typeof parsed !== 'object' || typeof parsed.trackId !== 'string') {
            return null;
          }

          return {
            currentTime: Number.isFinite(parsed.currentTime) ? Math.max(0, parsed.currentTime) : 0,
            duration: null,
            muted: Boolean(parsed.muted),
            playing: Boolean(parsed.wasPlaying),
            trackId: parsed.trackId,
            volume: Number.isFinite(parsed.volume) ? parsed.volume : null,
          };
        } catch {
          return null;
        }
      };

      const syncFromKnownState = () => {
        const nextState = readControllerState() || readSavedSessionState();

        if (!applyPlayerState(nextState)) {
          return false;
        }

        updateActiveButtons();
        updateDeck();
        return true;
      };

      const getCardByTrackId = (trackId) => cards.find((card) => card.dataset.trackId === trackId) || null;
      const getDeckCard = () => getCardByTrackId(activeTrackId) || getCardByTrackId(featuredTrackId) || cards[0] || null;

      const updateCount = (visible) => {
        if (!countNode) return;
        countNode.textContent = `${visible} ${visible === 1 ? singular : plural}`;
      };

      const updateActiveButtons = () => {
        cards.forEach((card) => {
          const trackId = card.dataset.trackId;
          const button = card.querySelector('[data-track-select]');
          const icon = card.querySelector('[data-track-button-icon]');
          const isActive = trackId === activeTrackId;

          card.classList.toggle('is-active-track', isActive);

          if (!button || !icon) {
            return;
          }

          if (button.disabled) {
            button.setAttribute('aria-label', unavailableLabel);
            button.setAttribute('title', unavailableLabel);
            icon.setAttribute('src', '/uploads/play.svg');
            return;
          }

          if (isActive && activePlaying) {
            button.setAttribute('aria-label', pauseLabel);
            button.setAttribute('title', pauseLabel);
            icon.setAttribute('src', '/uploads/pause.svg');
            return;
          }

          button.setAttribute('aria-label', playLabel);
          button.setAttribute('title', playLabel);
          icon.setAttribute('src', '/uploads/play.svg');
        });
      };

      const updateDeck = () => {
        const deckCard = getDeckCard();
        if (!deckCard || !deck) return;

        const trackId = deckCard.dataset.trackId || featuredTrackId;
        const durationSeconds = Number(deckCard.dataset.durationSeconds || 0);
        const stateMatchesDeck = activeState?.trackId === trackId;
        const currentTimeValue = stateMatchesDeck ? Number(activeState?.currentTime || 0) : 0;
        const liveDurationValue = stateMatchesDeck && Number.isFinite(activeState?.duration) ? Number(activeState.duration) : durationSeconds;
        const totalDurationLabel = liveDurationValue > 0
          ? formatTime(liveDurationValue)
          : (deckCard.dataset.durationLabel || '00:00');
        const volumeValue = typeof activeState?.volume === 'number'
          ? Math.round(activeState.volume * 100)
          : Number(deckVolume?.value || 68);
        const muted = !!activeState?.muted || volumeValue <= 0;
        const currentIndex = Math.max(0, cards.findIndex((card) => card.dataset.trackId === trackId));

        deck.classList.toggle('is-playing', stateMatchesDeck && activePlaying);

        if (deckArt) deckArt.setAttribute('src', deckCard.dataset.image || '');
        if (deckKind) deckKind.textContent = deckCard.dataset.kindLabel || '';
        if (deckTitle) deckTitle.textContent = deckCard.dataset.title || '';
        if (deckArtist) deckArtist.textContent = deckCard.dataset.artist || '';
        if (deckAlbum) deckAlbum.textContent = deckCard.dataset.album || '';
        if (deckSummary) deckSummary.textContent = deckCard.dataset.summary || '';
        if (deckCurrentTime) deckCurrentTime.textContent = formatTime(currentTimeValue);
        if (deckDuration) deckDuration.textContent = totalDurationLabel;
        if (deckStatus) {
          deckStatus.textContent = stateMatchesDeck
            ? (activePlaying ? playerPlaying : playerPaused)
            : playerReady;
        }
        if (deckToggle) {
          const label = stateMatchesDeck && activePlaying ? pauseLabel : playLabel;
          deckToggle.setAttribute('aria-label', label);
          deckToggle.setAttribute('title', label);
        }
        if (deckToggleIcon) {
          deckToggleIcon.setAttribute('src', stateMatchesDeck && activePlaying ? '/uploads/pause.svg' : '/uploads/play.svg');
        }
        if (deckPrev) deckPrev.disabled = currentIndex <= 0;
        if (deckNext) deckNext.disabled = currentIndex >= cards.length - 1;
        if (deckMute) {
          const label = muted ? unmuteLabel : muteLabel;
          deckMute.setAttribute('aria-label', label);
          deckMute.setAttribute('title', label);
        }
        if (deckVolume) deckVolume.value = String(volumeValue);
        if (deckVolumeValue) deckVolumeValue.textContent = String(volumeValue);
        if (deckVolumeIcon) {
          const iconSrc = muted
            ? '/uploads/speaker-mute.svg'
            : volumeValue < 45
              ? '/uploads/speaker-low.svg'
              : '/uploads/speaker-high.svg';
          deckVolumeIcon.setAttribute('src', iconSrc);
        }
        if (deckLink) {
          const query = encodeURIComponent(deckCard.dataset.linkQuery || deckCard.dataset.title || '');
          deckLink.setAttribute('href', `${searchBase}?q=${query}`);
        }
        if (deckProgress) {
          deckProgress.disabled = liveDurationValue <= 0;
          deckProgress.max = String(liveDurationValue > 0 ? liveDurationValue : 0);
          if (!seeking) {
            deckProgress.value = String(Math.min(currentTimeValue, liveDurationValue || 0));
          }
        }
      };

      const applyFilters = () => {
        let visible = 0;

        cards.forEach((card) => {
          card.hidden = false;
          visible += 1;
        });

        if (emptyState) emptyState.hidden = visible !== 0;
        updateCount(visible);
      };

      const selectTrack = (trackId, autoplay) => {
        if (!trackId) return;
        activeTrackId = trackId;
        updateActiveButtons();
        updateDeck();
        window.dispatchEvent(new CustomEvent('sine:music-select', {
          detail: {
            trackId,
            autoplay,
            openPanel: false,
          },
        }));
      };

      cards.forEach((card) => {
        if (!card.dataset.trackSrc) return;

        card.addEventListener('click', (event) => {
          const interactiveTarget = event.target instanceof Element
            ? event.target.closest('button, a, input, label')
            : null;

          if (interactiveTarget) return;

          const trackId = card.dataset.trackId;
          if (!trackId) return;

          selectTrack(trackId, true);
        }, { signal });

        card.addEventListener('keydown', (event) => {
          if (event.key !== 'Enter' && event.key !== ' ') return;

          const trackId = card.dataset.trackId;
          if (!trackId) return;

          event.preventDefault();
          selectTrack(trackId, true);
        }, { signal });
      });

      soundPage.querySelectorAll('[data-track-select]').forEach((button) => {
        button.addEventListener('click', (event) => {
          event.stopPropagation();
          const trackId = button.getAttribute('data-track-select');
          if (!trackId) return;

          if (trackId === activeTrackId) {
            window.dispatchEvent(new CustomEvent('sine:music-command', {
              detail: { command: activePlaying ? 'pause' : 'play' },
            }));
            return;
          }

          selectTrack(trackId, true);
        }, { signal });
      });

      deckToggle?.addEventListener('click', () => {
        const deckCard = getDeckCard();
        if (!deckCard) return;
        const trackId = deckCard.dataset.trackId;
        if (!trackId) return;

        if (trackId === activeTrackId) {
          window.dispatchEvent(new CustomEvent('sine:music-command', {
            detail: { command: activePlaying ? 'pause' : 'play' },
          }));
          return;
        }

        selectTrack(trackId, true);
      }, { signal });

      const stepDeck = (direction) => {
        const deckCard = getDeckCard();
        if (!deckCard) return;

        const currentIndex = cards.findIndex((card) => card.dataset.trackId === deckCard.dataset.trackId);
        if (currentIndex < 0) return;

        const nextCard = cards[currentIndex + direction];
        if (!nextCard) return;

        selectTrack(nextCard.dataset.trackId || '', activePlaying);
      };

      deckPrev?.addEventListener('click', () => stepDeck(-1), { signal });
      deckNext?.addEventListener('click', () => stepDeck(1), { signal });

      deckMute?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('sine:music-command', {
          detail: { command: 'mute' },
        }));
      }, { signal });

      deckVolume?.addEventListener('input', () => {
        window.dispatchEvent(new CustomEvent('sine:music-command', {
          detail: { command: 'volume', value: Number(deckVolume.value) / 100 },
        }));
      }, { signal });

      deckProgress?.addEventListener('input', () => {
        seeking = true;
        if (deckCurrentTime) deckCurrentTime.textContent = formatTime(deckProgress.value);
      }, { signal });

      deckProgress?.addEventListener('change', () => {
        seeking = false;
        window.dispatchEvent(new CustomEvent('sine:music-command', {
          detail: { command: 'seek', value: Number(deckProgress.value) },
        }));
      }, { signal });

      window.addEventListener('sine:music-state', (event) => {
        applyPlayerState(event.detail || null);
        activeTrackId = activeTrackId || featuredTrackId;
        updateActiveButtons();
        updateDeck();
      }, { signal });

      const hasSavedSession = (() => {
        try {
          return !!window.sessionStorage.getItem(sessionStateKey);
        } catch {
          return false;
        }
      })();

      applyFilters();
      syncFromKnownState();
      updateActiveButtons();
      updateDeck();

      if (!hasSavedSession && featuredTrackId) {
        selectTrack(featuredTrackId, false);
      }

      window.dispatchEvent(new CustomEvent('sine:music-request-state'));
      requestAnimationFrame(() => {
        if (signal.aborted) return;
        syncFromKnownState();
        window.dispatchEvent(new CustomEvent('sine:music-request-state'));
      });

      return () => listenerScope.abort();
    };

    window.registerPageInit?.('soundtracks-page', initializeSoundtracksPage);
  </script>

