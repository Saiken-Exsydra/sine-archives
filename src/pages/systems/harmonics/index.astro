---
import SystemInterfaceScaffold from "../../../components/systems/SystemInterfaceScaffold.astro";
import type { SiteLocale } from "../../../i18n/config";

const { locale = "en" } = Astro.props as { locale?: SiteLocale };
---

<SystemInterfaceScaffold
  locale={locale}
  id="harmonics"
  title="Harmonic Array"
  pageTitle="Harmonic Array - SiNE Archives"
  logo="/uploads/observatory-white/Harmonics_symbol.png"
  eyebrow="Systems Interface / Harmonics"
  summary="Harmonics are resonance watched over time: the same underlying pull becoming rhythm, surge, fade, or warning pattern."
  mechanism="Resonance under Time."
  interfaceLabel="Rhythm map / Time-ordered traversal"
  transitionName="observatory-harmonics-symbol"
/>
