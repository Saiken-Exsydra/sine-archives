---
import CharacterEntryLayout from "../../../layouts/CharacterEntryLayout.astro";
import { getLocalizedCollection } from "../../../i18n/content";

export async function getStaticPaths() {
  const entries = await getLocalizedCollection("characters", "en");
  return entries
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
---

<CharacterEntryLayout entry={entry} locale="en" />
