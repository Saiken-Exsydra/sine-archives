---
import CharacterCodexLayout from "../../../../layouts/CharacterCodexLayout.astro";
import { getLocalizedCollection } from "../../../../i18n/content";
import { getCharacterCodexRecord } from "../../../../utils/character-codex";

export async function getStaticPaths() {
  const entries = await getLocalizedCollection("characters", "en");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const codex = await getCharacterCodexRecord(entry);
---

<CharacterCodexLayout entry={entry} codex={codex} locale="en" />
