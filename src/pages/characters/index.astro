---
import MusicPlayer from "../../components/MusicPlayer.astro";
import { getLocalizedCollection } from "../../i18n/content";
import { localizedPath, type SiteLocale } from "../../i18n/config";
import { buildOptimizedImageBundle, getImageKind } from "../../utils/optimized-images";

const { locale = "en" } = Astro.props as { locale?: SiteLocale };
const copy = locale === "pt-br"
  ? {
      pageTitle: "Personagens - SiNE Archives",
      logo: "ARQUIVOS",
      index: "Indice",
      section: "Personagens",
      search: "Buscar",
      sectionDesc: "Individuos de relevancia dentro da Faixa do Crepusculo e alem.",
      searchPlaceholder: "Buscar dossies",
      clearSearch: "Limpar busca",
      noResults: "Nenhum dossie encontrado",
      filingYear: "SiNE Archives - Ano de Arquivo 1127",
      accessLevel: "Nivel de Acesso: Publico",
      portraitClassified: "RETRATO CLASSIFICADO",
      fileSealed: "ARQUIVOS SINE - REGISTRO SELADO",
      filed: "Arquivado",
      openDossier: "Abrir Dossier",
      hideOverlay: "Ocultar overlay",
      showOverlay: "Mostrar overlay",
      restoreOverlay: "Clique para restaurar overlay",
      fullscreen: "Tela cheia",
      exitFullscreen: "Sair da tela cheia",
      dossierOnFile: "Dossie em Arquivo",
      swipeToNavigate: "Deslize para navegar",
      nextImage: "Proxima imagem",
    }
  : {
      pageTitle: "Characters - SiNE Archives",
      logo: "ARCHIVES",
      index: "Index",
      section: "Characters",
      search: "Search",
      sectionDesc: "Individuals of note within the Twilight Band and beyond.",
      searchPlaceholder: "Search dossiers",
      clearSearch: "Clear search",
      noResults: "No dossiers found",
      filingYear: "SiNE Archives - Filing Year 1127",
      accessLevel: "Access Level: Public",
      portraitClassified: "PORTRAIT CLASSIFIED",
      fileSealed: "SiNE ARCHIVES - FILE SEALED",
      filed: "Filed",
      openDossier: "Open Dossier",
      hideOverlay: "Hide overlay",
      showOverlay: "Show overlay",
      restoreOverlay: "Click to restore overlay",
      fullscreen: "Full screen",
      exitFullscreen: "Exit full screen",
      dossierOnFile: "Dossier On File",
      swipeToNavigate: "Swipe to navigate",
      nextImage: "Next image",
    };
const all = await getLocalizedCollection("characters", locale);
const characters = all
  .filter((e) => e.data.status === "public")
  .sort((a, b) => {
    const pa = (a.data as any).priority ?? Infinity;
    const pb = (b.data as any).priority ?? Infinity;
    if (pa !== pb) return pa - pb;
    return a.data.title.localeCompare(b.data.title);
  });

const STAGE_IMAGE_SIZES = "(max-width: 700px) 100vw, calc(100vw - 310px)";
const FILMSTRIP_IMAGE_SIZES = "(max-width: 700px) 140px, 0px";

const charData = await Promise.all(
  characters.map(async (c) => {
    const heroCandidates = [
      c.data.image,
      c.data.hero_image,
      ...(Array.isArray((c.data as any).hero_gallery) ? (c.data as any).hero_gallery : []),
    ];

    const heroValues = heroCandidates
      .filter((value) => !!value && getImageKind(value) === "hero")
      .filter((value, index, list) => list.findIndex((item) => {
        const a = typeof item === "string" ? item : item?.src;
        const b = typeof value === "string" ? value : value?.src;
        return a === b;
      }) === index);

    const stageImages = (
      await Promise.all(
        heroValues.map((value) =>
          buildOptimizedImageBundle(value, {
            widths: [640, 1280, 1920],
            sizes: STAGE_IMAGE_SIZES,
            quality: 90,
            fit: "cover",
          })
        )
      )
    ).filter(Boolean);

    return {
      slug: c.slug,
      title: c.data.title,
      type: c.data.type ?? (locale === "pt-br" ? "Personagem" : "Character"),
      designation: (c.data as any).designation ?? "",
      summary: c.data.summary,
      images: stageImages,
      thumbImage: stageImages[0] ? { ...stageImages[0], sizes: FILMSTRIP_IMAGE_SIZES } : null,
      tags: c.data.tags ?? [],
      updated: c.data.updated,
      href: localizedPath(locale, `/characters/${c.slug}/?char=${encodeURIComponent(c.slug)}`),
    };
  })
);
const sectionEyebrow = locale === "pt-br"
  ? `Secao - ${charData.length} Dossies`
  : `Section - ${charData.length} Dossiers`;
---

<!doctype html>
<html lang={locale === "pt-br" ? "pt-BR" : "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#06060b" />
    <title>{copy.pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg:         #06060b;
        --surface:    #0a0a14;
        --border:     rgba(255, 255, 255, 0.07);
        --crimson:    #b13a34;
        --gold:       #b08d3c;
        --text:       #e8e4dc;
        --text-muted: rgba(232, 228, 220, 0.55);
        --text-dim:   rgba(232, 228, 220, 0.3);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        height: 100%;
        overflow: hidden;
        background: var(--bg);
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      ::selection { background: rgba(177, 58, 52, 0.35); color: var(--text); }
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: rgba(177, 58, 52, 0.3); border-radius: 2px; }

      button { font-family: inherit; }
      img { display: block; }

      /* â”€â”€ NAV â”€â”€ */
      .nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 32px;
        background: rgba(6, 6, 11, 0.88);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }
      .nav__logo {
        display: flex; align-items: center; gap: 10px;
        text-decoration: none; flex-shrink: 0;
      }
      .nav__logo-img { height: 26px; opacity: 0.9; }
      .nav__logo-text {
        font-family: 'DM Sans', sans-serif;
        font-size: 10px; font-weight: 600;
        letter-spacing: 0.22em;
        color: rgba(232, 228, 220, 0.45);
        text-transform: uppercase;
      }
      .nav__right {
        display: flex; align-items: center; gap: 16px;
      }
      .nav__crumb {
        display: flex; align-items: center; gap: 6px;
        font-family: 'DM Sans', sans-serif;
        font-size: 12px; letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .nav__crumb-link {
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.2s;
        font-size: 12px;
        letter-spacing: 0.08em;
        font-family: 'DM Sans', sans-serif;
        text-transform: uppercase;
      }
      .nav__crumb-link:hover { color: var(--text-muted); }
      .nav__crumb-sep { color: var(--crimson); font-size: 14px; }
      .nav__crumb-cur { color: var(--text-dim); font-size: 12px; }
      .nav__fullscreen-btn,
      .nav__search-btn {
        display: flex; align-items: center; justify-content: center;
        width: 34px; height: 34px;
        color: rgba(232, 228, 220, 0.5);
        text-decoration: none; transition: color 0.2s, background 0.2s;
        background: transparent;
        border: 0;
        border-radius: 4px;
        cursor: pointer;
        flex-shrink: 0;
      }
      .nav__fullscreen-btn:hover,
      .nav__fullscreen-btn.is-active,
      .nav__search-btn:hover {
        color: rgba(232, 228, 220, 0.9);
        background: rgba(255, 255, 255, 0.04);
      }

      /* â”€â”€ LAYOUT â”€â”€ */
      .chars-root {
        display: flex;
        height: 100vh;
        padding-top: 56px;
        background: var(--bg);
        overflow: hidden;
        position: relative;
      }

      /* â”€â”€ LEFT SIDEBAR â”€â”€ */
      .sidebar {
        width: 310px;
        flex-shrink: 0;
        border-right: 1px solid rgba(255, 255, 255, 0.06);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: rgba(5, 5, 10, 0.7);
        position: relative;
        z-index: 20;
      }

      .sidebar__head {
        padding: 36px 32px 24px;
      }
      .sidebar__eyebrow {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px; font-weight: 600;
        letter-spacing: 0.28em;
        color: var(--crimson);
        text-transform: uppercase;
        margin-bottom: 10px;
      }
      .sidebar__title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 40px; font-weight: 700;
        color: var(--text);
        line-height: 1; letter-spacing: 0.01em;
      }
      .sidebar__desc {
        margin-top: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        color: var(--text-muted);
        line-height: 1.65;
      }

      .sidebar__search {
        margin-top: 18px;
        position: relative;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .sidebar__search-icon {
        flex-shrink: 0;
        color: rgba(232, 228, 220, 0.18);
        pointer-events: none;
        display: flex;
        transition: color 0.3s;
      }
      .sidebar__search:hover .sidebar__search-icon,
      .sidebar__search:focus-within .sidebar__search-icon {
        color: rgba(232, 228, 220, 0.35);
      }
      .sidebar__search-input {
        flex: 1;
        background: transparent;
        border: none;
        border-bottom: 1px solid transparent;
        outline: none;
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        letter-spacing: 0.05em;
        padding: 8px 24px 8px 0;
        transition: border-color 0.3s;
        caret-color: var(--crimson);
      }
      .sidebar__search-input::placeholder {
        color: transparent;
        transition: color 0.3s;
        letter-spacing: 0.12em;
        font-size: 10px;
        text-transform: uppercase;
      }
      .sidebar__search:hover .sidebar__search-input::placeholder,
      .sidebar__search:focus-within .sidebar__search-input::placeholder {
        color: rgba(232, 228, 220, 0.2);
      }
      .sidebar__search:hover .sidebar__search-input,
      .sidebar__search-input:focus {
        border-bottom-color: rgba(255, 255, 255, 0.1);
      }
      .sidebar__search-input:focus {
        border-bottom-color: rgba(177, 58, 52, 0.4);
      }
      .sidebar__search-clear {
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(232, 228, 220, 0.25);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        display: none;
        align-items: center;
        line-height: 1;
        font-size: 14px;
        transition: color 0.2s;
      }
      .sidebar__search-clear:hover { color: var(--crimson); }
      .sidebar__search-clear.is-visible { display: flex; }

      .sidebar__no-results {
        padding: 24px 32px;
        font-family: 'DM Sans', sans-serif;
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(232, 228, 220, 0.18);
        display: none;
      }
      .sidebar__no-results.is-visible { display: block; }

      .sidebar__divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.06);
        margin: 0 32px;
        flex-shrink: 0;
      }

      .sidebar__list {
        overflow-y: auto;
        flex: 1;
        padding-bottom: 16px;
      }

      .sidebar__item {
        background: none;
        border: none;
        border-left: 2px solid transparent;
        padding: 20px 32px;
        cursor: pointer;
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 5px;
        transition: background 0.22s, border-color 0.22s;
        width: 100%;
      }
      .sidebar__item.is-active {
        background: rgba(177, 58, 52, 0.09);
        border-left-color: var(--crimson);
      }

      .sidebar__item-num {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px; font-weight: 600;
        letter-spacing: 0.24em;
        color: rgba(232, 228, 220, 0.2);
        text-transform: uppercase;
        transition: color 0.22s;
        display: flex; align-items: center; gap: 8px;
      }
      .sidebar__item.is-active .sidebar__item-num { color: var(--crimson); }

      .sidebar__item-num-line {
        display: inline-block;
        width: 16px; height: 1px;
        background: var(--crimson);
        vertical-align: middle;
      }

      .sidebar__item-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 22px; font-weight: 700;
        color: rgba(232, 228, 220, 0.42);
        line-height: 1.1; letter-spacing: 0.01em;
        transition: color 0.22s;
      }
      .sidebar__item.is-active .sidebar__item-name { color: var(--text); }

      .sidebar__item-des {
        font-family: 'DM Sans', sans-serif;
        font-size: 10px;
        color: rgba(232, 228, 220, 0.18);
        letter-spacing: 0.04em; line-height: 1.4;
        transition: color 0.22s;
      }
      .sidebar__item.is-active .sidebar__item-des { color: rgba(176, 141, 60, 0.8); }

      .sidebar__footer {
        padding: 18px 32px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        flex-shrink: 0;
      }
      .sidebar__stamp {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px; letter-spacing: 0.16em;
        color: rgba(232, 228, 220, 0.1);
        text-transform: uppercase; line-height: 1.7;
      }
      .sidebar__stamp-accent { color: rgba(177, 58, 52, 0.3); }

      /* â”€â”€ STAGE â”€â”€ */
      .stage {
        flex: 1;
        position: relative;
        overflow: hidden;
        background: #06060b;
      }
      .stage--ui-hidden { cursor: zoom-out; }

      .stage__portrait {
        position: absolute; inset: 0;
        transition: opacity 1s ease;
      }
      .stage__portrait.is-out { opacity: 0; }
      .stage__portrait.is-in  { opacity: 1; }

      .stage__portrait-img {
        width: 100%; height: 100%;
        object-fit: cover;
        object-position: center 18%;
        filter: saturate(1.08) brightness(1.1) contrast(1.02);
        will-change: transform;
      }

      .stage__placeholder {
        position: absolute; inset: 0;
      }

      /* gradients */
      .stage__grad-r,
      .stage__grad-b,
      .stage__grad-t {
        position: absolute; inset: 0; z-index: 2; pointer-events: none;
      }
      .stage__grad-r {
        background: linear-gradient(to right, rgba(6,6,11,0.72) 0%, rgba(6,6,11,0.22) 45%, rgba(6,6,11,0.04) 100%);
      }
      .stage__grad-b {
        background: linear-gradient(to top, rgba(6,6,11,0.84) 0%, rgba(6,6,11,0.52) 22%, rgba(6,6,11,0) 55%);
      }
      .stage__grad-t {
        background: linear-gradient(to bottom, rgba(6,6,11,0.42) 0%, transparent 18%);
      }

      .stage__scanlines {
        position: absolute; inset: 0; z-index: 3; pointer-events: none;
        background-image: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.025) 3px, rgba(0,0,0,0.025) 4px);
      }

      /* watermark */
      .stage__watermark {
        position: absolute; right: 0; top: 0; bottom: 0; left: 0;
        display: flex; flex-direction: column; justify-content: center; align-items: flex-end;
        z-index: 2; pointer-events: none;
        user-select: none;
        line-height: 0.82;
        padding-right: 44px;
        transition: opacity 0.9s ease 0.25s;
      }
      .stage__watermark.is-out { opacity: 0; }
      .stage__watermark.is-in  { opacity: 0.15; }
      .stage__watermark-word {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(64px, 8vw, 110px);
        font-weight: 700;
        color: var(--text);
        white-space: nowrap;
        letter-spacing: -0.03em;
      }

      /* top row */
      .stage__top {
        position: absolute; top: 0; left: 0; right: 0;
        z-index: 10; padding: 28px 40px;
        display: flex; align-items: flex-start; justify-content: space-between;
      }
      .stage__counter {
        font-family: 'DM Sans', sans-serif;
        font-size: 11px; letter-spacing: 0.22em;
        color: rgba(232, 228, 220, 0.18);
        display: flex; align-items: baseline; gap: 8px;
        transition: opacity 0.4s ease 0.2s;
      }
      .stage__counter.is-out { opacity: 0; }
      .stage__counter.is-in  { opacity: 1; }
      .stage__counter-num {
        font-family: 'Cormorant Garamond', serif;
        font-size: 28px; font-weight: 700;
        color: var(--crimson); line-height: 1;
      }

      .stage__tags {
        display: flex; flex-direction: column; gap: 6px; align-items: flex-end;
        transition: opacity 0.4s ease 0.3s;
      }
      .stage__tags.is-out { opacity: 0; }
      .stage__tags.is-in  { opacity: 1; }
      .stage__tag {
        background: rgba(6,6,11,0.72);
        border: 1px solid rgba(255,255,255,0.09);
        padding: 4px 11px;
        font-family: 'DM Sans', sans-serif;
        font-size: 9px; letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(232,228,220,0.4);
        backdrop-filter: blur(10px);
      }

      /* bottom content */
      .stage__bottom {
        position: absolute; bottom: 0; left: 0; right: 60px;
        z-index: 10; padding: 0 64px 52px;
      }

      .stage__rule {
        height: 1px;
        background: var(--crimson);
        margin-bottom: 18px;
        width: 0;
        transition: width 0.5s ease 0.1s;
      }
      .stage__rule.is-in { width: 48px; }

      .stage__type-label {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px; letter-spacing: 0.3em;
        color: var(--crimson); text-transform: uppercase; font-weight: 600;
        margin-bottom: 12px;
        transition: opacity 0.5s ease 0.12s, transform 0.5s ease 0.12s;
      }
      .stage__type-label.is-out { opacity: 0; transform: translateY(14px); }
      .stage__type-label.is-in  { opacity: 1; transform: translateY(0); }

      .stage__name {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(46px, 5.5vw, 84px); font-weight: 700;
        color: var(--text);
        margin: 0 0 14px 0; line-height: 0.92;
        letter-spacing: -0.01em; max-width: 640px;
        transition: opacity 0.55s ease 0.2s, transform 0.55s ease 0.2s;
      }
      .stage__name.is-out { opacity: 0; transform: translateY(18px); }
      .stage__name.is-in  { opacity: 1; transform: translateY(0); }

      .stage__designation {
        font-family: 'DM Sans', sans-serif;
        font-size: 12px; color: var(--gold);
        letter-spacing: 0.08em; margin-bottom: 18px;
        transition: opacity 0.5s ease 0.28s, transform 0.5s ease 0.28s;
      }
      .stage__designation.is-out { opacity: 0; transform: translateY(12px); }
      .stage__designation.is-in  { opacity: 0.82; transform: translateY(0); }

      .stage__summary {
        font-family: 'DM Sans', sans-serif;
        font-size: 14px; color: rgba(232,228,220,0.58);
        line-height: 1.75; margin: 0 0 30px 0; max-width: 500px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: opacity 0.5s ease 0.35s, transform 0.5s ease 0.35s;
      }
      .stage__summary.is-out { opacity: 0; transform: translateY(12px); }
      .stage__summary.is-in  { opacity: 1; transform: translateY(0); }

      .stage__actions {
        display: flex; align-items: center; gap: 14px;
        transition: opacity 0.5s ease 0.43s, transform 0.5s ease 0.43s;
      }
      .stage__actions.is-out { opacity: 0; transform: translateY(10px); }
      .stage__actions.is-in  { opacity: 1; transform: translateY(0); }

      .stage__cta {
        background: var(--crimson); border: none;
        color: var(--text); font-family: 'DM Sans', sans-serif;
        font-size: 10px; font-weight: 600;
        letter-spacing: 0.22em; text-transform: uppercase;
        padding: 12px 28px; border-radius: 2px;
        cursor: pointer; text-decoration: none;
        transition: background 0.2s;
        display: inline-block;
      }
      .stage__cta:hover { background: #c94040; }

      .stage__gallery {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .stage__gallery-count {
        min-width: 56px;
        padding: 0 12px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(232,228,220,0.55);
        font-family: 'DM Sans', sans-serif;
        font-size: 9px;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        border-radius: 2px;
      }
      .stage__gallery-btn {
        min-width: 38px;
        height: 38px;
        padding: 0 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(232,228,220,0.5);
        cursor: pointer;
        border-radius: 2px;
        transition: background 0.2s, color 0.2s, border-color 0.2s;
      }
      .stage__gallery-btn:hover {
        background: rgba(177,58,52,0.15);
        color: var(--text);
        border-color: rgba(177,58,52,0.45);
      }
      .stage__gallery[hidden] {
        display: none;
      }

      .stage__view-btn {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(232,228,220,0.5);
        width: 38px; height: 38px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; border-radius: 2px;
        transition: background 0.2s, color 0.2s, border-color 0.2s;
      }
      .stage__view-btn svg {
        width: 16px;
        height: 16px;
      }
      .stage__view-btn:hover,
      .stage__view-btn[aria-pressed="true"] {
        background: rgba(177,58,52,0.15);
        color: var(--text);
        border-color: rgba(177,58,52,0.45);
      }

      /* dot navigator */
      .stage__dots {
        position: absolute; right: 22px; top: 50%;
        transform: translateY(-50%);
        z-index: 10;
        display: flex; flex-direction: column; gap: 10px;
        align-items: center;
      }
      .stage__dot {
        border: none; padding: 0; cursor: pointer;
        background: rgba(255,255,255,0.18);
        border-radius: 2px; width: 3px; height: 14px;
        transition: height 0.35s cubic-bezier(0.16,1,0.3,1), background 0.3s ease;
      }
      .stage__dot.is-active {
        background: var(--crimson);
        height: 30px;
      }

      /* redacted stamp */
      .stage__stamp {
        position: absolute; bottom: 52px; right: 80px;
        z-index: 5; pointer-events: none;
        transform: rotate(-18deg);
        user-select: none;
        transition: opacity 0.7s ease 0.5s;
      }
      .stage__stamp.is-out { opacity: 0; }
      .stage__stamp.is-in  { opacity: 0.06; }
      .stage__stamp-inner {
        border: 2px solid var(--crimson);
        padding: 6px 16px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px; letter-spacing: 0.32em;
        color: var(--crimson); font-weight: 700;
        text-transform: uppercase; white-space: nowrap;
      }

      /* â”€â”€ Mobile filmstrip â”€â”€ */
      .filmstrip {
        display: none;
      }

      .stage--ui-hidden .stage__top,
      .stage--ui-hidden .stage__bottom,
      .stage--ui-hidden .stage__dots,
      .stage--ui-hidden .stage__stamp,
      .stage--ui-hidden .stage__watermark,
      .stage--ui-hidden .stage__grad-r,
      .stage--ui-hidden .stage__grad-b,
      .stage--ui-hidden .stage__grad-t,
      .stage--ui-hidden .stage__scanlines {
        opacity: 0;
        pointer-events: none;
      }

      @media (max-width: 768px) {
        html, body { overflow: auto; }
        .sidebar { display: none; }
        .chars-root { flex-direction: column; height: auto; min-height: calc(100dvh - 56px); }
        .stage {
          flex: none;
          height: calc(100dvh - 56px - 88px);
          min-height: 420px;
          touch-action: pan-y;
        }
        .nav { padding: 0 12px; }
        .nav__right { gap: 8px; }
        .nav__crumb { display: none; }
        .nav__fullscreen-btn,
        .nav__search-btn {
          width: 38px;
          height: 38px;
        }
        .stage__top { padding: 14px 18px; }
        .stage__counter-num { font-size: 22px; }
        .stage__bottom {
          left: 0;
          right: 0;
          padding: 0 20px 24px;
        }
        .stage__name { font-size: clamp(38px, 9vw, 56px); }
        .stage__designation { font-size: 11px; margin-bottom: 12px; }
        .stage__summary {
          font-size: 13px;
          margin: 0 0 18px;
          -webkit-line-clamp: 2;
        }
        .stage__actions { gap: 8px; flex-wrap: wrap; }
        .stage__cta { flex: 1; padding: 11px 16px; min-width: 140px; text-align: center; }
        .stage__view-btn { width: 40px; height: 40px; }
        .stage__dots { display: none; }
        .stage__watermark { display: none; }
        .stage__stamp { display: none; }
        .stage__type-label { font-size: 9px; margin-bottom: 8px; }

        /* Filmstrip thumbnail row */
        .filmstrip {
          display: flex;
          gap: 6px;
          padding: 10px 12px calc(14px + env(safe-area-inset-bottom));
          overflow-x: auto;
          background: rgba(5,5,10,0.95);
          border-top: 1px solid rgba(255,255,255,0.06);
          flex-shrink: 0;
          scrollbar-width: none;
          -webkit-overflow-scrolling: touch;
        }
        .filmstrip::-webkit-scrollbar { display: none; }
        .filmstrip__item {
          position: relative;
          width: 50px; height: 64px;
          flex-shrink: 0;
          border-radius: 3px; overflow: hidden;
          border: 1px solid rgba(255,255,255,0.08);
          background: rgba(10,10,18,0.8);
          padding: 0; cursor: pointer;
          opacity: 0.5;
          transform: scale(1);
          transition: border-color 0.2s, opacity 0.2s, transform 0.2s;
        }
        .filmstrip__item.is-active {
          border-color: var(--crimson);
          opacity: 1;
          transform: scale(1.06);
        }
        .filmstrip__item img {
          width: 100%; height: 100%;
          object-fit: cover; object-position: center 20%;
        }
        .filmstrip__item-fallback {
          width: 100%; height: 100%;
          background: rgba(177,58,52,0.12);
          display: flex; align-items: center; justify-content: center;
          font-family: 'Cormorant Garamond', serif;
          font-size: 13px; font-weight: 700;
          color: rgba(177,58,52,0.55);
        }
        .filmstrip__item.is-active::after {
          content: "";
          position: absolute; bottom: 0; left: 0; right: 0;
          height: 2px; background: var(--crimson);
        }

      }
    </style>
  </head>
  <body>
    <!-- NAV -->
    <nav class="nav">
      <a class="nav__logo" href={localizedPath(locale, "/")}>
        <img src="/uploads/ui-sine-logo.png" alt="SiNE" class="nav__logo-img" />
        <span class="nav__logo-text">{copy.logo}</span>
      </a>
      <div class="nav__right">
        <span class="nav__crumb">
          <a class="nav__crumb-link" href={localizedPath(locale, "/")}>{copy.index}</a>
          <span class="nav__crumb-sep">></span>
          <span class="nav__crumb-cur">{copy.section}</span>
        </span>
        <MusicPlayer locale={locale} />
        <button
          class="nav__fullscreen-btn"
          id="nav-fullscreen"
          type="button"
          aria-label={copy.fullscreen}
          title={copy.fullscreen}
          data-enter-label={copy.fullscreen}
          data-exit-label={copy.exitFullscreen}
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2.5 6V2.5H6M10 2.5h3.5V6M13.5 10v3.5H10M6 13.5H2.5V10" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <a class="nav__search-btn" href={localizedPath(locale, "/search/")} aria-label={copy.search}>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.4"/>
            <line x1="10" y1="10" x2="14" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </a>
      </div>
    </nav>

    <!-- MAIN -->
    <div class="chars-root" id="chars-root">

      <!-- LEFT SIDEBAR -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar__head">
          <div class="sidebar__eyebrow" id="sidebar-eyebrow">{sectionEyebrow}</div>
          <div class="sidebar__title">{copy.section}</div>
          <div class="sidebar__desc">{copy.sectionDesc}</div>
          <div class="sidebar__search">
            <span class="sidebar__search-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.4"/>
                <line x1="10" y1="10" x2="14" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
            </span>
            <input
              class="sidebar__search-input"
              id="sidebar-search"
              type="search"
              placeholder={copy.searchPlaceholder}
              autocomplete="off"
              spellcheck="false"
            />
            <button class="sidebar__search-clear" id="sidebar-search-clear" aria-label={copy.clearSearch}>x</button>
          </div>
        </div>
        <div class="sidebar__divider"></div>
        <div class="sidebar__no-results" id="sidebar-no-results">{copy.noResults}</div>
        <div class="sidebar__list" id="sidebar-list">
          {charData.map((c, i) => (
            <button
              class={`sidebar__item${i === 0 ? " is-active" : ""}`}
              data-idx={i}
              id={`sidebar-item-${i}`}
            >
              <div class="sidebar__item-num">
                <span>{String(i + 1).padStart(2, "0")}</span>
                {i === 0 && <span class="sidebar__item-num-line"></span>}
              </div>
              <div class="sidebar__item-name">{c.title}</div>
              {c.designation && (
                <div class="sidebar__item-des">
                  {c.designation}
                </div>
              )}
            </button>
          ))}
        </div>
        <div class="sidebar__footer">
          <div class="sidebar__stamp">
            {copy.filingYear}<br />
            <span class="sidebar__stamp-accent">{copy.accessLevel}</span>
          </div>
        </div>
      </aside>

      <!-- STAGE -->
      <div class="stage" id="stage">

        <!-- Portrait layer -->
        <div class="stage__portrait is-in" id="stage-portrait">
          {charData[0].images[0] ? (
            <picture id="stage-picture">
              {charData[0].images[0].avifSrcset && (
                <source
                  id="stage-source-avif"
                  srcset={charData[0].images[0].avifSrcset}
                  sizes={charData[0].images[0].sizes}
                  type="image/avif"
                />
              )}
              {charData[0].images[0].webpSrcset && (
                <source
                  id="stage-source-webp"
                  srcset={charData[0].images[0].webpSrcset}
                  sizes={charData[0].images[0].sizes}
                  type="image/webp"
                />
              )}
              <img
                class="stage__portrait-img"
                id="stage-img"
                src={charData[0].images[0].fallbackSrc}
                srcset={charData[0].images[0].fallbackSrcset || undefined}
                sizes={charData[0].images[0].sizes}
                width={charData[0].images[0].width || undefined}
                height={charData[0].images[0].height || undefined}
                alt=""
                loading="eager"
                decoding="async"
                style="transform: scale(1.07) translate(0%, 0%)"
              />
            </picture>
          ) : (
            <svg
              id="stage-placeholder"
              class="stage__placeholder"
              viewBox="0 0 900 1000"
              preserveAspectRatio="xMidYMid slice"
              xmlns="http://www.w3.org/2000/svg"
            >
              <defs>
                <radialGradient id="rg-ph" cx="50%" cy="38%" r="55%">
                  <stop offset="0%" stop-color="rgba(177,58,52,0.18)" />
                  <stop offset="100%" stop-color="rgba(6,6,11,0)" />
                </radialGradient>
              </defs>
              <rect width="900" height="1000" fill="#06060b" />
              <rect width="900" height="1000" fill="url(#rg-ph)" />
              {Array.from({ length: 50 }).map((_, i) => (
                <line x1="0" y1={i * 20} x2="900" y2={i * 20}
                  stroke="rgba(255,255,255,0.012)" stroke-width="1" />
              ))}
              {[60, 130, 210, 300, 400].map(r => (
                <circle cx="450" cy="380" r={r} fill="none"
                  stroke="rgba(255,255,255,0.035)" stroke-width="1" />
              ))}
              <line x1="450" y1="200" x2="450" y2="560" stroke="rgba(177,58,52,0.18)" stroke-width="0.8" />
              <line x1="270" y1="380" x2="630" y2="380" stroke="rgba(177,58,52,0.18)" stroke-width="0.8" />
              <path d="M310 240 L310 268 L338 268" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5" />
              <path d="M590 240 L590 268 L562 268" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5" />
              <path d="M310 520 L310 492 L338 492" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5" />
              <path d="M590 520 L590 492 L562 492" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5" />
              <circle cx="450" cy="342" r="52" fill="rgba(255,255,255,0.025)" stroke="rgba(255,255,255,0.055)" stroke-width="1" />
              <path d="M338 510 Q338 456 450 456 Q562 456 562 510" fill="rgba(255,255,255,0.025)" stroke="rgba(255,255,255,0.055)" stroke-width="1" />
              <text x="450" y="580" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" letter-spacing="6" fill="rgba(177,58,52,0.35)">{copy.portraitClassified}</text>
              <text x="450" y="596" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" letter-spacing="4" fill="rgba(255,255,255,0.1)">{copy.fileSealed}</text>
            </svg>
          )}
        </div>

        <!-- Gradient layers -->
        <div class="stage__grad-r"></div>
        <div class="stage__grad-b"></div>
        <div class="stage__grad-t"></div>
        <div class="stage__scanlines"></div>

        <!-- Watermark -->
        <div class="stage__watermark is-in" id="stage-watermark">
          {charData[0].title.split(" ").map((word) => (
            <div class="stage__watermark-word">{word}</div>
          ))}
        </div>

        <!-- Top row -->
        <div class="stage__top">
          <div class="stage__counter is-in" id="stage-counter">
            <span class="stage__counter-num" id="stage-counter-num">01</span>
            <span style="font-size:10px">/ {String(charData.length).padStart(2, "0")}</span>
          </div>
          <div class="stage__tags is-in" id="stage-tags">
            {charData[0].tags.slice(0, 3).map((t) => (
              <span class="stage__tag">{t}</span>
            ))}
          </div>
        </div>

        <!-- Bottom content -->
        <div class="stage__bottom">
          <div class="stage__rule is-in" id="stage-rule"></div>

          <div class="stage__type-label is-in" id="stage-type">
            {charData[0].type} - {copy.filed} {charData[0].updated}
          </div>

          <h1 class="stage__name is-in" id="stage-name">{charData[0].title}</h1>

          <div class="stage__designation is-in" id="stage-designation">
            {charData[0].designation}
          </div>

          <p class="stage__summary is-in" id="stage-summary">{charData[0].summary}</p>

          <div class="stage__actions is-in" id="stage-actions">
            <a class="stage__cta" id="stage-cta" href={charData[0].href}>{copy.openDossier}</a>
            <div class="stage__gallery" id="stage-gallery" hidden={charData[0].images.length < 2}>
              <div class="stage__gallery-count">
                <span id="stage-gallery-current">01</span>
                <span>&nbsp;/&nbsp;</span>
                <span id="stage-gallery-total">{String(Math.max(charData[0].images.length, 1)).padStart(2, "0")}</span>
              </div>
              <button
                class="stage__gallery-btn"
                id="stage-gallery-next"
                type="button"
                aria-label={copy.nextImage}
                title={copy.nextImage}
              >
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M5 3.25L8.75 7L5 10.75" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <button
              class="stage__view-btn"
              id="btn-stage-ui-toggle"
              type="button"
              aria-pressed="false"
              aria-label={copy.hideOverlay}
              title={copy.hideOverlay}
            >
              <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2.5 6V2.5H6M10 2.5h3.5V6M13.5 10v3.5H10M6 13.5H2.5V10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
        </div>

        <!-- Dot navigator -->
        <div class="stage__dots" id="stage-dots">
          {charData.map((_, i) => (
            <button
              class={`stage__dot${i === 0 ? " is-active" : ""}`}
              data-idx={i}
              id={`dot-${i}`}
              title={charData[i].title}
            ></button>
          ))}
        </div>

        <!-- Stamp -->
        <div class="stage__stamp is-in" id="stage-stamp">
          <div class="stage__stamp-inner">{copy.dossierOnFile}</div>
        </div>

      </div>

      <!-- Mobile filmstrip -->
      <div class="filmstrip" id="filmstrip">
        {charData.map((c, i) => (
          <button
            class={`filmstrip__item${i === 0 ? " is-active" : ""}`}
            data-idx={i}
            aria-label={c.title}
          >
            {c.thumbImage ? (
              <picture>
                {c.thumbImage.avifSrcset && (
                  <source srcset={c.thumbImage.avifSrcset} sizes={c.thumbImage.sizes} type="image/avif" />
                )}
                {c.thumbImage.webpSrcset && (
                  <source srcset={c.thumbImage.webpSrcset} sizes={c.thumbImage.sizes} type="image/webp" />
                )}
                <img
                  src={c.thumbImage.fallbackSrc}
                  srcset={c.thumbImage.fallbackSrcset || undefined}
                  sizes={c.thumbImage.sizes}
                  width={c.thumbImage.width || undefined}
                  height={c.thumbImage.height || undefined}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
              </picture>
            ) : (
              <div class="filmstrip__item-fallback">{String(i + 1).padStart(2, "0")}</div>
            )}
          </button>
        ))}
      </div>
    </div>

    <script define:vars={{ charData, copy }}>
      const chars = charData;
      const charactersInitKey = "__sineCharactersInit";
      const charactersCleanupKey = "__sineCharactersCleanup";
      const charactersBeforeSwapKey = "__sineCharactersBeforeSwap";

      const initializeCharactersPage = () => {
        if (typeof window[charactersCleanupKey] === "function") {
          window[charactersCleanupKey]();
          window[charactersCleanupKey] = null;
        }

        const charsRoot = document.getElementById("chars-root");
        if (!(charsRoot instanceof HTMLElement) || chars.length === 0) {
          return;
        }

        const listenerScope = new AbortController();
        const { signal } = listenerScope;
        const storageKey = `sine:characters:active:${document.documentElement.lang === "pt-BR" ? "pt-br" : "en"}`;
        const params = new URLSearchParams(window.location.search);
        const requestedSlug = params.get("char");
        const storedSlug = sessionStorage.getItem(storageKey);
        const initialSlug = requestedSlug || storedSlug;
        const initialIdx = Math.max(0, chars.findIndex((char) => char.slug === initialSlug));

        let activeIdx = initialIdx;
        let activeGalleryIdx = 0;
        let switchTimer = 0;
        let galleryTimer = 0;
        let galleryTransitionTimer = 0;
        let phaseTimer = 0;
        let filmstripObserver = null;
        let touchStartX = null;
        let touchStartY = null;
        let isOverlayHidden = false;

        window[charactersCleanupKey] = () => {
          listenerScope.abort();
          window.clearTimeout(switchTimer);
          window.clearTimeout(galleryTimer);
          window.clearTimeout(galleryTransitionTimer);
          window.clearTimeout(phaseTimer);
          filmstripObserver?.disconnect();
          filmstripObserver = null;
        };

        const stagePortrait = charsRoot.querySelector("#stage-portrait");
        const stageWatermark = charsRoot.querySelector("#stage-watermark");
        const stageCounter = charsRoot.querySelector("#stage-counter");
        const stageCounterNum = charsRoot.querySelector("#stage-counter-num");
        const stageTags = charsRoot.querySelector("#stage-tags");
        const stageRule = charsRoot.querySelector("#stage-rule");
        const stageType = charsRoot.querySelector("#stage-type");
        const stageName = charsRoot.querySelector("#stage-name");
        const stageDesignation = charsRoot.querySelector("#stage-designation");
        const stageSummary = charsRoot.querySelector("#stage-summary");
        const stageActions = charsRoot.querySelector("#stage-actions");
        const stageCta = charsRoot.querySelector("#stage-cta");
        const stageGallery = charsRoot.querySelector("#stage-gallery");
        const stageGalleryCurrent = charsRoot.querySelector("#stage-gallery-current");
        const stageGalleryTotal = charsRoot.querySelector("#stage-gallery-total");
        const stageGalleryNext = charsRoot.querySelector("#stage-gallery-next");
        const stageStamp = charsRoot.querySelector("#stage-stamp");
        const stageRoot = charsRoot.querySelector("#stage");
        const stageUiToggle = charsRoot.querySelector("#btn-stage-ui-toggle");
        const sidebarList = charsRoot.querySelector("#sidebar-list");
        const dotsEl = charsRoot.querySelector("#stage-dots");
        const searchInput = charsRoot.querySelector("#sidebar-search");
        const searchClear = charsRoot.querySelector("#sidebar-search-clear");
        const noResults = charsRoot.querySelector("#sidebar-no-results");
        const filmstrip = charsRoot.querySelector("#filmstrip");
        const fullscreenBtn = document.getElementById("nav-fullscreen");
        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const sidebarItems = Array.from(charsRoot.querySelectorAll(".sidebar__item"));
        const allAnimated = [stageCounter, stageTags, stageRule, stageType, stageName, stageDesignation, stageSummary, stageActions, stageWatermark, stageStamp, stagePortrait];

        if (!(stageRoot instanceof HTMLElement) || !(stagePortrait instanceof HTMLElement)) {
          return;
        }

        if (fullscreenBtn) {
          const enterLabel = fullscreenBtn.dataset.enterLabel || "Full screen";
          const exitLabel = fullscreenBtn.dataset.exitLabel || "Exit full screen";

          if (!document.documentElement.requestFullscreen) {
            fullscreenBtn.hidden = true;
          } else {
            const syncFullscreen = () => {
              const active = !!document.fullscreenElement;
              const label = active ? exitLabel : enterLabel;
              fullscreenBtn.setAttribute("aria-label", label);
              fullscreenBtn.setAttribute("title", label);
              fullscreenBtn.classList.toggle("is-active", active);
            };

            fullscreenBtn.addEventListener("click", async () => {
              try {
                if (document.fullscreenElement) {
                  await document.exitFullscreen();
                } else {
                  await document.documentElement.requestFullscreen();
                }
              } catch {
                syncFullscreen();
              }
            }, { signal });

            document.addEventListener("fullscreenchange", syncFullscreen, { signal });
            syncFullscreen();
          }
        }

        function setPhase(phase) {
          const inClass = "is-in";
          const outClass = "is-out";
          allAnimated.forEach((el) => {
            if (!el) return;
            if (phase === "in") {
              el.classList.remove(outClass);
              el.classList.add(inClass);
            } else {
              el.classList.remove(inClass);
              el.classList.add(outClass);
            }
          });
        }

        function syncOverlayToggle() {
          if (!stageUiToggle) return;
          const label = isOverlayHidden ? copy.showOverlay : copy.hideOverlay;
          stageUiToggle.setAttribute("aria-pressed", String(isOverlayHidden));
          stageUiToggle.setAttribute("aria-label", label);
          stageUiToggle.setAttribute("title", label);
          stageRoot.classList.toggle("stage--ui-hidden", isOverlayHidden);
          stageRoot.setAttribute("title", isOverlayHidden ? copy.restoreOverlay : "");
        }

        function toggleOverlay(force) {
          isOverlayHidden = typeof force === "boolean" ? force : !isOverlayHidden;
          syncOverlayToggle();
        }

        function buildPlaceholderSVG() {
          const ns = "http://www.w3.org/2000/svg";
          const svg = document.createElementNS(ns, "svg");
          svg.setAttribute("viewBox", "0 0 900 1000");
          svg.setAttribute("preserveAspectRatio", "xMidYMid slice");
          svg.setAttribute("class", "stage__placeholder");
          svg.style.position = "absolute";
          svg.style.inset = "0";
          svg.innerHTML = `
            <defs>
              <radialGradient id="rg-dyn" cx="50%" cy="38%" r="55%">
                <stop offset="0%" stop-color="rgba(177,58,52,0.18)"/>
                <stop offset="100%" stop-color="rgba(6,6,11,0)"/>
              </radialGradient>
            </defs>
            <rect width="900" height="1000" fill="#06060b"/>
            <rect width="900" height="1000" fill="url(#rg-dyn)"/>
            ${Array.from({ length: 50 }, (_, i) => `<line x1="0" y1="${i * 20}" x2="900" y2="${i * 20}" stroke="rgba(255,255,255,0.012)" stroke-width="1"/>`).join("")}
            ${[60, 130, 210, 300, 400].map((r) => `<circle cx="450" cy="380" r="${r}" fill="none" stroke="rgba(255,255,255,0.035)" stroke-width="1"/>`).join("")}
            <line x1="450" y1="200" x2="450" y2="560" stroke="rgba(177,58,52,0.18)" stroke-width="0.8"/>
            <line x1="270" y1="380" x2="630" y2="380" stroke="rgba(177,58,52,0.18)" stroke-width="0.8"/>
            <path d="M310 240 L310 268 L338 268" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5"/>
            <path d="M590 240 L590 268 L562 268" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5"/>
            <path d="M310 520 L310 492 L338 492" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5"/>
            <path d="M590 520 L590 492 L562 492" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5"/>
            <circle cx="450" cy="342" r="52" fill="rgba(255,255,255,0.025)" stroke="rgba(255,255,255,0.055)" stroke-width="1"/>
            <path d="M338 510 Q338 456 450 456 Q562 456 562 510" fill="rgba(255,255,255,0.025)" stroke="rgba(255,255,255,0.055)" stroke-width="1"/>
            <text x="450" y="580" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" letter-spacing="6" fill="rgba(177,58,52,0.35)">{copy.portraitClassified}</text>
            <text x="450" y="596" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" letter-spacing="4" fill="rgba(255,255,255,0.1)">{copy.fileSealed}</text>
          `;
          return svg;
        }

        function buildStagePicture(image) {
          const picture = document.createElement("picture");
          picture.id = "stage-picture";

          if (image.avifSrcset) {
            const sourceAvif = document.createElement("source");
            sourceAvif.id = "stage-source-avif";
            sourceAvif.type = "image/avif";
            sourceAvif.srcset = image.avifSrcset;
            sourceAvif.sizes = image.sizes;
            picture.appendChild(sourceAvif);
          }

          if (image.webpSrcset) {
            const sourceWebp = document.createElement("source");
            sourceWebp.id = "stage-source-webp";
            sourceWebp.type = "image/webp";
            sourceWebp.srcset = image.webpSrcset;
            sourceWebp.sizes = image.sizes;
            picture.appendChild(sourceWebp);
          }

          const img = document.createElement("img");
          img.className = "stage__portrait-img";
          img.id = "stage-img";
          img.src = image.fallbackSrc;
          if (image.fallbackSrcset) img.srcset = image.fallbackSrcset;
          img.sizes = image.sizes;
          if (image.width) img.width = image.width;
          if (image.height) img.height = image.height;
          img.alt = "";
          img.decoding = "async";
          img.style.transform = "scale(1.07) translate(0%, 0%)";
          picture.appendChild(img);

          return picture;
        }

        function syncGalleryUi(char = chars[activeIdx]) {
          const total = char?.images.length || 0;
          if (stageGallery) stageGallery.hidden = total < 2;
          if (stageGalleryCurrent) {
            stageGalleryCurrent.textContent = String(activeGalleryIdx + 1).padStart(2, "0");
          }
          if (stageGalleryTotal) {
            stageGalleryTotal.textContent = String(Math.max(total, 1)).padStart(2, "0");
          }
        }

        function scheduleGallery() {
          window.clearTimeout(galleryTimer);
          const char = chars[activeIdx];
          if (!char || reducedMotion || char.images.length < 2) return;
          galleryTimer = window.setTimeout(() => {
            cycleGalleryImage();
          }, 5000);
        }

        function renderGalleryImage(image) {
          const existing = stagePortrait.querySelector("picture, svg");
          if (existing) existing.remove();
          if (image) {
            stagePortrait.appendChild(buildStagePicture(image));
          } else {
            stagePortrait.appendChild(buildPlaceholderSVG());
          }
        }

        function cycleGalleryImage(nextIdx) {
          const char = chars[activeIdx];
          if (!char || char.images.length < 2) return;
          window.clearTimeout(galleryTimer);
          window.clearTimeout(galleryTransitionTimer);
          activeGalleryIdx = typeof nextIdx === "number"
            ? ((nextIdx % char.images.length) + char.images.length) % char.images.length
            : (activeGalleryIdx + 1) % char.images.length;
          stagePortrait.classList.remove("is-in");
          stagePortrait.classList.add("is-out");
          galleryTransitionTimer = window.setTimeout(() => {
            renderGalleryImage(char.images[activeGalleryIdx]);
            syncGalleryUi(char);
            requestAnimationFrame(() => {
              if (signal.aborted) return;
              stagePortrait.classList.remove("is-out");
              stagePortrait.classList.add("is-in");
            });
            scheduleGallery();
          }, 320);
        }

        function updateContent(idx) {
          const c = chars[idx];
          if (!c) return;

          activeIdx = idx;
          activeGalleryIdx = 0;
          window.clearTimeout(galleryTimer);
          window.clearTimeout(galleryTransitionTimer);

          renderGalleryImage(c.images[activeGalleryIdx]);
          syncGalleryUi(c);
          scheduleGallery();

          if (stageWatermark) {
            stageWatermark.innerHTML = c.title.split(" ")
              .map((word) => `<div class="stage__watermark-word">${word}</div>`)
              .join("");
          }

          if (stageCounterNum) {
            stageCounterNum.textContent = String(idx + 1).padStart(2, "0");
          }

          if (stageTags) {
            stageTags.innerHTML = c.tags.slice(0, 3)
              .map((tag) => `<span class="stage__tag">${tag}</span>`)
              .join("");
          }

          if (stageType) stageType.textContent = `${c.type} - ${copy.filed} ${c.updated}`;
          if (stageName) stageName.textContent = c.title;
          if (stageDesignation) {
            stageDesignation.textContent = c.designation;
            stageDesignation.style.display = c.designation ? "" : "none";
          }
          if (stageSummary) stageSummary.textContent = c.summary;
          if (stageCta instanceof HTMLAnchorElement) stageCta.href = c.href;
          sessionStorage.setItem(storageKey, c.slug);

          const next = new URL(window.location.href);
          next.searchParams.set("char", c.slug);
          history.replaceState(history.state || {}, "", next);

          charsRoot.querySelectorAll(".sidebar__item").forEach((el, itemIdx) => {
            const isActive = itemIdx === idx;
            el.classList.toggle("is-active", isActive);
            const numEl = el.querySelector(".sidebar__item-num");
            if (!(numEl instanceof HTMLElement)) return;
            let line = numEl.querySelector(".sidebar__item-num-line");
            if (isActive && !line) {
              line = document.createElement("span");
              line.className = "sidebar__item-num-line";
              numEl.appendChild(line);
            } else if (!isActive && line) {
              line.remove();
            }
          });

          charsRoot.querySelectorAll(".stage__dot").forEach((el, dotIdx) => {
            el.classList.toggle("is-active", dotIdx === idx);
          });
        }

        function switchTo(idx) {
          if (!Number.isInteger(idx) || idx < 0 || idx >= chars.length || idx === activeIdx) return;
          window.clearTimeout(switchTimer);
          window.clearTimeout(phaseTimer);
          setPhase("out");
          switchTimer = window.setTimeout(() => {
            updateContent(idx);
            phaseTimer = window.setTimeout(() => {
              setPhase("in");
            }, 60);
          }, 360);
        }

        function applySearch(query) {
          const q = query.trim().toLowerCase();
          let anyVisible = false;
          sidebarItems.forEach((item) => {
            const idx = parseInt(item.dataset.idx || "-1", 10);
            const c = chars[idx];
            if (!c) return;
            const hit = !q ||
              c.title.toLowerCase().includes(q) ||
              (c.designation && c.designation.toLowerCase().includes(q)) ||
              (c.type && c.type.toLowerCase().includes(q));
            item.style.display = hit ? "" : "none";
            if (hit) anyVisible = true;
          });
          noResults?.classList.toggle("is-visible", !anyVisible);
          searchClear?.classList.toggle("is-visible", q.length > 0);
        }

        stageRoot.addEventListener("mousemove", (event) => {
          const rect = stageRoot.getBoundingClientRect();
          const x = (event.clientX - rect.left) / rect.width - 0.5;
          const y = (event.clientY - rect.top) / rect.height - 0.5;
          const img = stagePortrait.querySelector("img");
          if (img) {
            img.style.transform = `scale(1.07) translate(${x * -3.5}%, ${y * -2.5}%)`;
          }
        }, { signal });

        stageUiToggle?.addEventListener("click", (event) => {
          event.stopPropagation();
          toggleOverlay();
        }, { signal });

        stageRoot.addEventListener("click", (event) => {
          if (!isOverlayHidden) return;
          if (event.target instanceof Element && event.target.closest("#btn-stage-ui-toggle, #stage-cta, #stage-dots, #stage-gallery-next")) return;
          toggleOverlay(false);
        }, { signal });

        stageGalleryNext?.addEventListener("click", (event) => {
          event.stopPropagation();
          cycleGalleryImage();
        }, { signal });

        sidebarList?.addEventListener("click", (event) => {
          const btn = event.target instanceof Element ? event.target.closest(".sidebar__item") : null;
          if (btn instanceof HTMLElement) {
            switchTo(parseInt(btn.dataset.idx || "-1", 10));
          }
        }, { signal });

        dotsEl?.addEventListener("click", (event) => {
          const btn = event.target instanceof Element ? event.target.closest(".stage__dot") : null;
          if (btn instanceof HTMLElement) {
            switchTo(parseInt(btn.dataset.idx || "-1", 10));
          }
        }, { signal });

        searchInput?.addEventListener("input", () => {
          applySearch(searchInput.value);
        }, { signal });

        searchClear?.addEventListener("click", () => {
          if (!searchInput) return;
          searchInput.value = "";
          applySearch("");
          searchInput.focus();
        }, { signal });

        filmstrip?.addEventListener("click", (event) => {
          const btn = event.target instanceof Element ? event.target.closest(".filmstrip__item") : null;
          if (btn instanceof HTMLElement) {
            switchTo(parseInt(btn.dataset.idx || "-1", 10));
          }
        }, { signal });

        if (filmstrip && dotsEl) {
          filmstripObserver = new MutationObserver(() => {
            const activeDot = dotsEl.querySelector(".stage__dot.is-active");
            const idx = activeDot instanceof HTMLElement ? parseInt(activeDot.dataset.idx || "0", 10) : 0;
            filmstrip.querySelectorAll(".filmstrip__item").forEach((el, itemIdx) => {
              el.classList.toggle("is-active", itemIdx === idx);
            });
            const active = filmstrip.querySelector(".filmstrip__item.is-active");
            active?.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
          });
          filmstripObserver.observe(dotsEl, { subtree: true, attributes: true, attributeFilter: ["class"] });
        }

        stageRoot.addEventListener("touchstart", (event) => {
          touchStartX = event.touches[0].clientX;
          touchStartY = event.touches[0].clientY;
        }, { passive: true, signal });

        stageRoot.addEventListener("touchend", (event) => {
          if (touchStartX === null) return;
          const dx = event.changedTouches[0].clientX - touchStartX;
          const dy = event.changedTouches[0].clientY - touchStartY;
          if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
            if (dx < 0) switchTo((activeIdx + 1) % chars.length);
            else switchTo((activeIdx - 1 + chars.length) % chars.length);
          }
          touchStartX = null;
          touchStartY = null;
        }, { passive: true, signal });

        syncOverlayToggle();
        if (initialIdx !== 0) {
          updateContent(initialIdx);
        } else {
          sessionStorage.setItem(storageKey, chars[0].slug);
          syncGalleryUi(chars[0]);
          scheduleGallery();
        }
        applySearch(searchInput?.value || "");
      };

      if (!window[charactersInitKey]) {
        window[charactersInitKey] = initializeCharactersPage;
        document.addEventListener("astro:page-load", window[charactersInitKey]);
      }

      if (!window[charactersBeforeSwapKey]) {
        window[charactersBeforeSwapKey] = () => {
          if (typeof window[charactersCleanupKey] === "function") {
            window[charactersCleanupKey]();
            window[charactersCleanupKey] = null;
          }
        };
        document.addEventListener("astro:before-swap", window[charactersBeforeSwapKey]);
      }

      window[charactersInitKey]();
    </script>
  </body>
</html>

