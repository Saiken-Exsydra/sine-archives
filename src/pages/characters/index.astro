---
import { getCollection } from "astro:content";

const all = await getCollection("characters");
const characters = all
  .filter((e) => e.data.status === "public")
  .sort((a, b) => {
    const pa = (a.data as any).priority ?? Infinity;
    const pb = (b.data as any).priority ?? Infinity;
    if (pa !== pb) return pa - pb;
    return a.data.title.localeCompare(b.data.title);
  });

const charData = characters.map((c) => ({
  slug: c.slug,
  title: c.data.title,
  type: c.data.type ?? "Character",
  designation: (c.data as any).designation ?? "",
  summary: c.data.summary,
  image: c.data.hero_image ?? "",
  tags: c.data.tags ?? [],
  updated: c.data.updated,
  href: `/characters/${c.slug}/`,
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Characters — SiNE Archives</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg:         #06060b;
        --surface:    #0a0a14;
        --border:     rgba(255, 255, 255, 0.07);
        --crimson:    #b13a34;
        --gold:       #b08d3c;
        --text:       #e8e4dc;
        --text-muted: rgba(232, 228, 220, 0.55);
        --text-dim:   rgba(232, 228, 220, 0.3);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        height: 100%;
        overflow: hidden;
        background: var(--bg);
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      ::selection { background: rgba(177, 58, 52, 0.35); color: var(--text); }
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: rgba(177, 58, 52, 0.3); border-radius: 2px; }

      button { font-family: inherit; }
      img { display: block; }

      /* ── NAV ── */
      .nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 32px;
        background: rgba(6, 6, 11, 0.88);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }
      .nav__logo {
        display: flex; align-items: center; gap: 10px;
        text-decoration: none; flex-shrink: 0;
      }
      .nav__logo-img { height: 26px; opacity: 0.9; }
      .nav__logo-text {
        font-family: 'DM Sans', sans-serif;
        font-size: 10px; font-weight: 600;
        letter-spacing: 0.22em;
        color: rgba(232, 228, 220, 0.45);
        text-transform: uppercase;
      }
      .nav__right {
        display: flex; align-items: center; gap: 16px;
      }
      .nav__crumb {
        display: flex; align-items: center; gap: 6px;
        font-family: 'DM Sans', sans-serif;
        font-size: 12px; letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .nav__crumb-link {
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.2s;
        font-size: 12px;
        letter-spacing: 0.08em;
        font-family: 'DM Sans', sans-serif;
        text-transform: uppercase;
      }
      .nav__crumb-link:hover { color: var(--text-muted); }
      .nav__crumb-sep { color: var(--crimson); font-size: 14px; }
      .nav__crumb-cur { color: var(--text-dim); font-size: 12px; }
      .nav__search-btn {
        display: flex; align-items: center; justify-content: center;
        width: 34px; height: 34px;
        color: rgba(232, 228, 220, 0.5);
        text-decoration: none; transition: color 0.2s;
        flex-shrink: 0;
      }
      .nav__search-btn:hover { color: rgba(232, 228, 220, 0.9); }

      /* ── LAYOUT ── */
      .chars-root {
        display: flex;
        height: 100vh;
        padding-top: 56px;
        background: var(--bg);
        overflow: hidden;
        position: relative;
      }

      /* ── LEFT SIDEBAR ── */
      .sidebar {
        width: 310px;
        flex-shrink: 0;
        border-right: 1px solid rgba(255, 255, 255, 0.06);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: rgba(5, 5, 10, 0.7);
        position: relative;
        z-index: 20;
      }

      .sidebar__head {
        padding: 36px 32px 24px;
      }
      .sidebar__eyebrow {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px; font-weight: 600;
        letter-spacing: 0.28em;
        color: var(--crimson);
        text-transform: uppercase;
        margin-bottom: 10px;
      }
      .sidebar__title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 40px; font-weight: 700;
        color: var(--text);
        line-height: 1; letter-spacing: 0.01em;
      }
      .sidebar__desc {
        margin-top: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        color: var(--text-muted);
        line-height: 1.65;
      }

      .sidebar__search {
        margin-top: 18px;
        position: relative;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .sidebar__search-icon {
        flex-shrink: 0;
        color: rgba(232, 228, 220, 0.18);
        pointer-events: none;
        display: flex;
        transition: color 0.3s;
      }
      .sidebar__search:hover .sidebar__search-icon,
      .sidebar__search:focus-within .sidebar__search-icon {
        color: rgba(232, 228, 220, 0.35);
      }
      .sidebar__search-input {
        flex: 1;
        background: transparent;
        border: none;
        border-bottom: 1px solid transparent;
        outline: none;
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        letter-spacing: 0.05em;
        padding: 8px 24px 8px 0;
        transition: border-color 0.3s;
        caret-color: var(--crimson);
      }
      .sidebar__search-input::placeholder {
        color: transparent;
        transition: color 0.3s;
        letter-spacing: 0.12em;
        font-size: 10px;
        text-transform: uppercase;
      }
      .sidebar__search:hover .sidebar__search-input::placeholder,
      .sidebar__search:focus-within .sidebar__search-input::placeholder {
        color: rgba(232, 228, 220, 0.2);
      }
      .sidebar__search:hover .sidebar__search-input,
      .sidebar__search-input:focus {
        border-bottom-color: rgba(255, 255, 255, 0.1);
      }
      .sidebar__search-input:focus {
        border-bottom-color: rgba(177, 58, 52, 0.4);
      }
      .sidebar__search-clear {
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(232, 228, 220, 0.25);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        display: none;
        align-items: center;
        line-height: 1;
        font-size: 14px;
        transition: color 0.2s;
      }
      .sidebar__search-clear:hover { color: var(--crimson); }
      .sidebar__search-clear.is-visible { display: flex; }

      .sidebar__no-results {
        padding: 24px 32px;
        font-family: 'DM Sans', sans-serif;
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(232, 228, 220, 0.18);
        display: none;
      }
      .sidebar__no-results.is-visible { display: block; }

      .sidebar__divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.06);
        margin: 0 32px;
        flex-shrink: 0;
      }

      .sidebar__list {
        overflow-y: auto;
        flex: 1;
        padding-bottom: 16px;
      }

      .sidebar__item {
        background: none;
        border: none;
        border-left: 2px solid transparent;
        padding: 20px 32px;
        cursor: pointer;
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 5px;
        transition: background 0.22s, border-color 0.22s;
        width: 100%;
      }
      .sidebar__item.is-active {
        background: rgba(177, 58, 52, 0.09);
        border-left-color: var(--crimson);
      }

      .sidebar__item-num {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px; font-weight: 600;
        letter-spacing: 0.24em;
        color: rgba(232, 228, 220, 0.2);
        text-transform: uppercase;
        transition: color 0.22s;
        display: flex; align-items: center; gap: 8px;
      }
      .sidebar__item.is-active .sidebar__item-num { color: var(--crimson); }

      .sidebar__item-num-line {
        display: inline-block;
        width: 16px; height: 1px;
        background: var(--crimson);
        vertical-align: middle;
      }

      .sidebar__item-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 22px; font-weight: 700;
        color: rgba(232, 228, 220, 0.42);
        line-height: 1.1; letter-spacing: 0.01em;
        transition: color 0.22s;
      }
      .sidebar__item.is-active .sidebar__item-name { color: var(--text); }

      .sidebar__item-des {
        font-family: 'DM Sans', sans-serif;
        font-size: 10px;
        color: rgba(232, 228, 220, 0.18);
        letter-spacing: 0.04em; line-height: 1.4;
        transition: color 0.22s;
      }
      .sidebar__item.is-active .sidebar__item-des { color: rgba(176, 141, 60, 0.8); }

      .sidebar__footer {
        padding: 18px 32px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        flex-shrink: 0;
      }
      .sidebar__stamp {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px; letter-spacing: 0.16em;
        color: rgba(232, 228, 220, 0.1);
        text-transform: uppercase; line-height: 1.7;
      }
      .sidebar__stamp-accent { color: rgba(177, 58, 52, 0.3); }

      /* ── STAGE ── */
      .stage {
        flex: 1;
        position: relative;
        overflow: hidden;
        background: #06060b;
      }

      .stage__portrait {
        position: absolute; inset: 0;
        transition: opacity 0.55s ease;
      }
      .stage__portrait.is-out { opacity: 0; }
      .stage__portrait.is-in  { opacity: 1; }

      .stage__portrait-img {
        width: 100%; height: 100%;
        object-fit: cover;
        object-position: center 18%;
        filter: saturate(0.85) brightness(1.05);
        will-change: transform;
      }

      .stage__placeholder {
        position: absolute; inset: 0;
      }

      /* gradients */
      .stage__grad-r,
      .stage__grad-b,
      .stage__grad-t {
        position: absolute; inset: 0; z-index: 2; pointer-events: none;
      }
      .stage__grad-r {
        background: linear-gradient(to right, rgba(6,6,11,0.9) 0%, rgba(6,6,11,0.35) 45%, rgba(6,6,11,0.1) 100%);
      }
      .stage__grad-b {
        background: linear-gradient(to top, rgba(6,6,11,1) 0%, rgba(6,6,11,0.75) 22%, rgba(6,6,11,0) 55%);
      }
      .stage__grad-t {
        background: linear-gradient(to bottom, rgba(6,6,11,0.6) 0%, transparent 18%);
      }

      .stage__scanlines {
        position: absolute; inset: 0; z-index: 3; pointer-events: none;
        background-image: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.025) 3px, rgba(0,0,0,0.025) 4px);
      }

      /* watermark */
      .stage__watermark {
        position: absolute; right: 0; top: 0; bottom: 0; left: 0;
        display: flex; flex-direction: column; justify-content: center; align-items: flex-end;
        z-index: 2; pointer-events: none;
        user-select: none;
        line-height: 0.82;
        padding-right: 44px;
        transition: opacity 0.9s ease 0.25s;
      }
      .stage__watermark.is-out { opacity: 0; }
      .stage__watermark.is-in  { opacity: 0.15; }
      .stage__watermark-word {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(64px, 8vw, 110px);
        font-weight: 700;
        color: var(--text);
        white-space: nowrap;
        letter-spacing: -0.03em;
      }

      /* top row */
      .stage__top {
        position: absolute; top: 0; left: 0; right: 0;
        z-index: 10; padding: 28px 40px;
        display: flex; align-items: flex-start; justify-content: space-between;
      }
      .stage__counter {
        font-family: 'DM Sans', sans-serif;
        font-size: 11px; letter-spacing: 0.22em;
        color: rgba(232, 228, 220, 0.18);
        display: flex; align-items: baseline; gap: 8px;
        transition: opacity 0.4s ease 0.2s;
      }
      .stage__counter.is-out { opacity: 0; }
      .stage__counter.is-in  { opacity: 1; }
      .stage__counter-num {
        font-family: 'Cormorant Garamond', serif;
        font-size: 28px; font-weight: 700;
        color: var(--crimson); line-height: 1;
      }

      .stage__tags {
        display: flex; flex-direction: column; gap: 6px; align-items: flex-end;
        transition: opacity 0.4s ease 0.3s;
      }
      .stage__tags.is-out { opacity: 0; }
      .stage__tags.is-in  { opacity: 1; }
      .stage__tag {
        background: rgba(6,6,11,0.72);
        border: 1px solid rgba(255,255,255,0.09);
        padding: 4px 11px;
        font-family: 'DM Sans', sans-serif;
        font-size: 9px; letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(232,228,220,0.4);
        backdrop-filter: blur(10px);
      }

      /* bottom content */
      .stage__bottom {
        position: absolute; bottom: 0; left: 0; right: 60px;
        z-index: 10; padding: 0 64px 52px;
      }

      .stage__rule {
        height: 1px;
        background: var(--crimson);
        margin-bottom: 18px;
        width: 0;
        transition: width 0.5s ease 0.1s;
      }
      .stage__rule.is-in { width: 48px; }

      .stage__type-label {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px; letter-spacing: 0.3em;
        color: var(--crimson); text-transform: uppercase; font-weight: 600;
        margin-bottom: 12px;
        transition: opacity 0.5s ease 0.12s, transform 0.5s ease 0.12s;
      }
      .stage__type-label.is-out { opacity: 0; transform: translateY(14px); }
      .stage__type-label.is-in  { opacity: 1; transform: translateY(0); }

      .stage__name {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(46px, 5.5vw, 84px); font-weight: 700;
        color: var(--text);
        margin: 0 0 14px 0; line-height: 0.92;
        letter-spacing: -0.01em; max-width: 640px;
        transition: opacity 0.55s ease 0.2s, transform 0.55s ease 0.2s;
      }
      .stage__name.is-out { opacity: 0; transform: translateY(18px); }
      .stage__name.is-in  { opacity: 1; transform: translateY(0); }

      .stage__designation {
        font-family: 'DM Sans', sans-serif;
        font-size: 12px; color: var(--gold);
        letter-spacing: 0.08em; margin-bottom: 18px;
        transition: opacity 0.5s ease 0.28s, transform 0.5s ease 0.28s;
      }
      .stage__designation.is-out { opacity: 0; transform: translateY(12px); }
      .stage__designation.is-in  { opacity: 0.82; transform: translateY(0); }

      .stage__summary {
        font-family: 'DM Sans', sans-serif;
        font-size: 14px; color: rgba(232,228,220,0.58);
        line-height: 1.75; margin: 0 0 30px 0; max-width: 500px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: opacity 0.5s ease 0.35s, transform 0.5s ease 0.35s;
      }
      .stage__summary.is-out { opacity: 0; transform: translateY(12px); }
      .stage__summary.is-in  { opacity: 1; transform: translateY(0); }

      .stage__actions {
        display: flex; align-items: center; gap: 14px;
        transition: opacity 0.5s ease 0.43s, transform 0.5s ease 0.43s;
      }
      .stage__actions.is-out { opacity: 0; transform: translateY(10px); }
      .stage__actions.is-in  { opacity: 1; transform: translateY(0); }

      .stage__cta {
        background: var(--crimson); border: none;
        color: var(--text); font-family: 'DM Sans', sans-serif;
        font-size: 10px; font-weight: 600;
        letter-spacing: 0.22em; text-transform: uppercase;
        padding: 12px 28px; border-radius: 2px;
        cursor: pointer; text-decoration: none;
        transition: background 0.2s;
        display: inline-block;
      }
      .stage__cta:hover { background: #c94040; }

      .stage__nav-btn {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(232,228,220,0.5);
        font-family: 'Cormorant Garamond', serif;
        font-size: 18px; width: 38px; height: 38px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; border-radius: 2px;
        transition: background 0.2s, color 0.2s;
      }
      .stage__nav-btn:hover {
        background: rgba(177,58,52,0.15);
        color: var(--text);
      }

      .stage__key-hint {
        font-family: 'DM Sans', sans-serif; font-size: 9px;
        letter-spacing: 0.16em; color: rgba(232,228,220,0.2);
        text-transform: uppercase; margin-left: 4px;
      }

      /* dot navigator */
      .stage__dots {
        position: absolute; right: 22px; top: 50%;
        transform: translateY(-50%);
        z-index: 10;
        display: flex; flex-direction: column; gap: 10px;
        align-items: center;
      }
      .stage__dot {
        border: none; padding: 0; cursor: pointer;
        background: rgba(255,255,255,0.18);
        border-radius: 2px; width: 3px; height: 14px;
        transition: height 0.35s cubic-bezier(0.16,1,0.3,1), background 0.3s ease;
      }
      .stage__dot.is-active {
        background: var(--crimson);
        height: 30px;
      }

      /* redacted stamp */
      .stage__stamp {
        position: absolute; bottom: 52px; right: 80px;
        z-index: 5; pointer-events: none;
        transform: rotate(-18deg);
        user-select: none;
        transition: opacity 0.7s ease 0.5s;
      }
      .stage__stamp.is-out { opacity: 0; }
      .stage__stamp.is-in  { opacity: 0.06; }
      .stage__stamp-inner {
        border: 2px solid var(--crimson);
        padding: 6px 16px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px; letter-spacing: 0.32em;
        color: var(--crimson); font-weight: 700;
        text-transform: uppercase; white-space: nowrap;
      }

      @media (max-width: 768px) {
        .sidebar { display: none; }
        .stage__bottom { left: 0; right: 40px; padding: 0 24px 40px; }
        .stage__name { font-size: clamp(36px, 8vw, 64px); }
        .stage__dots { right: 10px; }
      }
    </style>
  </head>
  <body>
    <!-- NAV -->
    <nav class="nav">
      <a class="nav__logo" href="/">
        <img src="/uploads/SLOGO.png" alt="SiNE" class="nav__logo-img" />
        <span class="nav__logo-text">ARCHIVES</span>
      </a>
      <div class="nav__right">
        <span class="nav__crumb">
          <a class="nav__crumb-link" href="/">Index</a>
          <span class="nav__crumb-sep">›</span>
          <span class="nav__crumb-cur">Characters</span>
        </span>
        <a class="nav__search-btn" href="/search/" aria-label="Search">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.4"/>
            <line x1="10" y1="10" x2="14" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </a>
      </div>
    </nav>

    <!-- MAIN -->
    <div class="chars-root" id="chars-root">

      <!-- LEFT SIDEBAR -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar__head">
          <div class="sidebar__eyebrow" id="sidebar-eyebrow">Section · {charData.length} Dossiers</div>
          <div class="sidebar__title">Characters</div>
          <div class="sidebar__desc">Individuals of note within the Twilight Band and beyond.</div>
          <div class="sidebar__search">
            <span class="sidebar__search-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.4"/>
                <line x1="10" y1="10" x2="14" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
            </span>
            <input
              class="sidebar__search-input"
              id="sidebar-search"
              type="search"
              placeholder="Search dossiers"
              autocomplete="off"
              spellcheck="false"
            />
            <button class="sidebar__search-clear" id="sidebar-search-clear" aria-label="Clear search">×</button>
          </div>
        </div>
        <div class="sidebar__divider"></div>
        <div class="sidebar__no-results" id="sidebar-no-results">No dossiers found</div>
        <div class="sidebar__list" id="sidebar-list">
          {charData.map((c, i) => (
            <button
              class={`sidebar__item${i === 0 ? " is-active" : ""}`}
              data-idx={i}
              id={`sidebar-item-${i}`}
            >
              <div class="sidebar__item-num">
                <span>{String(i + 1).padStart(2, "0")}</span>
                {i === 0 && <span class="sidebar__item-num-line"></span>}
              </div>
              <div class="sidebar__item-name">{c.title}</div>
              {c.designation && (
                <div class="sidebar__item-des">
                  {c.designation.split("·")[0].trim()}
                </div>
              )}
            </button>
          ))}
        </div>
        <div class="sidebar__footer">
          <div class="sidebar__stamp">
            SiNE Archives · Filing Year 1127<br />
            <span class="sidebar__stamp-accent">Access Level: Public</span>
          </div>
        </div>
      </aside>

      <!-- STAGE -->
      <div class="stage" id="stage">

        <!-- Portrait layer -->
        <div class="stage__portrait is-in" id="stage-portrait">
          {charData[0].image ? (
            <img
              class="stage__portrait-img"
              id="stage-img"
              src={charData[0].image}
              alt=""
              style="transform: scale(1.07) translate(0%, 0%)"
            />
          ) : (
            <svg
              id="stage-placeholder"
              class="stage__placeholder"
              viewBox="0 0 900 1000"
              preserveAspectRatio="xMidYMid slice"
              xmlns="http://www.w3.org/2000/svg"
            >
              <defs>
                <radialGradient id="rg-ph" cx="50%" cy="38%" r="55%">
                  <stop offset="0%" stop-color="rgba(177,58,52,0.18)" />
                  <stop offset="100%" stop-color="rgba(6,6,11,0)" />
                </radialGradient>
              </defs>
              <rect width="900" height="1000" fill="#06060b" />
              <rect width="900" height="1000" fill="url(#rg-ph)" />
              {Array.from({ length: 50 }).map((_, i) => (
                <line x1="0" y1={i * 20} x2="900" y2={i * 20}
                  stroke="rgba(255,255,255,0.012)" stroke-width="1" />
              ))}
              {[60, 130, 210, 300, 400].map(r => (
                <circle cx="450" cy="380" r={r} fill="none"
                  stroke="rgba(255,255,255,0.035)" stroke-width="1" />
              ))}
              <line x1="450" y1="200" x2="450" y2="560" stroke="rgba(177,58,52,0.18)" stroke-width="0.8" />
              <line x1="270" y1="380" x2="630" y2="380" stroke="rgba(177,58,52,0.18)" stroke-width="0.8" />
              <path d="M310 240 L310 268 L338 268" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5" />
              <path d="M590 240 L590 268 L562 268" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5" />
              <path d="M310 520 L310 492 L338 492" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5" />
              <path d="M590 520 L590 492 L562 492" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5" />
              <circle cx="450" cy="342" r="52" fill="rgba(255,255,255,0.025)" stroke="rgba(255,255,255,0.055)" stroke-width="1" />
              <path d="M338 510 Q338 456 450 456 Q562 456 562 510" fill="rgba(255,255,255,0.025)" stroke="rgba(255,255,255,0.055)" stroke-width="1" />
              <text x="450" y="580" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" letter-spacing="6" fill="rgba(177,58,52,0.35)">PORTRAIT CLASSIFIED</text>
              <text x="450" y="596" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" letter-spacing="4" fill="rgba(255,255,255,0.1)">SiNE ARCHIVES · FILE SEALED</text>
            </svg>
          )}
        </div>

        <!-- Gradient layers -->
        <div class="stage__grad-r"></div>
        <div class="stage__grad-b"></div>
        <div class="stage__grad-t"></div>
        <div class="stage__scanlines"></div>

        <!-- Watermark -->
        <div class="stage__watermark is-in" id="stage-watermark">
          {charData[0].title.split(" ").map((word) => (
            <div class="stage__watermark-word">{word}</div>
          ))}
        </div>

        <!-- Top row -->
        <div class="stage__top">
          <div class="stage__counter is-in" id="stage-counter">
            <span class="stage__counter-num" id="stage-counter-num">01</span>
            <span style="font-size:10px">/ {String(charData.length).padStart(2, "0")}</span>
          </div>
          <div class="stage__tags is-in" id="stage-tags">
            {charData[0].tags.slice(0, 3).map((t) => (
              <span class="stage__tag">{t}</span>
            ))}
          </div>
        </div>

        <!-- Bottom content -->
        <div class="stage__bottom">
          <div class="stage__rule is-in" id="stage-rule"></div>

          <div class="stage__type-label is-in" id="stage-type">
            {charData[0].type} · Filed {charData[0].updated}
          </div>

          <h1 class="stage__name is-in" id="stage-name">{charData[0].title}</h1>

          <div class="stage__designation is-in" id="stage-designation">
            {charData[0].designation}
          </div>

          <p class="stage__summary is-in" id="stage-summary">{charData[0].summary}</p>

          <div class="stage__actions is-in" id="stage-actions">
            <a class="stage__cta" id="stage-cta" href={charData[0].href}>Open Dossier</a>
            <button class="stage__nav-btn" id="btn-prev" aria-label="Previous character">&#8593;</button>
            <button class="stage__nav-btn" id="btn-next" aria-label="Next character">&#8595;</button>
            <span class="stage__key-hint">↑ ↓ Arrow keys</span>
          </div>
        </div>

        <!-- Dot navigator -->
        <div class="stage__dots" id="stage-dots">
          {charData.map((_, i) => (
            <button
              class={`stage__dot${i === 0 ? " is-active" : ""}`}
              data-idx={i}
              id={`dot-${i}`}
              title={charData[i].title}
            ></button>
          ))}
        </div>

        <!-- Stamp -->
        <div class="stage__stamp is-in" id="stage-stamp">
          <div class="stage__stamp-inner">Dossier On File</div>
        </div>
      </div>
    </div>

    <script define:vars={{ charData }}>
      const chars = charData;
      let activeIdx = 0;
      let switchTimer = null;

      const stagePortrait = document.getElementById("stage-portrait");
      const stageWatermark = document.getElementById("stage-watermark");
      const stageCounter = document.getElementById("stage-counter");
      const stageCounterNum = document.getElementById("stage-counter-num");
      const stageTags = document.getElementById("stage-tags");
      const stageRule = document.getElementById("stage-rule");
      const stageType = document.getElementById("stage-type");
      const stageName = document.getElementById("stage-name");
      const stageDesignation = document.getElementById("stage-designation");
      const stageSummary = document.getElementById("stage-summary");
      const stageActions = document.getElementById("stage-actions");
      const stageCta = document.getElementById("stage-cta");
      const stageStamp = document.getElementById("stage-stamp");
      const stageRoot = document.getElementById("stage");

      const allAnimated = [stageCounter, stageTags, stageRule, stageType, stageName, stageDesignation, stageSummary, stageActions, stageWatermark, stageStamp, stagePortrait];

      function setPhase(phase) {
        const inClass = "is-in";
        const outClass = "is-out";
        allAnimated.forEach(el => {
          if (!el) return;
          if (phase === "in") {
            el.classList.remove(outClass);
            el.classList.add(inClass);
          } else {
            el.classList.remove(inClass);
            el.classList.add(outClass);
          }
        });
      }

      function buildPlaceholderSVG(char) {
        const ns = "http://www.w3.org/2000/svg";
        const svg = document.createElementNS(ns, "svg");
        svg.setAttribute("viewBox", "0 0 900 1000");
        svg.setAttribute("preserveAspectRatio", "xMidYMid slice");
        svg.setAttribute("class", "stage__placeholder");
        svg.style.position = "absolute";
        svg.style.inset = "0";
        svg.innerHTML = `
          <defs>
            <radialGradient id="rg-dyn" cx="50%" cy="38%" r="55%">
              <stop offset="0%" stop-color="rgba(177,58,52,0.18)"/>
              <stop offset="100%" stop-color="rgba(6,6,11,0)"/>
            </radialGradient>
          </defs>
          <rect width="900" height="1000" fill="#06060b"/>
          <rect width="900" height="1000" fill="url(#rg-dyn)"/>
          ${Array.from({length:50},(_,i)=>`<line x1="0" y1="${i*20}" x2="900" y2="${i*20}" stroke="rgba(255,255,255,0.012)" stroke-width="1"/>`).join("")}
          ${[60,130,210,300,400].map(r=>`<circle cx="450" cy="380" r="${r}" fill="none" stroke="rgba(255,255,255,0.035)" stroke-width="1"/>`).join("")}
          <line x1="450" y1="200" x2="450" y2="560" stroke="rgba(177,58,52,0.18)" stroke-width="0.8"/>
          <line x1="270" y1="380" x2="630" y2="380" stroke="rgba(177,58,52,0.18)" stroke-width="0.8"/>
          <path d="M310 240 L310 268 L338 268" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5"/>
          <path d="M590 240 L590 268 L562 268" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5"/>
          <path d="M310 520 L310 492 L338 492" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5"/>
          <path d="M590 520 L590 492 L562 492" fill="none" stroke="rgba(177,58,52,0.45)" stroke-width="1.5"/>
          <circle cx="450" cy="342" r="52" fill="rgba(255,255,255,0.025)" stroke="rgba(255,255,255,0.055)" stroke-width="1"/>
          <path d="M338 510 Q338 456 450 456 Q562 456 562 510" fill="rgba(255,255,255,0.025)" stroke="rgba(255,255,255,0.055)" stroke-width="1"/>
          <text x="450" y="580" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" letter-spacing="6" fill="rgba(177,58,52,0.35)">PORTRAIT CLASSIFIED</text>
          <text x="450" y="596" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" letter-spacing="4" fill="rgba(255,255,255,0.1)">SiNE ARCHIVES · FILE SEALED</text>
        `;
        return svg;
      }

      function updateContent(idx) {
        const c = chars[idx];

        // portrait
        const existing = stagePortrait.querySelector("img, svg");
        if (existing) existing.remove();
        if (c.image) {
          const img = document.createElement("img");
          img.className = "stage__portrait-img";
          img.src = c.image;
          img.alt = "";
          // Apply base scale immediately so zoom is correct before any mousemove
          img.style.transform = "scale(1.07) translate(0%, 0%)";
          stagePortrait.appendChild(img);
        } else {
          stagePortrait.appendChild(buildPlaceholderSVG(c));
        }

        // watermark
        stageWatermark.innerHTML = c.title.split(" ")
          .map(w => `<div class="stage__watermark-word">${w}</div>`)
          .join("");

        // counter
        stageCounterNum.textContent = String(idx + 1).padStart(2, "0");

        // tags
        stageTags.innerHTML = c.tags.slice(0, 3)
          .map(t => `<span class="stage__tag">${t}</span>`)
          .join("");

        // text
        stageType.textContent = `${c.type} · Filed ${c.updated}`;
        stageName.textContent = c.title;
        stageDesignation.textContent = c.designation;
        stageDesignation.style.display = c.designation ? "" : "none";
        stageSummary.textContent = c.summary;
        stageCta.href = c.href;

        // sidebar items
        document.querySelectorAll(".sidebar__item").forEach((el, i) => {
          const isAct = i === idx;
          el.classList.toggle("is-active", isAct);
          const numEl = el.querySelector(".sidebar__item-num");
          let line = numEl.querySelector(".sidebar__item-num-line");
          if (isAct && !line) {
            line = document.createElement("span");
            line.className = "sidebar__item-num-line";
            numEl.appendChild(line);
          } else if (!isAct && line) {
            line.remove();
          }
        });

        // dots
        document.querySelectorAll(".stage__dot").forEach((el, i) => {
          el.classList.toggle("is-active", i === idx);
        });
      }

      function switchTo(idx) {
        if (idx === activeIdx) return;
        clearTimeout(switchTimer);
        setPhase("out");
        switchTimer = setTimeout(() => {
          activeIdx = idx;
          updateContent(idx);
          setTimeout(() => setPhase("in"), 60);
        }, 360);
      }

      // Mouse parallax
      stageRoot.addEventListener("mousemove", (e) => {
        const r = stageRoot.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        const img = stagePortrait.querySelector("img");
        if (img) {
          img.style.transform = `scale(1.07) translate(${x * -3.5}%, ${y * -2.5}%)`;
        }
      });

      // Buttons
      document.getElementById("btn-prev").addEventListener("click", () => {
        switchTo((activeIdx - 1 + chars.length) % chars.length);
      });
      document.getElementById("btn-next").addEventListener("click", () => {
        switchTo((activeIdx + 1) % chars.length);
      });

      // Sidebar clicks
      document.getElementById("sidebar-list").addEventListener("click", (e) => {
        const btn = e.target.closest(".sidebar__item");
        if (btn) switchTo(parseInt(btn.dataset.idx, 10));
      });

      // Dot clicks
      document.getElementById("stage-dots").addEventListener("click", (e) => {
        const btn = e.target.closest(".stage__dot");
        if (btn) switchTo(parseInt(btn.dataset.idx, 10));
      });

      // Keyboard
      window.addEventListener("keydown", (e) => {
        if (e.key === "ArrowUp" || e.key === "ArrowLeft") {
          e.preventDefault();
          switchTo((activeIdx - 1 + chars.length) % chars.length);
        }
        if (e.key === "ArrowDown" || e.key === "ArrowRight") {
          e.preventDefault();
          switchTo((activeIdx + 1) % chars.length);
        }
      });

      // Search
      const searchInput = document.getElementById("sidebar-search");
      const searchClear = document.getElementById("sidebar-search-clear");
      const noResults = document.getElementById("sidebar-no-results");
      const sidebarItems = Array.from(document.querySelectorAll(".sidebar__item"));

      function applySearch(query) {
        const q = query.trim().toLowerCase();
        let anyVisible = false;
        sidebarItems.forEach((item) => {
          const idx = parseInt(item.dataset.idx, 10);
          const c = chars[idx];
          const hit = !q ||
            c.title.toLowerCase().includes(q) ||
            (c.designation && c.designation.toLowerCase().includes(q)) ||
            (c.type && c.type.toLowerCase().includes(q));
          item.style.display = hit ? "" : "none";
          if (hit) anyVisible = true;
        });
        noResults.classList.toggle("is-visible", !anyVisible);
        searchClear.classList.toggle("is-visible", q.length > 0);
      }

      searchInput.addEventListener("input", () => applySearch(searchInput.value));

      searchClear.addEventListener("click", () => {
        searchInput.value = "";
        applySearch("");
        searchInput.focus();
      });
    </script>
  </body>
</html>
