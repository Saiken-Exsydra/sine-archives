---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout active="cosmology" pageTitle="Cosmology — SiNE Archives">
  <section class="cosmology-page">
    <div class="cosmology-hero" id="cosmologyHero" aria-label="Cosmology space scene">
      <img
        class="cosmology-hero-image"
        src="/uploads/COSMOLOGY.png"
        alt=""
        aria-hidden="true"
        loading="eager"
        decoding="async"
      />
      <div class="cosmology-copy">
        <h1>Cosmology</h1>
        <p>Vesperia, a miracle of creation.</p>
      </div>
    </div>

    <section class="cosmology-intro" aria-label="Cosmology introduction">
      <article class="body cosmology-body" data-entry-body>
        <div class="cosmology-overview-content" data-cosmology-overview>
          <p>Cosmology overview could not be loaded.</p>
        </div>
      </article>
    </section>
  </section>

  <script src="../../scripts/cosmology-overview.ts"></script>

  <style>
    .cosmology-page {
      margin-top: 18px;
      display: grid;
      gap: 16px;
    }

    .cosmology-hero {
      position: relative;
      min-height: clamp(320px, 56vw, 620px);
      aspect-ratio: 3 / 2;
      border: 1px solid rgba(176, 141, 60, 0.18);
      border-radius: 20px;
      overflow: hidden;
      background: rgba(5, 7, 12, 0.72);
    }

    .cosmology-hero::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background: linear-gradient(180deg, rgba(5, 7, 12, 0.2), rgba(5, 7, 12, 0.45));
    }

    .cosmology-hero-image {
      position: absolute;
      inset: 0;
      z-index: 0;
      width: 100%;
      height: 100%;
      display: block;
      object-fit: contain;
      object-position: center;
    }

    .cosmology-copy {
      position: absolute;
      left: clamp(14px, 3vw, 34px);
      bottom: clamp(14px, 4vh, 38px);
      z-index: 2;
      max-width: 46ch;
      padding: clamp(18px, 3vw, 30px);
      background: linear-gradient(90deg, rgba(4, 6, 12, 0.74), rgba(8, 10, 18, 0.2));
      border-radius: 14px;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
    }

    .cosmology-copy h1 {
      margin: 0 0 10px;
      font-size: clamp(1.8rem, 2.8vw, 2.6rem);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .cosmology-copy p {
      margin: 0;
      line-height: 1.55;
      color: rgba(238, 235, 232, 0.96);
    }

    .cosmology-intro {
      margin-top: 0;
    }

    .body {
      padding: 16px 18px;
      border-radius: 18px;
      border: 1px solid rgba(176, 141, 60, 0.18);
      background: rgba(11, 11, 16, 0.55);
      box-shadow: var(--shadow);
    }

    .body :global(h2),
    .body :global(h3) {
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .body :global(h2) {
      margin: 2rem 0 0.9rem;
      font-size: 1.12rem;
      border-top: 1px solid rgba(176, 141, 60, 0.18);
      padding-top: 1.15rem;
    }

    .body :global(h2:first-child) {
      margin-top: 0;
      padding-top: 0;
      border-top: none;
    }

    .body :global(h3) {
      margin: 1.5rem 0 0.8rem;
      font-size: 1rem;
    }

    .body :global(p),
    .body :global(li) {
      font-size: 17px;
      font-weight: 580;
      letter-spacing: 0.02em;
      line-height: 1.85;
      color: var(--text);
    }

    .body :global(p) {
      margin: 0 0 1.05rem;
    }

    .body :global(li) {
      margin-bottom: 0.35rem;
    }

    .body :global(ul),
    .body :global(ol) {
      padding-left: 24px;
      margin: 0 0 1.1rem;
    }

    .body :global(strong) {
      color: #d36a60;
      font-weight: 780;
    }

    .body :global(a) {
      color: #d8b473;
      text-underline-offset: 0.18em;
    }

    .body :global(a:hover) {
      color: #e3c58f;
    }

    .cosmology-body :global(p > img:only-child) {
      display: block;
      width: auto;
      max-width: 100%;
      height: auto;
      margin: 1.35rem auto 1.6rem;
    }

    .cosmology-body :global(p > img[src="/uploads/TwilightDG.png"]) {
      float: right;
      width: 45%;
      max-width: 45%;
      min-width: 180px;
      height: auto;
      margin: 0.25rem 0 1.25rem 1.75rem;
      border-radius: 8px;
    }

    .body :global(hr) {
      border: none;
      border-top: 1px solid rgba(176, 141, 60, 0.34);
      margin: 2rem 0;
    }

    .body :global(hr + h2),
    .body :global(hr + h3) {
      margin-top: 0;
      padding-top: 0;
      border-top: none;
    }

    .cosmology-body :global(p:last-child) {
      margin: 0;
    }

    @media (max-width: 900px) {
      .cosmology-hero {
        min-height: 360px;
      }

      .cosmology-body :global(p > img[src="/uploads/TwilightDG.png"]) {
        width: 30%;
        max-width: 220px;
        min-width: 160px;
      }

      .cosmology-copy {
        left: 14px;
        right: 14px;
        bottom: 14px;
        max-width: 96%;
        padding: 20px 18px;
      }
    }

    @media (max-width: 640px) {
      .cosmology-hero {
        min-height: 320px;
      }

      .cosmology-body :global(p > img[src="/uploads/TwilightDG.png"]) {
        float: none;
        display: block;
        width: 60%;
        max-width: 100%;
        margin: 1rem auto 1.25rem;
      }

      .cosmology-copy {
        left: 10px;
        right: 10px;
        bottom: 10px;
        padding: 18px 16px;
      }
    }
  </style>
</MainLayout>
