---
import MainLayout from "../../layouts/MainLayout.astro";
import SectionList from "../../components/SectionList.astro";
---

<MainLayout active="cosmology" pageTitle="Cosmology — SiNE Archives">
  <section class="cosmology-page">
    <div class="cosmology-hero" aria-label="Cosmology space scene">
      <img
        class="cosmology-hero-image"
        src="/uploads/COSMOLOGY.png"
        alt=""
        aria-hidden="true"
        loading="eager"
        decoding="async"
      />
      <div class="cosmology-copy">
        <h1>Cosmology</h1>
        <p>Vesperia, a miracle of creation.</p>
      </div>
    </div>

    <SectionList
      section="cosmology"
      active="cosmology"
      title="Cosmological Records"
      searchLabel="Search cosmology entries…"
      emptyLabel="No public cosmology entries yet."
    />
  </section>

  <style>
    .cosmology-page {
      margin-top: 18px;
      display: grid;
      gap: 16px;
    }

    .cosmology-hero {
      position: relative;
      min-height: clamp(320px, 56vw, 620px);
      aspect-ratio: 3 / 2;
      border: 1px solid rgba(176, 141, 60, 0.18);
      border-radius: 20px;
      overflow: hidden;
      background: rgba(5, 7, 12, 0.72);
    }

    .cosmology-hero::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background: linear-gradient(180deg, rgba(5, 7, 12, 0.2), rgba(5, 7, 12, 0.45));
    }

    .cosmology-hero-image {
      position: absolute;
      inset: 0;
      z-index: 0;
      width: 100%;
      height: 100%;
      display: block;
      object-fit: contain;
      object-position: center;
    }

    .cosmology-copy {
      position: absolute;
      left: clamp(14px, 3vw, 34px);
      bottom: clamp(14px, 4vh, 38px);
      z-index: 2;
      max-width: 46ch;
      padding: clamp(18px, 3vw, 30px);
      background: linear-gradient(90deg, rgba(4, 6, 12, 0.74), rgba(8, 10, 18, 0.2));
      border-radius: 14px;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
    }

    .cosmology-copy h1 {
      margin: 0 0 10px;
      font-size: clamp(1.8rem, 2.8vw, 2.6rem);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .cosmology-copy p {
      margin: 0;
      line-height: 1.55;
      color: rgba(238, 235, 232, 0.96);
    }

    @media (max-width: 900px) {
      .cosmology-hero {
        min-height: 360px;
      }

      .cosmology-copy {
        left: 14px;
        right: 14px;
        bottom: 14px;
        max-width: 96%;
        padding: 20px 18px;
      }
    }

    @media (max-width: 640px) {
      .cosmology-hero {
        min-height: 320px;
      }

      .cosmology-copy {
        left: 10px;
        right: 10px;
        bottom: 10px;
        padding: 18px 16px;
      }
    }
  </style>
</MainLayout>
