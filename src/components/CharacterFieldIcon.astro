---
type FieldIconName =
  | "registry"
  | "affiliation"
  | "house"
  | "year"
  | "age"
  | "build"
  | "birthplace"
  | "residence"
  | "occupation"
  | "default";

const {
  icon = "default",
  class: className = "",
} = Astro.props as {
  icon?: FieldIconName;
  class?: string;
};

const iconName = icon as FieldIconName;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  {iconName === "registry" && (
    <>
      <path d="M8.5 4.75H15.5L18.25 7.5V18.25H5.75V4.75H8.5Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
      <path d="M15.5 4.75V7.5H18.25" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
      <path d="M8.5 11.25L10.25 13L14.5 8.75" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
    </>
  )}

  {iconName === "affiliation" && (
    <>
      <circle cx="6.5" cy="8" r="2.25" stroke="currentColor" stroke-width="1.3" />
      <circle cx="17.5" cy="8" r="2.25" stroke="currentColor" stroke-width="1.3" />
      <circle cx="12" cy="16.25" r="2.25" stroke="currentColor" stroke-width="1.3" />
      <path d="M8.55 9.1L10.95 14.2M15.45 9.1L13.05 14.2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
    </>
  )}

  {iconName === "house" && (
    <>
      <path d="M12 4.75L18 7.25V11.25C18 15.05 15.55 18.1 12 19.25C8.45 18.1 6 15.05 6 11.25V7.25L12 4.75Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
      <path d="M12 8V16" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
      <path d="M9.25 10.5H14.75" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
    </>
  )}

  {iconName === "year" && (
    <>
      <rect x="5.75" y="6.75" width="12.5" height="11.5" rx="2" stroke="currentColor" stroke-width="1.3" />
      <path d="M8.5 4.75V8.25M15.5 4.75V8.25M5.75 10H18.25" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
    </>
  )}

  {iconName === "age" && (
    <>
      <circle cx="12" cy="12" r="6.25" stroke="currentColor" stroke-width="1.3" />
      <path d="M12 8.5V12L14.5 13.75" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
    </>
  )}

  {iconName === "build" && (
    <>
      <path d="M6.25 5.75V18.25M17.75 5.75V18.25" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
      <path d="M8.75 8.25H15.25M8.75 15.75H15.25" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
      <path d="M12 8.25V15.75" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
    </>
  )}

  {iconName === "birthplace" && (
    <>
      <path d="M12 19C14.95 15.95 17.25 13.35 17.25 10.25C17.25 7.2 14.95 5 12 5C9.05 5 6.75 7.2 6.75 10.25C6.75 13.35 9.05 15.95 12 19Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
      <circle cx="12" cy="10.25" r="1.9" stroke="currentColor" stroke-width="1.3" />
    </>
  )}

  {iconName === "residence" && (
    <>
      <path d="M5.75 10.75L12 5.75L18.25 10.75" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M7.25 9.75V18.25H16.75V9.75" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
      <path d="M10.25 18.25V13.5H13.75V18.25" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
    </>
  )}

  {iconName === "occupation" && (
    <>
      <rect x="4.75" y="8.25" width="14.5" height="9.5" rx="2" stroke="currentColor" stroke-width="1.3" />
      <path d="M9 8.25V6.75C9 5.92 9.67 5.25 10.5 5.25H13.5C14.33 5.25 15 5.92 15 6.75V8.25" stroke="currentColor" stroke-width="1.3" />
      <path d="M4.75 12.25H19.25" stroke="currentColor" stroke-width="1.3" />
    </>
  )}

  {iconName === "default" && (
    <circle cx="12" cy="12" r="6.25" stroke="currentColor" stroke-width="1.3" />
  )}
</svg>
