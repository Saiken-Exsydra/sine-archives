---
import MainLayout from "../../layouts/MainLayout.astro";
import { localizedPath, type SiteLocale } from "../../i18n/config";
import { getArchiveNavLabels, sectionLabel } from "../../i18n/ui";

type Props = {
  locale?: SiteLocale;
  id: "resonance" | "harmonics";
  title: string;
  pageTitle: string;
  logo: string;
  eyebrow: string;
  summary: string;
  mechanism: string;
  interfaceLabel: string;
  transitionName: string;
};

const {
  locale = "en",
  id,
  title,
  pageTitle,
  logo,
  eyebrow,
  summary,
  mechanism,
  interfaceLabel,
  transitionName,
} = Astro.props;
const navLabels = getArchiveNavLabels(locale);
const observatoryHref = localizedPath(locale, "/systems/observatory/");

const interfaceData = {
  harmonics: {
    status: "Time-readable resonance",
    thesis: "Resonance is the quiet pull between things that are built alike. Harmonics are what that pull looks like once Time turns it into recurrence, surge, fade, warning pattern, or exposure cadence.",
    instrumentTitle: "Follow the Rhythm",
    instrumentLabel: "Resonance, watched over time",
    instruction: "Pick a rhythm. The reader explains what is repeating, what it affects, and what people might wrongly assume.",
    metrics: [
      { label: "Starts with", value: "Resonance" },
      { label: "Time adds", value: "Rhythm" },
      { label: "Risk", value: "Wrong cause" },
    ],
    readings: [
      {
        name: "World Rhythm",
        marker: "G-00",
        level: "Normal recurrence",
        description: "Some patterns repeat because the world is stable enough to keep doing the same lawful thing: orbit, season, pressure, cycle.",
        output: "Usually this is just baseline behavior. It becomes interesting only when the rhythm gets louder, faster, or easier to conduct.",
        x: 15,
        y: 68,
        height: 31,
      },
      {
        name: "Calling Surge",
        marker: "S-17",
        level: "Crown pressure",
        description: "A Calling is the big local example: pressure from the Lunar Crown's containment struggle becomes a periodic surge the world can feel.",
        output: "Check thin places, BrightCrystal, Anchor stress, and institutional bias before calling it omen, prophecy, or divine speech.",
        x: 32,
        y: 39,
        height: 72,
      },
      {
        name: "Routing Echo",
        marker: "O-41",
        level: "Repeated Dive trace",
        description: "Repeated Redactory work can leave a pattern that shows up over time, like footsteps in dust after someone keeps taking the same route.",
        output: "The echo proves repeated disturbance. It does not reveal the Redactor's thoughts, and it does not make Redactory a harmonic system.",
        x: 51,
        y: 55,
        height: 49,
      },
      {
        name: "Living Conductor",
        marker: "B-09",
        level: "Biological response",
        description: "Bloom or other resonance-active life can carry a repeating pressure through tissue, blood, memory, or growth.",
        output: "Read it as a living response to resonance under Time. Do not turn Bloom into divinity or generic magic by default.",
        x: 69,
        y: 27,
        height: 86,
      },
      {
        name: "Shore Pulse",
        marker: "R-62",
        level: "Borderland recurrence",
        description: "Near a Shore, conceptual pressure can repeat strongly enough to reveal exposure cadence, Returnwake patterns, Calling overlap, or aperture instability.",
        output: "Read it as Shore-adjacent pressure becoming rhythmic. Harmonics can signal, amplify, dampen, or pattern the event. They do not cause Shorefall.",
        x: 86,
        y: 49,
        height: 58,
      },
    ],
    cautions: [
      "A loud pattern is not automatically an important source.",
      "A repeating pattern still needs context: what is being read, and under what timing conditions?",
      "A Shore-adjacent rhythm is not proof that Harmonics caused the aperture.",
    ],
  },
  resonance: {
    status: "Passive coherence field",
    thesis: "Some things are built alike. When they are alike enough, they begin to lean on each other. That quiet leaning is resonance.",
    tags: ["Similarity", "Pressure", "Stability"],
    instrumentTitle: "When Patterns Lean",
    instrumentLabel: "Invisible pattern pressure",
    instruction: "Click any dot to see why it matters.",
    metrics: [
      { label: "Reads", value: "Gradient" },
      { label: "Stabilizes", value: "Density" },
      { label: "Fails as", value: "Cascade" },
    ],
    readings: [
      {
        name: "Similarity Threshold",
        marker: "01",
        level: "Gradient source",
        description: "Two configurations begin to pressure one another when structural similarity exceeds a passive interaction threshold.",
        output: "Below threshold: relation exists without meaningful consequence. Above threshold: local stability begins to answer.",
        x: 18,
        y: 38,
        height: 48,
      },
      {
        name: "Density Reinforcement",
        marker: "02",
        level: "Field support",
        description: "Configurations in mutual support resist perturbation better than isolated configurations of equal individual coherence.",
        output: "Dense fields stabilize what belongs there and resist foreign translation pressure.",
        x: 39,
        y: 22,
        height: 67,
      },
      {
        name: "Thinness Conduit",
        marker: "03",
        level: "Transmission hazard",
        description: "Thin regions are easier to perturb, easier to index through, and more conductive to incoming disturbance.",
        output: "Cascade risk rises when similarity, narrow stability margins, and weak local reinforcement coincide.",
        x: 63,
        y: 42,
        height: 56,
      },
      {
        name: "Recursive Pressure",
        marker: "04",
        level: "Self-model field",
        description: "Recursive singularities continually resemble themselves. Many minds aligned around one attractor amplify local coherence.",
        output: "Worship, ideology, and mass fear can gain structural weight without becoming messages or magic commands.",
        x: 49,
        y: 70,
        height: 41,
      },
      {
        name: "Cascade Edge",
        marker: "05",
        level: "Disturbance overflow",
        description: "A configuration change shifts resonance relationships, then propagates through dependent similar structures.",
        output: "Dense coherence dampens it. Thin medium carries it. BrightCrystal and Calling events can escalate quickly.",
        x: 82,
        y: 61,
        height: 76,
      },
    ],
    cautions: [
      "Resonance is not indexing.",
      "Resonance is not energy, signal, force, or magic by itself.",
      "Resonance amplifies, dampens, stabilizes, or destabilizes what is already valid.",
    ],
  },
} as const;

const activeData = interfaceData[id];
const firstReading = activeData.readings[0];
const activeTags = id === "resonance" ? interfaceData.resonance.tags : [];

const harmonicVariables = [
  { label: "Resonance strength", note: "Underlying coherence pressure before Time makes it legible." },
  { label: "Traversal conditions", note: "Local timing conditions under which the relation is read." },
  { label: "Amplitude + interval", note: "How loud the expression is, and how far apart the pulses arrive." },
  { label: "Conductivity + damping", note: "Whether the medium carries the disturbance onward or absorbs it." },
] as const;

const harmonicPropagation = [
  { label: "Source strain", value: "Lunar Crown containment conflict intensifies." },
  { label: "Distributed load", value: "Lunar Ring and Precursor infrastructure spread the surge." },
  { label: "Conductive media", value: "BrightCrystal and thin regions carry the pulse efficiently." },
  { label: "Local reading", value: "Institutions see omen, turbulence, instability, or recurrence." },
] as const;
---

<MainLayout
  active="systems"
  pageTitle={pageTitle}
  locale={locale}
  navVariant="entry"
  hideFooter={true}
  pageClass={`system-interface-page system-interface-page--${id}`}
  routeKind="generic"
  transitionProfile="system-interface"
  navTrail={[
    { label: navLabels.index, href: localizedPath(locale, "/") },
    { label: sectionLabel(locale, "systems"), href: localizedPath(locale, "/systems/") },
    { label: "Observatory", href: observatoryHref },
    { label: title },
  ]}
>
  <section class:list={["system-interface", `system-interface--${id}`]} data-interface-root={id} data-system-interface={id}>
    <div class="system-interface__field" aria-hidden="true"></div>
    <div class="system-interface__grain sine-grain" aria-hidden="true"></div>
    <div class="system-interface__scan sine-scanline" aria-hidden="true"></div>

    <header class="system-interface__header">
      <p>{eyebrow}</p>
      <h1>{title}</h1>
      <span>{activeData.status}</span>
      <p class="system-interface__thesis">{activeData.thesis}</p>
      {id === "resonance" ? (
        <ul class="system-interface__tags" aria-label="Resonance concepts">
          {activeTags.map((tag) => <li>{tag}</li>)}
        </ul>
      ) : (
        <dl class="system-interface__metrics" aria-label={`${title} interface readings`}>
          {activeData.metrics.map((metric) => (
            <div>
              <dt>{metric.label}</dt>
              <dd>{metric.value}</dd>
            </div>
          ))}
        </dl>
      )}
    </header>

    {id === "resonance" ? (
      <div class="resonance-lab-shell" data-resonance-lab data-selected="default" style="--similarity: 0.62; --field-strength: 0.28;">
        <section class="resonance-lab" aria-labelledby="resonance-field-title">
          <div class="resonance-lab__head">
            <p>{activeData.instrumentLabel}</p>
            <h2 id="resonance-field-title">{activeData.instrumentTitle}</h2>
            <span>{activeData.instruction}</span>
          </div>

          <div class="resonance-fieldboard" data-fieldboard>
            <svg
              class="resonance-map"
              viewBox="0 0 760 460"
              role="img"
              aria-labelledby="resonance-map-title resonance-map-desc"
              data-resonance-map
            >
              <title id="resonance-map-title">Interactive resonance node field</title>
              <desc id="resonance-map-desc">A quiet node diagram showing similarity pressure, field overlap, dense damping, and thin transmission.</desc>
              <defs>
                <filter id="resonance-soft-glow" x="-70%" y="-70%" width="240%" height="240%">
                  <feGaussianBlur stdDeviation="4" result="blur" />
                  <feMerge>
                    <feMergeNode in="blur" />
                    <feMergeNode in="SourceGraphic" />
                  </feMerge>
                </filter>
              </defs>

              <g class="resonance-aperture" aria-hidden="true">
                <circle class="resonance-aperture__outer" cx="380" cy="230" r="190" />
                <circle class="resonance-aperture__mid" cx="380" cy="230" r="128" />
                <circle class="resonance-aperture__inner" cx="380" cy="230" r="66" />
                <path class="resonance-aperture__axis" d="M190 230 H570" />
                <path class="resonance-aperture__axis resonance-aperture__axis--vertical" d="M380 58 V402" />
                <image
                  class="resonance-aperture__symbol"
                  href={logo}
                  x="322"
                  y="172"
                  width="116"
                  height="116"
                  preserveAspectRatio="xMidYMid meet"
                />
              </g>

              <g class="resonance-signal-sweep" aria-hidden="true">
                <path d="M126 338 C 246 170, 428 118, 648 176" />
                <path d="M114 246 C 244 310, 422 356, 642 266" />
              </g>

              <g class="resonance-grid" aria-hidden="true">
                <ellipse cx="346" cy="222" rx="286" ry="166" />
                <ellipse cx="540" cy="322" rx="132" ry="112" />
                <path d="M96 228 C 210 104, 400 88, 638 126" />
              </g>

              <ellipse
                class="resonance-field-halo"
                data-lab-action="field"
                role="button"
                tabindex="0"
                aria-pressed="false"
                aria-label="Explain overlapping resonance field"
                cx="300"
                cy="218"
                rx="224"
                ry="138"
              />

              <g class="resonance-links" aria-hidden="true">
                <path class="resonance-line resonance-line--primary" data-line="primary" />
                <path class="resonance-line resonance-line--distant" data-line="distant" />
                <path class="resonance-line resonance-line--dense" data-line="dense" />
                <path class="resonance-line resonance-line--orbit" data-line="orbit" />
              </g>
              <path
                class="resonance-link-hit"
                data-lab-action="gradient"
                aria-hidden="true"
              />
              <circle
                class="resonance-line-touch"
                data-lab-action="gradient"
                data-gradient-touch
                role="button"
                tabindex="0"
                aria-pressed="false"
                aria-label="Explain the line between First Pattern and Almost the Same"
                r="18"
              />
              <g class="resonance-added-links" data-added-links aria-hidden="true"></g>
              <circle class="resonance-ripple" data-ripple cx="190" cy="220" r="1" />

              <g class="resonance-node resonance-node--a" data-node-id="a" data-lab-node="match" data-panel-state="first" data-node-kind="core" role="button" tabindex="0" aria-pressed="false" aria-label="First Pattern">
                <circle r="54" />
                <text y="-7">First</text>
                <text y="9">Pattern</text>
              </g>

              <g class="resonance-node resonance-node--similar" data-node-id="similar" data-lab-node="match" data-panel-state="same" data-node-kind="similar" role="button" tabindex="0" aria-pressed="false" aria-label="Almost the Same">
                <circle r="58" />
                <text y="-12">Almost</text>
                <text y="4">the Same</text>
              </g>

              <g class="resonance-node resonance-node--distant" data-node-id="distant" data-lab-node="different" data-panel-state="different" data-node-kind="distant" role="button" tabindex="0" aria-pressed="false" aria-label="Too Different">
                <circle r="46" />
                <text y="-5">Too</text>
                <text y="11">Different</text>
              </g>

              <g class="resonance-node resonance-node--dense" data-node-id="dense" data-lab-node="heavy" data-panel-state="heavy" data-node-kind="dense" role="button" tabindex="0" aria-pressed="false" aria-label="The Heavy Pattern">
                <circle r="70" />
                <circle class="resonance-node__core" r="16" />
                <text y="-12">The Heavy</text>
                <text y="5">Pattern</text>
              </g>

              <g class="resonance-node resonance-node--orbit" data-node-id="orbit" data-lab-node="nearby" data-panel-state="nearby" data-node-kind="orbiting" role="button" tabindex="0" aria-pressed="false" aria-label="Caught Nearby">
                <circle r="34" />
                <text y="-5">Caught</text>
                <text y="10">Nearby</text>
              </g>

              <g class="resonance-added-nodes" data-added-nodes aria-hidden="true"></g>
            </svg>
            <p class="resonance-field-note">In this diagram, distance means similarity. Close dots are not physically close. They are alike.</p>
          </div>

          <div class="resonance-gradient-control">
            <label for="resonance-similarity">Similarity</label>
            <input id="resonance-similarity" type="range" min="15" max="100" value="62" data-similarity-slider />
            <span data-similarity-label>Similarity: medium</span>
          </div>
        </section>

        <aside class="resonance-panel" aria-labelledby="resonance-panel-title" aria-live="polite">
          <p class="system-interface__kicker" data-panel-kicker>What you clicked</p>
          <h2 id="resonance-panel-title" data-panel-title>Start with the dots</h2>
          <div class="resonance-panel__signal" aria-hidden="true">
            <span></span>
            <strong data-panel-signal>Passive relation</strong>
          </div>
          <p data-panel-text>Each dot is a structure. Some are built almost the same way. Some are not. When two structures are similar enough, they start to pressure each other without meaning to.</p>
          <dl>
            <div>
              <dt>What this is not</dt>
              <dd data-panel-not>Nothing is being sent. Nobody is speaking. No power is traveling between them.</dd>
            </div>
            <div data-panel-rule-wrap hidden>
              <dt data-panel-rule-label>Rule</dt>
              <dd data-field-state></dd>
            </div>
          </dl>
        </aside>
      </div>
    ) : (
      <div class="harmonics-lab-shell" data-harmonics-lab>
        <section class="harmonics-lab" aria-labelledby={`${id}-instrument-title`}>
          <div class="harmonics-lab__head">
            <p>{activeData.instrumentLabel}</p>
            <h2 id={`${id}-instrument-title`}>{activeData.instrumentTitle}</h2>
            <span>{activeData.instruction}</span>
          </div>

          <div class="harmonics-diagram system-interface__display" style={`--active-x: ${firstReading.x}%; --active-y: ${firstReading.y}%;`}>
            <svg
              class="harmonics-diagram__map"
              viewBox="0 0 920 560"
              role="img"
              aria-labelledby="harmonics-map-title harmonics-map-desc"
            >
              <title id="harmonics-map-title">Harmonics explanatory array</title>
              <desc id="harmonics-map-desc">A diagram showing resonance relations becoming temporal expression, then signatures, propagation, regulation, and failure modes.</desc>
              <defs>
                <linearGradient id="harmonic-wave" x1="0%" x2="100%" y1="0%" y2="0%">
                  <stop offset="0%" stop-color="rgba(176, 141, 60, 0.1)" />
                  <stop offset="42%" stop-color="rgba(232, 228, 220, 0.72)" />
                  <stop offset="100%" stop-color="rgba(177, 58, 52, 0.28)" />
                </linearGradient>
                <filter id="harmonic-glow" x="-40%" y="-40%" width="180%" height="180%">
                  <feGaussianBlur stdDeviation="5" result="blur" />
                  <feMerge>
                    <feMergeNode in="blur" />
                    <feMergeNode in="SourceGraphic" />
                  </feMerge>
                </filter>
              </defs>

              <g class="harmonics-diagram__grid" aria-hidden="true">
                <path d="M90 278 H830" />
                <path d="M460 66 V498" />
                <ellipse cx="460" cy="282" rx="318" ry="178" />
                <ellipse cx="460" cy="282" rx="226" ry="126" />
                <ellipse cx="460" cy="282" rx="136" ry="76" />
              </g>

              <g class="harmonics-diagram__source" aria-hidden="true">
                <circle cx="168" cy="282" r="70" />
                <circle cx="254" cy="282" r="70" />
                <path d="M168 282 C 194 236, 228 236, 254 282 C 228 328, 194 328, 168 282" />
                <text x="212" y="390">Resonance relation</text>
              </g>

              <g class="harmonics-diagram__time" aria-hidden="true">
                <path class="harmonics-diagram__wave" d="M292 282 C 326 214, 368 214, 402 282 S 478 350, 512 282 S 588 214, 622 282 S 698 350, 732 282" />
                <path class="harmonics-diagram__wave harmonics-diagram__wave--echo" d="M292 316 C 326 278, 368 278, 402 316 S 478 354, 512 316 S 588 278, 622 316 S 698 354, 732 316" />
                <text x="506" y="202">Time orders traversal</text>
              </g>

              <g class="harmonics-diagram__symbol" style={`view-transition-name: ${transitionName};`} aria-hidden="true">
                <image href={logo} x="402" y="222" width="116" height="116" preserveAspectRatio="xMidYMid meet" />
              </g>

              <g class="harmonics-diagram__output" aria-hidden="true">
                <path d="M748 172 L826 172 L826 392 L748 392" />
                <text x="760" y="142">Temporal expression</text>
                <text x="762" y="201">interval</text>
                <text x="762" y="248">pulse</text>
                <text x="762" y="295">surge</text>
                <text x="762" y="342">damping</text>
              </g>
            </svg>

            {activeData.readings.map((reading, index) => (
              <button
                class:list={["harmonics-diagram__node", index === 0 && "is-active"]}
                type="button"
                data-reading-jump={index}
                aria-pressed={index === 0 ? "true" : "false"}
                aria-label={`Tune ${reading.name}`}
                style={`--band-x: ${reading.x}%; --band-y: ${reading.y}%; --band-h: ${reading.height}%;`}
              >
                <span>{reading.marker}</span>
                <strong>{reading.name}</strong>
              </button>
            ))}
          </div>
        </section>

        <aside class="harmonics-reader system-interface__output" aria-live="polite" aria-labelledby={`${id}-reader-title`}>
          <p class="system-interface__output-marker" data-reading-marker>{firstReading.marker}</p>
          <h2 id={`${id}-reader-title`} data-reading-name>{firstReading.name}</h2>
          <p class="system-interface__output-level" data-reading-level>{firstReading.level}</p>
          <p data-reading-description>{firstReading.description}</p>
          <div>
            <span>Codex Reading</span>
            <p data-reading-output>{firstReading.output}</p>
          </div>
          <dl>
            <div>
              <dt>Interface</dt>
              <dd>{interfaceLabel}</dd>
            </div>
            <div>
              <dt>Core mechanism</dt>
              <dd>{mechanism}</dd>
            </div>
            <div>
              <dt>Summary</dt>
              <dd>{summary}</dd>
            </div>
            <div>
              <dt>Boundary</dt>
              <dd>Harmonics read temporal recurrence. They do not create information, author futures, override Time, or replace Continuity.</dd>
            </div>
          </dl>
          <a href={observatoryHref} data-astro-prefetch="load">Return to Observatory</a>
        </aside>
      </div>
    )}

    {id === "resonance" ? (
      <section class="resonance-experiment" aria-labelledby="resonance-experiment-title">
        <div>
          <p>Try breaking the field</p>
          <h2 id="resonance-experiment-title">Test the Field</h2>
          <span data-experiment-status>Add patterns, then shake the field. Watch what holds and what passes the disturbance onward.</span>
          <details class="resonance-codex-term">
            <summary>Want the codex term?</summary>
            <p>Resonance is the relation itself. Harmonics are what that relation looks like when Time reads it as rhythm, recurrence, surge, warning cadence, or decay.</p>
          </details>
        </div>
        <div class="resonance-experiment__actions">
          <button type="button" data-lab-action="add-similar">Add Matching Pattern</button>
          <button type="button" data-lab-action="add-thin">Add Fragile Pattern</button>
          <button type="button" data-lab-action="disturb">Shake the Field</button>
        </div>
      </section>
    ) : (
      <>
        <section class="harmonics-codex" aria-labelledby={`${id}-codex-title`}>
          <div class="harmonics-codex__head">
            <p>Codex Matrix</p>
            <h2 id={`${id}-codex-title`}>How to read a harmonic event without misnaming it</h2>
          </div>

          <div class="harmonics-codex__grid">
            <article class="harmonics-codex__panel harmonics-codex__panel--wide">
              <p>Variables</p>
              <h3>No single reading is enough</h3>
              <div class="harmonics-variable-list">
                {harmonicVariables.map((variable) => (
                  <div>
                    <strong>{variable.label}</strong>
                    <span>{variable.note}</span>
                  </div>
                ))}
              </div>
            </article>

            <article class="harmonics-codex__panel">
              <p>Calling propagation</p>
              <h3>Lunar Crown surge path</h3>
              <ol class="harmonics-chain">
                {harmonicPropagation.map((step) => (
                  <li>
                    <strong>{step.label}</strong>
                    <span>{step.value}</span>
                  </li>
                ))}
              </ol>
            </article>

            <article class="harmonics-codex__panel">
              <p>BrightCrystal clause</p>
              <h3>The same help creates risk</h3>
              <p>BrightCrystal lowers resistance to routing and conducts pressure efficiently. Under Calling conditions, that conductivity can transmit disturbance into cascade.</p>
            </article>
          </div>
        </section>

        <section class="system-interface__cautions" aria-labelledby={`${id}-cautions-title`}>
          <p>Misclassification Guard</p>
          <h2 id={`${id}-cautions-title`}>What the instrument refuses to claim</h2>
          <ul>
            {activeData.cautions.map((caution) => <li>{caution}</li>)}
          </ul>
        </section>
      </>
    )}
  </section>
</MainLayout>

<script is:inline define:vars={{ id, readings: activeData.readings }}>
  window.registerPageInit?.(`system-interface-${id}`, () => {
    const root = document.querySelector(`[data-interface-root="${id}"]`);
    if (!root) return;

    const controller = new AbortController();
    const { signal } = controller;
    const cards = Array.from(root.querySelectorAll("[data-reading-card]"));
    const jumps = Array.from(root.querySelectorAll("[data-reading-jump]"));
    const display = root.querySelector(".system-interface__display");
    const fields = {
      marker: root.querySelector("[data-reading-marker]"),
      name: root.querySelector("[data-reading-name]"),
      level: root.querySelector("[data-reading-level]"),
      description: root.querySelector("[data-reading-description]"),
      output: root.querySelector("[data-reading-output]"),
    };

    function setPressed(elements, activeIndex) {
      elements.forEach((element) => {
        const index = Number(element.getAttribute("data-reading-card") ?? element.getAttribute("data-reading-jump"));
        const active = index === activeIndex;
        element.classList.toggle("is-active", active);
        element.setAttribute("aria-pressed", active ? "true" : "false");
      });
    }

    function setActive(index) {
      const reading = readings[index];
      if (!reading) return;

      setPressed(cards, index);
      setPressed(jumps, index);
      display?.style.setProperty("--active-x", `${reading.x}%`);
      display?.style.setProperty("--active-y", `${reading.y}%`);
      if (fields.marker) fields.marker.textContent = reading.marker;
      if (fields.name) fields.name.textContent = reading.name;
      if (fields.level) fields.level.textContent = reading.level;
      if (fields.description) fields.description.textContent = reading.description;
      if (fields.output) fields.output.textContent = reading.output;
    }

    [...cards, ...jumps].forEach((element) => {
      element.addEventListener("click", () => {
        const index = Number(element.getAttribute("data-reading-card") ?? element.getAttribute("data-reading-jump"));
        setActive(index);
      }, { signal });
    });

    setActive(0);

    return () => controller.abort();
  });
</script>

<script is:inline>
  window.registerPageInit?.("resonance-field-lab", () => {
    const root = document.querySelector("[data-resonance-lab]");
    if (!root) return;
    const pageRoot = root.closest("[data-interface-root='resonance']") || root;

    const controller = new AbortController();
    const { signal } = controller;
    const field = root.querySelector("[data-fieldboard]");
    const map = root.querySelector("[data-resonance-map]");
    const slider = root.querySelector("[data-similarity-slider]");
    const sliderLabel = root.querySelector("[data-similarity-label]");
    const addedNodes = root.querySelector("[data-added-nodes]");
    const addedLinks = root.querySelector("[data-added-links]");
    const ripple = root.querySelector("[data-ripple]");
    const gradientTouch = root.querySelector("[data-gradient-touch]");
    const experimentStatus = pageRoot.querySelector("[data-experiment-status]");
    const fieldState = root.querySelector("[data-field-state]");
    const panel = {
      kicker: root.querySelector("[data-panel-kicker]"),
      title: root.querySelector("[data-panel-title]"),
      text: root.querySelector("[data-panel-text]"),
      ruleWrap: root.querySelector("[data-panel-rule-wrap]"),
      ruleLabel: root.querySelector("[data-panel-rule-label]"),
      not: root.querySelector("[data-panel-not]"),
      signal: root.querySelector("[data-panel-signal]"),
    };

    const copy = {
      default: {
        title: "Start with the dots",
        signal: "Passive relation",
        text: "Each dot is a structure. Some are built almost the same way. Some are not. When two structures are similar enough, they start to pressure each other without meaning to.",
        not: "Nothing is being sent. Nobody is speaking. No power is traveling between them.",
      },
      first: {
        title: "This one has a near-match",
        signal: "Threshold approaching",
        text: "This dot shares a hidden shape with the one beside it. They are not copies. They simply have enough in common for resonance to begin.",
        rule: "Similar enough means: they start to matter to each other.",
      },
      same: {
        title: "Almost the same is enough",
        signal: "Pressure increasing",
        text: "Resonance does not need perfection. Two things can be different on the outside and still share the same deep arrangement underneath.",
        rule: "The more they match, the stronger the quiet pressure between them.",
      },
      line: {
        title: "The line is not a message",
        signal: "Gradient visible",
        text: "This line does not mean something is traveling. It only shows that the two patterns are leaning on each other.",
        rule: "Stronger similarity makes a stronger connection.",
      },
      slider: {
        title: "Try making them more alike",
        signal: "Similarity tuning",
        text: "Move the slider left, and the dots stop caring about each other. Move it right, and the connection wakes up.",
        rule: "Resonance begins only after enough similarity gathers in one place.",
      },
      different: {
        title: "This one is quiet",
        signal: "Below threshold",
        text: "This dot may share a little with the others, but not enough. It sits near the field without joining it.",
        rule: "A weak resemblance is not always enough to create resonance.",
      },
      heavy: {
        title: "This one holds its shape",
        signal: "Density anchor",
        text: "Some patterns are harder to disturb. They have more internal support, so nearby weaker patterns tend to settle around them.",
        ruleLabel: "Important",
        rule: "It is not commanding the others. It is simply harder to ignore.",
      },
      nearby: {
        title: "Following without being told",
        signal: "Orbit captured",
        text: "This smaller pattern has fallen into the heavy pattern's neighborhood. It keeps circling because that relation is easier to hold than drifting away.",
        rule: "Resonance can organize without intention.",
      },
      field: {
        title: "One connection becomes a field",
        signal: "Field overlap",
        text: "Two similar patterns make a line. Many similar patterns make a field. The shared pattern becomes steadier because many pieces are holding it together.",
        rule: "A group can resist disturbance better than a lonely dot.",
      },
      addMatching: {
        title: "The field gets steadier",
        signal: "Coherence reinforced",
        text: "Another similar pattern has joined. The shared shape is now reinforced from one more angle.",
        rule: "More matching pieces make the field harder to shake.",
      },
      addFragile: {
        title: "This one is easy to shake",
        signal: "Thin conduit",
        text: "This pattern does not have much support inside itself. If disturbance reaches it, it passes the shake onward instead of swallowing it.",
        rule: "Fragile patterns transmit disturbance.",
      },
      cascade: {
        title: "The shake runs loose",
        signal: "Cascade edge",
        text: "One fragile pattern shakes the next. Then that one shakes another. The field stops being quiet and starts answering itself.",
        rule: "That is a cascade.",
      },
      damping: {
        title: "The field absorbs the shake",
        signal: "Disturbance damped",
        text: "The disturbance spreads out and loses its bite. The stronger patterns share the burden, so nothing breaks.",
        rule: "Dense fields dampen disturbance.",
      },
    };

    let similarCount = 0;
    let thinCount = 0;
    let similarityValue = 62;
    let orbitFrame = 0;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const nodes = {
      a: { x: 190, y: 220 },
      similar: { x: 366, y: 218 },
      distant: { x: 616, y: 132 },
      dense: { x: 530, y: 298 },
      orbit: { x: 652, y: 298 },
    };
    const similarSlots = [
      { x: 280, y: 126 },
      { x: 262, y: 304 },
      { x: 428, y: 286 },
      { x: 352, y: 112 },
      { x: 154, y: 318 },
      { x: 454, y: 146 },
      { x: 344, y: 342 },
      { x: 128, y: 134 },
    ];
    const thinSlots = [
      { x: 126, y: 342 },
      { x: 486, y: 106 },
      { x: 666, y: 244 },
      { x: 232, y: 92 },
      { x: 646, y: 386 },
      { x: 88, y: 254 },
      { x: 422, y: 390 },
      { x: 706, y: 156 },
    ];

    function setPanel(key) {
      const next = copy[key] || copy.default;
      const hasRule = Boolean(next.rule);
      if (panel.kicker) panel.kicker.textContent = "What you clicked";
      if (panel.title) panel.title.textContent = next.title;
      if (panel.text) panel.text.textContent = next.text;
      if (panel.not && next.not) panel.not.textContent = next.not;
      if (panel.signal) panel.signal.textContent = next.signal || "Passive relation";
      if (panel.ruleWrap instanceof HTMLElement) panel.ruleWrap.hidden = !hasRule;
      if (panel.ruleLabel) panel.ruleLabel.textContent = next.ruleLabel || "Rule";
      if (fieldState) fieldState.textContent = next.rule || "";
      root.dataset.lesson = key;
      if (!prefersReducedMotion) {
        root.classList.remove("is-panel-shifting");
        window.requestAnimationFrame(() => {
          root.classList.add("is-panel-shifting");
          window.setTimeout(() => root.classList.remove("is-panel-shifting"), 520);
        });
      }
    }

    function setSelected(target) {
      root.dataset.selected = target || "default";
      pageRoot.querySelectorAll("[data-lab-node], [data-lab-action]").forEach((element) => {
        const nodeId = element.getAttribute("data-node-id");
        const action = element.getAttribute("data-lab-action");
        const isSelected = Boolean(target && (nodeId === target || action === target));
        element.classList.toggle("is-selected", isSelected);
        if (element.hasAttribute("aria-pressed")) {
          element.setAttribute("aria-pressed", isSelected ? "true" : "false");
        }
      });
    }

    function pulse(kind) {
      root.dataset.pulse = kind;
      window.setTimeout(() => {
        if (root.dataset.pulse === kind) root.removeAttribute("data-pulse");
      }, 760);
    }

    function curve(from, to, lift = -18) {
      const midX = (from.x + to.x) / 2;
      const midY = (from.y + to.y) / 2 + lift;
      return `M ${from.x} ${from.y} Q ${midX} ${midY} ${to.x} ${to.y}`;
    }

    function setNodePosition(id, x, y) {
      nodes[id] = { x, y };
      root.querySelector(`[data-node-id="${id}"]`)?.setAttribute("transform", `translate(${x} ${y})`);
    }

    function setPath(name, value) {
      root.querySelector(`[data-line="${name}"]`)?.setAttribute("d", value);
    }

    function drawField() {
      setPath("primary", curve(nodes.a, nodes.similar, -34));
      setPath("distant", curve(nodes.a, nodes.distant, -92));
      setPath("dense", curve(nodes.similar, nodes.dense, 42));
      setPath("orbit", curve(nodes.dense, nodes.orbit, -18));
      root.querySelector("[data-lab-action='gradient']")?.setAttribute("d", curve(nodes.a, nodes.similar, -34));
      const touchX = (nodes.a.x + nodes.similar.x) / 2;
      const touchY = (nodes.a.y + nodes.similar.y) / 2 - 34;
      gradientTouch?.setAttribute("cx", String(touchX));
      gradientTouch?.setAttribute("cy", String(touchY));
      ripple?.setAttribute("cx", String(nodes.a.x));
      ripple?.setAttribute("cy", String(nodes.a.y));
    }

    function updateSimilarity(value) {
      const numeric = Number(value) || 62;
      similarityValue = numeric;
      const normalized = numeric / 100;
      const similarX = 452 - numeric * 1.36;
      const similarY = 238 - numeric * 0.2;
      setNodePosition("similar", similarX, similarY);
      root.style.setProperty("--similarity", normalized.toFixed(2));
      root.style.setProperty("--line-strength", normalized.toFixed(2));
      root.style.setProperty("--field-strength", String(Math.min(0.88, 0.18 + normalized * 0.5 + similarCount * 0.08)));
      drawField();
      if (sliderLabel) {
        sliderLabel.textContent = numeric < 38
          ? "Similarity: low"
          : numeric < 76
            ? "Similarity: medium"
            : "Similarity: high";
      }
      setPanel("slider");
    }

    function svgElement(name) {
      return document.createElementNS("http://www.w3.org/2000/svg", name);
    }

    function drawAddedLink(kind, point) {
      if (!addedLinks) return;
      const link = svgElement("path");
      link.setAttribute("class", `resonance-added-link resonance-added-link--${kind}`);
      link.setAttribute("d", curve(kind === "thin" ? nodes.distant : nodes.similar, point, kind === "thin" ? 24 : -14));
      link.setAttribute("fill", "none");
      link.setAttribute("stroke", kind === "thin" ? "rgba(166, 184, 196, 0.26)" : "rgba(232, 228, 220, 0.32)");
      link.setAttribute("stroke-width", "0.8");
      link.setAttribute("stroke-linecap", "round");
      link.setAttribute("opacity", "0.32");
      if (kind === "thin") link.setAttribute("stroke-dasharray", "2 8");
      addedLinks.append(link);
    }

    function tuneThinNodes(cascades) {
      addedNodes?.querySelectorAll(".resonance-added-node--thin circle").forEach((circle) => {
        circle.setAttribute("stroke", cascades ? "rgba(177, 58, 52, 0.62)" : "rgba(232, 228, 220, 0.2)");
        circle.style.filter = cascades ? "drop-shadow(0 0 14px rgba(177, 58, 52, 0.2))" : "none";
      });
    }

    function addNode(kind) {
      if (!addedNodes) return;
      const index = kind === "thin" ? thinCount : similarCount;
      const slot = kind === "thin"
        ? thinSlots[index % thinSlots.length]
        : similarSlots[index % similarSlots.length];
      const point = {
        x: slot.x + Math.floor(index / 8) * 12,
        y: slot.y + Math.floor(index / 8) * 10,
      };
      const node = svgElement("g");
      const circle = svgElement("circle");
      const title = svgElement("title");
      node.setAttribute("class", `resonance-added-node resonance-added-node--${kind}`);
      node.setAttribute("transform", `translate(${point.x} ${point.y})`);
      circle.setAttribute("r", kind === "thin" ? "13" : "19");
      circle.setAttribute("fill", "rgba(2, 6, 10, 0.86)");
      circle.setAttribute("stroke", "rgba(232, 228, 220, 0.2)");
      circle.setAttribute("stroke-width", "1");
      if (kind === "similar") circle.style.filter = "drop-shadow(0 0 10px rgba(232, 228, 220, 0.12))";
      if (kind === "thin") {
        node.setAttribute("opacity", "0.75");
        node.style.animation = "thinFlicker 3.2s steps(2, end) infinite";
      }
      title.textContent = kind === "thin" ? "Fragile Pattern" : "Matching Pattern";
      node.append(title, circle);
      addedNodes.append(node);
      drawAddedLink(kind, point);

      if (kind === "thin") {
        thinCount += 1;
        setPanel("addFragile");
        if (experimentStatus) experimentStatus.textContent = "Fragile pattern added. It passes shaking onward more easily.";
      } else {
        similarCount += 1;
        root.style.setProperty("--field-strength", String(Math.min(0.74, 0.28 + similarCount * 0.12)));
        root.classList.add("is-field-visible");
        setPanel("addMatching");
        if (experimentStatus) experimentStatus.textContent = "Matching pattern added. The field grows steadier.";
      }
    }

    function disturb() {
      const densityBuffer = 2 + similarCount + (similarityValue >= 76 ? 1 : 0);
      const cascades = thinCount > densityBuffer;
      root.classList.remove("is-damped", "is-cascade", "is-disturbed");
      root.classList.add("is-disturbed", cascades ? "is-cascade" : "is-damped");
      tuneThinNodes(cascades);
      setPanel(cascades ? "cascade" : "damping");
      if (experimentStatus) {
        experimentStatus.textContent = cascades
          ? "The shake runs loose."
          : "The field absorbs the shake.";
      }
      window.setTimeout(() => {
        root.classList.remove("is-disturbed");
        tuneThinNodes(false);
      }, 1400);
    }

    root.querySelectorAll("[data-lab-node]").forEach((node) => {
      const key = node.getAttribute("data-lab-node");
      const panelKey = node.getAttribute("data-panel-state") || key;
      node.addEventListener("mouseenter", () => {
        root.dataset.hover = key || "";
      }, { signal });
      node.addEventListener("mouseleave", () => {
        root.removeAttribute("data-hover");
      }, { signal });
      node.addEventListener("focus", () => {
        root.dataset.hover = key || "";
      }, { signal });
      node.addEventListener("blur", () => {
        root.removeAttribute("data-hover");
      }, { signal });
      node.addEventListener("click", () => {
        const nodeId = node.getAttribute("data-node-id") || "";
        if (key === "match") pulse("similarity");
        if (key === "heavy") {
          root.classList.add("is-density-drift");
          window.setTimeout(() => root.classList.remove("is-density-drift"), 2200);
        }
        setSelected(nodeId);
        setPanel(panelKey);
      }, { signal });
      node.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" && event.key !== " ") return;
        event.preventDefault();
        node.dispatchEvent(new MouseEvent("click", { bubbles: true }));
      }, { signal });
    });

    pageRoot.querySelectorAll("[data-lab-action]").forEach((control) => {
      control.addEventListener("click", () => {
        const action = control.getAttribute("data-lab-action");
        if (action === "gradient") {
          root.classList.add("is-gradient-visible");
          pulse("gradient");
          setSelected("gradient");
          setPanel("line");
        } else if (action === "field") {
          root.classList.add("is-field-visible");
          setSelected("field");
          setPanel("field");
        } else if (action === "add-similar") {
          setSelected("add-similar");
          addNode("similar");
        } else if (action === "add-thin") {
          setSelected("add-thin");
          addNode("thin");
        } else if (action === "disturb") {
          setSelected("disturb");
          disturb();
        }
      }, { signal });
      control.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" && event.key !== " ") return;
        event.preventDefault();
        control.dispatchEvent(new MouseEvent("click", { bubbles: true }));
      }, { signal });
    });

    if (slider instanceof HTMLInputElement) {
      slider.addEventListener("input", () => updateSimilarity(slider.value), { signal });
    }

    field?.addEventListener("pointerdown", (event) => {
      if (event.target === field || event.target === map) disturb();
    }, { signal });

    function orbit(time) {
      const angle = time / 7600;
      const x = nodes.dense.x + Math.cos(angle) * 122;
      const y = nodes.dense.y + Math.sin(angle) * 118;
      setNodePosition("orbit", x, y);
      drawField();
      orbitFrame = window.requestAnimationFrame(orbit);
    }

    setNodePosition("a", nodes.a.x, nodes.a.y);
    setNodePosition("distant", nodes.distant.x, nodes.distant.y);
    setNodePosition("dense", nodes.dense.x, nodes.dense.y);
    updateSimilarity(similarityValue);
    if (!prefersReducedMotion) orbitFrame = window.requestAnimationFrame(orbit);
    else {
      setNodePosition("orbit", nodes.orbit.x, nodes.orbit.y);
      drawField();
    }
    setPanel("default");
    setSelected("default");
    return () => {
      controller.abort();
      if (orbitFrame) window.cancelAnimationFrame(orbitFrame);
    };
  });
</script>

