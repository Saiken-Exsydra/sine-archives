  .resonance-node--dense circle:first-child {
    fill: rgba(2, 6, 10, 0.95);
    stroke: rgba(232, 228, 220, 0.32);
    filter:
      drop-shadow(0 0 18px rgba(232, 228, 220, 0.12))
      drop-shadow(0 14px 28px rgba(0, 0, 0, 0.36));
  }

  .resonance-node__core {
    fill: rgba(246, 247, 241, 0.16);
    stroke: rgba(246, 247, 241, 0.34);
  }

  .resonance-node--distant {
