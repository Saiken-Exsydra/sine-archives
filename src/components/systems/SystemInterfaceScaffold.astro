  @keyframes interfaceDrift {
    to { transform: rotate(360deg); }
  }

  @keyframes pressureDrift {
    to { stroke-dashoffset: -24; }
  }

  @keyframes resonanceRipple {
    0% {
      opacity: 0;
      r: 4;
    }
    14% {
      opacity: 0.72;
    }
    100% {
      opacity: 0;
      r: 78;
    }
  }

  @keyframes orbitTurn {
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @keyframes orbitCounterTurn {
    to { transform: translate(-50%, -50%) rotate(-360deg); }
  }

  @keyframes thinFlicker {
    0%, 100% { opacity: 0.64; }
    50% { opacity: 0.96; }
  }

  @keyframes densityDrift {
    0%, 100% { filter: none; }
    50% { filter: drop-shadow(0 0 14px rgba(232, 228, 220, 0.18)); }
  }

  @keyframes fieldDash {
    to { stroke-dashoffset: -24; }
  }

  @media (max-width: 1040px) {
    .system-interface__stage,
    .system-interface__reader-grid,
    .resonance-lab-shell {
      grid-template-columns: 1fr;
    }

    .system-interface__panel,
    .resonance-panel {
      max-width: 760px;
      margin: 0 auto;
    }

    .system-interface__cards {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .system-interface {
      padding: 34px 16px 64px;
    }

    .system-interface__header {
      text-align: left;
    }

    .system-interface__tags {
      justify-content: flex-start;
