  }

  .resonance-aperture__outer,
  .resonance-aperture__mid,
  .resonance-aperture__inner {
    fill: none;
    stroke: rgba(232, 228, 220, 0.11);
    stroke-width: 1;
  }

  .resonance-aperture__outer {
    stroke-dasharray: 1 10;
    filter: drop-shadow(0 0 18px rgba(176, 141, 60, 0.1));
  }

  .resonance-aperture__mid {
    stroke: rgba(176, 141, 60, 0.18);
    stroke-dasharray: 38 18 2 18;
  }

  .resonance-aperture__inner {
    stroke: rgba(177, 58, 52, 0.22);
    filter: drop-shadow(0 0 14px rgba(177, 58, 52, 0.14));
  }

  .resonance-aperture__axis {
    fill: none;
    stroke: rgba(232, 228, 220, 0.09);
    stroke-dasharray: 2 12;
    stroke-width: 1;
  }

  .resonance-aperture__symbol {
    opacity: 0.13;
    filter: drop-shadow(0 0 18px rgba(232, 228, 220, 0.24));
    mix-blend-mode: screen;
  }

  .resonance-signal-sweep path {
    fill: none;
    stroke: rgba(176, 141, 60, 0.18);
    stroke-width: 0.85;
    stroke-dasharray: 3 16;
    stroke-linecap: round;
    opacity: 0.56;
    filter: drop-shadow(0 0 8px rgba(176, 141, 60, 0.08));
    animation: pressureDrift 13s linear infinite;
  }

  .resonance-signal-sweep path + path {
    stroke: rgba(177, 58, 52, 0.14);
    animation-duration: 17s;
    animation-direction: reverse;
  }

  .resonance-grid ellipse,
  .resonance-grid path {
    fill: none;
    stroke: rgba(232, 228, 220, 0.08);
    stroke-width: 1;
  }

  .resonance-field-halo {
    fill: rgba(232, 228, 220, calc(var(--field-strength, 0.48) * 0.055));
