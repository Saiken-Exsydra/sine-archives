  }

  .resonance-lab-shell[data-selected="distant"] .resonance-line--distant,
  .resonance-lab-shell[data-selected="dense"] .resonance-line--dense,
  .resonance-lab-shell[data-selected="orbit"] .resonance-line--orbit,
