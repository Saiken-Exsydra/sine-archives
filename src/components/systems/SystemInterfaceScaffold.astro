    transition: opacity 0.24s ease, fill 0.24s ease, stroke 0.24s ease;
  }

  .resonance-lab-shell.is-field-visible .resonance-field-halo,
  .resonance-field-halo.is-selected,
  .resonance-field-halo:hover,
  .resonance-field-halo:focus-visible {
