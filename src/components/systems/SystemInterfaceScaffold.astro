    border-radius: 50%;
    background:
      conic-gradient(from 28deg, transparent, rgba(176, 141, 60, 0.12), transparent 20%, rgba(177, 58, 52, 0.1), transparent 48%, rgba(232, 228, 220, 0.08), transparent 68%),
      radial-gradient(circle, transparent 0 58%, rgba(232, 228, 220, 0.05) 58.4% 58.8%, transparent 59.2%);
    mask-image: radial-gradient(circle, transparent 0 24%, #000 25% 72%, transparent 73%);
