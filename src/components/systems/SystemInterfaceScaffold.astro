              <g class="resonance-node resonance-node--distant" data-node-id="distant" data-lab-node="different" data-panel-state="different" data-node-kind="distant" role="button" tabindex="0" aria-label="Too Different">
                <circle r="46" />
                <text y="-5">Too</text>
                <text y="11">Different</text>
              </g>

              <g class="resonance-node resonance-node--dense" data-node-id="dense" data-lab-node="heavy" data-panel-state="heavy" data-node-kind="dense" role="button" tabindex="0" aria-label="The Heavy Pattern">
                <circle r="70" />
                <circle class="resonance-node__core" r="16" />
                <text y="-12">The Heavy</text>
                <text y="5">Pattern</text>
              </g>

              <g class="resonance-node resonance-node--orbit" data-node-id="orbit" data-lab-node="nearby" data-panel-state="nearby" data-node-kind="orbiting" role="button" tabindex="0" aria-label="Caught Nearby">
                <circle r="34" />
                <text y="-5">Caught</text>
                <text y="10">Nearby</text>
              </g>

