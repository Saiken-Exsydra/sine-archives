    inset: 126px 18px 86px;
    overflow: hidden;
    border: 1px solid rgba(232, 228, 220, 0.11);
    border-radius: 6px;
    background:
      radial-gradient(circle at 50% 52%, rgba(232, 228, 220, calc(var(--field-strength, 0.48) * 0.18)), transparent 15rem),
      radial-gradient(circle at 39% 48%, rgba(176, 141, 60, calc(var(--field-strength, 0.48) * 0.13)), transparent 18rem),
      radial-gradient(circle at 72% 70%, rgba(177, 58, 52, 0.1), transparent 13rem),
      linear-gradient(180deg, rgba(3, 5, 10, 0.94), rgba(0, 2, 5, 0.72));
    box-shadow:
      inset 0 0 72px rgba(0, 0, 0, 0.62),
      inset 0 0 0 1px rgba(255, 255, 255, 0.025);
