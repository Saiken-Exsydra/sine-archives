  }

  .resonance-line,
  .resonance-added-link {
    fill: none;
    stroke: rgba(232, 228, 220, 0.22);
    stroke-linecap: round;
    stroke-width: 1;
    pointer-events: none;
  }

  .resonance-line--primary {
    stroke: rgba(246, 247, 241, calc(0.16 + var(--line-strength, 0.62) * 0.66));
    stroke-width: calc(0.75px + var(--line-strength, 0.62) * 2px);
    filter: drop-shadow(0 0 8px rgba(232, 228, 220, calc(var(--line-strength, 0.62) * 0.22)));
  }

  .resonance-line--distant {
    stroke-dasharray: 4 10;
    opacity: 0.32;
  }

  .resonance-line--dense {
    opacity: 0.58;
  }

  .resonance-line--orbit {
    stroke-dasharray: 2 7;
    opacity: 0.4;
  }

  .resonance-link-hit {
    fill: none;
    stroke: rgba(255, 255, 255, 0.001);
    stroke-linecap: round;
    stroke-width: 14;
    cursor: pointer;
    pointer-events: stroke;
  }

  .resonance-line-touch {
    fill: rgba(232, 228, 220, 0.001);
    stroke: rgba(232, 228, 220, 0.12);
    stroke-width: 1;
    cursor: pointer;
    opacity: 0.42;
    transition: opacity 0.2s ease, stroke 0.2s ease, fill 0.2s ease;
  }

  .resonance-line-touch:hover,
  .resonance-line-touch:focus-visible,
  .resonance-line-touch.is-selected {
    fill: rgba(232, 228, 220, 0.05);
    stroke: rgba(246, 247, 241, 0.56);
    opacity: 1;
  }

  .resonance-lab-shell.is-gradient-visible .resonance-line--primary {
    stroke-dasharray: 6 12;
    animation: pressureDrift 5s linear infinite;
  }

  .resonance-ripple {
    fill: none;
    stroke: rgba(232, 228, 220, 0);
    stroke-width: 1.2;
    pointer-events: none;
  }

  .resonance-lab-shell.is-disturbed .resonance-ripple {
    animation: resonanceRipple 1.35s ease-out;
  }

  .resonance-lab-shell.is-cascade .resonance-ripple {
    stroke: rgba(177, 58, 52, 0.72);
  }

  .resonance-lab-shell.is-damped .resonance-ripple {
    stroke: rgba(232, 228, 220, 0.58);
  }

  .resonance-node {
    cursor: pointer;
    outline: none;
    transform-box: fill-box;
    transform-origin: center;
  }

  .resonance-node circle {
    fill: rgba(2, 6, 10, 0.92);
    stroke: rgba(232, 228, 220, 0.2);
    stroke-width: 1;
    filter:
      drop-shadow(0 0 14px rgba(166, 184, 196, 0.06))
      drop-shadow(0 8px 18px rgba(0, 0, 0, 0.3));
    transition: fill 0.22s ease, stroke 0.22s ease, stroke-width 0.22s ease, filter 0.22s ease, opacity 0.22s ease;
  }

  .resonance-node text {
    fill: rgba(232, 228, 220, 0.74);
    font-family: "DM Sans", sans-serif;
