    stroke: rgba(176, 141, 60, 0.78);
  }

  .resonance-node.is-selected text {
    fill: rgba(246, 239, 226, 0.96);
  }

  .resonance-node:focus-visible {
    filter: drop-shadow(0 0 0 rgba(0, 0, 0, 0));
  }

  .resonance-lab-shell[data-hover="match"] .resonance-node--a circle,
  .resonance-lab-shell[data-hover="match"] .resonance-node--similar circle,
