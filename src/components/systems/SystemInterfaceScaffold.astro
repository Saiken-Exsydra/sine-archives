---
import MainLayout from "../../layouts/MainLayout.astro";
import { localizedPath, type SiteLocale } from "../../i18n/config";
import { getArchiveNavLabels, sectionLabel } from "../../i18n/ui";

type Props = {
  locale?: SiteLocale;
  id: "resonance" | "harmonics";
  title: string;
  pageTitle: string;
  logo: string;
  eyebrow: string;
  summary: string;
  mechanism: string;
  interfaceLabel: string;
  transitionName: string;
};

const {
  locale = "en",
  id,
  title,
  pageTitle,
  logo,
  eyebrow,
  summary,
  mechanism,
  interfaceLabel,
  transitionName,
} = Astro.props;
const navLabels = getArchiveNavLabels(locale);
const observatoryHref = localizedPath(locale, "/systems/observatory/");
---

<MainLayout
  active="systems"
  pageTitle={pageTitle}
  locale={locale}
  navVariant="entry"
  hideFooter={true}
  pageClass={`system-interface-page system-interface-page--${id}`}
  routeKind="generic"
  transitionProfile="system-interface"
  navTrail={[
    { label: navLabels.index, href: localizedPath(locale, "/") },
    { label: sectionLabel(locale, "systems"), href: localizedPath(locale, "/systems/") },
    { label: "Observatory", href: observatoryHref },
    { label: title },
  ]}
>
  <section class="system-interface" data-system-interface={id}>
    <div class="system-interface__field" aria-hidden="true"></div>
    <header class="system-interface__header">
      <p>{eyebrow}</p>
      <h1>{title}</h1>
      <span>Interactive interface scaffold</span>
    </header>

    <div class="system-interface__stage">
      <div class="system-interface__orb" aria-hidden="true">
        <span
          class="system-interface__symbol"
          style={`view-transition-name: ${transitionName};`}
        >
          <img src={logo} alt="" loading="eager" decoding="async" />
        </span>
      </div>

      <aside class="system-interface__panel" aria-labelledby={`${id}-interface-title`}>
        <p class="system-interface__kicker">Filed Mechanism</p>
        <h2 id={`${id}-interface-title`}>{mechanism}</h2>
        <p>{summary}</p>
        <dl>
          <div>
            <dt>Interface</dt>
            <dd>{interfaceLabel}</dd>
          </div>
          <div>
            <dt>Status</dt>
            <dd>Interactive archive pending reconstruction.</dd>
          </div>
        </dl>
        <a href={observatoryHref} data-astro-prefetch="load">Return to Observatory</a>
      </aside>
    </div>
  </section>
</MainLayout>

<style>
  .system-interface {
    position: relative;
    min-height: calc(100svh - var(--nav-height, 56px));
    overflow: hidden;
    padding: clamp(48px, 6vw, 84px) clamp(18px, 5vw, 72px) 78px;
    background:
      radial-gradient(circle at 48% 48%, rgba(232, 228, 220, 0.08), transparent 26rem),
      radial-gradient(circle at 58% 42%, rgba(177, 58, 52, 0.08), transparent 38rem),
      linear-gradient(180deg, #050407, #030407 52%, #050407);
    color: var(--text);
  }

  .system-interface__field,
  .system-interface::before,
  .system-interface::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .system-interface__field {
    opacity: 0.44;
    background:
      repeating-radial-gradient(circle at 48% 52%, rgba(232, 228, 220, 0.11) 0 1px, transparent 1px 16px),
      repeating-linear-gradient(112deg, rgba(232, 228, 220, 0.055) 0 1px, transparent 1px 34px);
    mask-image: radial-gradient(circle at 48% 52%, #000 0 34%, transparent 68%);
  }

  .system-interface::before {
    background:
      radial-gradient(circle at 18% 12%, rgba(176, 141, 60, 0.08), transparent 24rem),
      radial-gradient(circle at 90% 70%, rgba(84, 133, 166, 0.08), transparent 26rem);
  }

  .system-interface::after {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.16), transparent 28%, rgba(0, 0, 0, 0.34));
  }

  .system-interface__header,
  .system-interface__stage {
    position: relative;
    z-index: 1;
  }

  .system-interface__header {
    max-width: 900px;
    margin: 0 auto clamp(30px, 5vw, 58px);
    text-align: center;
  }

  .system-interface__header p,
  .system-interface__header span,
  .system-interface__kicker,
  .system-interface dt {
    font-family: "DM Sans", sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .system-interface__header p,
  .system-interface__kicker,
  .system-interface dt {
    color: rgba(176, 141, 60, 0.84);
  }

  .system-interface__header h1 {
    margin: 10px 0;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(54px, 8vw, 104px);
    line-height: 0.92;
    color: rgba(246, 239, 226, 0.98);
  }

  .system-interface__header span {
    color: rgba(232, 228, 220, 0.42);
  }

  .system-interface__stage {
    display: grid;
    grid-template-columns: minmax(320px, 1fr) minmax(280px, 390px);
    gap: clamp(28px, 5vw, 78px);
    align-items: center;
    max-width: 1180px;
    margin: 0 auto;
  }

  .system-interface__orb {
    position: relative;
    display: grid;
    place-items: center;
    min-height: clamp(360px, 50vw, 620px);
  }

  .system-interface__orb::before,
  .system-interface__orb::after {
    content: "";
    position: absolute;
    width: min(62vw, 560px);
    aspect-ratio: 1;
    border-radius: 50%;
  }

  .system-interface__orb::before {
    border: 1px solid rgba(232, 228, 220, 0.18);
    box-shadow:
      inset 0 0 80px rgba(232, 228, 220, 0.035),
      0 0 70px rgba(176, 141, 60, 0.08);
  }

  .system-interface__orb::after {
    width: min(48vw, 430px);
    background:
      radial-gradient(circle, rgba(246, 239, 226, 0.16), transparent 18%),
      conic-gradient(from 20deg, transparent, rgba(232, 228, 220, 0.16), transparent, rgba(177, 58, 52, 0.14), transparent);
    filter: blur(0.2px);
    opacity: 0.72;
    animation: scaffoldOrbit 36s linear infinite;
  }

  .system-interface__symbol {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    width: clamp(190px, 24vw, 300px);
    aspect-ratio: 1;
    border: 1px solid rgba(232, 228, 220, 0.22);
    border-radius: 8px;
    background:
      radial-gradient(circle at 50% 48%, rgba(246, 239, 226, 0.15), transparent 60%),
      rgba(3, 6, 10, 0.72);
    box-shadow:
      inset 0 0 42px rgba(232, 228, 220, 0.04),
      0 22px 70px rgba(0, 0, 0, 0.34);
  }

  .system-interface__symbol img {
    width: 84%;
    height: 84%;
    object-fit: contain;
    opacity: 0.96;
    filter: drop-shadow(0 0 18px rgba(232, 228, 220, 0.22));
  }

  .system-interface__panel {
    position: relative;
    padding: 24px;
    border: 1px solid rgba(232, 228, 220, 0.18);
    border-radius: 8px;
    background:
      radial-gradient(circle at 8% 0%, rgba(176, 141, 60, 0.09), transparent 38%),
      linear-gradient(145deg, rgba(7, 8, 13, 0.94), rgba(1, 4, 8, 0.88));
  }

  .system-interface__panel h2 {
    margin: 8px 0 12px;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(34px, 4vw, 48px);
    line-height: 1;
  }

  .system-interface__panel p,
  .system-interface dd {
    font-family: "DM Sans", sans-serif;
    font-size: 13px;
    line-height: 1.7;
    color: rgba(232, 228, 220, 0.64);
  }

  .system-interface dl {
    display: grid;
    gap: 12px;
    margin: 20px 0 0;
  }

  .system-interface dl div {
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .system-interface dd {
    margin: 4px 0 0;
  }

  .system-interface a {
    display: inline-flex;
    margin-top: 22px;
    padding: 10px 14px;
    border: 1px solid rgba(177, 58, 52, 0.62);
    border-radius: 4px;
    color: rgba(242, 223, 218, 0.92);
    text-decoration: none;
    font-family: "DM Sans", sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .system-interface a:hover,
  .system-interface a:focus-visible {
    background: rgba(122, 42, 56, 0.22);
    outline: 2px solid rgba(232, 228, 220, 0.74);
    outline-offset: 4px;
  }

  @keyframes scaffoldOrbit {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 820px) {
    .system-interface {
      padding-inline: 16px;
    }

    .system-interface__header {
      text-align: left;
    }

    .system-interface__stage {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .system-interface__orb::after {
      animation: none;
    }
  }
</style>
