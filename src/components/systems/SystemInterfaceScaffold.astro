    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(232, 228, 220, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(232, 228, 220, 0.018) 1px, transparent 1px);
    background-size: 100% 34px, 42px 100%;
    mask-image: radial-gradient(circle at 50% 50%, #000 0 48%, transparent 82%);
    pointer-events: none;
  }

  .resonance-fieldboard::after {
    content: "";
    position: absolute;
    inset: 9%;
