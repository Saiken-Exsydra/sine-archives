    pointer-events: none;
    animation: resonanceApertureTurn 54s linear infinite;
  }

  .resonance-field-note {
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 14px;
    z-index: 3;
    margin: 0;
    padding: 8px 10px;
    border: 1px solid rgba(232, 228, 220, 0.1);
    border-radius: 4px;
    background: rgba(1, 4, 8, 0.7);
    color: rgba(232, 228, 220, 0.58);
    font-family: "DM Sans", sans-serif;
    font-size: 11px;
    line-height: 1.45;
