  .resonance-added-link {
    opacity: 0.32;
    stroke-width: 0.8;
  }

  .resonance-added-link--similar {
    stroke: rgba(232, 228, 220, 0.32);
  }

  .resonance-added-link--thin {
    stroke: rgba(166, 184, 196, 0.26);
