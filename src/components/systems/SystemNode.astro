---
type Props = {
  id: string;
  title: string;
  summary: string;
  logo: string;
  angle: number;
  x: number;
  y: number;
  href?: string;
  action?: string;
  transitionName?: string;
};

const { id, title, summary, logo, angle, x, y, href, action, transitionName } = Astro.props;
const Tag = href ? "a" : "button";
const label = action ? `${action}: ${summary}` : `${title}: ${summary}`;
---

<Tag
  class="observatory-node"
  type={href ? undefined : "button"}
  href={href}
  data-system-node={id}
  data-system-launch={href ? id : undefined}
  data-system-transition-name={transitionName}
  data-transition-trigger={href ? "observatory-system" : undefined}
  data-astro-prefetch={href ? "load" : undefined}
  data-angle={angle}
  style={`--node-x: ${x}%; --node-y: ${y}%;`}
  aria-label={label}
>
  <span class="observatory-node__dot" aria-hidden="true"></span>
  <span
    class="observatory-node__mark"
    data-system-mark
    aria-hidden="true"
  >
    <img src={logo} alt="" loading="eager" decoding="async" />
  </span>
  <span class="observatory-node__label">{title}</span>
  <span class="observatory-node__summary">{summary}</span>
</Tag>
