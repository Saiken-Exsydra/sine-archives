---
import type { SiteLocale } from "../../i18n/config";
import { getRedactoryDiveContent } from "../../data/redactory-dive";
import DepthMeter from "./DepthMeter.astro";
import DepthSection from "./DepthSection.astro";
import InkFlowBackground from "./InkFlowBackground.astro";

interface Props {
  locale?: SiteLocale;
  enableCanvas?: boolean;
}

const { locale = "en", enableCanvas = true } = Astro.props;
const content = getRedactoryDiveContent(locale);
const depthItems = content.sections.map((section) => ({ id: section.id, label: section.depthLabel }));
---

<article class="redactory-dive" data-redactory-dive data-current-depth="surface">
  <InkFlowBackground enableCanvas={enableCanvas} />

  <header class="redactory-dive__hero">
    <div class="redactory-dive__inkwell" transition:name="redactory-inkpot" aria-hidden="true">
      <span></span>
    </div>
    <span class="redactory-dive__eyebrow">{content.eyebrow}</span>
    <h1>{content.title}</h1>
    <p>{content.intro}</p>
    <a class="redactory-dive__scroll" href="#surface">
      {content.scrollLabel}
      <span aria-hidden="true"></span>
    </a>
  </header>

  <aside class="redactory-dive__legend" aria-labelledby="dive-legend-title">
    <h2 id="dive-legend-title">{content.legendTitle}</h2>
    <ol>
      {content.legend.map((item) => (
        <li>
          <strong>{item.term}</strong>
          <span>{item.explanation}</span>
        </li>
      ))}
    </ol>
  </aside>

  <section class="redactory-dive__seals" aria-labelledby="dive-seals-title">
    <div class="redactory-dive__seals-copy">
      <span class="redactory-dive__eyebrow">Anchor notation</span>
      <h2 id="dive-seals-title">{content.sealTitle}</h2>
      <p>{content.sealIntro}</p>
    </div>
    <ol class="redactory-dive__seal-list">
        {content.seals.map((seal, index) => (
          <li class={`redactory-dive__seal-card redactory-dive__seal-card--${index}`} style={`--seal-symbol: url("${seal.symbolAsset}");`}>
            <span class="redactory-dive__seal-symbol" role="img" aria-label={seal.alt}></span>
            <div>
              <span>{seal.eyebrow}</span>
              <strong>{seal.label}</strong>
            <p>{seal.summary}</p>
            <em>{seal.depth}</em>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <div class="redactory-dive__layout">
    <DepthMeter items={depthItems} />
    <div class="redactory-dive__sections">
      {content.sections.map((section, index) => (
        <DepthSection
          {...section}
          depthIndex={index}
          shoresStatus={content.returnLabel}
          locale={locale}
        />
      ))}
    </div>
  </div>
</article>

<script is:inline>
  window.registerPageInit?.("redactory-dive-depth", () => {
    const dive = document.querySelector("[data-redactory-dive]");
    if (!(dive instanceof HTMLElement)) return;

    const sections = Array.from(dive.querySelectorAll("[data-depth-section]"));
    const markers = Array.from(dive.querySelectorAll("[data-depth-marker]"));
    if (!sections.length) return;

    const setDepth = (section) => {
      if (!(section instanceof HTMLElement)) return;
      const index = Number.parseInt(section.dataset.depthIndex || "0", 10);
      const key = section.dataset.depthKey || "surface";
      document.documentElement.style.setProperty("--ink-depth", String(index));
      dive.dataset.currentDepth = key;

      markers.forEach((marker, markerIndex) => {
        const current = markerIndex === index;
        marker.classList.toggle("is-current", current);
        if (current) marker.setAttribute("aria-current", "step");
        else marker.removeAttribute("aria-current");
      });
    };

    setDepth(sections[0]);
    const observer = new IntersectionObserver((entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (visible) setDepth(visible.target);
    }, {
      rootMargin: "-28% 0px -48% 0px",
      threshold: [0.12, 0.3, 0.55],
    });

    sections.forEach((section) => observer.observe(section));
    return () => {
      observer.disconnect();
      document.documentElement.style.removeProperty("--ink-depth");
      delete dive.dataset.currentDepth;
    };
  });
</script>

<style>
  :global(:root) {
    --ink-black: #02030a;
    --ink-blue: #243e69;
    --ink-red: #681f24;
    --ink-silver: #aeb9ca;
    --ink-depth: 0;
  }

  .redactory-dive {
    --depth-background:
      radial-gradient(circle at 50% 16%, rgba(41, 76, 132, 0.3), transparent 42%),
      linear-gradient(180deg, #07101f 0%, #030712 72%, #020309 100%);
    --depth-blue-wash: 0.18;
    --depth-red-wash: 0.04;
    --depth-vignette: 0.48;
    --depth-compression: 18%;
    position: relative;
    min-height: 100vh;
    overflow: clip;
    isolation: isolate;
    background: var(--ink-black);
  }

  .redactory-dive[data-current-depth="shallow"],
  .redactory-dive[data-current-depth="practical"] {
    --depth-background:
      radial-gradient(circle at 50% 22%, rgba(51, 93, 155, 0.32), transparent 40%),
      linear-gradient(180deg, #07101d 0%, #040914 66%, #02040a 100%);
    --depth-blue-wash: 0.24;
    --depth-red-wash: 0.05;
    --depth-vignette: 0.52;
    --depth-compression: 21%;
  }

  .redactory-dive[data-current-depth="deepening"] {
    --depth-background:
      radial-gradient(ellipse at 50% 32%, rgba(35, 58, 97, 0.24), transparent 34%),
      linear-gradient(180deg, #050a13 0%, #02040a 62%, #010205 100%);
    --depth-blue-wash: 0.14;
    --depth-red-wash: 0.07;
    --depth-vignette: 0.66;
    --depth-compression: 27%;
  }

  .redactory-dive[data-current-depth="deep-anchor"] {
    --depth-background:
      radial-gradient(ellipse at 50% 36%, rgba(37, 52, 82, 0.2), transparent 32%),
      linear-gradient(180deg, #040810 0%, #020308 64%, #010104 100%);
    --depth-blue-wash: 0.1;
    --depth-red-wash: 0.1;
    --depth-vignette: 0.7;
    --depth-compression: 29%;
  }

  .redactory-dive[data-current-depth="near-strata"] {
    --depth-background:
      radial-gradient(ellipse at 56% 44%, rgba(105, 32, 38, 0.18), transparent 36%),
      radial-gradient(circle at 24% 22%, rgba(28, 51, 88, 0.15), transparent 30%),
      linear-gradient(180deg, #04070d 0%, #030306 72%, #010103 100%);
    --depth-blue-wash: 0.08;
    --depth-red-wash: 0.16;
    --depth-vignette: 0.72;
    --depth-compression: 31%;
  }

  .redactory-dive[data-current-depth="strata"] {
    --depth-background:
      radial-gradient(ellipse at 50% 56%, rgba(74, 27, 31, 0.1), transparent 28%),
      linear-gradient(180deg, #030407 0%, #010103 58%, #000001 100%);
    --depth-blue-wash: 0.03;
    --depth-red-wash: 0.08;
    --depth-vignette: 0.8;
    --depth-compression: 35%;
  }

  .redactory-dive[data-current-depth="abyssal"],
  .redactory-dive[data-current-depth="abyssal-warning"],
  .redactory-dive[data-current-depth="boundary"] {
    --depth-background:
      radial-gradient(ellipse at 50% 52%, rgba(48, 18, 22, 0.07), transparent 22%),
      linear-gradient(180deg, #010103 0%, #000001 55%, #000 100%);
    --depth-blue-wash: 0.01;
    --depth-red-wash: 0.035;
    --depth-vignette: 0.9;
    --depth-compression: 39%;
  }

  .redactory-dive__hero,
  .redactory-dive__legend,
  .redactory-dive__seals,
  .redactory-dive__layout {
    position: relative;
    z-index: 2;
  }

  .redactory-dive__hero {
    display: flex;
    min-height: calc(100svh - var(--nav-height, 56px));
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px 126px;
    text-align: center;
  }

  .redactory-dive__hero::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -1px;
    width: 1px;
    height: 116px;
    background: linear-gradient(to bottom, rgba(111, 151, 214, 0.12), rgba(111, 151, 214, 0.72));
  }

  .redactory-dive__inkwell {
    position: relative;
    display: grid;
    width: clamp(126px, 17vw, 190px);
    aspect-ratio: 1;
    margin-bottom: 24px;
    place-items: center;
    border: 1px solid rgba(119, 151, 204, 0.2);
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 45%, rgba(52, 91, 155, 0.23), transparent 31%),
      radial-gradient(circle, rgba(2, 3, 8, 0.92), rgba(0, 0, 3, 0.98) 68%);
    box-shadow: inset 0 0 45px rgba(45, 75, 127, 0.13), 0 0 70px rgba(29, 58, 106, 0.16);
  }

  .redactory-dive__inkwell span {
    width: 49%;
    aspect-ratio: 1;
    border-radius: 48% 52% 57% 43%;
    background:
      radial-gradient(circle at 38% 35%, rgba(94, 131, 194, 0.28), transparent 24%),
      #010208;
    box-shadow: 0 0 28px rgba(61, 102, 168, 0.22), inset 0 0 20px rgba(91, 118, 166, 0.12);
    animation: diveInkwell 9s ease-in-out infinite alternate;
  }

  .redactory-dive__eyebrow {
    font-family: "DM Sans", sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(126, 159, 213, 0.76);
  }

  h1 {
    margin: 7px 0 15px;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(76px, 13vw, 150px);
    line-height: 0.84;
    color: var(--text);
    text-shadow: 0 20px 70px rgba(0, 0, 0, 0.64);
  }

  .redactory-dive__hero p {
    max-width: 650px;
    margin: 0;
    font-family: "DM Sans", sans-serif;
    font-size: clamp(13px, 1.8vw, 16px);
    line-height: 1.75;
    color: rgba(232, 228, 220, 0.62);
  }

  .redactory-dive__scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-top: 48px;
    font-family: "DM Sans", sans-serif;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.4);
    text-decoration: none;
  }

  .redactory-dive__scroll span {
    width: 1px;
    height: 34px;
    background: linear-gradient(to bottom, rgba(126, 159, 213, 0.78), transparent);
    transition: height 240ms ease;
  }

  .redactory-dive__scroll:hover,
  .redactory-dive__scroll:focus-visible {
    color: rgba(232, 228, 220, 0.78);
  }

  .redactory-dive__scroll:hover span,
  .redactory-dive__scroll:focus-visible span {
    height: 46px;
  }

  .redactory-dive__scroll:focus-visible {
    outline: 2px solid rgba(218, 227, 243, 0.94);
    outline-offset: 7px;
  }

  .redactory-dive__layout {
    width: min(100%, 1540px);
    margin: 0 auto;
    padding-bottom: 120px;
  }

  .redactory-dive__legend {
    width: min(1120px, calc(100% - 48px));
    margin: -70px auto 70px;
    padding: 24px;
    border: 1px solid rgba(139, 166, 207, 0.13);
    background: rgba(4, 8, 16, 0.78);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(14px);
  }

  .redactory-dive__legend h2 {
    margin: 0 0 18px;
    font-family: "DM Sans", sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(151, 181, 226, 0.8);
  }

  .redactory-dive__legend ol {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 1px;
    margin: 0;
    padding: 0;
    list-style: none;
    background: rgba(139, 166, 207, 0.11);
  }

  .redactory-dive__legend li {
    display: grid;
    gap: 5px;
    padding: 14px;
    background: rgba(3, 6, 12, 0.96);
  }

  .redactory-dive__legend strong,
  .redactory-dive__legend span {
    font-family: "DM Sans", sans-serif;
  }

  .redactory-dive__legend strong {
    font-size: 11px;
    color: rgba(239, 236, 229, 0.88);
  }

  .redactory-dive__legend span {
    font-size: 11px;
    line-height: 1.45;
    color: rgba(239, 236, 229, 0.52);
  }

  .redactory-dive__seals {
    display: grid;
    width: min(1120px, calc(100% - 48px));
    grid-template-columns: minmax(220px, 0.68fr) minmax(0, 1.32fr);
    gap: clamp(22px, 4vw, 48px);
    align-items: stretch;
    margin: 0 auto 80px;
    padding: clamp(22px, 4vw, 34px);
    border: 1px solid rgba(139, 166, 207, 0.14);
    background:
      radial-gradient(circle at 12% 18%, rgba(51, 93, 155, 0.12), transparent 34%),
      rgba(4, 8, 16, 0.74);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(14px);
  }

  .redactory-dive__seals-copy {
    display: grid;
    align-content: center;
    gap: 14px;
  }

  .redactory-dive__seals-copy h2 {
    margin: 0;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(34px, 4.2vw, 54px);
    font-weight: 500;
    line-height: 0.98;
    color: rgba(239, 236, 229, 0.92);
  }

  .redactory-dive__seals-copy p {
    margin: 0;
    font-family: "DM Sans", sans-serif;
    font-size: 13.5px;
    line-height: 1.7;
    color: rgba(239, 236, 229, 0.62);
  }

  .redactory-dive__seal-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .redactory-dive__seal-list li {
    --seal-color: #91add9;
    --seal-glow: rgba(126, 172, 236, 0.26);
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 15px;
    min-width: 0;
    padding: 15px;
    border: 1px solid rgba(139, 166, 207, 0.13);
    background:
      linear-gradient(180deg, rgba(216, 211, 199, 0.035), transparent 40%),
      rgba(3, 6, 12, 0.86);
  }

  .redactory-dive__seal-card--1 {
    --seal-color: #5578b4;
    --seal-glow: rgba(55, 94, 155, 0.26);
  }

  .redactory-dive__seal-card--2 {
    --seal-color: #b13a34;
    --seal-glow: rgba(177, 58, 52, 0.24);
  }

  .redactory-dive__seal-symbol {
    display: block;
    width: min(158px, 100%);
    aspect-ratio: 1;
    justify-self: center;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--seal-color) 70%, #eff5ff), var(--seal-color));
    filter:
      drop-shadow(0 0 18px var(--seal-glow))
      drop-shadow(0 18px 28px rgba(0, 0, 0, 0.42));
    mask: var(--seal-symbol) center / contain no-repeat;
    -webkit-mask: var(--seal-symbol) center / contain no-repeat;
  }

  .redactory-dive__seal-list div {
    display: grid;
    gap: 7px;
    text-align: center;
  }

  .redactory-dive__seal-list span,
  .redactory-dive__seal-list em {
    font-family: "DM Sans", sans-serif;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(126, 159, 213, 0.7);
  }

  .redactory-dive__seal-list strong {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(23px, 2.5vw, 30px);
    font-weight: 600;
    line-height: 1;
    color: rgba(239, 236, 229, 0.9);
  }

  .redactory-dive__seal-list p {
    margin: 0;
    font-family: "DM Sans", sans-serif;
    font-size: 12px;
    line-height: 1.55;
    color: rgba(239, 236, 229, 0.58);
  }

  .redactory-dive__seal-list em {
    align-self: end;
    font-style: normal;
    color: rgba(164, 78, 73, 0.72);
  }

  .redactory-dive__sections {
    position: relative;
    min-width: 0;
  }

  .redactory-dive__sections::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    z-index: 1;
    width: 2px;
    background:
      linear-gradient(
        to bottom,
        rgba(87, 130, 199, 0.68) 0%,
        rgba(65, 100, 159, 0.64) 25%,
        rgba(73, 64, 91, 0.64) 48%,
        rgba(121, 47, 51, 0.62) 68%,
        rgba(55, 25, 29, 0.72) 84%,
        rgba(3, 3, 6, 0.94) 100%
      );
    box-shadow: 0 0 25px rgba(58, 93, 151, 0.18);
    transform: translateX(-50%);
  }

  @keyframes diveInkwell {
    from { transform: rotate(-5deg) scale(0.94); border-radius: 48% 52% 57% 43%; }
    to { transform: rotate(7deg) scale(1.04); border-radius: 57% 43% 46% 54%; }
  }

  @media (max-width: 900px) {
    .redactory-dive__hero::after,
    .redactory-dive__sections::before {
      left: 37px;
    }

    .redactory-dive__hero {
      padding-bottom: 118px;
    }

    .redactory-dive__legend {
      width: calc(100% - 32px);
      margin-bottom: 34px;
      overflow-x: auto;
    }

    .redactory-dive__legend ol {
      grid-template-columns: repeat(7, minmax(150px, 1fr));
    }

    .redactory-dive__seals {
      width: calc(100% - 32px);
      grid-template-columns: 1fr;
      margin-bottom: 38px;
    }

    .redactory-dive__seals-copy {
      max-width: 640px;
      text-align: center;
      justify-self: center;
    }

    .redactory-dive__seal-list {
      grid-template-columns: repeat(3, minmax(160px, 1fr));
      overflow-x: auto;
    }
  }

  @media (max-width: 520px) {
    .redactory-dive__seal-list {
      grid-template-columns: 1fr;
      overflow-x: visible;
    }

    .redactory-dive__seal-list li {
      min-height: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .redactory-dive__inkwell span {
      animation: none;
    }

    .redactory-dive__scroll span {
      transition: none;
    }
  }
</style>
