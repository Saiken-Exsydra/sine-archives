---
const { html } = Astro.props as { html: string };
---

<article class="dossier-prose" data-dossier-prose data-character-prose set:html={html} />

<style>
  .dossier-prose {
    counter-reset: dossier-section;
    color: var(--char-text-muted, rgba(232, 228, 220, 0.68));
    overflow-wrap: anywhere;
  }

  .dossier-prose :global(h2) {
    display: grid;
    grid-template-columns: auto auto minmax(2rem, 1fr);
    align-items: center;
    gap: 16px;
    margin: 3.75rem 0 1.35rem;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2.05rem, 3.2vw, 2.9rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--char-text, #e8e4dc);
    scroll-margin-top: 7.5rem;
  }

  .dossier-prose :global(h2:first-child) {
    margin-top: 0;
  }

  .dossier-prose :global(h2)::before {
    counter-increment: dossier-section;
    content: counter(dossier-section, decimal-leading-zero);
    font-family: "DM Sans", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--char-crimson, #b13a34);
    align-self: center;
    transform: translateY(0.1em);
  }

  .dossier-prose :global(h2)::after {
    content: "";
    height: 1px;
    background:
      linear-gradient(90deg, rgba(177, 58, 52, 0.38), rgba(255, 255, 255, 0.08) 38%, transparent 100%);
  }

  .dossier-prose :global(h3) {
    margin: 2rem 0 0.9rem;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    font-family: "DM Sans", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.5);
    max-width: 76ch;
  }

  .dossier-prose :global(p),
  .dossier-prose :global(ul),
  .dossier-prose :global(ol),
  .dossier-prose :global(dl),
  .dossier-prose :global(blockquote),
  .dossier-prose :global(pre) {
    max-width: 76ch;
  }

  .dossier-prose :global(p),
  .dossier-prose :global(li),
  .dossier-prose :global(td),
  .dossier-prose :global(dd) {
    font-size: 0.97rem;
    line-height: 1.9;
    color: rgba(232, 228, 220, 0.66);
    text-wrap: pretty;
  }

  .dossier-prose :global(p) {
    margin: 0 0 1rem;
  }

  .dossier-prose :global(h2 + p) {
    color: rgba(232, 228, 220, 0.78);
  }

  .dossier-prose :global(strong) {
    color: rgba(232, 228, 220, 0.92);
    font-weight: 650;
  }

  .dossier-prose :global(em) {
    color: rgba(176, 141, 60, 0.86);
    font-style: italic;
  }

  .dossier-prose :global(a:not(.archive-ref__link)) {
    color: rgba(232, 228, 220, 0.86);
    text-decoration: none;
    border-bottom: 1px solid rgba(176, 141, 60, 0.42);
    box-shadow: inset 0 -0.1em 0 rgba(176, 141, 60, 0.12);
    transition: color 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .dossier-prose :global(a:not(.archive-ref__link):hover),
  .dossier-prose :global(a:not(.archive-ref__link):focus-visible) {
    color: var(--char-text, #e8e4dc);
    border-bottom-color: rgba(177, 58, 52, 0.76);
    box-shadow: inset 0 -0.16em 0 rgba(177, 58, 52, 0.18);
    outline: none;
  }

  .dossier-prose :global(.archive-ref) {
    vertical-align: baseline;
  }

  .dossier-prose :global(.archive-ref__link) {
    display: inline-flex;
    align-items: center;
    min-height: 1.55rem;
    padding: 0 0.45rem;
    border: 1px solid rgba(176, 141, 60, 0.2);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(176, 141, 60, 0.08), rgba(176, 141, 60, 0.02)),
      rgba(12, 11, 16, 0.92);
    color: rgba(232, 228, 220, 0.88);
    box-shadow: none;
    line-height: 1.15;
  }

  .dossier-prose :global(.archive-ref__link:hover),
  .dossier-prose :global(.archive-ref__link:focus-visible) {
    border-color: rgba(177, 58, 52, 0.45);
    background:
      linear-gradient(180deg, rgba(177, 58, 52, 0.14), rgba(177, 58, 52, 0.04)),
      rgba(12, 11, 16, 0.98);
    color: var(--char-text, #e8e4dc);
    box-shadow: none;
  }

  .dossier-prose :global(blockquote) {
    position: relative;
    margin: 1.8rem 0 2rem;
    padding: 1.1rem 1.25rem 1.15rem 1.3rem;
    border: 1px solid rgba(177, 58, 52, 0.16);
    border-left: 2px solid rgba(177, 58, 52, 0.58);
    border-radius: 0 0.9rem 0.9rem 0;
    background:
      radial-gradient(circle at 100% 0%, rgba(176, 141, 60, 0.07), transparent 24%),
      rgba(12, 10, 16, 0.76);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .dossier-prose :global(blockquote)::before {
    content: "\201C";
    position: absolute;
    top: 0.45rem;
    left: 0.65rem;
    font-family: "Cormorant Garamond", serif;
    font-size: 3.3rem;
    line-height: 1;
    color: rgba(255, 255, 255, 0.09);
    pointer-events: none;
  }

  .dossier-prose :global(blockquote p) {
    position: relative;
    margin: 0;
    padding-left: 1.4rem;
    font-family: "Cormorant Garamond", serif;
    font-size: 1.18rem;
    line-height: 1.55;
    font-style: italic;
    color: rgba(232, 228, 220, 0.8);
  }

  .dossier-prose :global(blockquote p + p) {
    margin-top: 0.65rem;
    font-family: "DM Sans", sans-serif;
    font-size: 0.77rem;
    font-style: normal;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.44);
  }

  .dossier-prose :global(ul),
  .dossier-prose :global(ol) {
    margin: 0 0 1.25rem;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }

  .dossier-prose :global(ul) {
    list-style: none;
  }

  .dossier-prose :global(ul > li) {
    position: relative;
    padding-left: 1.15rem;
  }

  .dossier-prose :global(ul > li)::before {
    content: "";
    position: absolute;
    top: 0.78rem;
    left: 0;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--char-crimson, #b13a34);
    box-shadow: 0 0 0 3px rgba(177, 58, 52, 0.12);
  }

  .dossier-prose :global(ol) {
    list-style: none;
    counter-reset: dossier-list;
  }

  .dossier-prose :global(ol > li) {
    position: relative;
    padding-left: 2rem;
  }

  .dossier-prose :global(ol > li)::before {
    counter-increment: dossier-list;
    content: counter(dossier-list, decimal-leading-zero);
    position: absolute;
    top: 0.02rem;
    left: 0;
    font-family: "DM Sans", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(177, 58, 52, 0.88);
  }

  .dossier-prose :global(li > ul),
  .dossier-prose :global(li > ol) {
    margin-top: 0.7rem;
    padding-top: 0.1rem;
  }

  .dossier-prose :global(hr) {
    max-width: 76ch;
    margin: 2.3rem 0;
    border: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(90deg, rgba(177, 58, 52, 0.32), rgba(255, 255, 255, 0.06), transparent 100%);
  }

  .dossier-prose :global(table) {
    display: block;
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0 2rem;
    overflow-x: auto;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.95rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01)),
      rgba(10, 10, 18, 0.82);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.02);
  }

  .dossier-prose :global(thead) {
    background: rgba(255, 255, 255, 0.03);
  }

  .dossier-prose :global(th),
  .dossier-prose :global(td) {
    padding: 0.85rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    vertical-align: top;
    text-align: left;
  }

  .dossier-prose :global(tr:last-child td) {
    border-bottom: 0;
  }

  .dossier-prose :global(th:last-child),
  .dossier-prose :global(td:last-child) {
    border-right: 0;
  }

  .dossier-prose :global(th) {
    font-family: "DM Sans", sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.52);
  }

  .dossier-prose :global(td) {
    color: rgba(232, 228, 220, 0.68);
  }

  .dossier-prose :global(code) {
    padding: 0.12rem 0.38rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.4rem;
    background: rgba(255, 255, 255, 0.03);
    font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
    font-size: 0.88em;
    color: rgba(232, 228, 220, 0.9);
  }

  .dossier-prose :global(pre) {
    margin: 1.35rem 0 1.75rem;
    padding: 1rem 1.1rem;
    overflow: auto;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.9rem;
    background: rgba(9, 9, 16, 0.94);
  }

  .dossier-prose :global(pre code) {
    padding: 0;
    border: 0;
    background: transparent;
  }

  @media (max-width: 700px) {
    .dossier-prose :global(h2) {
      grid-template-columns: auto 1fr;
      gap: 0.75rem 0.9rem;
      font-size: 2rem;
    }

    .dossier-prose :global(h2)::after {
      grid-column: 1 / -1;
    }

    .dossier-prose :global(h3) {
      max-width: 100%;
    }

    .dossier-prose :global(blockquote p) {
      font-size: 1.08rem;
    }

    .dossier-prose :global(th),
    .dossier-prose :global(td) {
      padding: 0.75rem 0.8rem;
    }
  }
</style>
