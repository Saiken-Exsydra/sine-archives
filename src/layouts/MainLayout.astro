---
import "../styles/global.css";
import {
  getHtmlLang,
  localizeCurrentPath,
  localizedPath,
  LOCALE_LABELS,
  LOCALES,
  type SiteLocale,
} from "../i18n/config";

const {
  pageTitle = "SiNE Archives",
  active = "home",
  locale = "en",
} = Astro.props;
const siteLocale = locale as SiteLocale;
const currentPath = Astro.url.pathname;
const searchLabel = siteLocale === "pt-br" ? "Buscar" : "Search";
const footerText = siteLocale === "pt-br"
  ? "ARQUIVOS SiNE · DISTRIBUICAO RESTRITA · TODOS OS REGISTROS SUJEITOS A REVISAO"
  : "SiNE ARCHIVES · RESTRICTED DISTRIBUTION · ALL RECORDS SUBJECT TO REVISION";
---

<!doctype html>
<html lang={getHtmlLang(siteLocale)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <nav class="nav" aria-label="Primary navigation">
      <a class="nav__logo" href={localizedPath(siteLocale, "/")}>
        <img src="/uploads/ui-sine-logo.png" alt="SiNE" class="nav__logo-img" />
        <span class="nav__logo-text">ARCHIVES</span>
      </a>

      <div class="nav__actions">
        <div class="nav__locale-switch" aria-label={siteLocale === "pt-br" ? "Seletor de idioma" : "Language switcher"}>
          {LOCALES.map((targetLocale) => (
            <a
              class={`nav__locale-pill${targetLocale === siteLocale ? " is-active" : ""}`}
              href={localizeCurrentPath(currentPath, targetLocale)}
              hreflang={getHtmlLang(targetLocale)}
              aria-current={targetLocale === siteLocale ? "page" : undefined}
            >
              {LOCALE_LABELS[targetLocale]}
            </a>
          ))}
        </div>
        <a class="nav__search-btn" href={localizedPath(siteLocale, "/search/")} aria-label={searchLabel}>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.4" />
            <line x1="10" y1="10" x2="14" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </svg>
        </a>
      </div>
    </nav>

    <main class="main">
      <slot />
    </main>

    <footer class="footer">
      <img src="/uploads/ui-sine-logo.png" alt="SiNE" class="footer__logo" />
      <span class="footer__text">{footerText}</span>
    </footer>
  </body>
</html>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    background: rgba(6, 6, 11, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav__logo-img {
    height: 26px;
    opacity: 0.9;
  }

  .nav__logo-text {
    font-family: "DM Sans", sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: rgba(232, 228, 220, 0.45);
    text-transform: uppercase;
  }

  .nav__search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    color: rgba(232, 228, 220, 0.5);
    text-decoration: none;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .nav__search-btn:hover {
    color: rgba(232, 228, 220, 0.9);
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav__locale-switch {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
  }

  .nav__locale-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 26px;
    padding: 0 10px;
    font-family: "DM Sans", sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.42);
    text-decoration: none;
    border-radius: 999px;
    transition: color 0.2s, background 0.2s;
  }

  .nav__locale-pill:hover {
    color: rgba(232, 228, 220, 0.9);
  }

  .nav__locale-pill.is-active {
    color: rgba(232, 228, 220, 0.96);
    background: rgba(177, 58, 52, 0.18);
  }

  .main {
    padding-top: 56px;
    min-height: 100vh;
  }

  .footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 60px 32px 48px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer__logo {
    height: 18px;
    opacity: 0.18;
  }

  .footer__text {
    font-family: "DM Sans", sans-serif;
    font-size: 10px;
    letter-spacing: 0.18em;
    color: rgba(232, 228, 220, 0.15);
    text-transform: uppercase;
    text-align: center;
  }

  @media (max-width: 768px) {
    .nav {
      padding: 0 16px;
    }

    .nav__logo-text {
      display: none;
    }

    .nav__locale-pill {
      padding: 0 8px;
      font-size: 8px;
      letter-spacing: 0.12em;
    }
  }
</style>
