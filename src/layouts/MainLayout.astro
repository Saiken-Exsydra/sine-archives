---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import MusicPlayer from "../components/MusicPlayer.astro";
import {
  getHtmlLang,
  localizeCurrentPath,
  localizedPath,
  LOCALE_LABELS,
  LOCALES,
  type SiteLocale,
} from "../i18n/config";

type NavTrailItem = {
  label: string;
  href?: string;
};

const {
  pageTitle = "SiNE Archives",
  active = "home",
  locale = "en",
  hideFooter = false,
  pageClass = "",
  navVariant = "default",
  navTrail = [],
} = Astro.props;
const siteLocale = locale as SiteLocale;
const currentPath = Astro.url.pathname;
const searchLabel = siteLocale === "pt-br" ? "Buscar" : "Search";
const fullscreenLabel = siteLocale === "pt-br" ? "Tela cheia" : "Full screen";
const exitFullscreenLabel = siteLocale === "pt-br" ? "Sair da tela cheia" : "Exit full screen";
const footerText = siteLocale === "pt-br"
  ? "ARQUIVOS SiNE · DISTRIBUICAO RESTRITA · TODOS OS REGISTROS SUJEITOS A REVISAO"
  : "SiNE ARCHIVES · RESTRICTED DISTRIBUTION · ALL RECORDS SUBJECT TO REVISION";
const resolvedNavTrail = Array.isArray(navTrail) ? navTrail as NavTrailItem[] : [];
const showNavTrail = resolvedNavTrail.length > 0;
---

<!doctype html>
<html lang={getHtmlLang(siteLocale)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#06060b" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>

  <body class={pageClass || undefined}>
    <nav class:list={["nav", navVariant !== "default" && `nav--${navVariant}`]} aria-label="Primary navigation">
      <a class="nav__logo" href={localizedPath(siteLocale, "/")}>
        <img src="/uploads/ui-sine-logo.png" alt="SiNE" class="nav__logo-img" />
        <span class="nav__logo-text">ARCHIVES</span>
      </a>

      {navVariant === "entry" && showNavTrail && (
        <div class="nav__center">
          <div class="nav__crumb">
            {resolvedNavTrail.map((item, index) => (
              <>
                {index > 0 && <span class="nav__crumb-sep" aria-hidden="true">&gt;</span>}
                {item.href ? (
                  <a class="nav__crumb-link" href={item.href}>{item.label}</a>
                ) : (
                  <span class="nav__crumb-cur">{item.label}</span>
                )}
              </>
            ))}
          </div>
        </div>
      )}

      <div class="nav__actions">
        {navVariant === "section" && showNavTrail && (
          <div class="nav__crumb">
            {resolvedNavTrail.map((item, index) => (
              <>
                {index > 0 && <span class="nav__crumb-sep" aria-hidden="true">&gt;</span>}
                {item.href ? (
                  <a class="nav__crumb-link" href={item.href}>{item.label}</a>
                ) : (
                  <span class="nav__crumb-cur">{item.label}</span>
                )}
              </>
            ))}
          </div>
        )}
        <MusicPlayer locale={siteLocale} />
        <div class="nav__locale-switch" aria-label={siteLocale === "pt-br" ? "Seletor de idioma" : "Language switcher"}>
          {LOCALES.map((targetLocale) => (
            <a
              class={`nav__locale-pill${targetLocale === siteLocale ? " is-active" : ""}`}
              href={localizeCurrentPath(currentPath, targetLocale)}
              hreflang={getHtmlLang(targetLocale)}
              aria-current={targetLocale === siteLocale ? "page" : undefined}
            >
              {LOCALE_LABELS[targetLocale]}
            </a>
          ))}
        </div>
        <button
          class="nav__icon-btn nav__fullscreen-btn"
          type="button"
          data-fullscreen-toggle
          data-enter-label={fullscreenLabel}
          data-exit-label={exitFullscreenLabel}
          aria-label={fullscreenLabel}
          title={fullscreenLabel}
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2.5 6V2.5H6M10 2.5h3.5V6M13.5 10v3.5H10M6 13.5H2.5V10" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <a
          class="nav__icon-btn nav__search-btn"
          href={localizedPath(siteLocale, "/search/")}
          data-search-trigger
          data-astro-prefetch="viewport"
          aria-label={searchLabel}
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.4" />
            <line x1="10" y1="10" x2="14" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </svg>
        </a>
      </div>
    </nav>

    <main class="main">
      <slot />
    </main>

    {!hideFooter && (
      <footer class="footer">
        <img src="/uploads/ui-sine-logo.png" alt="SiNE" class="footer__logo" />
        <span class="footer__text">{footerText}</span>
      </footer>
    )}

    <script>
      import "../scripts/searchViewTransition";

      const fullscreenButton = document.querySelector<HTMLButtonElement>("[data-fullscreen-toggle]");

      if (fullscreenButton) {
        const canFullscreen = !!document.documentElement.requestFullscreen;
        const enterLabel = fullscreenButton.dataset.enterLabel || fullscreenButton.ariaLabel || "Full screen";
        const exitLabel = fullscreenButton.dataset.exitLabel || "Exit full screen";

        if (!canFullscreen) {
          fullscreenButton.hidden = true;
        } else {
          const updateFullscreenState = () => {
            const active = !!document.fullscreenElement;
            const label = active ? exitLabel : enterLabel;
            fullscreenButton.setAttribute("aria-label", label);
            fullscreenButton.setAttribute("title", label);
            fullscreenButton.classList.toggle("is-active", active);
          };

          fullscreenButton.addEventListener("click", async () => {
            try {
              if (document.fullscreenElement) {
                await document.exitFullscreen();
              } else {
                await document.documentElement.requestFullscreen();
              }
            } catch {
              updateFullscreenState();
            }
          });

          document.addEventListener("fullscreenchange", updateFullscreenState);
          updateFullscreenState();
        }
      }
    </script>
  </body>
</html>

<style>
  :global(:root) {
    --nav-height: 56px;
  }

  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    min-height: var(--nav-height);
    height: calc(var(--nav-height) + env(safe-area-inset-top));
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: env(safe-area-inset-top) max(32px, env(safe-area-inset-right)) 0 max(32px, env(safe-area-inset-left));
    background: rgba(6, 6, 11, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav__center {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    justify-content: center;
    width: min(100%, 720px);
    max-width: calc(100% - 360px);
    pointer-events: none;
  }

  .nav__center .nav__crumb {
    pointer-events: auto;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav__logo-img {
    height: 26px;
    opacity: 0.9;
  }

  .nav__logo-text {
    font-family: "DM Sans", sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: rgba(232, 228, 220, 0.45);
    text-transform: uppercase;
  }

  .nav__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    color: rgba(232, 228, 220, 0.5);
    text-decoration: none;
    background: transparent;
    border: 0;
    border-radius: 4px;
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
    flex-shrink: 0;
  }

  .nav__icon-btn:hover,
  .nav__icon-btn.is-active {
    color: rgba(232, 228, 220, 0.9);
    background: rgba(255, 255, 255, 0.04);
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .nav__crumb {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-width: 0;
    font-family: "DM Sans", sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nav__crumb-link {
    color: rgba(232, 228, 220, 0.48);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav__crumb-link:hover {
    color: rgba(232, 228, 220, 0.9);
  }

  .nav__crumb-sep {
    color: var(--crimson, #b13a34);
    font-size: 13px;
    flex-shrink: 0;
  }

  .nav__crumb-cur {
    color: rgba(232, 228, 220, 0.3);
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav__locale-switch {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
  }

  .nav__locale-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 26px;
    padding: 0 10px;
    font-family: "DM Sans", sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.42);
    text-decoration: none;
    border-radius: 999px;
    transition: color 0.2s, background 0.2s;
  }

  .nav__locale-pill:hover {
    color: rgba(232, 228, 220, 0.9);
  }

  .nav__locale-pill.is-active {
    color: rgba(232, 228, 220, 0.96);
    background: rgba(177, 58, 52, 0.18);
  }

  .main {
    padding-top: calc(var(--nav-height) + env(safe-area-inset-top));
    min-height: 100vh;
  }

  .footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 60px 32px 48px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer__logo {
    height: 18px;
    opacity: 0.18;
  }

  .footer__text {
    font-family: "DM Sans", sans-serif;
    font-size: 10px;
    letter-spacing: 0.18em;
    color: rgba(232, 228, 220, 0.15);
    text-transform: uppercase;
    text-align: center;
  }

  @media (max-width: 768px) {
    .nav {
      padding: env(safe-area-inset-top) max(12px, env(safe-area-inset-right)) 0 max(12px, env(safe-area-inset-left));
    }

    .nav__center {
      display: none;
    }

    .nav--section .nav__crumb {
      display: none;
    }

    .nav__logo-text {
      display: none;
    }

    .nav__locale-pill {
      padding: 0 8px;
      font-size: 8px;
      letter-spacing: 0.12em;
    }

    .nav__actions {
      gap: 6px;
    }

    .nav__icon-btn {
      width: 36px;
      height: 36px;
    }

    .footer {
      padding: 40px 20px calc(34px + env(safe-area-inset-bottom));
    }
  }
</style>
