---
import MainLayout from "./MainLayout.astro";
import { getCollection } from "astro:content";
import { CONTENT_KEYS } from "../content-keys";
import { SECTIONS } from "../sections";

const { entry, active } = Astro.props;
const { Content, headings } = await entry.render();

const isCharacterEntry = active === "characters";
const isApparatusEntry = active === "apparatus";
const isSystemEntry    = active === "systems";
const isSineEntry      = active === "sine";
const isSkyphon        = isCharacterEntry && String(entry.data?.type ?? "").trim() === "Skyphon";

// ── field helpers ──
const str = (v: unknown) => String(v ?? "").trim();

const designation       = str(entry.data?.designation);
const summary           = str(entry.data?.summary);
const affiliation       = str(entry.data?.affiliation);
const age               = entry.data?.age;
const height            = entry.data?.height;
const birthYear         = entry.data?.birth_year !== undefined ? str(entry.data.birth_year) : "";
const birthplace        = str(entry.data?.birthplace);
const rank              = str(entry.data?.rank);
const house             = str(entry.data?.house);
const registryStatus    = str(entry.data?.registry_status);
const build             = str(entry.data?.build);
const residence         = str(entry.data?.residence);
const occupation        = str(entry.data?.occupation);
const orgHQ             = str(entry.data?.headquarters);
const orgFounded        = str(entry.data?.founded);
const orgJurisdiction   = str(entry.data?.jurisdiction);
const orgStatusLabel    = str(entry.data?.status_label);
const appSealingStatus  = str(entry.data?.sealing_status);
const appCustody        = str(entry.data?.custody);
const appKnownPrinciple = str(entry.data?.known_principle);
const appUserStatus     = str(entry.data?.user_status);
const skyphonDomain     = str(entry.data?.domain);
const skyphonChurchName = str(entry.data?.church_name);
const skyphonPrinciple  = str(entry.data?.principle);
const skyphonKeeperName = str(entry.data?.keeper_name);

const sectionLabel =
  SECTIONS.find((s) => s.key === active)?.label ??
  ((active || "").charAt(0).toUpperCase() + (active || "").slice(1));
const sectionHref = `/${active}/`;

// ── Related entries ──
function normalizeTags(tags: unknown): string[] {
  if (!Array.isArray(tags)) return [];
  return tags.map((t) => String(t).trim().toLowerCase()).filter(Boolean);
}
function sharedCount(a: string[], b: string[]): number {
  const setB = new Set(b);
  let n = 0;
  for (const t of a) if (setB.has(t)) n++;
  return n;
}

const currentSlug = entry.slug;
const currentTags = normalizeTags(entry.data?.tags);

const allPublic = (
  await Promise.all(
    CONTENT_KEYS.map((c) => getCollection(c, (e) => e.data.status === "public"))
  )
).flat();

const related = allPublic
  .filter((e) => e.slug !== currentSlug)
  .map((e) => {
    const tags = normalizeTags(e.data?.tags);
    const score = currentTags.length ? sharedCount(currentTags, tags) : 0;
    return { e, score };
  })
  .filter((x) => x.score > 0)
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    const au = new Date(a.e.data?.updated ?? 0).getTime();
    const bu = new Date(b.e.data?.updated ?? 0).getTime();
    return bu - au;
  })
  .slice(0, 6);

// ── Build sidebar fields list ──
type Field = { label: string; value: string; wide?: boolean };
const fields: Field[] = [];

if (isSkyphon) {
  if (occupation)      fields.push({ label: "Jurisdiction",        value: occupation });
  if (affiliation)     fields.push({ label: "Classification",      value: affiliation });
  if (registryStatus)  fields.push({ label: "Post-Fracture Status",value: registryStatus, wide: true });
  if (skyphonDomain)   fields.push({ label: "Domain",              value: skyphonDomain });
  if (skyphonChurchName) fields.push({ label: "Church Name",       value: skyphonChurchName });
  if (skyphonPrinciple)  fields.push({ label: "Principle",         value: skyphonPrinciple });
  if (skyphonKeeperName) fields.push({ label: "Keeper Name",       value: skyphonKeeperName, wide: true });
} else if (isApparatusEntry) {
  if (appSealingStatus)  fields.push({ label: "Sealing Status",    value: appSealingStatus });
  if (affiliation)       fields.push({ label: "Origin",            value: affiliation });
  if (appCustody)        fields.push({ label: "Custody",           value: appCustody });
  if (appKnownPrinciple) fields.push({ label: "Known Principle",   value: appKnownPrinciple });
  if (appUserStatus)     fields.push({ label: "User Status",       value: appUserStatus });
} else if (isCharacterEntry) {
  if (registryStatus)  fields.push({ label: "Registry Status",     value: registryStatus });
  if (affiliation)     fields.push({ label: "Affiliation",         value: affiliation });
  if (house)           fields.push({ label: "House",               value: house });
  if (birthYear)       fields.push({ label: "Year of Birth",       value: birthYear });
  if (age !== undefined && age !== null && String(age).trim())
                       fields.push({ label: "Age",                  value: String(age) });
  if (height !== undefined && height !== null && String(height).trim()) {
    const hv = [String(height).trim(), build].filter(Boolean).join(" · ");
    fields.push({ label: "Height / Build", value: hv });
  }
  if (birthplace)      fields.push({ label: "Birthplace",          value: birthplace });
  if (residence)       fields.push({ label: "Residence",           value: residence });
  if (occupation)      fields.push({ label: "Occupation",          value: occupation });
} else {
  if (orgStatusLabel)  fields.push({ label: "Status",              value: orgStatusLabel, wide: true });
  if (orgHQ)           fields.push({ label: "Headquarters",        value: orgHQ });
  if (orgFounded)      fields.push({ label: "Founded",             value: orgFounded });
  if (affiliation)     fields.push({ label: "Affiliation",         value: affiliation });
  if (orgJurisdiction) fields.push({ label: "Jurisdiction",        value: orgJurisdiction, wide: true });
}
---

<MainLayout active={active} pageTitle={`${entry.data.title} — ${sectionLabel} — SiNE Archives`}>

  <!-- ── HERO ── -->
  <div class="ent-hero">
    {!isCharacterEntry && entry.data.image ? (
      <>
        <img class="ent-hero__img" src={entry.data.image} alt="" aria-hidden="true" />
        <div class="ent-hero__overlay"></div>
      </>
    ) : (
      <div class="ent-hero__fallback"></div>
    )}
    <div class="ent-hero__content">
      <!-- breadcrumb -->
      <nav class="ent-crumbs" aria-label="Breadcrumb">
        <a class="ent-crumbs__link" href={sectionHref}>{sectionLabel}</a>
        <span class="ent-crumbs__sep" aria-hidden="true">›</span>
        <span class="ent-crumbs__cur">{entry.data.title}</span>
      </nav>

      <div class="ent-hero__type">{entry.data.type ?? sectionLabel}</div>
      <h1 class="ent-hero__title">{entry.data.title}</h1>
      {designation && <div class="ent-hero__designation">{designation}</div>}
      {isSkyphon && rank && <div class="ent-hero__rank">{rank}</div>}

      {(entry.data.tags ?? []).length ? (
        <div class="ent-hero__tags">
          {(entry.data.tags ?? []).map((t: string) => (
            <span class="ent-hero__tag">{String(t).toUpperCase()}</span>
          ))}
        </div>
      ) : null}
    </div>
  </div>

  <!-- ── BODY ── -->
  <div class="ent-body">

    <!-- SIDEBAR -->
    <aside class="ent-sidebar">
      {fields.length ? (
        <details class="ent-sidebar__card" open>
          <summary class="ent-sidebar__card-title">
            File Data
            <svg class="ent-sidebar__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          {fields.map(f => (
            <div class={`ent-sidebar__row${f.wide ? " ent-sidebar__row--wide" : ""}`}>
              <span class="ent-sidebar__label">{f.label}</span>
              <span class="ent-sidebar__value" set:html={f.value} />
            </div>
          ))}
        </details>
      ) : null}

      <div class="ent-sidebar__updated">Filed: {entry.data.updated}</div>

      {/* TOC — only shown in sidebar when headings >= 3 */}
      {(headings?.length ?? 0) >= 3 ? (
        <details class="ent-toc" open>
          <summary class="ent-toc__summary">On this page</summary>
          <nav class="ent-toc__nav">
            <ul class="ent-toc__list">
              {(headings as { depth: number; slug: string; text: string }[])
                .filter((h) => h.depth === 2 || h.depth === 3)
                .map((h) => (
                  <li class={`ent-toc__item ent-toc__item--d${h.depth}`}>
                    <a class="ent-toc__link" href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
            </ul>
          </nav>
        </details>
      ) : null}
    </aside>

    <!-- MAIN PROSE -->
    <main class="ent-main">
      {summary ? (
        <p class="ent-lead">{summary}</p>
      ) : null}
      <div class="ent-divider"></div>

      {/* Character portrait in prose area when no hero image */}
      {isCharacterEntry && !entry.data.image && (
        <div class="ent-portrait-placeholder">
          <svg class="ent-portrait-placeholder__icon" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.2"/>
            <path d="M4 20c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <span class="ent-portrait-placeholder__text">Portrait Pending</span>
        </div>
      )}

      {/* Apparatus / cosmology / org image in main area when not character */}
      {!isCharacterEntry && !isSystemEntry && !isSineEntry && entry.data.image ? (
        <div class="ent-media">
          <img class="ent-media__img" src={entry.data.image} alt={`${entry.data.title} image`} loading="lazy" />
        </div>
      ) : null}

      <article class="ent-prose" data-entry-body>
        <Content />
      </article>
    </main>
  </div>

  <!-- ── RELATED ── -->
  {related.length ? (
    <section class="ent-related" aria-label="Related entries">
      <div class="ent-related__inner">
        <div class="ent-related__header">
          <div class="ent-related__line"></div>
          <span class="ent-related__label">Related entries</span>
          <div class="ent-related__line"></div>
        </div>
        <div class="ent-related__grid">
          {related.map(({ e, score }) => (
            <a class="ent-related__item" href={`/${e.collection}/${e.slug}/`}>
              <div class="ent-related__name">{e.data.title}</div>
              {e.data.summary ? (
                <div class="ent-related__summary">{e.data.summary}</div>
              ) : null}
              <div class="ent-related__meta">{score} shared tag{score === 1 ? "" : "s"}</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ) : null}

</MainLayout>

<style>
  /* ── Hero ── */
  .ent-hero {
    position: relative;
    min-height: 420px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .ent-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    filter: saturate(0.6) brightness(0.35);
  }

  .ent-hero__fallback {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(177, 58, 52, 0.15), rgba(6, 6, 11, 0.8));
  }

  .ent-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(6, 6, 11, 0.2) 0%,
      rgba(6, 6, 11, 0.5) 50%,
      var(--bg) 100%
    );
  }

  .ent-hero__content {
    position: relative;
    z-index: 2;
    padding: 60px 48px;
    max-width: 1000px;
  }

  /* breadcrumb */
  .ent-crumbs {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .ent-crumbs__link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .ent-crumbs__link:hover { color: var(--text); }
  .ent-crumbs__sep { color: var(--crimson); opacity: 0.7; }
  .ent-crumbs__cur { color: var(--text-dim); }

  .ent-hero__type {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--crimson);
    margin-bottom: 10px;
  }

  .ent-hero__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 6vw, 62px);
    font-weight: 700;
    color: var(--text);
    margin: 0 0 10px;
    line-height: 1;
    letter-spacing: 0.01em;
  }

  .ent-hero__designation {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--gold);
    letter-spacing: 0.06em;
    margin-bottom: 18px;
    opacity: 0.85;
  }

  .ent-hero__rank {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 8px;
  }

  .ent-hero__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .ent-hero__tag {
    padding: 4px 10px;
    background: rgba(177, 58, 52, 0.18);
    border: 1px solid rgba(177, 58, 52, 0.3);
    border-radius: 3px;
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.7);
  }

  /* ── Body layout ── */
  .ent-body {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 32px 80px;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 48px;
    align-items: start;
  }

  /* ── Sidebar ── */
  .ent-sidebar {
    position: sticky;
    top: 76px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ent-sidebar__card {
    background: rgba(10, 10, 18, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 6px;
    overflow: hidden;
  }

  .ent-sidebar__card-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--crimson);
    padding: 14px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    user-select: none;
  }

  .ent-sidebar__card-title::-webkit-details-marker { display: none; }

  .ent-sidebar__chevron {
    color: var(--crimson);
    opacity: 0.6;
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .ent-sidebar__card[open] .ent-sidebar__chevron {
    transform: rotate(180deg);
  }

  .ent-sidebar__card:not([open]) .ent-sidebar__card-title {
    border-bottom: none;
  }

  .ent-sidebar__row {
    padding: 10px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .ent-sidebar__row:last-child { border-bottom: none; }

  .ent-sidebar__label {
    font-family: 'DM Sans', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .ent-sidebar__value {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .ent-sidebar__updated {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.04em;
    padding: 0 4px;
  }

  /* TOC */
  .ent-toc {
    background: rgba(10, 10, 18, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 6px;
    overflow: hidden;
    border-left: 2px solid rgba(177, 58, 52, 0.4);
  }

  .ent-toc__summary {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--crimson);
    padding: 14px 16px;
    cursor: pointer;
    list-style: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .ent-toc__summary::-webkit-details-marker { display: none; }

  .ent-toc__nav { padding: 8px 0; }

  .ent-toc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ent-toc__item { padding: 0 8px; }
  .ent-toc__item--d3 { padding-left: 20px; }

  .ent-toc__link {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: var(--text-muted);
    text-decoration: none;
    padding: 4px 8px;
    border-radius: 3px;
    transition: background 0.15s, color 0.15s;
    line-height: 1.4;
  }

  .ent-toc__item--d3 .ent-toc__link {
    font-size: 11px;
    opacity: 0.8;
  }

  .ent-toc__link:hover {
    background: rgba(177, 58, 52, 0.12);
    color: var(--text);
  }

  /* ── Main prose area ── */
  .ent-main { min-width: 0; }

  .ent-lead {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    color: rgba(232, 228, 220, 0.75);
    line-height: 1.75;
    font-style: italic;
    margin: 0 0 24px;
    letter-spacing: 0.01em;
  }

  .ent-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.07);
    margin: 0 0 32px;
  }

  .ent-portrait-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 100px;
    margin-bottom: 24px;
    background: repeating-linear-gradient(
      45deg,
      rgba(177, 58, 52, 0.03),
      rgba(177, 58, 52, 0.03) 10px,
      transparent 10px,
      transparent 20px
    );
    border: 1px dashed rgba(177, 58, 52, 0.2);
    border-radius: 6px;
  }

  .ent-portrait-placeholder__icon {
    width: 28px; height: 28px;
    color: rgba(177, 58, 52, 0.35);
  }

  .ent-portrait-placeholder__text {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .ent-media {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.07);
    margin-bottom: 32px;
    background: rgba(10, 10, 18, 0.6);
  }

  .ent-media__img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ── Prose styles ── */
  .ent-prose {
    font-family: 'DM Sans', sans-serif;
    color: var(--text-muted);
    line-height: 1.8;
  }

  .ent-prose :global(h2) {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 700;
    color: var(--text);
    margin: 40px 0 12px;
    letter-spacing: 0.02em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    padding-bottom: 8px;
    line-height: 1.2;
  }

  .ent-prose :global(h3) {
    font-family: 'Cormorant Garamond', serif;
    font-size: 19px;
    font-weight: 600;
    color: rgba(232, 228, 220, 0.85);
    margin: 28px 0 8px;
    letter-spacing: 0.04em;
  }

  .ent-prose :global(p) {
    margin: 0 0 14px;
    font-size: 15px;
    line-height: 1.85;
    color: var(--text-muted);
  }

  .ent-prose :global(li) {
    font-size: 15px;
    line-height: 1.85;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .ent-prose :global(ul),
  .ent-prose :global(ol) {
    padding-left: 24px;
    margin: 0 0 16px;
  }

  .ent-prose :global(strong) {
    color: rgba(232, 228, 220, 0.9);
    font-weight: 650;
  }

  .ent-prose :global(em) {
    color: rgba(176, 141, 60, 0.9);
  }

  .ent-prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    margin: 32px 0;
  }

  .ent-prose :global(blockquote) {
    margin: 24px 0;
    padding: 16px 24px;
    border-left: 2px solid var(--crimson);
    background: rgba(177, 58, 52, 0.06);
    border-radius: 0 4px 4px 0;
  }

  .ent-prose :global(blockquote p) {
    margin: 0;
    font-size: 15px;
    font-style: italic;
    color: rgba(232, 228, 220, 0.65);
    line-height: 1.8;
  }

  .ent-prose :global(hr + h2),
  .ent-prose :global(hr + h3) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  /* ── Related ── */
  .ent-related {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 60px 0 80px;
  }

  .ent-related__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .ent-related__header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
  }

  .ent-related__line {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.07);
  }

  .ent-related__label {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: rgba(232, 228, 220, 0.3);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .ent-related__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 12px;
  }

  .ent-related__item {
    display: block;
    padding: 16px 20px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 6px;
    background: rgba(10, 10, 18, 0.7);
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, background 0.2s;
  }

  .ent-related__item:hover {
    border-color: rgba(177, 58, 52, 0.35);
