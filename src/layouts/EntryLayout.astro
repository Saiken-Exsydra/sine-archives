<script>
  // Assign IDs to headings inside prose for TOC links
  const body = document.querySelector("[data-entry-body]");
  if (body) {
    body.querySelectorAll("h2, h3").forEach((h) => {
      if (!h.id) {
        const slug = (h.textContent || "")
          .trim().toLowerCase()
          .replace(/[^a-z0-9\s-]/g, "")
          .replace(/\s+/g, "-")
          .replace(/-+/g, "-");
        if (slug) h.id = slug;
      }
    });
  }

</script>
