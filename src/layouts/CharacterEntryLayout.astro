---
import { unified } from "unified";
import remarkParse from "remark-parse";
import remarkGfm from "remark-gfm";
import remarkRehype from "remark-rehype";
import rehypeStringify from "rehype-stringify";
import SiteShell from "./SiteShell.astro";
import CharacterDossierMarkdown from "../components/CharacterDossierMarkdown.astro";
import CharacterFieldIcon from "../components/CharacterFieldIcon.astro";
import "../styles/archive-refs.css";
import remarkArchiveHeadingIds from "../utils/remark-archive-heading-ids.mjs";
import remarkArchiveWikiLinks from "../utils/remark-archive-wiki-links.mjs";
import { localizedPath, type SiteLocale } from "../i18n/config";
import { getImageKind, getImageUrl } from "../utils/optimized-images";
import { getCharacterCodexRecord } from "../utils/character-codex";

type QuoteData = {
  text: string;
  source?: string;
};

type RelatedLink = {
  label: string;
  href: string;
};

type AbilitySnapshotCard = {
  eyebrow?: string;
  title: string;
  body?: string;
  items?: string[];
};

type NormalizedAbilitySnapshotCard = {
  eyebrow: string;
  title: string;
  body: string;
  items: string[];
};

type ArchiveNote = {
  label?: string;
  text: string;
};

type FieldIconName =
  | "registry"
  | "affiliation"
  | "house"
  | "year"
  | "age"
  | "build"
  | "birthplace"
  | "residence"
  | "occupation";

const { entry, locale = "en" } = Astro.props as { entry: any; locale?: SiteLocale };
const { headings } = await entry.render();

const copy = locale === "pt-br"
  ? {
      index: "Indice",
      section: "Personagens",
      pageTitle: "Personagens",
      dossier: "Dossie - Arquivos SiNE - Ano de Arquivo 1127",
      fileData: "Dados do Registro",
      fullRecord: "Registro Completo",
      contents: "Conteudo",
      sectionsLabel: "secoes",
      relatedLinks: "Links Relacionados",
      gallery: "Galeria",
      notes: "Notas",
      heightBuild: "Altura / Porte",
      birthplace: "Local de Nascimento",
      residence: "Residencia",
      occupation: "Ocupacao",
      fullscreen: "Tela cheia",
      exitFullscreen: "Sair da tela cheia",
      nextImage: "Proxima imagem",
      openCodex: "Abrir Codex",
      codexReady: "Dossie completo",
      codexPending: "Codex indisponivel",
      imageAlt: (name: string, index: number) => `${name} imagem ${index + 1}`,
    }
  : {
      index: "Index",
      section: "Characters",
      pageTitle: "Characters",
      dossier: "Dossier - SiNE Archives Filing Year 1127",
      fileData: "File Data",
      fullRecord: "Full Record",
      contents: "Contents",
      sectionsLabel: "sections",
      relatedLinks: "Related Links",
      gallery: "Gallery",
      notes: "Notes",
      heightBuild: "Height / Build",
      birthplace: "Birthplace",
      residence: "Residence",
      occupation: "Occupation",
      fullscreen: "Full screen",
      exitFullscreen: "Exit full screen",
      nextImage: "Next image",
      openCodex: "Open Codex",
      codexReady: "Full dossier",
      codexPending: "Codex unavailable",
      imageAlt: (name: string, index: number) => `${name} image ${index + 1}`,
    };

const str = (value: unknown) => String(value ?? "").trim();

function normalizeText(value: string): string {
  return value
    .toLowerCase()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, " ")
    .trim();
}

function trimOuterEmphasis(value: string): string {
  const trimmed = value.trim();
  if (
    (trimmed.startsWith("*") && trimmed.endsWith("*")) ||
    (trimmed.startsWith("_") && trimmed.endsWith("_"))
  ) {
    return trimmed.slice(1, -1).trim();
  }
  return trimmed;
}

function parseLeadingQuote(body: string): { quote: QuoteData | null; cleanedBody: string } {
  const normalized = body.replace(/\r\n?/g, "\n").trimStart();
  const match = normalized.match(/^((?:>[^\n]*(?:\n|$))+)\s*\n(?:-{3,}|\*{3,}|_{3,})\s*\n?/);

  if (!match) {
    return { quote: null, cleanedBody: normalized };
  }

  const blockLines = match[1]
    .split("\n")
    .map((line) => line.replace(/^>\s?/, "").trim())
    .filter(Boolean);

  const sourceLine = blockLines[blockLines.length - 1] ?? "";
  const hasSource = /^[-—]/.test(sourceLine);
  const source = hasSource ? sourceLine.replace(/^[-—]\s*/, "").trim() : "";
  const textLines = hasSource ? blockLines.slice(0, -1) : blockLines;
  const text = trimOuterEmphasis(textLines.join(" ").trim());

  return {
    quote: text ? { text, source } : null,
    cleanedBody: normalized.slice(match[0].length).trimStart(),
  };
}

async function renderCharacterMarkdown(markdown: string, sourcePath: string): Promise<string> {
  const rendered = await unified()
    .use(remarkParse)
    .use(remarkGfm)
    .use(remarkArchiveHeadingIds)
    .use(remarkArchiveWikiLinks)
    .use(remarkRehype, { allowDangerousHtml: true })
    .use(rehypeStringify, { allowDangerousHtml: true })
    .process({ value: markdown, path: sourcePath });

  return String(rendered);
}

const title = str(entry.data?.title);
const designation = str(entry.data?.designation);
const summary = str(entry.data?.summary);
const updated = str(entry.data?.updated);
const type = str(entry.data?.type ?? (locale === "pt-br" ? "Personagem" : "Character"));
const imagePosition = str(entry.data?.image_position) || "center top";
const heroImagePosition = str(entry.data?.hero_image_position) || imagePosition;
const galleryTransition = entry.data?.portrait_gallery_transition === "slide" ? "slide" : "fade";
const galleryAutoplay = entry.data?.portrait_gallery_autoplay !== false;

const portraitCandidates = [
  ...(Array.isArray(entry.data?.portrait_gallery) ? entry.data.portrait_gallery : []),
  entry.data?.image,
];

const portraitImages = portraitCandidates
  .map((value) => ({ value, url: getImageUrl(value), kind: getImageKind(value) }))
  .filter((item) => !!item.value && !!item.url)
  .sort((a, b) => {
    const score = (kind: ReturnType<typeof getImageKind>) => {
      if (kind === "portrait") return 0;
      if (kind === "neutral") return 1;
      if (kind === "hero") return 2;
      return 3;
    };
    return score(a.kind) - score(b.kind);
  })
  .filter((item, index, list) => list.findIndex((entry) => entry.url === item.url) === index);

const railUrls = new Set(portraitImages.map((item) => item.url));
const extraGalleryImages = [
  entry.data?.hero_image,
  ...(Array.isArray(entry.data?.hero_gallery) ? entry.data.hero_gallery : []),
  ...portraitImages.slice(1).map((item) => item.value),
]
  .map((value) => ({ value, url: getImageUrl(value), kind: getImageKind(value) }))
  .filter((item) => !!item.value && !!item.url)
  .filter((item, index, list) => list.findIndex((entry) => entry.url === item.url) === index)
  .filter((item) => item.url !== portraitImages[0]?.url || !railUrls.has(item.url));

const tags: string[] = Array.isArray(entry.data?.tags) ? entry.data.tags : [];

type Field = { label: string; value: string; icon: FieldIconName };
const fields: Field[] = [];
const push = (label: string, key: string, icon: FieldIconName) => {
  const value = str((entry.data as Record<string, unknown>)?.[key]);
  if (value) fields.push({ label, value, icon });
};

push(locale === "pt-br" ? "Status de Registro" : "Registry Status", "registry_status", "registry");
push(locale === "pt-br" ? "Afiliacao" : "Affiliation", "affiliation", "affiliation");
push(locale === "pt-br" ? "Casa" : "House", "house", "house");
push(locale === "pt-br" ? "Ano de Nascimento" : "Year of Birth", "birth_year", "year");
push(locale === "pt-br" ? "Idade" : "Age", "age", "age");

const height = str(entry.data?.height);
const build = str(entry.data?.build);
if (height) {
  fields.push({ label: copy.heightBuild, value: [height, build].filter(Boolean).join(" - "), icon: "build" });
}

push(copy.birthplace, "birthplace", "birthplace");
push(copy.residence, "residence", "residence");
push(copy.occupation, "occupation", "occupation");

const sourcePath = `src/content/characters_${locale === "pt-br" ? "pt_br" : "en"}/${entry.slug}.md`;
const rawBody = String(entry.body ?? "");
const leadingQuoteResult = parseLeadingQuote(rawBody);
const explicitQuote = entry.data?.dossier_quote as QuoteData | undefined;
const dossierQuote = explicitQuote?.text
  ? { text: str(explicitQuote.text), source: str(explicitQuote.source) }
  : leadingQuoteResult.quote;

const proseHtml = await renderCharacterMarkdown(leadingQuoteResult.cleanedBody, sourcePath);
const contentHeadings = (Array.isArray(headings) ? headings : [])
  .filter((heading) => heading.depth === 2)
  .map((heading) => ({
    text: String(heading.text ?? "").trim(),
    slug: String(heading.slug ?? "").trim(),
  }))
  .filter((heading) => heading.text && heading.slug);

const tocEnabled = false;
const showToc = tocEnabled && contentHeadings.length > 0;

const relatedLinks: RelatedLink[] = Array.isArray(entry.data?.related_links)
  ? entry.data.related_links
      .map((item: RelatedLink) => ({ label: str(item?.label), href: str(item?.href) }))
      .filter((item: RelatedLink) => item.label && item.href)
  : [];

const abilitySnapshot: NormalizedAbilitySnapshotCard[] = Array.isArray(entry.data?.ability_snapshot)
  ? entry.data.ability_snapshot
      .map((card: AbilitySnapshotCard) => ({
        eyebrow: str(card?.eyebrow),
        title: str(card?.title),
        body: str(card?.body),
        items: Array.isArray(card?.items) ? card.items.map((item) => str(item)).filter(Boolean) : [],
      }))
      .filter((card: NormalizedAbilitySnapshotCard) => card.title)
  : [];

const abilitySnapshotSection = str(entry.data?.ability_snapshot_section);
const abilitySnapshotSectionKey = normalizeText(abilitySnapshotSection);

const explicitArchiveNote = entry.data?.archive_note as ArchiveNote | undefined;
const archiveNote = explicitArchiveNote?.text
  ? {
      label: str(explicitArchiveNote.label),
      text: str(explicitArchiveNote.text),
    }
  : dossierQuote?.text
    ? {
        label: str(dossierQuote.source),
        text: str(dossierQuote.text),
      }
    : null;

const codex = await getCharacterCodexRecord(entry);
const codexHref = localizedPath(locale, `/characters/${entry.slug}/codex/`);
---

<SiteShell
  pageTitle={`${title} - ${copy.pageTitle} - SiNE Archives`}
  locale={locale}
  routeKind="character-detail"
  transitionProfile="character-stage"
>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --char-bg: #06060b;
      --char-surface: rgba(10, 10, 18, 0.76);
      --char-surface-strong: rgba(9, 9, 16, 0.92);
      --char-border: rgba(255, 255, 255, 0.07);
      --char-border-strong: rgba(255, 255, 255, 0.12);
      --char-crimson: #b13a34;
      --char-gold: #b08d3c;
      --char-text: #e8e4dc;
      --char-text-muted: rgba(232, 228, 220, 0.64);
      --char-text-dim: rgba(232, 228, 220, 0.36);
      --char-shadow: 0 24px 80px rgba(0, 0, 0, 0.36);
      --char-nav-height: 56px;
    }

    html, body {
      background:
        radial-gradient(circle at 18% 18%, rgba(177, 58, 52, 0.11), transparent 30%),
        radial-gradient(circle at 82% 16%, rgba(68, 98, 132, 0.12), transparent 28%),
        var(--char-bg);
      color: var(--char-text);
      font-family: "DM Sans", sans-serif;
      min-height: 100%;
    }

    body.character-stage-ready {
      overflow: hidden;
    }

    ::selection {
      background: rgba(177, 58, 52, 0.35);
      color: var(--char-text);
    }

    .char-nav {
      position: fixed;
      inset: 0 0 auto;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      height: var(--char-nav-height);
      padding: 0 20px;
      background: rgba(6, 6, 11, 0.9);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    .char-nav__brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
      text-decoration: none;
      color: inherit;
    }

    .char-nav__brand img {
      height: 22px;
      opacity: 0.88;
    }

    .char-nav__brand-text,
    .char-nav__crumbs,
    .char-nav__crumb-link,
    .char-nav__crumb-current {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .char-nav__brand-text {
      color: rgba(232, 228, 220, 0.44);
    }

    .char-nav__meta {
      display: flex;
      align-items: center;
      gap: 14px;
      min-width: 0;
    }

    .char-nav__crumbs {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
      overflow: hidden;
      white-space: nowrap;
    }

    .char-nav__crumb-link {
      color: var(--char-text-muted);
      text-decoration: none;
      transition: color 0.18s ease;
    }

    .char-nav__crumb-link:hover {
      color: var(--char-text);
    }

    .char-nav__crumb-sep {
      color: var(--char-crimson);
      font-size: 13px;
    }

    .char-nav__crumb-current {
      color: var(--char-text-dim);
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .char-nav__fullscreen {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: 1px solid transparent;
      border-radius: 999px;
      background: transparent;
      color: rgba(232, 228, 220, 0.56);
      cursor: pointer;
      transition: color 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }

    .char-nav__fullscreen:hover,
    .char-nav__fullscreen.is-active {
      color: var(--char-text);
      border-color: rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.04);
    }

    .char-page {
      --char-rail-col: clamp(380px, 29vw, 540px);
      --char-tools-col: clamp(208px, 13vw, 248px);
      display: grid;
      grid-template-columns: minmax(360px, var(--char-rail-col)) minmax(0, 1fr);
      min-height: 100dvh;
      padding-top: var(--char-nav-height);
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.02), transparent 16%),
        var(--char-bg);
    }

    .char-page[data-has-tools="true"] {
      grid-template-columns:
        minmax(360px, var(--char-rail-col))
        minmax(200px, var(--char-tools-col))
        minmax(0, 1fr);
    }

    .char-rail {
      position: sticky;
      top: var(--char-nav-height);
      height: calc(100dvh - var(--char-nav-height));
      overflow: auto;
      border-right: 1px solid rgba(255, 255, 255, 0.05);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.015), transparent 180px),
        rgba(7, 7, 13, 0.94);
      scrollbar-width: thin;
      scrollbar-color: rgba(177, 58, 52, 0.22) transparent;
    }

    .char-rail::-webkit-scrollbar,
    .char-tools::-webkit-scrollbar,
    .char-main::-webkit-scrollbar {
      width: 5px;
    }

    .char-rail::-webkit-scrollbar-thumb,
    .char-tools::-webkit-scrollbar-thumb,
    .char-main::-webkit-scrollbar-thumb {
      background: rgba(177, 58, 52, 0.22);
      border-radius: 999px;
    }

    .char-rail__hero {
      position: relative;
      min-height: clamp(460px, 60vh, 760px);
      overflow: hidden;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      background: linear-gradient(180deg, rgba(8, 10, 18, 0.65), rgba(6, 6, 11, 0.94));
    }

    .char-rail__gallery {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }

    .char-rail__img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      opacity: 0;
      transform: translateX(0);
      transition: opacity 1000ms ease, transform 1000ms ease;
      will-change: opacity, transform;
    }

    .char-rail__img[data-state="active"] {
      opacity: 1;
    }

    .char-rail__gallery[data-transition="slide"] .char-rail__img {
      transform: translateX(10%);
    }

    .char-rail__gallery[data-transition="slide"] .char-rail__img[data-state="active"],
    .char-rail__gallery[data-transition="slide"] .char-rail__img[data-state="entering"] {
      opacity: 1;
      transform: translateX(0);
    }

    .char-rail__gallery[data-transition="slide"] .char-rail__img[data-state="pre-enter"] {
      opacity: 0;
      transform: translateX(10%);
    }

    .char-rail__gallery[data-transition="slide"] .char-rail__img[data-state="leaving"] {
      opacity: 0;
      transform: translateX(-10%);
    }

    .char-rail__placeholder {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 50% 20%, rgba(177, 58, 52, 0.18), transparent 42%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent 40%),
        #07070d;
    }

    .char-rail__placeholder::before,
    .char-rail__placeholder::after {
      content: "";
      position: absolute;
      inset: 24px;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .char-rail__placeholder::after {
      inset: 40px;
      border-color: rgba(177, 58, 52, 0.18);
    }

    .char-rail__veil {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(180deg, rgba(6, 6, 11, 0.2), transparent 18%, transparent 56%, rgba(6, 6, 11, 0.94)),
        linear-gradient(90deg, rgba(6, 6, 11, 0.3), transparent 30%, transparent 74%, rgba(6, 6, 11, 0.4)),
        repeating-linear-gradient(180deg, transparent, transparent 4px, rgba(0, 0, 0, 0.02) 4px, rgba(0, 0, 0, 0.02) 5px);
    }

    .char-rail__controls {
      position: absolute;
      top: 18px;
      right: 18px;
      z-index: 2;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .char-rail__counter,
    .char-rail__next {
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(6, 6, 11, 0.58);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .char-rail__counter {
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.16em;
      color: rgba(232, 228, 220, 0.76);
      text-transform: uppercase;
    }

    .char-rail__next {
      width: 34px;
      height: 34px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: rgba(232, 228, 220, 0.82);
      cursor: pointer;
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }

    .char-rail__next:hover {
      transform: translateX(1px);
      border-color: rgba(177, 58, 52, 0.34);
      background: rgba(177, 58, 52, 0.14);
    }

    .char-rail__identity {
      position: absolute;
      inset: auto 0 0;
      z-index: 2;
      padding: 0 28px 28px;
    }

    .char-rail__eyebrow,
    .char-rail__filedate,
    .char-rail__tag,
    .char-card__eyebrow,
    .char-main__eyebrow,
    .char-field__label,
    .char-gallery__eyebrow {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .char-rail__filedate {
      display: inline-block;
      margin-bottom: 14px;
      color: rgba(177, 58, 52, 0.72);
    }

    .char-rail__eyebrow {
      color: var(--char-crimson);
      margin-bottom: 12px;
    }

    .char-rail__name {
      margin: 0;
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(40px, 4.8vw, 68px);
      line-height: 0.94;
      letter-spacing: -0.03em;
      text-wrap: balance;
    }

    .char-rail__designation {
      margin-top: 12px;
      color: var(--char-gold);
      font-size: 15px;
      line-height: 1.5;
    }

    .char-rail__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 16px;
    }

    .char-rail__tag {
      display: inline-flex;
      align-items: center;
      min-height: 28px;
      padding: 0 10px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(8, 8, 14, 0.65);
      color: rgba(232, 228, 220, 0.52);
    }

    .char-rail__body {
      padding: 24px 28px 36px;
      display: grid;
      gap: 18px;
    }

    .char-tools {
      position: sticky;
      top: var(--char-nav-height);
      height: calc(100dvh - var(--char-nav-height));
      overflow: auto;
      padding: 24px 16px 36px;
      border-right: 1px solid rgba(255, 255, 255, 0.05);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.015), transparent 180px),
        rgba(7, 7, 13, 0.86);
      scrollbar-width: thin;
      scrollbar-color: rgba(177, 58, 52, 0.22) transparent;
    }

    .char-tools__inner {
      display: grid;
      align-content: start;
      gap: 18px;
      width: 100%;
      max-width: 280px;
    }

    .char-card {
      border: 1px solid var(--char-border);
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01)),
        var(--char-surface);
      box-shadow: var(--char-shadow);
    }

    .char-card__inner {
      padding: 18px 18px 20px;
    }

    .char-card__eyebrow {
      color: rgba(232, 228, 220, 0.36);
      margin-bottom: 12px;
    }

    .char-toc {
      width: min(100%, 21rem);
      justify-self: start;
      overflow: hidden;
      border-radius: 14px;
    }

    .char-toc[open] .char-toc__summary svg {
      transform: rotate(180deg);
    }

    .char-toc__summary {
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 12px 14px 10px;
      cursor: pointer;
    }

    .char-toc__summary::-webkit-details-marker { display: none; }

    .char-toc__summary-copy {
      display: grid;
      gap: 4px;
      min-width: 0;
    }

    .char-toc__meta {
      color: rgba(177, 58, 52, 0.72);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .char-toc__summary svg {
      color: var(--char-text-dim);
      transition: transform 0.18s ease;
      flex-shrink: 0;
    }

    .char-toc__list {
      list-style: none;
      margin: 0;
      padding: 0 10px 10px;
      display: grid;
      gap: 1px;
    }

    .char-toc__item {
      border-top: 1px solid rgba(255, 255, 255, 0.04);
    }

    .char-toc__item a {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 10px;
      align-items: start;
      padding: 9px 12px 9px 10px;
      border-left: 1px solid rgba(255, 255, 255, 0.08);
      color: var(--char-text-muted);
      text-decoration: none;
      transition: color 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }

    .char-toc__item a:hover {
      color: var(--char-text);
      border-color: rgba(177, 58, 52, 0.42);
      background: rgba(177, 58, 52, 0.06);
    }

    .char-toc__item.is-active a {
      color: var(--char-text);
      border-color: var(--char-crimson);
      background: linear-gradient(90deg, rgba(177, 58, 52, 0.14), transparent 72%);
    }

    .char-toc__number {
      color: var(--char-crimson);
      font-family: "DM Sans", sans-serif;
      font-size: 11px;
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: 0.18em;
      min-width: 22px;
      padding-top: 2px;
    }

    .char-toc__label {
      font-size: 13px;
      line-height: 1.4;
      text-wrap: balance;
    }

    .char-quote {
      color: rgba(232, 228, 220, 0.8);
    }

    .char-quote .char-card__inner {
      display: grid;
      gap: 12px;
      padding: 22px 20px 20px;
    }

    .char-quote__mark {
      display: block;
      margin: 0;
      font-family: "Cormorant Garamond", serif;
      font-size: 58px;
      line-height: 0.72;
      color: rgba(255, 255, 255, 0.1);
    }

    .char-quote__text {
      margin: 0;
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(22px, 2vw, 34px);
      line-height: 1.3;
      font-style: italic;
      text-wrap: balance;
    }

    .char-quote__source {
      margin-top: 0;
      color: var(--char-text-dim);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .char-links__list {
      display: grid;
      gap: 8px;
    }

    .char-links__item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 14px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.02);
      color: var(--char-text-muted);
      text-decoration: none;
      transition: border-color 0.18s ease, color 0.18s ease, background 0.18s ease, transform 0.18s ease;
    }

    .char-links__item:hover {
      transform: translateY(-1px);
      border-color: rgba(177, 58, 52, 0.28);
      color: var(--char-text);
      background: rgba(177, 58, 52, 0.08);
    }

    .char-main {
      min-width: 0;
      height: calc(100dvh - var(--char-nav-height));
      overflow: auto;
      background:
        radial-gradient(circle at 100% 0%, rgba(48, 66, 88, 0.12), transparent 26%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 120px),
        rgba(6, 6, 11, 0.92);
      scrollbar-width: thin;
      scrollbar-color: rgba(177, 58, 52, 0.22) transparent;
    }

    .char-main__header {
      position: sticky;
      top: 0;
      z-index: 10;
      padding: 34px clamp(28px, 2.8vw, 64px) 28px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      background: rgba(6, 6, 11, 0.88);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }

    .char-main__header-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 20px;
    }

    .char-main__eyebrow {
      color: var(--char-crimson);
      margin-bottom: 8px;
    }

    .char-main__designation {
      color: var(--char-gold);
      font-size: 16px;
      line-height: 1.5;
    }

    .char-main__codex {
      display: inline-flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 4px;
      min-width: 170px;
      padding: 12px 14px;
      border: 1px solid rgba(176, 141, 60, 0.26);
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(176, 141, 60, 0.12), rgba(176, 141, 60, 0.03)),
        rgba(8, 8, 14, 0.9);
      color: inherit;
      text-decoration: none;
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }

    .char-main__codex:hover {
      transform: translateY(-1px);
      border-color: rgba(176, 141, 60, 0.42);
      background:
        linear-gradient(180deg, rgba(176, 141, 60, 0.18), rgba(176, 141, 60, 0.05)),
        rgba(8, 8, 14, 0.94);
    }

    .char-main__codex.is-disabled {
      opacity: 0.56;
      pointer-events: none;
    }

    .char-main__codex-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(232, 228, 220, 0.84);
    }

    .char-main__codex-meta {
      font-size: 12px;
      line-height: 1.4;
      color: rgba(232, 228, 220, 0.5);
    }

    .char-main__body {
      width: 100%;
      min-width: 0;
      padding: 36px clamp(28px, 2.8vw, 64px) 96px;
    }

    .char-main__summary {
      max-width: 68ch;
      margin: 0 0 24px;
      padding-left: 16px;
      border-left: 1px solid rgba(176, 141, 60, 0.26);
      font-size: 16px;
      line-height: 1.85;
      color: rgba(232, 228, 220, 0.74);
      text-wrap: pretty;
    }

    .char-fields {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      border: 1px solid var(--char-border);
      border-radius: 16px;
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01)),
        var(--char-surface);
      box-shadow: var(--char-shadow);
    }

    .char-field {
      position: relative;
      padding: 15px 16px 14px 50px;
      border-right: 1px solid rgba(255, 255, 255, 0.05);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      min-height: 72px;
      transition: background 0.18s ease, border-color 0.18s ease;
    }

    .char-field:hover {
      background: linear-gradient(180deg, rgba(177, 58, 52, 0.06), transparent 72%);
    }

    .char-field:nth-child(2n) {
      border-right: none;
    }

    .char-field:nth-last-child(-n + 2) {
      border-bottom: none;
    }

    .char-field__icon {
      position: absolute;
      top: 15px;
      left: 18px;
      width: 18px;
      height: 18px;
      color: rgba(232, 228, 220, 0.5);
      transition: color 0.18s ease;
    }

    .char-field:hover .char-field__icon {
      color: rgba(176, 141, 60, 0.74);
    }

    .char-field__label {
      display: block;
      color: var(--char-text-dim);
      margin-bottom: 4px;
    }

    .char-field__value {
      display: block;
      font-size: 15px;
      line-height: 1.45;
      color: var(--char-text-muted);
      text-wrap: pretty;
    }

    .char-section-block {
      margin-top: 30px;
    }

    .char-ability-template {
      display: none;
    }

    .char-ability {
      margin: 22px 0 4px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .char-ability__card {
      padding: 18px;
      border: 1px solid rgba(176, 141, 60, 0.2);
      border-radius: 16px;
      background:
        linear-gradient(180deg, rgba(176, 141, 60, 0.08), rgba(176, 141, 60, 0.02)),
        rgba(10, 10, 18, 0.82);
    }

    .char-ability__eyebrow {
      margin-bottom: 10px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(232, 228, 220, 0.4);
    }

    .char-ability__title {
      margin: 0 0 10px;
      font-family: "Cormorant Garamond", serif;
      font-size: 28px;
      line-height: 1;
      color: var(--char-text);
    }

    .char-ability__body {
      margin: 0;
      font-size: 14px;
      line-height: 1.7;
      color: var(--char-text-muted);
    }

    .char-ability__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 8px;
    }

    .char-ability__list li {
      position: relative;
      padding-left: 16px;
      font-size: 14px;
      line-height: 1.65;
      color: var(--char-text-muted);
    }

    .char-ability__list li::before {
      content: "";
      position: absolute;
      top: 0.65em;
      left: 0;
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: var(--char-crimson);
    }

    .char-note {
      margin-top: 30px;
      padding: 18px 20px;
      border: 1px solid rgba(177, 58, 52, 0.22);
      border-radius: 16px;
      background:
        radial-gradient(circle at 100% 100%, rgba(177, 58, 52, 0.08), transparent 22%),
        rgba(10, 10, 18, 0.82);
    }

    .char-note__label {
      display: block;
      margin-bottom: 12px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(232, 228, 220, 0.44);
    }

    .char-note__text {
      margin: 0;
      font-family: "Cormorant Garamond", serif;
      font-size: 24px;
      line-height: 1.3;
      font-style: italic;
      color: rgba(232, 228, 220, 0.78);
      text-wrap: balance;
    }

    .char-gallery {
      margin-top: 30px;
      display: grid;
      gap: 14px;
    }

    .char-gallery__header {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .char-gallery__eyebrow {
      color: var(--char-text-dim);
      white-space: nowrap;
    }

    .char-gallery__line {
      flex: 1;
      height: 1px;
      background: rgba(255, 255, 255, 0.08);
    }

    .char-gallery__grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .char-gallery__item {
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      overflow: hidden;
      background: rgba(9, 9, 16, 0.92);
      box-shadow: var(--char-shadow);
    }

    .char-gallery__item img {
      display: block;
      width: 100%;
      height: 280px;
      object-fit: cover;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent);
    }

    .char-gallery__meta {
      padding: 12px 14px 14px;
      color: rgba(232, 228, 220, 0.46);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    @media (min-width: 1600px) {
      .char-page {
        --char-rail-col: clamp(460px, 30vw, 620px);
        --char-tools-col: clamp(220px, 13vw, 260px);
      }

      .char-rail__hero {
        min-height: clamp(540px, 68vh, 860px);
      }

      .char-rail__identity {
        padding: 0 34px 34px;
      }

      .char-rail__body {
        padding: 28px 34px 42px;
      }
    }

    @media (min-width: 1900px) {
      .char-page {
        --char-rail-col: clamp(520px, 31vw, 700px);
        --char-tools-col: clamp(230px, 12vw, 280px);
      }

      .char-rail__hero {
        min-height: clamp(620px, 74vh, 980px);
      }

      .char-main__header {
        padding-left: clamp(36px, 3.1vw, 84px);
        padding-right: clamp(36px, 3.1vw, 84px);
      }

      .char-main__body {
        padding-left: clamp(36px, 3.1vw, 84px);
        padding-right: clamp(36px, 3.1vw, 84px);
      }
    }

    @media (max-width: 1180px) {
      .char-page {
        --char-rail-col: clamp(320px, 34vw, 420px);
        --char-tools-col: clamp(188px, 18vw, 220px);
      }

      .char-main__header,
      .char-main__body {
        padding-left: 28px;
        padding-right: 28px;
      }
    }

    @media (max-width: 860px) {
      body.character-stage-ready {
        overflow: auto;
      }

      .char-page {
        display: block;
        min-height: auto;
      }

      .char-rail,
      .char-tools,
      .char-main {
        position: static;
        height: auto;
        overflow: visible;
      }

      .char-rail {
        border-right: none;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }

      .char-tools {
        padding: 0 28px 20px;
        border-right: none;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        background: transparent;
      }

      .char-tools__inner {
        max-width: none;
      }

      .char-main__header {
        position: static;
      }

      .char-main__header-row {
        flex-direction: column;
        align-items: stretch;
      }

      .char-main__codex {
        align-items: flex-start;
        min-width: 0;
      }
    }

    @media (max-width: 700px) {
      .char-nav {
        padding: 0 12px;
      }

      .char-nav__brand-text,
      .char-nav__crumb-current {
        display: none;
      }

      .char-rail__hero {
        min-height: 52dvh;
      }

      .char-rail__identity {
        padding: 0 20px 22px;
      }

      .char-rail__body {
        padding: 18px 20px 26px;
      }

      .char-tools {
        padding: 0 20px 18px;
      }

      .char-main__header,
      .char-main__body {
        padding-left: 20px;
        padding-right: 20px;
      }

      .char-fields,
      .char-ability,
      .char-gallery__grid {
        grid-template-columns: 1fr;
      }

      .char-field {
        border-right: none;
      }

      .char-field:not(:last-child) {
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }

      .char-field:nth-last-child(-n + 2) {
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }

      .char-field:last-child {
        border-bottom: none;
      }

      .char-note__text {
        font-size: 22px;
      }
    }

    @media (max-width: 520px) {
      .char-rail__name {
        font-size: clamp(34px, 10vw, 54px);
      }

      .char-main__summary {
        font-size: 14px;
      }

      .char-gallery__item img {
        height: 220px;
      }
    }
  </style>

  <main id="page-content" transition:name="page-content">
    <nav class="char-nav">
      <a class="char-nav__brand" href={localizedPath(locale, "/")}>
        <img src="/uploads/ui-sine-logo.png" alt="SiNE" />
        <span class="char-nav__brand-text">{locale === "pt-br" ? "Arquivos" : "Archives"}</span>
      </a>

      <div class="char-nav__meta">
        <div class="char-nav__crumbs">
          <a class="char-nav__crumb-link" href={localizedPath(locale, "/")}>{copy.index}</a>
          <span class="char-nav__crumb-sep">></span>
          <a class="char-nav__crumb-link" href={localizedPath(locale, "/characters/")}>{copy.section}</a>
          <span class="char-nav__crumb-sep">></span>
          <span class="char-nav__crumb-current">{title}</span>
        </div>

        <button
          id="character-entry-fullscreen"
          class="char-nav__fullscreen"
          type="button"
          aria-label={copy.fullscreen}
          title={copy.fullscreen}
          data-enter-label={copy.fullscreen}
          data-exit-label={copy.exitFullscreen}
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2.5 6V2.5H6M10 2.5h3.5V6M13.5 10v3.5H10M6 13.5H2.5V10" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
    </nav>

    <div class="char-page" data-has-tools={showToc ? "true" : "false"}>
      <aside class="char-rail">
        <div class="char-rail__hero">
          {portraitImages.length > 0 ? (
            <div
              class="char-rail__gallery"
              data-portrait-gallery
              data-transition={galleryTransition}
              data-autoplay={galleryAutoplay ? "true" : "false"}
              data-interval="5000"
            >
              {portraitImages.map((item, index) => (
                <img
                  class="char-rail__img"
                  data-portrait-slide
                  data-state={index === 0 ? "active" : "idle"}
                  src={item.url ?? ""}
                  alt=""
                  style={`object-position:${imagePosition};`}
                />
              ))}
            </div>
          ) : (
            <div class="char-rail__placeholder" aria-hidden="true"></div>
          )}

          {portraitImages.length > 1 && (
            <div class="char-rail__controls">
              <div class="char-rail__counter">
                <span data-portrait-current>1</span> / <span>{portraitImages.length}</span>
              </div>
              <button
                class="char-rail__next"
                type="button"
                data-portrait-next
                aria-label={copy.nextImage}
                title={copy.nextImage}
              >
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M5 3.25L8.75 7L5 10.75" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
            </div>
          )}

          <div class="char-rail__veil"></div>

          <div class="char-rail__identity">
            <div class="char-rail__filedate">{type} - {updated}</div>
            <div class="char-rail__eyebrow">{type}</div>
            <h1 class="char-rail__name">{title}</h1>
            {designation && <p class="char-rail__designation">{designation}</p>}
            {tags.length > 0 && (
              <div class="char-rail__tags">
                {tags.slice(0, 6).map((tag) => (
                  <span class="char-rail__tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </div>

        <div class="char-rail__body">
          {dossierQuote?.text && (
            <section class="char-card char-quote">
              <div class="char-card__inner">
                <span class="char-quote__mark" aria-hidden="true">“</span>
                <p class="char-quote__text">{dossierQuote.text}</p>
                {dossierQuote.source && <div class="char-quote__source">{dossierQuote.source}</div>}
              </div>
            </section>
          )}

          {relatedLinks.length > 0 && (
            <section class="char-card char-links">
              <div class="char-card__inner">
                <div class="char-card__eyebrow">{copy.relatedLinks}</div>
                <div class="char-links__list">
                  {relatedLinks.map((link) => (
                    <a class="char-links__item" href={link.href}>
                      <span>{link.label}</span>
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M4 10L10 4M5 4H10V9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </a>
                  ))}
                </div>
              </div>
            </section>
          )}
        </div>
      </aside>

      {showToc && (
        <aside class="char-tools">
          <div class="char-tools__inner">
            <details class="char-card char-toc" open>
              <summary class="char-toc__summary">
                <span class="char-toc__summary-copy">
                  <span class="char-card__eyebrow">{copy.contents}</span>
                  <span class="char-toc__meta">{String(contentHeadings.length).padStart(2, "0")} {copy.sectionsLabel}</span>
                </span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6.25L8 10.25L12 6.25" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </summary>
              <ol class="char-toc__list" data-character-toc>
                {contentHeadings.map((heading, index) => (
                  <li class="char-toc__item" data-toc-item data-heading-id={heading.slug}>
                    <a href={`#${heading.slug}`}>
                      <span class="char-toc__number">{String(index + 1).padStart(2, "0")}</span>
                      <span class="char-toc__label">{heading.text}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </details>
          </div>
        </aside>
      )}

      <section class="char-main" data-character-main>
        <div class="char-main__header">
          <div class="char-main__header-row">
            <div>
              <div class="char-main__eyebrow">{copy.dossier}</div>
              {designation && <div class="char-main__designation">{designation}</div>}
            </div>

            <a
              class={`char-main__codex${codex.exists ? "" : " is-disabled"}`}
              href={codex.exists ? codexHref : undefined}
              aria-disabled={codex.exists ? undefined : "true"}
            >
              <span class="char-main__codex-label">{copy.openCodex}</span>
              <span class="char-main__codex-meta">{codex.exists ? copy.codexReady : copy.codexPending}</span>
            </a>
          </div>
        </div>

        <div class="char-main__body">
          {summary && <p class="char-main__summary">{summary}</p>}

          {fields.length > 0 && (
            <section class="char-section-block">
              <div class="char-card__eyebrow">{copy.fileData}</div>
              <div class="char-fields">
                {fields.map((field) => (
                  <div class="char-field">
                    <CharacterFieldIcon class="char-field__icon" icon={field.icon} />
                    <span class="char-field__label">{field.label}</span>
                    <span class="char-field__value">{field.value}</span>
                  </div>
                ))}
              </div>
            </section>
          )}

          <section class="char-section-block">
            <div class="char-card__eyebrow">{copy.fullRecord}</div>
            <CharacterDossierMarkdown html={proseHtml} />
          </section>

          {abilitySnapshot.length > 0 && abilitySnapshotSectionKey && (
            <template class="char-ability-template" data-ability-template data-target-section={abilitySnapshotSectionKey}>
              <div class="char-ability">
                {abilitySnapshot.map((card) => (
                  <article class="char-ability__card">
                    {card.eyebrow && <div class="char-ability__eyebrow">{card.eyebrow}</div>}
                    <h3 class="char-ability__title">{card.title}</h3>
                    {card.body && <p class="char-ability__body">{card.body}</p>}
                    {card.items.length > 0 && (
                      <ul class="char-ability__list">
                        {card.items.map((item) => <li>{item}</li>)}
                      </ul>
                    )}
                  </article>
                ))}
              </div>
            </template>
          )}

          {archiveNote && (
            <section class="char-note">
              {(archiveNote.label || copy.notes) && (
                <span class="char-note__label">{archiveNote.label || copy.notes}</span>
              )}
              <p class="char-note__text">{archiveNote.text}</p>
            </section>
          )}

          {extraGalleryImages.length > 0 && (
            <section class="char-gallery">
              <div class="char-gallery__header">
                <span class="char-gallery__eyebrow">{copy.gallery}</span>
                <div class="char-gallery__line"></div>
              </div>
              <div class="char-gallery__grid">
                {extraGalleryImages.map((item, index) => (
                  <figure class="char-gallery__item">
                    <img
                      src={item.url ?? ""}
                      alt={copy.imageAlt(title, index)}
                      loading="lazy"
                      style={`object-position:${item.kind === "hero" ? heroImagePosition : imagePosition};`}
                    />
                    <figcaption class="char-gallery__meta">{item.kind === "hero" ? "Hero" : "Portrait"}</figcaption>
                  </figure>
                ))}
              </div>
            </section>
          )}
        </div>
      </section>
    </div>
  </main>

  <script define:vars={{ headingSlugs: contentHeadings.map((heading) => heading.slug) }} is:inline>
    window.registerPageInit?.("character-entry-page", () => {
      const listenerScope = new AbortController();
      const { signal } = listenerScope;
      let galleryTimer = 0;
      let galleryTransitionTimer = 0;

      document.body.classList.add("character-stage-ready");

      const prose = document.querySelector("[data-character-prose]");
      if (prose instanceof HTMLElement) {
        const headingEls = Array.from(prose.querySelectorAll("h2"));
        headingEls.forEach((heading, index) => {
          const targetId = headingSlugs[index] || heading.id;
          if (targetId) {
            heading.id = targetId;
          } else if (!heading.id) {
            heading.id = (heading.textContent || "")
              .trim()
              .toLowerCase()
              .replace(/[^a-z0-9\\s-]/g, "")
              .replace(/\\s+/g, "-")
              .replace(/-+/g, "-");
          }
        });

        prose.querySelectorAll("h3").forEach((heading) => {
          if (heading.id) return;
          const slug = (heading.textContent || "")
            .trim()
            .toLowerCase()
            .replace(/[^a-z0-9\\s-]/g, "")
            .replace(/\\s+/g, "-")
            .replace(/-+/g, "-");
          if (slug) {
            heading.id = slug;
          }
        });

        const abilityTemplate = document.querySelector("template[data-ability-template]");
        if (abilityTemplate instanceof HTMLTemplateElement) {
          const targetSection = (abilityTemplate.dataset.targetSection || "").trim();
          const normalize = (value) => value
            .toLowerCase()
            .normalize("NFKD")
            .replace(/[\\u0300-\\u036f]/g, "")
            .replace(/[^a-z0-9]+/g, " ")
            .trim();

          const headings = Array.from(prose.querySelectorAll("h2"));
          const targetHeading = headings.find((heading) => normalize(heading.textContent || "") === targetSection);

          if (targetHeading) {
            let insertionPoint = targetHeading.nextSibling;
            while (insertionPoint && !(insertionPoint instanceof HTMLHeadingElement && insertionPoint.tagName === "H2")) {
              insertionPoint = insertionPoint.nextSibling;
            }
            const abilityContent = abilityTemplate.content.firstElementChild?.cloneNode(true) || document.createElement("div");
            prose.insertBefore(abilityContent, insertionPoint);
          }

          abilityTemplate.remove();
        }
      }

      const mainPane = document.querySelector("[data-character-main]");
      const tocDetails = document.querySelector(".char-toc");
      if (tocDetails instanceof HTMLDetailsElement) {
        const mobileQuery = window.matchMedia("(max-width: 860px)");
        const syncTocMode = () => {
          tocDetails.open = !mobileQuery.matches;
        };

        syncTocMode();
        mobileQuery.addEventListener("change", syncTocMode, { signal });
      }

      const tocItems = Array.from(document.querySelectorAll("[data-toc-item]"));
      if (prose instanceof HTMLElement && tocItems.length > 0) {
        const syncToc = (activeId) => {
          tocItems.forEach((item) => {
            item.classList.toggle("is-active", item.getAttribute("data-heading-id") === activeId);
          });
        };

        tocItems.forEach((item) => {
          const link = item.querySelector("a");
          const targetId = item.getAttribute("data-heading-id");
          if (!(link instanceof HTMLAnchorElement) || !targetId) return;

          link.addEventListener("click", (event) => {
            const target = prose.querySelector(`#${CSS.escape(targetId)}`);
            if (!(target instanceof HTMLElement)) return;
            event.preventDefault();
            target.scrollIntoView({ behavior: "smooth", block: "start" });
          }, { signal });
        });

        const observedHeadings = Array.from(prose.querySelectorAll("h2[id]"));
        if (observedHeadings.length > 0) {
          const observer = new IntersectionObserver((entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

            if (visible?.target instanceof HTMLElement) {
              syncToc(visible.target.id);
            }
          }, {
            root: window.matchMedia("(max-width: 860px)").matches ? null : (mainPane instanceof HTMLElement ? mainPane : null),
            rootMargin: "-16% 0px -58% 0px",
            threshold: [0.1, 0.35, 0.7],
          });

          observedHeadings.forEach((heading) => observer.observe(heading));
          syncToc(observedHeadings[0].id);

          listenerScope.signal.addEventListener("abort", () => observer.disconnect(), { once: true });
        }
      }

      const fullscreenBtn = document.getElementById("character-entry-fullscreen");
      if (fullscreenBtn instanceof HTMLButtonElement) {
        const enterLabel = fullscreenBtn.dataset.enterLabel || "Full screen";
        const exitLabel = fullscreenBtn.dataset.exitLabel || "Exit full screen";

        if (!document.documentElement.requestFullscreen) {
          fullscreenBtn.hidden = true;
        } else {
          const syncFullscreen = () => {
            const active = !!document.fullscreenElement;
            const label = active ? exitLabel : enterLabel;
            fullscreenBtn.setAttribute("aria-label", label);
            fullscreenBtn.setAttribute("title", label);
            fullscreenBtn.classList.toggle("is-active", active);
          };

          fullscreenBtn.addEventListener("click", async () => {
            try {
              if (document.fullscreenElement) {
                await document.exitFullscreen();
              } else {
                await document.documentElement.requestFullscreen();
              }
            } catch {
              syncFullscreen();
            }
          }, { signal });

          document.addEventListener("fullscreenchange", syncFullscreen, { signal });
          syncFullscreen();
        }
      }

      const portraitGallery = document.querySelector("[data-portrait-gallery]");
      if (portraitGallery instanceof HTMLElement) {
        const slides = Array.from(portraitGallery.querySelectorAll("[data-portrait-slide]"));
        const nextBtn = document.querySelector("[data-portrait-next]");
        const currentCount = document.querySelector("[data-portrait-current]");
        const transition = portraitGallery.getAttribute("data-transition") === "slide" ? "slide" : "fade";
        const autoplay = portraitGallery.getAttribute("data-autoplay") !== "false";
        const interval = Number(portraitGallery.getAttribute("data-interval") || "5000");
        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        let activeIndex = 0;
        let locked = false;

        const syncCount = () => {
          if (currentCount instanceof HTMLElement) {
            currentCount.textContent = String(activeIndex + 1);
          }
        };

        const schedule = () => {
          window.clearTimeout(galleryTimer);
          if (!autoplay || reducedMotion || slides.length < 2) return;
          galleryTimer = window.setTimeout(() => {
            advance();
          }, interval);
        };

        const settleSlideStates = (nextIndex) => {
          slides.forEach((slide, index) => {
            slide.setAttribute("data-state", index === nextIndex ? "active" : "idle");
          });
          activeIndex = nextIndex;
          locked = false;
          syncCount();
          schedule();
        };

        const advance = () => {
          if (locked || slides.length < 2) return;
          const nextIndex = (activeIndex + 1) % slides.length;
          const current = slides[activeIndex];
          const next = slides[nextIndex];

          window.clearTimeout(galleryTimer);
          window.clearTimeout(galleryTransitionTimer);

          if (transition === "slide") {
            locked = true;
            current.setAttribute("data-state", "leaving");
            next.setAttribute("data-state", "pre-enter");
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                next.setAttribute("data-state", "entering");
              });
            });
            galleryTransitionTimer = window.setTimeout(() => settleSlideStates(nextIndex), 1020);
            return;
          }

          current.setAttribute("data-state", "idle");
          next.setAttribute("data-state", "active");
          activeIndex = nextIndex;
          syncCount();
          schedule();
        };

        if (nextBtn instanceof HTMLElement) {
          nextBtn.addEventListener("click", advance, { signal });
        }

        portraitGallery.addEventListener("mouseenter", () => window.clearTimeout(galleryTimer), { signal });
        portraitGallery.addEventListener("mouseleave", schedule, { signal });

        syncCount();
        schedule();
      }

      return () => {
        listenerScope.abort();
        window.clearTimeout(galleryTimer);
        window.clearTimeout(galleryTransitionTimer);
        document.body.classList.remove("character-stage-ready");
      };
    });
  </script>
</SiteShell>
