---
import { ClientRouter } from "astro:transitions";
import { CONTENT_KEYS } from "../content-keys";
import { getLocalizedCollection } from "../i18n/content";
import { getHtmlLang, localizedEntryPath, localizedPath, type SiteLocale } from "../i18n/config";
import { getImageKind, getImageUrl } from "../utils/optimized-images";
import { getCharacterCodexRecord } from "../utils/character-codex";

const { entry, locale = "en" } = Astro.props as { entry: any; locale?: SiteLocale };
const { Content, headings } = await entry.render();
const currentPath = Astro.url.pathname;
const copy = locale === "pt-br"
  ? {
      index: "Indice",
      section: "Personagens",
      pageTitle: "Personagens",
      onFile: "Em Arquivo",
      dossier: "Dossie - Arquivos SiNE - Ano de Arquivo 1127",
      access: "Nivel de Acesso",
      public: "Publico",
      fileData: "Dados do Registro",
      fullRecord: "Registro Completo",
      related: "Entradas relacionadas",
      portraitClassified: "RETRATO CLASSIFICADO",
      fileSealed: "ARQUIVOS SINE - REGISTRO SELADO",
      restrictedDistribution: "Distribuicao Restrita",
      heightBuild: "Altura / Porte",
      birthplace: "Local de Nascimento",
      residence: "Residencia",
      occupation: "Ocupacao",
      sharedTags: (n: number) => `${n} tag${n === 1 ? "" : "s"} em comum`,
      fullscreen: "Tela cheia",
      exitFullscreen: "Sair da tela cheia",
      languageLabel: "Seletor de idioma",
      nextImage: "Proxima imagem",
      openCodex: "Abrir Codex",
      codexReady: "Dossie completo",
      codexPending: "Codex indisponivel",
    }
  : {
      index: "Index",
      section: "Characters",
      pageTitle: "Characters",
      onFile: "On File",
      dossier: "Dossier - SiNE Archives Filing Year 1127",
      access: "Access Level",
      public: "Public",
      fileData: "File Data",
      fullRecord: "Full Record",
      related: "Related entries",
      portraitClassified: "PORTRAIT CLASSIFIED",
      fileSealed: "SiNE ARCHIVES - FILE SEALED",
      restrictedDistribution: "Restricted Distribution",
      heightBuild: "Height / Build",
      birthplace: "Birthplace",
      residence: "Residence",
      occupation: "Occupation",
      sharedTags: (n: number) => `${n} shared tag${n === 1 ? "" : "s"}`,
      fullscreen: "Full screen",
      exitFullscreen: "Exit full screen",
      languageLabel: "Language switcher",
      nextImage: "Next image",
      openCodex: "Open Codex",
      codexReady: "Full dossier",
      codexPending: "Codex unavailable",
    };

const str = (v: unknown) => String(v ?? "").trim();

const title          = str(entry.data.title);
const designation    = str(entry.data?.designation);
const summary        = str(entry.data?.summary);
const updated        = str(entry.data?.updated);
const type           = str(entry.data?.type ?? (locale === "pt-br" ? "Personagem" : "Character"));
const galleryTransition = entry.data?.portrait_gallery_transition === "slide" ? "slide" : "fade";
const galleryAutoplay = entry.data?.portrait_gallery_autoplay !== false;
const showRelatedEntries = locale !== "en";
const portraitCandidates = [
  ...(Array.isArray(entry.data?.portrait_gallery) ? entry.data.portrait_gallery : []),
  entry.data?.image,
];
const portraitImages = portraitCandidates
  .map((value) => ({ value, url: getImageUrl(value), kind: getImageKind(value) }))
  .filter((item) => !!item.value && !!item.url)
  .sort((a, b) => {
    const score = (kind: ReturnType<typeof getImageKind>) => {
      if (kind === "portrait") return 0;
      if (kind === "neutral") return 1;
      if (kind === "hero") return 2;
      return 3;
    };
    return score(a.kind) - score(b.kind);
  })
  .filter((item, index, list) => list.findIndex((entry) => entry.url === item.url) === index);
const tags: string[] = Array.isArray(entry.data?.tags) ? entry.data.tags : [];

// â”€â”€ Field grid â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
type Field = { label: string; value: string };
const fields: Field[] = [];

const push = (label: string, key: string) => {
  const v = str((entry.data as any)[key]);
  if (v) fields.push({ label, value: v });
};

push(locale === "pt-br" ? "Status de Registro" : "Registry Status", "registry_status");
push(locale === "pt-br" ? "Afiliacao" : "Affiliation", "affiliation");
push(locale === "pt-br" ? "Casa" : "House", "house");
push(locale === "pt-br" ? "Ano de Nascimento" : "Year of Birth", "birth_year");
push(locale === "pt-br" ? "Idade" : "Age", "age");

const height = str(entry.data?.height);
const build  = str(entry.data?.build);
if (height) fields.push({ label: copy.heightBuild, value: [height, build].filter(Boolean).join(" - ") });

push(copy.birthplace, "birthplace");
push(copy.residence, "residence");
push(copy.occupation, "occupation");

// â”€â”€ Related â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
function normTags(t: unknown): string[] {
  if (!Array.isArray(t)) return [];
  return t.map((x) => String(x).trim().toLowerCase()).filter(Boolean);
}
const curTags = normTags(entry.data?.tags);

const related = showRelatedEntries
  ? (
      await Promise.all(CONTENT_KEYS.map((c) => getLocalizedCollection(c, locale)))
    )
      .flat()
      .filter((e) => e.data.status === "public")
      .filter((e) => e.slug !== entry.slug)
      .map((e) => {
        const n = normTags(e.data?.tags).filter((t) => curTags.includes(t)).length;
        return { e, n };
      })
      .filter((x) => x.n > 0)
      .sort((a, b) => b.n - a.n || new Date(b.e.data?.updated ?? 0).getTime() - new Date(a.e.data?.updated ?? 0).getTime())
      .slice(0, 6)
  : [];

const codex = await getCharacterCodexRecord(entry);
const codexHref = localizedPath(locale, `/characters/${entry.slug}/codex/`);
---

<!doctype html>
<html lang={getHtmlLang(locale)}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#06060b" />
  <title>{title} - {copy.pageTitle} - SiNE Archives</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <ClientRouter />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:         #06060b;
      --surface:    #0a0a14;
      --border:     rgba(255,255,255,0.07);
      --crimson:    #b13a34;
      --gold:       #b08d3c;
      --text:       #e8e4dc;
      --text-muted: rgba(232,228,220,0.55);
      --text-dim:   rgba(232,228,220,0.28);
    }

    html, body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      -webkit-font-smoothing: antialiased;
      height: 100%;
      overflow: hidden;
    }

    ::selection { background: rgba(177,58,52,0.35); color: var(--text); }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(177,58,52,0.25); border-radius: 2px; }

    button { font-family: inherit; }
    img { display: block; }

    /* â”€â”€ NAV â”€â”€ */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 32px; height: 56px;
      background: rgba(6,6,11,0.9);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .nav__logo {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none;
    }
    .nav__logo-img { height: 24px; opacity: 0.88; }
    .nav__logo-text {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px; font-weight: 600;
      letter-spacing: 0.22em;
      color: rgba(232,228,220,0.4);
      text-transform: uppercase;
    }
    .nav__actions {
      display: flex; align-items: center; gap: 12px;
      min-width: 0;
    }
    .nav__crumb {
      display: flex; align-items: center; gap: 7px;
      font-family: 'DM Sans', sans-serif;
      font-size: 11px; letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .nav__crumb-link {
      color: var(--text-muted); text-decoration: none;
      transition: color 0.2s;
    }
    .nav__crumb-link:hover { color: var(--text); }
    .nav__crumb-sep { color: var(--crimson); font-size: 13px; }
    .nav__crumb-cur { color: rgba(232,228,220,0.35); }
    .nav__fullscreen-btn {
      display: flex; align-items: center; justify-content: center;
      width: 36px; height: 36px;
      color: rgba(232,228,220,0.5);
      background: transparent;
      border: 0;
      border-radius: 4px;
      cursor: pointer;
      flex-shrink: 0;
      transition: color 0.2s, background 0.2s;
    }
    .nav__fullscreen-btn:hover,
    .nav__fullscreen-btn.is-active {
      color: rgba(232,228,220,0.9);
      background: rgba(255,255,255,0.04);
    }

    /* â”€â”€ ROOT LAYOUT â”€â”€ */
    .dos-root {
      display: flex;
      height: 100vh;
      padding-top: 56px;
      overflow: hidden;
      background: var(--bg);
    }

    /* â”€â”€ LEFT PORTRAIT PANEL â”€â”€ */
    .dos-left {
      width: 38%;
      flex-shrink: 0;
      position: relative;
      overflow: hidden;
      background: #06060b;
    }

    .dos-portrait {
      position: absolute; inset: 0;
    }
    .dos-portrait__gallery {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }
    .dos-portrait__img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: contain;
      object-position: center top;
      filter: saturate(0.9) brightness(0.96);
      opacity: 0;
      transform: translateX(0);
      transition: opacity 1000ms ease, transform 1000ms ease;
      will-change: opacity, transform;
    }
    .dos-portrait__img[data-state="active"] {
      opacity: 1;
    }
    .dos-portrait__gallery[data-transition="slide"] .dos-portrait__img {
      transform: translateX(12%);
    }
    .dos-portrait__gallery[data-transition="slide"] .dos-portrait__img[data-state="active"],
    .dos-portrait__gallery[data-transition="slide"] .dos-portrait__img[data-state="entering"] {
      opacity: 1;
      transform: translateX(0);
    }
    .dos-portrait__gallery[data-transition="slide"] .dos-portrait__img[data-state="pre-enter"] {
      opacity: 0;
      transform: translateX(12%);
    }
    .dos-portrait__gallery[data-transition="slide"] .dos-portrait__img[data-state="leaving"] {
      opacity: 0;
      transform: translateX(-12%);
    }
    .dos-portrait__placeholder {
      position: absolute; inset: 0;
    }
    .dos-portrait__controls {
      position: absolute;
      top: 24px;
      right: 24px;
      z-index: 11;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .dos-portrait__counter {
      padding: 6px 10px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(6,6,11,0.58);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.16em;
      color: rgba(232,228,220,0.72);
      text-transform: uppercase;
    }
    .dos-portrait__next {
      width: 34px;
      height: 34px;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 999px;
      background: rgba(6,6,11,0.58);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      color: rgba(232,228,220,0.82);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
    }
    .dos-portrait__next:hover {
      background: rgba(177,58,52,0.18);
      border-color: rgba(177,58,52,0.32);
      color: var(--text);
      transform: translateX(1px);
    }

    .dos-grad-right {
      position: absolute; inset: 0; z-index: 2;
      background: linear-gradient(
        to right,
        rgba(6,6,11,0.22) 0%,
        rgba(6,6,11,0.08) 14%,
        rgba(6,6,11,0) 38%,
        rgba(6,6,11,0) 62%,
        rgba(6,6,11,0.14) 78%,
        rgba(6,6,11,0.4) 100%
      );
    }
    .dos-grad-bottom {
      position: absolute; inset: 0; z-index: 2;
      background: linear-gradient(to top, rgba(6,6,11,0.86) 0%, rgba(6,6,11,0.54) 25%, rgba(6,6,11,0) 55%);
    }
    .dos-grad-top {
      position: absolute; inset: 0; z-index: 2;
      background: linear-gradient(to bottom, rgba(6,6,11,0.32) 0%, transparent 20%);
    }
    .dos-scanlines {
      position: absolute; inset: 0; z-index: 3; pointer-events: none;
      background-image: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.022) 3px, rgba(0,0,0,0.022) 4px);
    }

    /* corner brackets */
    .dos-bracket {
      position: absolute; z-index: 8;
      width: 32px; height: 32px;
    }
    .dos-bracket--tl { top: 28px; left: 28px; border-top: 1px solid rgba(177,58,52,0.45); border-left: 1px solid rgba(177,58,52,0.45); }
    .dos-bracket--tr { top: 28px; right: 28px; border-top: 1px solid rgba(177,58,52,0.45); border-right: 1px solid rgba(177,58,52,0.45); }

    /* file index label */
    .dos-file-idx {
      position: absolute; top: 18px; left: 72px; z-index: 9;
      font-family: 'DM Sans', sans-serif;
      font-size: 8px; letter-spacing: 0.22em;
      color: rgba(177,58,52,0.55); text-transform: uppercase;
    }

    /* "On File" stamp */
    .dos-stamp {
      position: absolute; top: 44%; right: 28px; z-index: 5; pointer-events: none;
      transform: rotate(-14deg);
      opacity: 0.07; user-select: none;
    }
    .dos-stamp__inner {
      border: 2px solid var(--crimson);
      padding: 5px 12px;
      font-family: 'DM Sans', sans-serif;
      font-size: 11px; letter-spacing: 0.3em;
      color: var(--crimson); font-weight: 700;
      text-transform: uppercase; white-space: nowrap;
    }

    /* bottom identity block */
    .dos-identity {
      position: absolute; bottom: 0; left: 0; right: 0;
      z-index: 10; padding: 0 32px 36px;
    }
    .dos-identity__rule {
      width: 48px; height: 1px;
      background: var(--crimson);
      margin-bottom: 16px;
    }
    .dos-identity__type {
      font-family: 'DM Sans', sans-serif;
      font-size: 9px; letter-spacing: 0.28em;
      color: var(--crimson); text-transform: uppercase;
      font-weight: 600; margin-bottom: 10px;
    }
    .dos-identity__name {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(32px, 4vw, 52px); font-weight: 700;
      color: var(--text); line-height: 0.96;
      letter-spacing: -0.01em; margin: 0 0 10px;
    }
    .dos-identity__designation {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px; color: var(--gold);
      letter-spacing: 0.06em; opacity: 0.82;
      margin-bottom: 14px; line-height: 1.4;
    }
    .dos-identity__tags {
      display: flex; flex-wrap: wrap; gap: 5px;
    }
    .dos-identity__tag {
      background: rgba(6,6,11,0.7);
      border: 1px solid rgba(255,255,255,0.09);
      padding: 3px 9px;
      font-family: 'DM Sans', sans-serif;
      font-size: 8px; letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(232,228,220,0.38);
      backdrop-filter: blur(8px);
    }


    /* â”€â”€ RIGHT DOSSIER PANEL â”€â”€ */
    .dos-right {
      flex: 1;
      overflow: hidden auto;
      background: var(--bg);
      border-left: 1px solid rgba(255,255,255,0.055);
      position: relative;
    }

    /* sticky header strip */
    .dos-header {
      padding: 36px 52px 32px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      position: sticky; top: 0; z-index: 20;
      background: rgba(6,6,11,0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }
    .dos-header__inner {
      display: flex; align-items: flex-start;
      justify-content: space-between; gap: 24px;
    }
    .dos-header__actions {
      display: flex;
      align-items: flex-start;
      flex-shrink: 0;
    }
    .dos-header__file-label {
      font-family: 'DM Sans', sans-serif;
      font-size: 9px; letter-spacing: 0.26em;
      color: var(--crimson); text-transform: uppercase;
      font-weight: 600; margin-bottom: 6px;
    }
    .dos-header__designation {
      font-family: 'DM Sans', sans-serif;
      font-size: 12px; color: rgba(176,141,60,0.75);
      letter-spacing: 0.06em; line-height: 1.4;
    }
    .dos-codex-link {
      display: inline-flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 4px;
      min-width: 164px;
      padding: 11px 14px 10px;
      border: 1px solid rgba(176,141,60,0.26);
      border-radius: 4px;
      text-decoration: none;
      background:
        linear-gradient(180deg, rgba(176,141,60,0.14), rgba(176,141,60,0.04)),
        rgba(8,8,14,0.9);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.02);
      transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }
    .dos-codex-link:hover {
      transform: translateY(-1px);
      border-color: rgba(176,141,60,0.42);
      background:
        linear-gradient(180deg, rgba(176,141,60,0.2), rgba(176,141,60,0.06)),
        rgba(8,8,14,0.94);
    }
    .dos-codex-link__label {
      font-family: 'DM Sans', sans-serif;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(232,228,220,0.88);
    }
    .dos-codex-link__meta {
      font-family: 'DM Sans', sans-serif;
      font-size: 9px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(176,141,60,0.72);
    }
    .dos-codex-link.is-disabled {
      pointer-events: none;
      opacity: 0.56;
      border-color: rgba(255,255,255,0.08);
      background: rgba(10,10,18,0.8);
    }

    /* summary lead */
    .dos-lead-wrap {
      padding: 38px 52px 0;
    }
    .dos-lead {
      font-family: 'Cormorant Garamond', serif;
      font-size: 19px; font-style: italic;
      color: rgba(232,228,220,0.7);
      line-height: 1.72; letter-spacing: 0.01em;
      margin: 0;
      padding-left: 20px;
      border-left: 2px solid rgba(177,58,52,0.35);
    }

    /* field data grid */
    .dos-fields {
      padding: 36px 52px 0;
    }
    .dos-section-label {
      display: flex; align-items: center; gap: 16px;
      margin-bottom: 20px;
    }
    .dos-section-label__text {
      font-family: 'DM Sans', sans-serif;
      font-size: 8px; letter-spacing: 0.26em;
      color: var(--text-dim); text-transform: uppercase;
      white-space: nowrap;
    }
    .dos-section-label__line {
      flex: 1; height: 1px;
      background: rgba(255,255,255,0.055);
    }
    .dos-field-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 4px; overflow: hidden;
    }
    .dos-field {
      background: rgba(6,6,11,0.85);
      padding: 11px 16px;
    }
    .dos-field:nth-child(odd) {
      border-right: 1px solid rgba(255,255,255,0.04);
    }
    .dos-field__key {
      font-family: 'DM Sans', sans-serif;
      font-size: 8px; font-weight: 600;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--text-dim); margin-bottom: 4px;
    }
    .dos-field__val {
      font-family: 'DM Sans', sans-serif;
      font-size: 12px; color: var(--text-muted);
      line-height: 1.45;
    }

    /* prose body */
    .dos-body {
      padding: 44px 52px 80px;
    }
    .dos-body-label {
      display: flex; align-items: center; gap: 16px;
      margin-bottom: 32px;
    }

    /* prose styles */
    .dos-prose { font-family: 'DM Sans', sans-serif; color: var(--text-muted); line-height: 1.8; }

    .dos-prose :global(h2) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px; font-weight: 700;
      color: var(--text); margin-top: 44px; margin-bottom: 14px;
      letter-spacing: 0.04em;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .dos-prose :global(h3) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 17px; font-weight: 600;
      color: rgba(232,228,220,0.8); margin-top: 30px; margin-bottom: 8px;
      letter-spacing: 0.06em;
    }
    .dos-prose :global(p) {
      font-family: 'DM Sans', sans-serif;
      font-size: 14px; color: var(--text-muted);
      line-height: 1.88; margin: 0 0 14px;
    }
    .dos-prose :global(li) {
      font-size: 14px; color: var(--text-muted);
      line-height: 1.85; margin-bottom: 6px;
    }
    .dos-prose :global(ul), .dos-prose :global(ol) {
      padding-left: 22px; margin: 0 0 16px;
    }
    .dos-prose :global(strong) {
      color: rgba(232,228,220,0.9); font-weight: 650;
    }
    .dos-prose :global(em) {
      color: rgba(176,141,60,0.9);
    }
    .dos-prose :global(hr) {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.06);
      margin: 36px 0;
    }
    .dos-prose :global(blockquote) {
      margin: 24px 0; padding: 16px 22px;
      border-left: 2px solid var(--crimson);
      background: rgba(177,58,52,0.06);
      border-radius: 0 4px 4px 0;
    }
    .dos-prose :global(blockquote p) {
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: 16px; font-style: italic;
      color: rgba(232,228,220,0.6); line-height: 1.8;
    }

    /* footer stamp */
    .dos-footer-stamp {
      margin-top: 64px; padding-top: 24px;
      border-top: 1px solid rgba(255,255,255,0.05);
      display: flex; align-items: center; gap: 16px;
    }
    .dos-footer-stamp__logo { height: 14px; opacity: 0.18; }
    .dos-footer-stamp__text {
      font-family: 'DM Sans', sans-serif;
      font-size: 9px; letter-spacing: 0.16em;
      color: rgba(232,228,220,0.12); text-transform: uppercase;
    }

    /* â”€â”€ RELATED â”€â”€ */
    .dos-related {
      padding: 0 52px 80px;
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    .dos-related__header {
      display: flex; align-items: center; gap: 16px;
      padding: 36px 0 24px;
    }
    .dos-related__label {
      font-family: 'DM Sans', sans-serif;
      font-size: 9px; letter-spacing: 0.22em;
      color: rgba(232,228,220,0.25); text-transform: uppercase;
      white-space: nowrap; font-weight: 600;
    }
    .dos-related__line {
      flex: 1; height: 1px;
      background: rgba(255,255,255,0.055);
    }
    .dos-related__grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 10px;
    }
    .dos-related__item {
      display: block; padding: 14px 18px;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 4px;
      background: rgba(10,10,18,0.7);
      text-decoration: none; color: var(--text);
      transition: border-color 0.2s, background 0.2s;
    }
    .dos-related__item:hover {
      border-color: rgba(177,58,52,0.35);
      background: rgba(12,12,20,0.9);
    }
    .dos-related__name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 17px; font-weight: 700;
      color: var(--text); margin-bottom: 5px; line-height: 1.2;
    }
    .dos-related__summary {
      font-family: 'DM Sans', sans-serif;
      font-size: 12px; color: var(--text-muted);
      line-height: 1.55; margin-bottom: 8px;
    }
    .dos-related__meta {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px; color: var(--text-dim);
      letter-spacing: 0.04em;
    }

    @media (max-width: 900px) {
      .dos-left { width: 44%; }
    }
    @media (max-width: 700px) {
      .dos-root { flex-direction: column; overflow: auto; }
      .dos-left { width: 100%; height: 52dvh; min-height: 340px; flex-shrink: 0; }
      .dos-right { overflow: visible; }
      html, body { overflow: auto; height: auto; }
      .nav { padding: 0 12px; }
      .nav__logo-text,
      .nav__crumb-cur {
        display: none;
      }
      .nav__crumb {
        min-width: 0;
        overflow: hidden;
        white-space: nowrap;
      }
      .dos-header { position: static; padding: 18px 20px; }
      .dos-header__inner,
      .dos-header__actions {
        flex-direction: column;
        align-items: stretch;
      }
      .dos-codex-link {
        min-width: 0;
        align-items: flex-start;
      }
      .nav__pills { display: none; }
      .dos-body, .dos-fields, .dos-lead-wrap { padding-left: 20px; padding-right: 20px; }
      .dos-identity { padding: 0 20px 28px; }
      .dos-portrait__controls { top: 18px; right: 18px; }
      .dos-identity__name { font-size: clamp(38px, 9vw, 56px); }
      .dos-identity__designation { font-size: 12px; }
      .dos-identity__tag { font-size: 9px; }
      .dos-fields { padding-top: 24px; padding-bottom: 24px; }
      .dos-lead-wrap { padding-top: 24px; }
      .dos-body { padding-bottom: calc(60px + env(safe-area-inset-bottom)); }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <a class="nav__logo" href={localizedPath(locale, "/")}>
    <img src="/uploads/ui-sine-logo.png" alt="SiNE" class="nav__logo-img" />
    <span class="nav__logo-text">{locale === "pt-br" ? "ARQUIVOS" : "ARCHIVES"}</span>
  </a>

  <div class="nav__crumb">
    <a class="nav__crumb-link" href={localizedPath(locale, "/")}>{copy.index}</a>
    <span class="nav__crumb-sep">></span>
    <a class="nav__crumb-link" href={localizedPath(locale, `/characters/?char=${encodeURIComponent(entry.slug)}`)}>{copy.section}</a>
    <span class="nav__crumb-sep">></span>
    <span class="nav__crumb-cur">{title}</span>
  </div>
  <button
    class="nav__fullscreen-btn"
    id="character-entry-fullscreen"
    type="button"
    aria-label={copy.fullscreen}
    title={copy.fullscreen}
    data-enter-label={copy.fullscreen}
    data-exit-label={copy.exitFullscreen}
  >
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M2.5 6V2.5H6M10 2.5h3.5V6M13.5 10v3.5H10M6 13.5H2.5V10" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

</nav>

<div class="dos-root">

  <!-- â”€â”€ LEFT PORTRAIT PANEL â”€â”€ -->
  <div class="dos-left" id="dos-left">

    <!-- Portrait -->
    <div class="dos-portrait">
      {portraitImages.length > 0 ? (
        <div
          class="dos-portrait__gallery"
          data-portrait-gallery
          data-transition={galleryTransition}
          data-autoplay={galleryAutoplay ? "true" : "false"}
          data-interval="5000"
        >
          {portraitImages.map((item, index) => (
            <img
              class="dos-portrait__img"
              data-portrait-slide
              data-state={index === 0 ? "active" : "idle"}
              src={item.url}
              alt=""
            />
          ))}
        </div>
      ) : (
        <svg
          class="dos-portrait__placeholder"
          viewBox="0 0 900 1200"
          preserveAspectRatio="xMidYMid slice"
          xmlns="http://www.w3.org/2000/svg"
        >
          <defs>
            <radialGradient id="rg-ph" cx="50%" cy="38%" r="55%">
              <stop offset="0%" stop-color="rgba(177,58,52,0.16)" />
              <stop offset="100%" stop-color="rgba(6,6,11,0)" />
            </radialGradient>
          </defs>
          <rect width="900" height="1200" fill="#07070e" />
          <rect width="900" height="1200" fill="url(#rg-ph)" />
          {Array.from({ length: 60 }).map((_, i) => (
            <line x1="0" y1={i * 20} x2="900" y2={i * 20}
              stroke="rgba(255,255,255,0.01)" stroke-width="1" />
          ))}
          {[80, 160, 260, 370, 490].map(r => (
            <circle cx="450" cy="420" r={r} fill="none"
              stroke="rgba(255,255,255,0.028)" stroke-width="1" />
          ))}
          <line x1="450" y1="220" x2="450" y2="620" stroke="rgba(177,58,52,0.15)" stroke-width="0.8" />
          <line x1="250" y1="420" x2="650" y2="420" stroke="rgba(177,58,52,0.15)" stroke-width="0.8" />
          <path d="M300 280 L300 310 L330 310" fill="none" stroke="rgba(177,58,52,0.4)" stroke-width="1.5" />
          <path d="M600 280 L600 310 L570 310" fill="none" stroke="rgba(177,58,52,0.4)" stroke-width="1.5" />
          <path d="M300 560 L300 530 L330 530" fill="none" stroke="rgba(177,58,52,0.4)" stroke-width="1.5" />
          <path d="M600 560 L600 530 L570 530" fill="none" stroke="rgba(177,58,52,0.4)" stroke-width="1.5" />
          <circle cx="450" cy="390" r="56" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.05)" stroke-width="1" />
          <path d="M328 560 Q328 500 450 500 Q572 500 572 560" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.05)" stroke-width="1" />
          <text x="450" y="640" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" letter-spacing="6" fill="rgba(177,58,52,0.3)">{copy.portraitClassified}</text>
          <text x="450" y="656" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" letter-spacing="4" fill="rgba(255,255,255,0.08)">{copy.fileSealed}</text>
        </svg>
      )}
    </div>

    {portraitImages.length > 1 && (
      <div class="dos-portrait__controls">
        <div class="dos-portrait__counter">
          <span data-portrait-current>1</span> / <span>{portraitImages.length}</span>
        </div>
        <button
          class="dos-portrait__next"
          type="button"
          data-portrait-next
          aria-label={copy.nextImage}
          title={copy.nextImage}
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M5 3.25L8.75 7L5 10.75" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    )}

    <!-- Gradient overlays -->
    <div class="dos-grad-right"></div>
    <div class="dos-grad-bottom"></div>
    <div class="dos-grad-top"></div>
    <div class="dos-scanlines"></div>

    <!-- Corner brackets -->
    <div class="dos-bracket dos-bracket--tl"></div>
    <div class="dos-bracket dos-bracket--tr"></div>

    <!-- File index top-left -->
    <div class="dos-file-idx">{type} - {updated}</div>

    <!-- "On File" stamp -->
    <div class="dos-stamp" aria-hidden="true">
      <div class="dos-stamp__inner">{copy.onFile}</div>
    </div>

    <!-- Identity block (bottom) -->
    <div class="dos-identity">
      <div class="dos-identity__rule"></div>
      <div class="dos-identity__type">{type}</div>
      <h1 class="dos-identity__name">{title}</h1>
      {designation && (
        <div class="dos-identity__designation">{designation}</div>
      )}
      <div class="dos-identity__tags">
        {tags.slice(0, 4).map((t) => (
          <span class="dos-identity__tag">{t}</span>
        ))}
      </div>
    </div>

  </div>

  <!-- â”€â”€ RIGHT DOSSIER PANEL â”€â”€ -->
  <div class="dos-right">

    <!-- Sticky header strip -->
    <div class="dos-header">
      <div class="dos-header__inner">
        <div>
          <div class="dos-header__file-label">{copy.dossier}</div>
          {designation && (
            <div class="dos-header__designation">{designation}</div>
          )}
        </div>
        <div class="dos-header__actions">
          <a
            class={`dos-codex-link${codex.exists ? "" : " is-disabled"}`}
            href={codex.exists ? codexHref : undefined}
            aria-disabled={codex.exists ? undefined : "true"}
          >
            <span class="dos-codex-link__label">{copy.openCodex}</span>
            <span class="dos-codex-link__meta">{codex.exists ? copy.codexReady : copy.codexPending}</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Summary lead -->
    {summary && (
      <div class="dos-lead-wrap">
        <p class="dos-lead">{summary}</p>
      </div>
    )}

    <!-- Field data grid -->
    {fields.length > 0 && (
      <div class="dos-fields">
        <div class="dos-section-label">
          <span class="dos-section-label__text">{copy.fileData}</span>
          <div class="dos-section-label__line"></div>
        </div>
        <div class="dos-field-grid">
          {fields.map((f) => (
            <div class="dos-field">
              <div class="dos-field__key">{f.label}</div>
              <div class="dos-field__val">{f.value}</div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Prose body -->
    <div class="dos-body">
      <div class="dos-body-label">
        <span class="dos-section-label__text">{copy.fullRecord}</span>
        <div class="dos-section-label__line"></div>
      </div>

      <article class="dos-prose" data-dos-body>
        <Content />
      </article>

      <!-- Footer stamp -->
      <div class="dos-footer-stamp">
        <img src="/uploads/ui-sine-logo.png" alt="SiNE" class="dos-footer-stamp__logo" />
        <span class="dos-footer-stamp__text">
          SiNE Archives - {copy.dossier} - {updated} - {copy.restrictedDistribution}
        </span>
      </div>
    </div>

    <!-- Related entries -->
    {related.length > 0 && (
      <div class="dos-related">
        <div class="dos-related__header">
          <div class="dos-related__line"></div>
          <span class="dos-related__label">{copy.related}</span>
          <div class="dos-related__line"></div>
        </div>
        <div class="dos-related__grid">
          {related.map(({ e, n }) => (
            <a class="dos-related__item" href={localizedEntryPath(locale, e.collection as any, e.slug)}>
              <div class="dos-related__name">{e.data.title}</div>
              {e.data.summary && (
                <div class="dos-related__summary">{e.data.summary}</div>
              )}
              <div class="dos-related__meta">{copy.sharedTags(n)}</div>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>
</div>

<script>
  // Assign IDs to headings for potential in-page anchors
  const body = document.querySelector("[data-dos-body]");
  if (body) {
    body.querySelectorAll("h2, h3").forEach((h) => {
      if (!h.id) {
        const slug = (h.textContent || "")
          .trim().toLowerCase()
          .replace(/[^a-z0-9\s-]/g, "")
          .replace(/\s+/g, "-")
          .replace(/-+/g, "-");
        if (slug) h.id = slug;
      }
    });
  }

  const fullscreenBtn = document.getElementById("character-entry-fullscreen");
  if (fullscreenBtn) {
    const enterLabel = fullscreenBtn.dataset.enterLabel || "Full screen";
    const exitLabel = fullscreenBtn.dataset.exitLabel || "Exit full screen";

    if (!document.documentElement.requestFullscreen) {
      fullscreenBtn.hidden = true;
    } else {
      const syncFullscreen = () => {
        const active = !!document.fullscreenElement;
        const label = active ? exitLabel : enterLabel;
        fullscreenBtn.setAttribute("aria-label", label);
        fullscreenBtn.setAttribute("title", label);
        fullscreenBtn.classList.toggle("is-active", active);
      };

      fullscreenBtn.addEventListener("click", async () => {
        try {
          if (document.fullscreenElement) {
            await document.exitFullscreen();
          } else {
            await document.documentElement.requestFullscreen();
          }
        } catch {
          syncFullscreen();
        }
      });

      document.addEventListener("fullscreenchange", syncFullscreen);
      syncFullscreen();
    }
  }

  const portraitGallery = document.querySelector("[data-portrait-gallery]");
  if (portraitGallery) {
    const slides = Array.from(portraitGallery.querySelectorAll("[data-portrait-slide]"));
    const nextBtn = document.querySelector("[data-portrait-next]");
    const currentCount = document.querySelector("[data-portrait-current]");
    const transition = portraitGallery.getAttribute("data-transition") === "slide" ? "slide" : "fade";
    const autoplay = portraitGallery.getAttribute("data-autoplay") !== "false";
    const interval = Number(portraitGallery.getAttribute("data-interval") || "5000");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let activeIndex = 0;
    let timer = 0;
    let locked = false;

    const syncCount = () => {
      if (currentCount) currentCount.textContent = String(activeIndex + 1);
    };

    const schedule = () => {
      window.clearTimeout(timer);
      if (!autoplay || reducedMotion || slides.length < 2) return;
      timer = window.setTimeout(() => {
        advance();
      }, interval);
    };

    const settleSlideStates = (nextIndex) => {
      slides.forEach((slide, index) => {
        slide.setAttribute("data-state", index === nextIndex ? "active" : "idle");
      });
      activeIndex = nextIndex;
      locked = false;
      syncCount();
      schedule();
    };

    const advance = () => {
      if (locked || slides.length < 2) return;
      const nextIndex = (activeIndex + 1) % slides.length;
      const current = slides[activeIndex];
      const next = slides[nextIndex];

      window.clearTimeout(timer);

      if (transition === "slide") {
        locked = true;
        current.setAttribute("data-state", "leaving");
        next.setAttribute("data-state", "pre-enter");
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            next.setAttribute("data-state", "entering");
          });
        });
        window.setTimeout(() => settleSlideStates(nextIndex), 1020);
        return;
      }

      current.setAttribute("data-state", "idle");
      next.setAttribute("data-state", "active");
      activeIndex = nextIndex;
      syncCount();
      schedule();
    };

    nextBtn?.addEventListener("click", advance);
    portraitGallery.addEventListener("mouseenter", () => window.clearTimeout(timer));
    portraitGallery.addEventListener("mouseleave", schedule);

    syncCount();
    schedule();
  }
</script>

</body>
</html>

